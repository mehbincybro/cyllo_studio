<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_hr_employee_kanban" model="ir.ui.view">
        <field name="name">view.hr.employee.kanban</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.hr_kanban_view_employees"/>
        <field name="arch" type="xml">
            <xpath expr="//div[hasclass('o_kanban_record_bottom')]" position="replace">
                <t t-set="id" t-value="record.id.value"/>
                <div class="o_kanban_record_bottom mt-3 pb-2">
                    <div class="oe_kanban_bottom_left">
                        <field name="activity_ids" widget="kanban_activity">Activities</field>
                    </div>
                    <div class="">
                        <button type='object' name='action_open_record' context="{'id': id}" class="btn cy-button-stroke cy-card-btn cy-card-view">View Profile</button>
                    </div>
                </div>
            </xpath>
            <xpath expr='//div[hasclass("oe_kanban_global_click")]' position='attributes'>
                <attribute name="class" add="cy_oe_kanban" separator=" "/>
            </xpath>
        </field>
    </record>
</odoo>