<?xml version="1.0" encoding="utf-8"?>
<templates>
    <!-- Template for the Consolidated Balance Report-->
    <t t-name="con_bal_template" owl="1">
        <div class="w-100">
            <div style="border-bottom: 1px solid #d8dadd;">
                <div class="filter_view_dfr p-2">
                    <div class="">
                        <h1 class="p-2">
                            <span>Consolidation Report</span>
                        </h1>
                    </div>
                    <div class="sub_container_right d-flex mx-2" t-ref="filter">
                        <t t-if="state.filter">
                            <div class="report_print">
                                <button type="button" class="btn btn-primary btn-report-print" t-on-click="print_pdf"
                                        style="position: relative;">
                                    Print (PDF)
                                </button>
                                <button type="button" class="btn btn-primary btn-report-print" t-on-click="print_xlsx"
                                        style="position: relative;">
                                    Export (XLSX)
                                </button>
                            </div>
                            <div class="filter d-flex ms-auto" style="gap: 1.5rem;">
                                <div class="comparison_filter dropdown">
                                    <a type="button" class="dropdown-toggle" data-bs-toggle="dropdown"
                                       t-ref="comparison">
                                        <span class="fa fa-signal" title="Comparison" role="img"
                                              aria-label="Comparison"/>
                                        Comparison:
                                        <span class="code"/>
                                    </a>
                                    <div class="dropdown-menu Comparison" name="states[]">
                                        <div role="separator" class="dropdown-divider"/>
                                        <t t-foreach="state.filter.comparison" t-as="comparison"
                                           t-key="comparison_index">
                                            <span class="dropdown-item" role="menuitem" t-att-value="comparison[0]"
                                                  t-on-click="applyComparison">
                                                <t t-esc="comparison[1]"/>
                                            </span>
                                        </t>
                                    </div>
                                </div>
                                <div class="journals_filter dropdown">
                                    <a type="button" class="dropdown-toggle" data-bs-toggle="dropdown" t-ref="journal">
                                        <span class="fa fa-book"/>
                                        Journals:
                                        <span class="code"/>
                                    </a>
                                    <div class="dropdown-menu journals" name="states[]">
                                        <div role="separator" class="dropdown-divider"/>
                                        <t t-foreach="state.filter.journal" t-as="journal" t-key="journal_index">
                                            <span class="dropdown-item" role="menuitem" t-att-value="journal[0]"
                                                  t-on-click="applyFilter">
                                                <t t-esc="journal[1]"/>
                                            </span>
                                        </t>
                                    </div>
                                </div>
                                <div class="group_filter dropdown" t-if="this.state.data">
                                    <a type="button" class="dropdown-toggle" data-bs-toggle="dropdown" t-ref="group">
                                        <span class="fa fa-book"/>
                                        Group:
                                        <span class="code"/>
                                    </a>
                                    <div class="dropdown-menu journals" name="states[]">
                                        <div role="separator" class="dropdown-divider"/>
                                        <t t-foreach="this.state.data.all_group" t-as="group" t-key="group_index">
                                            <span class="dropdown-item" role="menuitem" t-att-value="group.id"
                                                  t-on-click="applyGroupFilter">
                                                <t t-esc="group.name"/>
                                            </span>
                                        </t>
                                    </div>
                                </div>
                                <div class="search_Target_move" style="">
                                    <a type="button" class="dropdown-toggle" data-bs-toggle="dropdown">
                                        <span class="fa fa-filter"/>
                                        Options:
                                        <span class="target"/>
                                    </a>
                                    <div class="dropdown-menu" role="menu">
                                        <div class="form-group">
                                            <button class="report-filter-button" type="button" t-ref="unfoldButton"
                                                    t-on-click="unfoldAll">
                                                Unfold All
                                            </button>
                                            <button class="report-filter-button" type="button" t-on-click="hideAtZero">
                                                Hide Line at 0
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </div>
                </div>
            </div>
            <div class="table_style">
                <div class="table_view_dfr" t-ref="table_view_gl">
                    <div>
                        <div class="table_main_view table_main_view">

                            <div t-if="state.data and (!state.data.group or state.data.group.length === 0)"
                                 class="o_view_nocontent" style="position: relative;">
                                <div class="o_nocontent_help">
                                    <p class="o_view_nocontent_smiling_face">
                                        No data to display !
                                    </p>
                                    <p>
                                        Click Compute to generate the consolidated report.
                                    </p>
                                </div>
                            </div>
                            <table t-else="" cellspacing="0" width="100%">
                                <thead>
                                    <tr class="o_heading">
                                        <th colspan="6"/>
                                        <t t-if="state.data">
                                            <t t-foreach="state.data.header" t-as="header" t-key="header_index">
                                                <th class="text-right">
                                                    <t t-esc="header[0]"/>
                                                    <br/>
                                                    <t t-esc="header[1]"/>
                                                </th>
                                            </t>
                                            <th class="text-right fw-bolder">
                                                Total
                                            </th>
                                        </t>
                                    </tr>
                                </thead>
                                <tbody t-ref="tbody">
                                    <t t-if="state.data">
                                        <t t-foreach="state.data.group"
                                           t-as="group" t-key="group_index">
                                            <tr class="border-bottom border-dark cy-report-line">
                                                <th colspan="6">
                                                    <t t-esc="group[1]"/>
                                                </th>
                                                <t t-foreach="group" t-as="amount" t-key="amount_index">
                                                    <t t-if="amount_index >= 2">
                                                        <th>
                                                            <t t-if="amount">
                                                                <span class="fw-bolder">
                                                                    <t t-esc="state.data.symbol"/>
                                                                    <t t-esc="amount"/>
                                                                </span>
                                                            </t>
                                                            <t t-else="">
                                                                <span class="text-muted">
                                                                    <t t-esc="state.data.symbol"/>
                                                                    <t t-esc="amount"/>
                                                                </span>
                                                            </t>
                                                        </th>
                                                    </t>
                                                </t>
                                            </tr>
                                            <t t-foreach="state.data.child"
                                               t-as="child" t-key="child_index">
                                                <t t-if="child[0]==group[0]">
                                                    <tr class="border-bottom border-gainsboro cy-report-line"
                                                        t-attf-id="group-{{group_index}}">
                                                        <th colspan="6">
                                                            <div data-bs-toggle="collapse"
                                                                 t-attf-href="#child-{{child_index}}"
                                                                 aria-expanded="false"
                                                                 t-attf-aria-controls="child-{{child_index}}"
                                                                 class="ms-3">
                                                                <a class="btn header">
                                                                    <span class="toggle-icon">
                                                                        <i class="fa fa-caret-down"/>
                                                                    </span>
                                                                    <span class="ms-3">
                                                                        <t t-esc="child[2]"/>
                                                                    </span>
                                                                </a>
                                                            </div>
                                                        </th>
                                                        <t t-foreach="child" t-as="amount" t-key="amount_index">
                                                            <t t-if="amount_index >= 3">
                                                                <th>
                                                                    <t t-if="amount">
                                                                        <span class="fw-bolder">
                                                                            <t t-esc="state.data.symbol"/>
                                                                            <t t-esc="amount"/>
                                                                        </span>
                                                                    </t>
                                                                    <t t-else="">
                                                                        <span class="text-muted">
                                                                            <t t-esc="state.data.symbol"/>
                                                                            <t t-esc="amount"/>
                                                                        </span>
                                                                    </t>
                                                                </th>
                                                            </t>
                                                        </t>
                                                    </tr>
                                                    <t t-foreach="state.data.accounts" t-as="accounts"
                                                       t-key="accounts_index">
                                                        <t t-if="!state.hideZero ? accounts[accounts.length - 1] !== 0 and child[1]==accounts[0]:true and child[1]==accounts[0]">
                                                            <tr class="border-bottom border-gainsboro cy-report-line"
                                                                t-attf-id="child-{{child_index}}"
                                                                t-attf-class="group-{{group_index}}">
                                                                <td colspan="6">
                                                                    <span class="ms-5" style="gap: 12px;display: flex;">
                                                                        <t t-esc="accounts[1]"/>
                                                                    </span>
                                                                </td>
                                                                <t t-foreach="accounts" t-as="amount"
                                                                   t-key="amount_index">
                                                                    <t t-if="amount_index >= 2">
                                                                        <td>
                                                                            <t t-if="amount">
                                                                                <span class="fw-bolder">
                                                                                    <t t-esc="state.data.symbol"/>
                                                                                    <t t-esc="amount"/>
                                                                                </span>
                                                                            </t>
                                                                            <t t-else="">
                                                                                <span class="text-muted">
                                                                                    <t t-esc="state.data.symbol"/>
                                                                                    <t t-esc="amount"/>
                                                                                </span>
                                                                            </t>
                                                                        </td>
                                                                    </t>
                                                                </t>
                                                            </tr>
                                                        </t>
                                                    </t>
                                                </t>
                                            </t>
                                            <t t-foreach="state.data.accounts" t-as="accounts" t-key="accounts_index">
                                                <t t-if="!state.hideZero ? accounts[accounts.length - 1] !== 0 and group[0] == accounts[0]:true and group[0] == accounts[0]">
                                                    <tr class="border-bottom border-gainsboro cy-report-line"
                                                        t-attf-id="group-{{group_index}}">
                                                        <td colspan="6">
                                                            <span class="ms-5" style="gap: 12px;display: flex;">
                                                                <t t-esc="accounts[1]"/>
                                                            </span>
                                                        </td>
                                                        <t t-foreach="accounts" t-as="amount" t-key="amount_index">
                                                            <t t-if="amount_index >= 2">
                                                                <td>
                                                                    <t t-if="amount">
                                                                        <span class="fw-bolder">
                                                                            <t t-esc="state.data.symbol"/>
                                                                            <t t-esc="amount"/>
                                                                        </span>
                                                                    </t>
                                                                    <t t-else="">
                                                                        <span class="text-muted">
                                                                            <t t-esc="state.data.symbol"/>
                                                                            <t t-esc="amount"/>
                                                                        </span>
                                                                    </t>
                                                                </td>
                                                            </t>
                                                        </t>
                                                    </tr>
                                                </t>
                                            </t>
                                            <tr class="border-bottom border-gainsboro last_element cy-report-line"
                                                t-attf-id="group-{{group_index}}">
                                                <th colspan="6">
                                                    <span class="ms-3 fw-bolder">
                                                        Total
                                                        <t t-esc="group[1]"/>
                                                    </span>
                                                </th>
                                                <t t-foreach="group" t-as="amount" t-key="amount_index">
                                                    <t t-if="amount_index >= 2">
                                                        <th>
                                                            <t t-if="amount">
                                                                <span class="fw-bolder">
                                                                    <t t-esc="state.data.symbol"/>
                                                                    <t t-esc="amount"/>
                                                                </span>
                                                            </t>
                                                            <t t-else="">
                                                                <span class="text-muted">
                                                                    <t t-esc="state.data.symbol"/>
                                                                    <t t-esc="amount"/>
                                                                </span>
                                                            </t>
                                                        </th>
                                                    </t>
                                                </t>
                                            </tr>
                                        </t>
                                        <tr>
                                            <th colspan="6" class="o_heading">Total</th>
                                            <t t-set="total" t-value="0"/>
                                            <t t-foreach="state.data.total" t-as="amount" t-key="amount_index">
                                                <th class="o_heading">
                                                    <t t-esc="state.data.symbol"/>
                                                    <t t-esc="amount"/>
                                                    <t t-set="total" t-value="total+amount"/>
                                                </th>
                                            </t>
                                            <th class="o_heading">
                                                <t t-esc="state.data.symbol"/>
                                                <t t-out="total"/>
                                            </th>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </t>
</templates>