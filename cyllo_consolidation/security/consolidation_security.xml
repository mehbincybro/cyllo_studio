<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Multi-Company Rules -->
    
    <!-- Consolidation Chart Rules -->
    <record id="consolidation_chart_comp_rule" model="ir.rule">
        <field name="name">Consolidation Chart: multi-company</field>
        <field name="model_id" ref="model_consolidation_chart"/>
        <field name="domain_force">
            [('company_id', 'in', company_ids)]
        </field>
    </record>

    <!-- Consolidation Account Rules -->
    <record id="consolidation_account_comp_rule" model="ir.rule">
        <field name="name">Consolidation Account: multi-company</field>
        <field name="model_id" ref="model_consolidation_account"/>
        <field name="domain_force">
            [('chart_id.company_id', 'in', company_ids)]
        </field>
    </record>

    <!-- Consolidation Period Rules -->
    <record id="consolidation_period_comp_rule" model="ir.rule">
        <field name="name">Consolidation Period: multi-company</field>
        <field name="model_id" ref="model_consolidation_period"/>
        <field name="domain_force">
            [('chart_id.company_id', 'in', company_ids)]
        </field>
    </record>

    <!-- Consolidation Company Period Rules -->
    <record id="consolidation_company_period_comp_rule" model="ir.rule">
        <field name="name">Consolidation Company Period: multi-company</field>
        <field name="model_id" ref="model_consolidation_company_period"/>
        <field name="domain_force">
            [('period_id.chart_id.company_id', 'in', company_ids)]
        </field>
    </record>

    <!-- Consolidation Journal Rules -->
    <record id="consolidation_journal_comp_rule" model="ir.rule">
        <field name="name">Consolidation Journal: multi-company</field>
        <field name="model_id" ref="model_consolidation_journal"/>
        <field name="domain_force">
            [('period_id.chart_id.company_id', 'in', company_ids)]
        </field>
    </record>

    <!-- Consolidation Journal Line Rules -->
    <record id="consolidation_journal_line_comp_rule" model="ir.rule">
        <field name="name">Consolidation Journal Line: multi-company</field>
        <field name="model_id" ref="model_consolidation_journal_line"/>
        <field name="domain_force">
            [('journal_id.period_id.chart_id.company_id', 'in', company_ids)]
        </field>
    </record>

    <!-- Consolidation Group Rules -->
    <record id="consolidation_group_comp_rule" model="ir.rule">
        <field name="name">Consolidation Group: multi-company</field>
        <field name="model_id" ref="model_consolidation_group"/>
        <field name="domain_force">
            [('chart_id.company_id', 'in', company_ids)]
        </field>
    </record>

</odoo>
