<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--Tree view of the Consolidation Journal-->
    <record id="view_consolidation_journal_tree" model="ir.ui.view">
        <field name="name">view.consolidation.journal.tree</field>
        <field name="model">consolidation.journal</field>
        <field name="arch" type="xml">
            <tree string="consolidation.journal">
                <field name="name"/>
                <field name="chart_id"/>
                <field name="period_id"/>
                <field name="company_id"/>
            </tree>
        </field>
    </record>
    <!--Form view of the Consolidation Journal-->
    <record id="view_consolidation_journal_form" model="ir.ui.view">
        <field name="name">view.consolidation.journal.form</field>
        <field name="model">consolidation.journal</field>
        <field name="arch" type="xml">
            <form string="consolidation_journal">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" class="oe_title"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="chart_id"/>
                            <field name="period_id"/>
                        </group>
                        <group>
                            <field name="company_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page name="journalLine" string="JournalLine">
                            <field name="journal_line_ids">
                                <tree editable="bottom" create="false">
                                    <field name="group_id"/>
                                    <field name="account_id"/>
                                    <field name="balance"/>
                                    <field name="currency_id" column_invisible="1"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                    <div>
                        <group>
                            <group class="oe_subtotal_footer oe_right">
                                <field name="currency_id" invisible="1"/>
                                <field name="total"/>
                            </group>
                        </group>
                    </div>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                    <field name="activity_ids"/>
                </div>
            </form>
        </field>
    </record>
    <!--Search view of the Consolidation Journal-->
    <record id="view_consolidation_journal_search" model="ir.ui.view">
        <field name="name">view.consolidation.journal.search</field>
        <field name="model">consolidation.journal</field>
        <field name="priority">15</field>
        <field name="arch" type="xml">
            <search string="Search">
                <field name="name" string="Name"/>
                <field name="chart_id" string="Consolidation"/>
                <field name="period_id" string="Period"/>
                <field name="company_id" string="Company"/>
                <separator/>
                <filter string="Creation Date" name="creation_date" date="create_date"/>
                <separator/>
                <group expand="0" string="Group By" colspan="16">
                    <filter string="Consolidation" name="chart_id" context="{'group_by':'chart_id'}"/>
                    <filter name="period_id" string="Period" context="{'group_by':'period_id'}"/>
                    <filter string="Company" name="company_id" context="{'group_by':'company_id'}"/>
                </group>
            </search>
        </field>
    </record>
    <!--Action specified for the Consolidation Journal-->
    <record id="action_view_journal_entry" model="ir.actions.act_window">
        <field name="name">Journal Entry</field>
        <field name="res_model">consolidation.journal</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No Consolidation Journal Found
            </p>
            <p>
                Creates separate journals specifically for consolidation entries
            </p>
        </field>
    </record>
</odoo>