<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!-- Consolidation root menu -->
    <menuitem id="menu_cyllo_consolidation_root" name="Consolidation"
              web_icon="cyllo_consolidation,static/description/cyllo_consolidaton.svg"/>

    <!-- Dashboard -->
    <menuitem id="menu_dashboard" name="Dashboard" sequence="0"
              action="action_view_dashboard"
              parent="cyllo_consolidation.menu_cyllo_consolidation_root"/>

    <!-- Operations -->
    <menuitem id="menu_operations_categ" name="Operations" sequence="1"
              parent="cyllo_consolidation.menu_cyllo_consolidation_root"/>
    <!-- Operations > Journal Entry -->
    <menuitem id="menu_journal_entry" name="Journal Entry" action="action_view_journal_entry"
              parent="cyllo_consolidation.menu_operations_categ"/>

    <!-- Configurations -->
    <menuitem id="menu_configurations_categ" name="Configurations" sequence="2"
              parent="cyllo_consolidation.menu_cyllo_consolidation_root"/>
    <!-- Configurations > Consolidation -->
    <menuitem id="menu_consolidation" name="Consolidation"
              action="action_view_consolidation"
              parent="cyllo_consolidation.menu_configurations_categ"/>
    <!-- Configurations > Consolidation Account -->
    <menuitem id="menu_consolidation_account" name="Consolidation Account"
              action="action_view_consolidation_account"
              parent="cyllo_consolidation.menu_configurations_categ"/>
    <!-- Configurations > Periods -->
    <menuitem id="menu_periods" name="Periods"
              action="action_view_periods"
              parent="cyllo_consolidation.menu_configurations_categ"/>
    <!-- Configurations > Account Group -->
    <menuitem id="menu_account_group" name="Account Group"
              action="action_view_account_group"
              parent="cyllo_consolidation.menu_configurations_categ"/>
</odoo>