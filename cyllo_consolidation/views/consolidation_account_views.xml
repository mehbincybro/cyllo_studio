<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--Tree view of the Consolidation Account-->
    <record id="view_consolidation_account_tree" model="ir.ui.view">
        <field name="name">view.consolidation.account.tree</field>
        <field name="model">consolidation.account</field>
        <field name="arch" type="xml">
            <tree string="consolidation.account">
                <field name="view_name"/>
                <field name="chart_id"/>
                <field name="account_ids" widget="many2many_tags"/>
            </tree>
        </field>
    </record>
    <!--Form view of the Consolidation Account-->
    <record id="view_consolidation_account_form" model="ir.ui.view">
        <field name="name">view.consolidation.account.form</field>
        <field name="model">consolidation.account</field>
        <field name="arch" type="xml">
            <form string="consolidation_account">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" class="oe_title" placeholder="e.g. Income"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="company_id" invisible="True"/>
                            <field name="chart_id" placeholder="Select Consolidation"/>
                            <field name="is_invert_sign"/>
                        </group>
                        <group>
                            <field name="group_id" placeholder="Select Consolidation group"
                                   domain="[('chart_id', '=', chart_id)]"/>
                        </group>
                    </group>
                    <group string="Consolidated Companies">
                        <field name="account_ids" options="{'no_create':True}" nolabel="1" colspan="2">
                            <tree>
                                <field name="name"/>
                                <field name="company_id"/>
                            </tree>
                        </field>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                    <field name="activity_ids"/>
                </div>
            </form>
        </field>
    </record>
    <!--Search view of the Consolidation Account-->
    <record id="view_consolidation_account_search" model="ir.ui.view">
        <field name="name">view.consolidation.account.search</field>
        <field name="model">consolidation.account</field>
        <field name="priority">15</field>
        <field name="arch" type="xml">
            <search string="Search Opportunities">
                <field name="name" string="Account"/>
                <field name="view_name" string="Name"/>
                <field name="chart_id" string="Consolidation"/>
                <field name="group_id" string="Group"/>
                <separator/>
                <filter string="Creation Date" name="creation_date" date="create_date"/>
                <separator/>
                <group expand="0" string="Group By" colspan="16">
                    <filter string="Consolidation" name="chart_id" context="{'group_by':'chart_id'}"/>
                    <filter string="Group" name="group_id" context="{'group_by':'group_id'}"/>
                </group>
            </search>
        </field>
    </record>
    <!--Action specified for the Consolidation Account-->
    <record id="action_view_consolidation_account" model="ir.actions.act_window">
        <field name="name">Consolidation Account</field>
        <field name="res_model">consolidation.account</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No Accounts Found</p>
            <p>Links accounts across companies for precise data aggregation.</p>
        </field>
    </record>
</odoo>