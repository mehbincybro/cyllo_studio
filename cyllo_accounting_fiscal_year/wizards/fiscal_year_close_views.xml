<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_fiscal_year_close_form" model="ir.ui.view">
        <field name="name">view.fiscal.year.close.form</field>
        <field name="model">fiscal.year.close</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="all_periods"/>
                            <field name="fiscal_year_id" invisible="1"/>
                            <field name="end_period_id" domain="[('fiscal_year_id', '=', fiscal_year_id), ('state', '=', 'open')]" invisible="all_periods == True" required="all_periods == False"/>
                        </group>
                        <div invisible="all_periods == False">
                            All the periods in this fiscal year will be closed
                        </div>
                        <div invisible="all_periods == True">
                            The periods until this month will be closed
                        </div>
                    </group>
                    <footer>
                        <button name="action_close_fiscal_year" type="object" string="Confirm" class="oe_highlight"/>
                        <button string="Cancel" class="btn-default" special="cancel"/>
                    </footer>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_view_close_fiscal_year" model="ir.actions.act_window">
        <field name="name">Close Fiscal Year</field>
        <field name="res_model">fiscal.year.close</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>