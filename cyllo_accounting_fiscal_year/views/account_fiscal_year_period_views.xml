<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_account_fiscal_year_period_form" model="ir.ui.view">
        <field name="name">view.account.fiscal.year.period.form</field>
        <field name="model">account.fiscal.year.period</field>
        <field name="arch" type="xml">
            <form string="Fiscal Year Period" create="false">
                <header>
                    <button name="action_close" invisible="state != 'open'" string="Close"
                            type="object" class="oe_highlight"/>
                    <button name="action_reopen" invisible="state != 'close'" string="Re-Open"
                            type="object" class="oe_highlight"/>
                    <field name="state" statusbar_visible="open,close" widget="statusbar"/>
                </header>
                <sheet>
                    <group col="2">
                        <group>
                            <field name="name" readonly="state == 'closed'"/>
                            <field name="fiscal_year_id" readonly="state == 'closed'"/>
                            <field name="company_id"/>
                        </group>
                        <group>
                            <field name="sequence" invisible="1"/>
                            <field name="start_date" readonly="state == 'closed'"/>
                            <field name="end_date" readonly="state == 'closed'"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="view_account_fiscal_year_period_tree" model="ir.ui.view">
        <field name="name">view.account.fiscal.year.period.tree</field>
        <field name="model">account.fiscal.year.period</field>
        <field name="arch" type="xml">
            <tree string="Fiscal Year Periods" create="false">
                <field name="name"/>
                <field name="start_date"/>
                <field name="end_date" />
                <field name="state" />
            </tree>
        </field>
    </record>
    <record id="view_account_fiscal_year_period_search" model="ir.ui.view">
        <field name="name">view.account.fiscal.year.period.search</field>
        <field name="model">account.fiscal.year.period</field>
        <field name="arch" type="xml">
            <search string="Fiscal Year Period">
                <field name="name"/>
                <filter name="closed" string="Closed" domain="[('state', '=', 'close')]"/>
                <filter name="opened" string="Opened" domain="[('state', '=', 'open')]"/>
                <group expand="0" string="Group By">
                    <filter string="Status" name="status" context="{'group_by':'state'}"/>
                    <filter string="Fiscal Year" name="fiscal_year_id" context="{'group_by':'fiscal_year_id'}"/>
                </group>
            </search>
        </field>
    </record>
    <record id="action_view_periods" model="ir.actions.act_window">
        <field name="name">Fiscal Year Periods</field>
        <field name="res_model">account.fiscal.year.period</field>
        <field name="search_view_id" ref="view_account_fiscal_year_period_search"/>
        <field name="view_ids" eval="[Command.clear(),
            Command.create({'view_mode': 'tree', 'view_id': ref('view_account_fiscal_year_period_tree')}),
            Command.create({'view_mode': 'form', 'view_id': ref('view_account_fiscal_year_period_form')})]"/>
    </record>
    <menuitem id="menu_periods" name="Periods" action="action_view_periods" parent="menu_fiscal_years_and_periods_categ"/>
</odoo>
