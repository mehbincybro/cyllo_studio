<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_account_fiscal_year_form" model="ir.ui.view">
        <field name="name">view.account.fiscal.year.form</field>
        <field name="model">account.fiscal.year</field>
        <field name="arch" type="xml">
            <form string="Fiscal Year">
                <header>
                    <button name="action_create_periods" string="Create Periods"
                            type="object" class="oe_highlight" invisible="period_ids or state != 'draft'"/>
                    <button name="action_reopen" invisible="state != 'close'" string="Re-Open"
                            type="object" class="oe_highlight"/>
                    <button name="action_open" string="Open" type="object" class="oe_highlight"
                            invisible="not period_ids or state != 'draft'"/>
                    <button name="action_draft" invisible="state != 'open'" string="Set to draft"
                            type="object" class="oe_highlight"/>
                    <button name="%(cyllo_accounting_fiscal_year.action_view_close_fiscal_year)d"
                            invisible="state != 'open'" string="Close" type="action" class="oe_highlight"/>
                    <field name="state" statusbar_visible="draft,open" widget="statusbar"/>
                </header>
                <sheet>
                    <group col="2">
                        <group>
                            <field name="name"/>
                            <field name="company_id"/>
                        </group>
                        <group>
                            <field name="start_date"/>
                            <field name="end_date"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Periods" invisible="not period_ids">
                            <field name="period_ids" colspan="4" string="Periods" nolabel="1" widget="one2many">
                                <tree string="Period" decoration-info="state == 'open'" editable="bottom"
                                      create="false" delete="false">
                                    <field name="sequence" invisible="1"/>
                                    <field name="name" readonly="1"/>
                                    <field name="start_date" readonly="1"/>
                                    <field name="end_date" readonly="1"/>
                                    <field name="state" readonly="1"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
    <record id="view_account_fiscal_year_tree" model="ir.ui.view">
        <field name="name">view.account.fiscal.year.tree</field>
        <field name="model">account.fiscal.year</field>
        <field name="arch" type="xml">
            <tree string="Fiscal Years">
                <field name="name"/>
                <field name="start_date"/>
                <field name="end_date" />
                <field name="state"/>
            </tree>
        </field>
    </record>
    <record id="view_account_fiscal_year_search" model="ir.ui.view">
        <field name="name">view.account.fiscal.year.search</field>
        <field name="model">account.fiscal.year</field>
        <field name="arch" type="xml">
            <search string="Fiscal Year">
                <field name="name"/>
                <filter name="closed" string="Closed" domain="[('state', '=', 'close')]"/>
                <filter name="opened" string="Opened" domain="[('state', '=', 'open')]"/>
                <group expand="0" string="Group By">
                    <filter string="Status" name="status" context="{'group_by':'state'}"/>
                </group>
            </search>
        </field>
    </record>
    <record id="action_view_fiscal_years" model="ir.actions.act_window">
        <field name="name">Fiscal Years</field>
        <field name="res_model">account.fiscal.year</field>
        <field name="search_view_id" ref="view_account_fiscal_year_search"/>
        <field name="view_ids" eval="[Command.clear(),
            Command.create({'view_mode': 'tree', 'view_id': ref('view_account_fiscal_year_tree')}),
            Command.create({'view_mode': 'form', 'view_id': ref('view_account_fiscal_year_form')})]"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create new fiscal year
            </p>
        </field>
    </record>
    <menuitem id="menu_fiscal_years_and_periods_categ" name="Fiscal Years and Periods"
              parent="account.menu_finance_configuration"/>
    <menuitem id="menu_fiscal_years" name="Fiscal Years" action="action_view_fiscal_years"
              parent="menu_fiscal_years_and_periods_categ"/>
</odoo>
