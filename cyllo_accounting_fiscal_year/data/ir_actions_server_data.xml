<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- To close selected periods -->
    <record id="model_account_fiscal_year_period_action_close_periods" model="ir.actions.server">
        <field name="name">Close</field>
        <field name="model_id" ref="model_account_fiscal_year_period"/>
        <field name="binding_model_id" ref="cyllo_accounting_fiscal_year.model_account_fiscal_year_period"/>
        <field name="state">code</field>
        <field name="code">
            records.action_close_periods()
        </field>
    </record>
    <!-- To close selected fiscal years -->
    <record id="model_account_fiscal_year_period_action_re_open_periods" model="ir.actions.server">
        <field name="name">Re-Open</field>
        <field name="model_id" ref="model_account_fiscal_year_period"/>
        <field name="binding_model_id" ref="cyllo_accounting_fiscal_year.model_account_fiscal_year_period"/>
        <field name="state">code</field>
        <field name="code">
            records.action_re_open_periods()
        </field>
    </record>
</odoo>