<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_account_analytic_line_grid" model="ir.ui.view">
        <field name="name">view.account.analytic.line.grid</field>
        <field name="model">account.analytic.line</field>
        <field name="arch" type="xml">
            <grid string="My Grid View">
                <!-- Add your columns here -->
                <field name="employee_id"/>
                <field name="name"/>
                <field name="id"/>
                <field name="task_id"/>
                <field name="project_id"/>
                <field name="unit_amount"/>
                <field name="date"/>
                <field name="display_name"/>
            </grid>
        </field>
    </record>
    <record id="hr_timesheet.timesheet_action_all"
            model="ir.actions.act_window">
        <field name="view_mode">grid,form,kanban,pivot,graph,tree</field>
    </record>
    <record id="hr_timesheet.act_hr_timesheet_line"
            model="ir.actions.act_window">
        <field name="view_mode">grid,form,kanban,tree</field>
    </record>
    <record id="timesheet_action_view_all_grid"
            model="ir.actions.act_window.view">
        <field name="sequence" eval="1"/>
        <field name="view_mode">grid</field>
        <field name="view_id"
               ref="cyllo_timesheet_grid.view_account_analytic_line_grid"/>
        <field name="act_window_id" ref="hr_timesheet.timesheet_action_all"/>
    </record>
    <record id="timesheet_action_view_all_grid"
            model="ir.actions.act_window.view">
        <field name="sequence" eval="1"/>
        <field name="view_mode">grid</field>
        <field name="view_id"
               ref="cyllo_timesheet_grid.view_account_analytic_line_grid"/>
        <field name="act_window_id" ref="hr_timesheet.timesheet_action_all"/>
    </record>
    <record id="timesheet_action_view_grid" model="ir.actions.act_window.view">
        <field name="sequence" eval="1"/>
        <field name="view_mode">grid</field>
        <field name="view_id"
               ref="cyllo_timesheet_grid.view_account_analytic_line_grid"/>
        <field name="act_window_id" ref="hr_timesheet.act_hr_timesheet_line"/>
    </record>
</odoo>