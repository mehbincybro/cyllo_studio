<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <!-- Multi-company record filtration and security group-->
    <record id="rule_email_digitization_config_company" model="ir.rule">
        <field name="name">Email Digitization Multi-Company</field>
        <field name="model_id" ref="model_email_digitization_config"/>
        <field name="domain_force">['|',('company_id','=',False),('company_id', 'in', company_ids)]</field>
    </record>
    <record id="rule_email_digitization_data_company" model="ir.rule">
        <field name="name">Email Digitization Multi-Company</field>
        <field name="model_id" ref="model_email_digitization_data"/>
        <field name="domain_force">['|',('company_id','=',False),('company_id', 'in', company_ids)]</field>
    </record>
</odoo>