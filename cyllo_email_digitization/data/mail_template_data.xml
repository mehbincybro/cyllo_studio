<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <record id="mail_template_purchase_order_request_for_quotation_email_body"
            model="mail.template">
        <field name="name">Purchase Order Request For Quotation (Email Body)
        </field>
        <field name="model_id" ref="purchase.model_purchase_order"/>
        <field name="subject">
            {{ object.company_id.name }} Order (Ref {{ object.name or 'n/a' }})
        </field>
        <field name="partner_to">{{ object.partner_id.id }}</field>
        <field name="description">
            Sent manually to vendor to request a quotation
        </field>
        <field name="body_html" type="html">
            <div style="margin: 0px; padding: 0px;">
                <p style="margin: 0px; padding: 0px; font-size: 13px;">
                    Dear
                    <t t-out="object.partner_id.name or ''">Brandon Freeman,</t>
                    <t t-if="object.partner_id.parent_id">
                        (<t t-out="object.partner_id.parent_id.name or ''">
                        Azure Interior</t>)
                    </t>
                    <br/>
                    <br/>
                    Here is in a request for quotation
                    <span style="font-weight:bold;" t-out="object.name or ''">
                        P00015
                    </span>
                    <t t-if="object.partner_ref">
                        with reference:
                        <t t-out="object.partner_ref or ''">REF_XXX</t>
                    </t>
                    from <t t-out="object.company_id.name or ''">YourCompany</t>.
                    <br/>
                    <br/>
                    <table class="table table-sm mt-4">
                        <thead style="display: table-row-group">
                            <tr>
                                <th>Description</th>
                                <th>Expected Date</th>
                                <th>Qty</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="object.order_line" t-as="line">
                                <tr>
                                    <td>
                                        <span t-out="line.name"/>
                                    </td>
                                    <td>
                                        <span t-field="line.date_planned"/>
                                    </td>
                                    <td>
                                        <span t-field="line.product_qty"/>
                                        <span t-field="line.product_uom"
                                              groups="uom.group_uom"/>
                                        <span t-if="line.product_packaging_id">
                                            (
                                            <span t-out="line.product_packaging_qty"
                                                  t-options='{"widget": "integer"}'/>
                                            <span t-out="line.product_packaging_id"/>
                                            )
                                        </span>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                    <br/>
                    <br/>
                    If you have any questions, please do not hesitate to contact
                    us.
                    <br/>
                    <br/>
                    Best regards,
                    <t t-if="not is_html_empty(object.user_id.signature)">
                        <br/>
                        <br/>
                        <t t-out="object.user_id.signature or ''">--
                            <br/>
                            Mitchell Admin
                        </t>
                    </t>
                </p>
            </div>
        </field>
        <field name="report_template_ids"
               eval="[(4, ref('purchase.report_purchase_quotation'))]"/>
        <field name="lang">{{ object.partner_id.lang }}</field>
        <field name="auto_delete" eval="True"/>
    </record>
</odoo>