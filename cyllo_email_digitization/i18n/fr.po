#. module: cyllo_email_digitization
#: model:mail.template,body_html:cyllo_email_digitization.mail_template_purchase_order_request_for_quotation_email_body
msgid ""
"<div style=\"margin: 0px; padding: 0px;\">\n"
"                <p style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"                    Dear\n"
"                    <t t-out=\"object.partner_id.name or ''\">Brandon Freeman,</t>\n"
"                    <t t-if=\"object.partner_id.parent_id\">\n"
"                        (<t t-out=\"object.partner_id.parent_id.name or ''\">Azure\n"
"                        Interior</t>)\n"
"                    </t>\n"
"                    <br>\n"
"                    <br>\n"
"                    Here is in a request for quotation\n"
"                    <span style=\"font-weight:bold;\" t-out=\"object.name or ''\">\n"
"                        P00015\n"
"                    </span>\n"
"                    <t t-if=\"object.partner_ref\">\n"
"                        with reference:\n"
"                        <t t-out=\"object.partner_ref or ''\">REF_XXX</t>\n"
"                    </t>\n"
"                    from <t t-out=\"object.company_id.name or ''\">YourCompany</t>.\n"
"                    <br>\n"
"                    <br>\n"
"                    <table class=\"table table-sm mt-4\">\n"
"                        <thead style=\"display: table-row-group\">\n"
"                            <tr>\n"
"                                <th>Description</th>\n"
"                                <th>Expected Date</th>\n"
"                                <th>Qty</th>\n"
"                            </tr>\n"
"                        </thead>\n"
"                        <tbody>\n"
"                            <t t-foreach=\"object.order_line\" t-as=\"line\">\n"
"                                <tr>\n"
"                                    <td>\n"
"                                        <span t-out=\"line.name\"></span>\n"
"                                    </td>\n"
"                                    <td>\n"
"                                        <span t-field=\"line.date_planned\"></span>\n"
"                                    </td>\n"
"                                    <td>\n"
"                                        <span t-field=\"line.product_qty\"></span>\n"
"                                        <span t-field=\"line.product_uom\" groups=\"uom.group_uom\"></span>\n"
"                                        <span t-if=\"line.product_packaging_id\">\n"
"                                            (\n"
"                                            <span t-out=\"line.product_packaging_qty\" t-options='{\"widget\": \"integer\"}'></span>\n"
"                                            <span t-out=\"line.product_packaging_id\"></span>\n"
"                                            )\n"
"                                        </span>\n"
"                                    </td>\n"
"                                </tr>\n"
"                            </t>\n"
"                        </tbody>\n"
"                    </table>\n"
"                    <br>\n"
"                    <br>\n"
"                    If you have any questions, please do not hesitate to contact\n"
"                    us.\n"
"                    <br>\n"
"                    <br>\n"
"                    Best regards,\n"
"                    <t t-if=\"not is_html_empty(object.user_id.signature)\">\n"
"                        <br>\n"
"                        <br>\n"
"                        <t t-out=\"object.user_id.signature or ''\">--\n"
"                            <br>\n"
"                            Mitchell Admin\n"
"                        </t>\n"
"                    </t>\n"
"                </p>\n"
"            </div>\n"
"        "
msgstr ""
"<div style=\"margin: 0px; padding: 0px;\">\n"
"                <p style=\"margin: 0px; padding: 0px; font-size: 13px;\">\n"
"                    Cher(e)\n"
"                    <t t-out=\"object.partner_id.name or ''\">Brandon Freeman,</t>\n"
"                    <t t-if=\"object.partner_id.parent_id\">\n"
"                        (<t t-out=\"object.partner_id.parent_id.name or ''\">Azure\n"
"                        Interior</t>)\n"
"                    </t>\n"
"                    <br>\n"
"                    <br>\n"
"                    Vous trouverez ci-joint une demande de devis\n"
"                    <span style=\"font-weight:bold;\" t-out=\"object.name or ''\">\n"
"                        P00015\n"
"                    </span>\n"
"                    <t t-if=\"object.partner_ref\">\n"
"                        avec la référence:\n"
"                        <t t-out=\"object.partner_ref or ''\">REF_XXX</t>\n"
"                    </t>\n"
"                    de la part de <t t-out=\"object.company_id.name or ''\">YourCompany</t>.\n"
"                    <br>\n"
"                    <br>\n"
"                    <table class=\"table table-sm mt-4\">\n"
"                        <thead style=\"display: table-row-group\">\n"
"                            <tr>\n"
"                                <th>Description</th>\n"
"                                <th>Date d'échéance</th>\n"
"                                <th>Qté</th>\n"
"                            </tr>\n"
"                        </thead>\n"
"                        <tbody>\n"
"                            <t t-foreach=\"object.order_line\" t-as=\"line\">\n"
"                                <tr>\n"
"                                    <td>\n"
"                                        <span t-out=\"line.name\"></span>\n"
"                                    </td>\n"
"                                    <td>\n"
"                                        <span t-field=\"line.date_planned\"></span>\n"
"                                    </td>\n"
"                                    <td>\n"
"                                        <span t-field=\"line.product_qty\"></span>\n"
"                                        <span t-field=\"line.product_uom\" groups=\"uom.group_uom\"></span>\n"
"                                        <span t-if=\"line.product_packaging_id\">\n"
"                                            (\n"
"                                            <span t-out=\"line.product_packaging_qty\" t-options='{\"widget\": \"integer\"}'></span>\n"
"                                            <span t-out=\"line.product_packaging_id\"></span>\n"
"                                            )\n"
"                                        </span>\n"
"                                    </td>\n"
"                                </tr>\n"
"                            </t>\n"
"                        </tbody>\n"
"                    </table>\n"
"                    <br>\n"
"                    <br>\n"
"                    Si vous avez des questions, n'hésitez pas à nous contacter.\n"
"                    <br>\n"
"                    <br>\n"
"                    Cordialement,\n"
"                    <t t-if=\"not is_html_empty(object.user_id.signature)\">\n"
"                        <br>\n"
"                        <br>\n"
"                        <t t-out=\"object.user_id.signature or ''\">--\n"
"                            <br>\n"
"                            Mitchell Admin\n"
"                        </t>\n"
"                    </t>\n"
"                </p>\n"
"            </div>\n"
"        "

