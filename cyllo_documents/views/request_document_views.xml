<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!-- Incoming Request Document -->
    <!-- This XML record defines a form view for creating or editing incoming document requests.-->
    <record id="view_request_document_incoming_form" model="ir.ui.view">
        <field name="name">view.request.document.incoming.form</field>
        <field name="model">request.document</field>
        <field name="arch" type="xml">
            <form string="Request document">
                <header>
                    <button type="action" name="%(cyllo_documents.action_view_document_request_accept)d"
                            string="ACCEPT" class="btn-primary" invisible="state != 'requested'"
                            context="{'default_document_request_id': id,'default_workspace_id':workspace_id}"/>
                    <button type="action" name="%(cyllo_documents.action_view_document_request_reject)d"
                            string="REJECT" class="btn-secondary" invisible="state != 'requested'"
                            context="{'default_document_request_id': id}"/>
                    <field name="state" widget="statusbar" statusbar_visible="requested,accepted,rejected"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <div class="d-flex">
                                <field name="display_name" class="text-break" options="{'line_breaks': False}"
                                       widget="text" readonly="1"/>
                            </div>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="user_id" string="Request To"/>
                            <field name="needed_doc" colspan="2" string="Note" placeholder="Document Needed....."/>
                            <field name="workspace_id" string="Workspace"/>
                        </group>
                        <group>
                            <field name="requested_by_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page name="public" string="Reject reason" invisible="state != 'rejected'">
                            <field name="reject_reason"/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>
    <!-- This XML record defines a tree view for creating or editing incoming document requests.-->
    <record id="view_request_document_incoming_tree" model="ir.ui.view">
        <field name="name">view.request.document.incoming.tree</field>
        <field name="model">request.document</field>
        <field name="arch" type="xml">
            <tree>
                <field name="needed_doc" string="Request"/>
                <field name="display_name" string="Name"/>
                <field name="requested_by_id" string="Requested by" widget="many2one_avatar_user"/>
                <field name="user_id" string="Requested to" widget="many2one_avatar_user"/>
                <field name="create_date" string="Requested Date"/>
                <field name="workspace_id" string="Workspace"/>
                <field name="needed_doc" string="Document"/>
                <field name="state" string="State" widget="badge" decoration-warning="state == 'requested'"
                       decoration-danger="state == 'rejected'" decoration-success="state == 'accepted'"/>
            </tree>
        </field>
    </record>
    <!-- This XML code defines an Odoo search view for searching and filtering incoming request documents. -->
    <record id="view_request_document_incoming_search" model="ir.ui.view">
        <field name="name">view.request.document.incoming.search</field>
        <field name="model">request.document</field>
        <field name="arch" type="xml">
            <search string="Document Search">
                <field name="display_name" string="Name"/>
                <field name="needed_doc" string="Request"/>
                <field name="create_date"/>
                <field name="workspace_id"/>
                <field name="state"/>
                <filter string="Requested" name="requested" domain="[('state', '=', 'requested')]"/>
                <filter string="Accepted" name="accepted" domain="[('state', '=', 'accepted')]"/>
                <filter string="Rejected" name="rejected" domain="[('state', '=', 'rejected')]"/>
                <group expand="0" string="Group By">
                    <filter name="group_workspace" string="Workspace" context="{'group_by':'workspace_id'}"/>
                    <filter name="group_state" string="State" context="{'group_by':'state'}"/>
                    <filter name="group_requested_by" string="Requested By" context="{'group_by':'requested_by_id'}"/>
                    <filter name="group_date" string="Date" context="{'group_by':'create_date'}"/>
                </group>
            </search>
        </field>
    </record>
    <!-- This XML record defines an action for opening the incoming requests related to the document.-->
    <record id="action_view_incoming_requests" model="ir.actions.act_window">
        <field name="name">Incoming Requests</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">request.document</field>
        <field name="domain">[('user_id','=', uid)]</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="view_request_document_incoming_tree"/>
        <field name="view_ids" eval="[Command.clear(),
                Command.create({'view_mode': 'tree', 'view_id': ref('view_request_document_incoming_tree')}),
                Command.create({'view_mode': 'form', 'view_id': ref('view_request_document_incoming_form')})]"/>
        <field name="context">{'create':False,'edit':False,'search_default_requested':True, }</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a Request for document from user
            </p>
        </field>
    </record>

    <!-- Outgoing Request Document -->
    <!-- This XML record defines a form view for creating or editing incoming document requests.-->
    <record id="view_request_document_outgoing_form" model="ir.ui.view">
        <field name="name">view.request.document.form</field>
        <field name="model">request.document</field>
        <field name="arch" type="xml">
            <form string="Request document">
                <header>
                    <button name="action_send_document_request" string="REQUEST" type="object" class="btn-primary"
                            invisible="state != 'draft'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,requested,accepted,rejected"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <div class="d-flex">
                                <field name="display_name" class="text-break" options="{'line_breaks': False}"
                                       widget="text" readonly="1"/>
                            </div>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="user_id" string="Request To"/>
                            <field name="needed_doc" colspan="2" string="Note" placeholder="Document Needed....."/>
                            <field name="workspace_id" string="Workspace"/>
                        </group>
                    </group>
                    <notebook>
                        <page name="public" string="Reject reason" invisible="state != 'rejected'">
                            <field name="reject_reason"/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>
    <!--  This XML record defines a tree view for the 'request.document' model.-->
    <record id="view_request_document_outgoing_tree" model="ir.ui.view">
        <field name="name">view.request.document.outgoing.tree</field>
        <field name="model">request.document</field>
        <field name="arch" type="xml">
            <tree>
                <field name="display_name" string="Name"/>
                <field name="needed_doc" string="Request"/>
                <field name="requested_by_id" string="Requested by" widget="many2one_avatar_user"/>
                <field name="user_id" string="Requested to" widget="many2one_avatar_user"/>
                <field name="create_date" string="Requested Date"/>
                <field name="workspace_id" string="Workspace"/>
                <field name="needed_doc" string="Document"/>
                <field name="state" string="State" widget="badge" decoration-info="state == 'draft'"
                       decoration-warning="state == 'requested'" decoration-danger="state == 'rejected'"
                       decoration-success="state == 'accepted'"/>
            </tree>
        </field>
    </record>
    <!-- This XML code defines an Odoo search view for searching and filtering outgoing request documents. -->
    <record id="view_request_document_outgoing_search" model="ir.ui.view">
        <field name="name">view.request.document.outgoing.search</field>
        <field name="model">request.document</field>
        <field name="arch" type="xml">
            <search string="Document Search">
                <field name="display_name" string="Name"/>
                <field name="needed_doc" string="Request"/>
                <field name="create_date"/>
                <field name="workspace_id"/>
                <field name="state"/>
                <filter string="My requests" name="user_id" domain="[('requested_by_id.id', '=', uid )]"/>
                <separator/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Requested" name="requested" domain="[('state', '=', 'requested')]"/>
                <filter string="Accepted" name="accepted" domain="[('state', '=', 'accepted')]"/>
                <filter string="Rejected" name="rejected" domain="[('state', '=', 'rejected')]"/>
                <group expand="0" string="Group By">
                    <filter name="group_workspace" string="Workspace" context="{'group_by':'workspace_id'}"/>
                    <filter name="group_state" string="State" context="{'group_by':'state'}"/>
                    <filter name="group_date" string="Date" context="{'group_by':'create_date'}"/>
                </group>
            </search>
        </field>
    </record>
    <!--  This XML record defines an action window to open the Outgoing Requests list view.-->
    <record id="action_view_outgoing_requests" model="ir.actions.act_window">
        <field name="name">Outgoing Requests</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">request.document</field>
        <field name="domain">[('requested_by_id','=', uid)]</field>
        <field name="search_view_id" ref="view_request_document_outgoing_search"/>
        <field name="view_mode">tree,form</field>
        <field name="context">{"search_default_user_id":uid}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a Request for document from user
            </p>
        </field>
    </record>


    <!-- This record defines a wizard form view for the model 'request.document'. -->
    <record id="view_request_document_wizard_form" model="ir.ui.view">
        <field name="name">view.request.document.wizard.form</field>
        <field name="model">request.document</field>
        <field name="arch" type="xml">
            <form string="Request document">
                <group>
                    <group>
                        <field name="user_id" string="Request To"/>
                        <field name="needed_doc" colspan="2" string="Note" placeholder="Document Needed....."/>
                    </group>
                    <group>
                        <field name="workspace_id" string="Workspace"/>
                    </group>
                </group>
                <footer>
                    <button name="action_send_document_request" string="REQUEST" type="object" class="btn-primary"/>
                    <button class="btn" string="DISCARD" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>