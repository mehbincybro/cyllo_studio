<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!--Defines a menu structure for a document module.-->
    <!-- Root Menu: Documents -->
    <menuitem id="menu_cyllo_documents_root" name="Documents"
              web_icon="cyllo_documents,static/description/cyllo_documents.svg" sequence="0"/>

    <!-- Sub Menu: Documents (Child of Root) -->
    <menuitem id="menu_documents" name="Documents" action="action_view_documents"
              parent="menu_cyllo_documents_root" sequence="1"/>

    <!-- Configuration Menu (Child of Root) -->
    <menuitem id="menu_configuration_categ" name="Configuration" parent="menu_cyllo_documents_root"/>
    <!-- Settings (Child of Configuration) -->
    <menuitem id="menu_settings" name="Settings" action="cyllo_documents.action_view_document_config_settings"
              parent="menu_configuration_categ" sequence="0"/>
    <!-- Workspace Document (Child of Configuration) -->
    <menuitem id="menu_workspace" name="Workspace" action="action_view_workspace"
              parent="menu_configuration_categ" sequence="1"/>
    <!-- Trash Document (Child of Configuration) -->
    <menuitem id="menu_trash" name="Trash" action="action_view_trash"
              parent="menu_configuration_categ" sequence="2"/>
    <!-- Tags Menu (Child of Configuration) -->
    <menuitem id="menu_tags" name="Tags" action="action_view_tags" parent="menu_configuration_categ"
              sequence="3"/>
    <!-- Requests Menu (Child of Configuration) -->
    <menuitem id="menu_operations_categ" name="Operations" parent="menu_cyllo_documents_root" sequence="1"/>

    <!-- Incoming Requests (Child of Requests) -->
    <menuitem id="menu_incoming_requests" name="Incoming Requests" action="action_view_incoming_requests"
              parent="menu_operations_categ" sequence="3"/>
    <!-- Outgoing Requests (Child of Requests) -->
    <menuitem id="menu_outgoing_requests" name="Outgoing Requests" action="action_view_outgoing_requests"
              parent="menu_operations_categ" sequence="3"/>
    <!-- Document Request Template (Child of Requests) -->
    <menuitem id="menu_document_request_template" name="Document Template"
              action="action_view_document_request_template" parent="menu_operations_categ" sequence="3"/>
    <!-- Request a Template (Child of Requests) -->
    <menuitem id="menu_request_a_template" name="Request a Template"
              action="action_view_request_a_template"
              parent="menu_operations_categ"
              sequence="2"/>
</odoo>