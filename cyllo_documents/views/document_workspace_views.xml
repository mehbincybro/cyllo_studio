<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!-- This XML record defines a form view for managing WorkSpaces.-->
    <record id="view_document_workspace_form" model="ir.ui.view">
        <field name="name">view.document.workspace.form</field>
        <field name="model">document.workspace</field>
        <field name="arch" type="xml">
            <form string="Workspace">
                <sheet>
                    <div name="button_box" class="oe_button_box">
                        <button id="button_view_document" name="action_button_view_document" type="object"
                                class="oe_stat_button" icon="fa-edit" invisible="document_count == 0">
                            <field name="document_count" string="Documents" widget="statinfo"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <div class="d-flex">
                                <field name="name" class="text-break" options="{'line_breaks': False}"
                                       widget="text" readonly="1"/>
                            </div>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="company_id"/>
                        </group>
                        <group>
                            <field name="google_drive_folder_id"/>
                            <field name="onedrive_folder_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description">
                            <field name="description"/>
                        </page>
                        <page string="Settings" groups="cyllo_documents.group_cyllo_documents_manager">
                            <label for="privacy_visibility"/>
                            <field name="privacy_visibility" string='Visibility' widget="radio"
                                   groups="cyllo_documents.group_cyllo_documents_manager" style="margin: 10px;"/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>
    <!-- This XML record defines a tree view for displaying WorkSpaces.-->
    <record id="view_document_workspace_tree" model="ir.ui.view">
        <field name="name">view.document.workspace.tree</field>
        <field name="model">document.workspace</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="company_id"/>
            </tree>
        </field>
    </record>
    <!-- This XML code defines an Odoo search view for searching and filtering Workspace. -->
    <record id="view_document_workspace_search" model="ir.ui.view">
        <field name="name">view.document.workspace.search</field>
        <field name="model">document.workspace</field>
        <field name="arch" type="xml">
            <search string="Workspace Search">
                <field name="name" string="Name"/>
                <field name="company_id" string="Company"/>
            </search>
        </field>
    </record>
    <!-- This XML record defines an action for managing WorkSpaces.-->
    <record id="action_view_workspace" model="ir.actions.act_window">
        <field name="name">WorkSpace</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">document.workspace</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a Workspace
            </p>
        </field>
    </record>
</odoo>
