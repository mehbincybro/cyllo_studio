<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_document_tag_tree" model="ir.ui.view">
        <field name="name">view.document.tag.tree</field>
        <field name="model">document.tag</field>
        <field name="arch" type="xml">
                <tree string="Tags" editable="bottom" sample="1">
                <field name="name"/>
            </tree>
        </field>
    </record>
    <record id="action_view_tags" model="ir.actions.act_window">
        <field name="name">Document tag</field>
        <field name="res_model">document.tag</field>
        <field name="view_mode">tree</field>
    </record>
</odoo>