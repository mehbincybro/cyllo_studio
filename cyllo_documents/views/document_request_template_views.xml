<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!--Tree view-->
    <record id="view_document_request_template_tree" model="ir.ui.view">
        <field name="name">view.document.request.template.tree</field>
        <field name="model">document.request.template</field>
        <field name="arch" type="xml">
            <tree string="Document request template">
                <field name="name"/>
                <field name="manager_id"/>
            </tree>
        </field>
    </record>
    <!-- Form view-->
    <record id="view_document_request_template_form" model="ir.ui.view">
        <field name="name">view.document.request.template.form</field>
        <field name="model">document.request.template</field>
        <field name="arch" type="xml">
            <form string="Document request template">
                <sheet>
                    <field name="stamp" widget="image" class="oe_avatar" options="{'preview_image': 'stamp'}"/>
                    <div class="oe_title">
                        <h1>
                            <div class="d-flex">
                                <field name="name" class="text-break" options="{'line_breaks': False}" widget="text"
                                       placeholder="e.g. Leave Letter" readonly="1"/>
                            </div>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="manager_id" domain="[('id', 'in', user_ids)]"/>
                            <field name="company_id"/>
                            <field name="user_ids" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Template">
                            <field name="template"/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>
    <!-- This XML code defines an Odoo search view for searching and filtering incoming  documents request . -->
    <record id="view_document_request_template_search" model="ir.ui.view">
        <field name="name">view.document.request.template.search</field>
        <field name="model">document.request.template</field>
        <field name="arch" type="xml">
            <search string="Document Template">
                <field name="name" string="Name"/>
                <field name="company_id" string="Company"/>
                <filter string="My Document Templates" name="manager_id" domain="[('manager_id.id', '=', uid)]"/>
            </search>
        </field>
    </record>
    <!--Action for document.request.template model-->
    <record id="action_view_document_request_template" model="ir.actions.act_window">
        <field name="name">Document Template</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">document.request.template</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_manager_id': uid}</field>
    </record>
</odoo>