<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!-- Define a module category for Document Management -->
    <record id="ir_module_category_document_management" model="ir.module.category">
        <field name="name">Document Management</field>
        <field name="description">Access for Document module</field>
        <field name="sequence">50</field>
    </record>
    <!-- Define a group 'User' -->
    <record id="group_cyllo_documents_user" model="res.groups">
        <field name="name">User</field>
        <field name="category_id" ref="ir_module_category_document_management"/>
    </record>
    <!-- Define a group 'Manager' with implied 'User' group and associated users -->
    <record id="group_cyllo_documents_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="category_id" ref="ir_module_category_document_management"/>
        <field name="implied_ids" eval="[Command.link(ref('group_cyllo_documents_user'))]"/>
        <field name="users" eval="[Command.link(ref('base.user_admin'))]"/>
    </record>

    <!-- Set default groups for the base.default_user -->
    <record id="base.default_user" model="res.users">
        <field name="groups_id" eval="[Command.link(ref('cyllo_documents.group_cyllo_documents_user'))]"/>
    </record>
</odoo>