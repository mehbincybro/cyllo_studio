<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!--  Template for requested document -->
    <template id="document_download">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <t t-foreach="docs" t-as="o">
                    <img t-if='o.stamp' t-attf-src="data:image/png;base64,{{o.stamp}}" alt="Logo"
                         style="margin-left:75%;"/>
                    <t t-raw="o.template"/>
                </t>
                <img t-if='image' t-attf-src="data:image/png;base64,{{image}}" alt="Logo" style="margin-left:75%;"/>
                <t t-if="template" t-raw="template"/>
            </t>
        </t>
    </template>
</odoo>
