<?xml version="1.0" encoding="UTF-8" ?>
<odoo noupdate="1">
    <!--Defines a sequence for document template requests.
        Code: document.template.request
        Prefix: DTR, Padding: 5 digits-->
    <record id="ir_sequence_document_template_request" model="ir.sequence">
        <field name="name">Document Template Request</field>
        <field name="code">document.template.request</field>
        <field name="prefix">DTR</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>
    <!--Defines a sequence for document requests.
    Code: document request
    Prefix: DR, Padding: 5 digits-->
    <record id="ir_sequence_document_request" model="ir.sequence">
        <field name="name">Document Request</field>
        <field name="code">document.request</field>
        <field name="prefix">DR</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>
</odoo>