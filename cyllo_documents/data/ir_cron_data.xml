<?xml version="1.0" encoding="UTF-8" ?>
<odoo noupdate="1">
    <!-- scheduled task to delete documents at regular intervals -->
    <record id="ir_cron_document_delete" model="ir.cron">
        <field name="name">Document Delete</field>
        <field name="model_id" ref="cyllo_documents.model_document_file"/>
        <field name="state">code</field>
        <field name="code">model.delete_doc()</field>
        <field name="user_id" ref="base.user_root"/>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
    </record>
    <!-- scheduled task for automatic document deletion at regular intervals -->
    <record id="ir_cron_auto_document_delete" model="ir.cron">
        <field name="name">Auto Document Delete</field>
        <field name="model_id" ref="cyllo_documents.model_document_trash"/>
        <field name="state">code</field>
        <field name="code">model.auto_delete_doc()</field>
        <field name="user_id" ref="base.user_root"/>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
    </record>
    <!--  scheduled task to sync OneDrive at regular intervals  -->
    <record id="ir_cron_sync_one_drive" model="ir.cron">
        <field name="name">Sync One Drive</field>
        <field name="model_id" ref="cyllo_documents.model_one_drive_connector"/>
        <field name="state">code</field>
        <field name="code">model.auto_sync_one_drive()</field>
        <field name="user_id" ref="base.user_root"/>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
    </record>
    <!-- scheduled task to sync Google Drive at regular intervals -->
    <record id="ir_cron_sync_google_drive" model="ir.cron">
        <field name="name">Sync Google Drive</field>
        <field name="model_id" ref="cyllo_documents.model_google_drive_connector"/>
        <field name="state">code</field>
        <field name="code">model.auto_sync_google_drive()</field>
        <field name="user_id" ref="base.user_root"/>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
    </record>
</odoo>