<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!-- Define a form view for the document.share model -->
    <record id="view_document_share_form" model="ir.ui.view">
        <field name="name">view.document.share.form</field>
        <field name="model">document.share</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="url" widget="CopyClipboardChar"/>
                    </group>
                </sheet>
                <footer>
                    <button special="cancel">Cancel</button>
                </footer>
            </form>
        </field>
    </record>
    <!-- Define an action to open the "Share Document" wizard -->
    <record id="action_view_document_share" model="ir.actions.act_window">
        <field name="name">Share Document</field>
        <field name="res_model">document.share</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
