<?xml version="1.0" encoding="UTF-8" ?>
<templates>
    <t t-name="authentication">
        <Dialog size="'md'" footer="false" title="props.title" contentClass="'doc_auth_content'">
            <div class="doc_auth_container_pass">
                <div>
                    <div>
                        <form t-on-submit.prevent="">
                            <input placeholder="Password" t-att-class="passwordClass" class="form-control cy_password_widget"
                                   type="password" autocomplete="current-password"
                                   t-model="state.password" t-on-keydown="handleKeyDown"/>
                        </form>
                    </div>
                </div>
                <div class="d-flex gap-2 justify-content-center h-40px">
                    <button type="button" class="btn btn-secondary w-100" t-on-click="handleAuthConfirm">Ok</button>
                    <button type="button" class="btn btn-secondary w-100" t-on-click="handleAuthClose">Cancel</button>
                </div>
            </div>

        </Dialog>

    </t>
</templates>