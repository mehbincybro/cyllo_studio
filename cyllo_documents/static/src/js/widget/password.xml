<?xml version="1.0" encoding="UTF-8" ?>
<templates>
    <t t-name="Password" t-inherit="web.CharField" t-inherit-mode="primary">
        <xpath expr="//input[hasclass('o_input')]" position="attributes">
            <attribute name="t-attf-class" add="{{ props.isPassword ? 'cy_password_widget form-control background-color-unset' : 'form-control' }}" separator=" "/>
        </xpath>
    </t>
</templates>