<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <!-- This is a template for a web interface, specifically for a Kanban view. -->
    <t t-inherit="web.KanbanView" t-inherit-mode="extension" owl="1"
       t-name="button_in_kanban.button">
        <!-- Modify the content using XPath -->
        <xpath expr="//t[@t-if='canCreate']" position="replace">
            <!-- Condition: Check if the document type is 'document.file' -->
            <t t-if="model.env.searchModel.resModel == 'document.file'">
                <!-- Check if the user can create documents -->
                <t t-if="!canCreate">
                    <!-- Input element for file uploads -->
                    <div class="d-flex gap-3 mx-4">
                        <input type="file" id="fileInput" class="fileInput"
                               style="display: none;"
                               t-on-change="fileUpload"/>
                        <!-- Button group for various actions -->
                        <div class="btn-group gap-3">
                            <!-- Button to trigger file input click -->
                            <ul class="navbar-nav flex-row flex-wrap gap-4">
                                <li class="nav-item">
                                    <a class="cy-navitem-list cursor-pointer" onclick="$('#fileInput').click()" data-hotkey="a"
                                       style="color: #6F7500 !important; font-weight: 600;">
                                        <i class="ri-upload-line on_upload_doc"/>
                                        Upload
                                    </a>
                                </li>
                                <!-- Button to create a request -->
                                <li class="nav-item">
                                    <a class="cy-navitem-list cursor-pointer" data-hotkey="r" t-on-click="_onRequestDoc">
                                        <i class="ri-file-add-line on_add_request"/>Create Request</a>
                                </li>
                                <!-- Button to add a URL -->
                                <li class="nav-item">
                                    <a class="cy-navitem-list cursor-pointer" data-hotkey="l" t-on-click="_onAddUrl">
                                        <i class="ri-link on_add_url"/>
                                        Add Url</a>
                                </li>
                                <li class="nav-item select_document" style="display:none;">
                                <a class="cy-navitem-list  select_document_cy cursor-pointer"
                                   t-on-click="Select_Doc">
                                        <i class="ri-checkbox-line"/>
                                    Select
                                </a>
                            </li>
                                <!-- Button to cancel document selection -->
                                <li class="nav-item cancel_btn" style="display:none;">
                                <a class=" cy-navitem-list" id="cancelBtn"
                                   t-on-click="CancelSelect">
                                    <i class="ri-close-line"/>
                                    Cancel
                                </a>
                            </li>
                            </ul>
                        </div>
                        <!-- Container for additional actions -->
                        <div class="new_container toast"
                             style="overflow-x: hidden;">
                            <!-- Share button -->
                            <button type="button" name="cl"
                                    class="btn btn-secondary fa fa-share-alt btn-sm on_share_button"
                                    style="width: 43px; padding-top: 10px; padding-left: 11px;
                                    padding-right: 13px; padding-bottom: 8px;
                                    border-radius: 11px; background: #e60023;
                                    color: white; font-size: 23px;"
                                    title="Share"
                                    t-on-click="_onShare"/>
                            <!-- Download archive button -->
                            <button type="button" name="archive_"
                                    class="btn btn-secondary btn-sm on_download_archive fa fa-file-archive-o"
                                    style="width: 43px; padding-top: 10px; padding-left: 11px;
                                    padding-right: 13px; padding-bottom: 8px;
                                    border-radius: 11px; background: #ff0000;
                                    color: white; font-size: 23px;"
                                    title="Download Zip File"
                                    t-on-click="_onDownloadArchive"/>
                            <!-- Mail document button -->
                            <button type="button" name="mail" title='Mail'
                                    class="btn btn-secondary btn-sm fa fa-envelope on_mail_document"
                                    style="width: 43px; padding-top: 9px; padding-left: 9px;
                                    padding-right: 13px; padding-bottom: 8px;
                                    border-radius: 11px; background: #4267b2;
                                    color: white; font-size: 23px;"
                                    t-on-click="_onMailDocument"
                            />
                            <!-- Copy/Move button -->
                            <button type="button" name="copy"
                                    title='Copy/Move'
                                    class="btn btn-secondary btn-sm fa fa-clone on_copy_document"
                                    style="width: 43px; padding-top: 10px; padding-left: 10px;
                                    padding-right: 13px; padding-bottom: 7px;
                                    border-radius: 11px; background: #1da1f2;
                                    color: white; font-size: 23px;"
                                    t-on-click="_onCopyDocument"
                            />
                            <!-- Archive/Unarchive button -->
                            <button type="button"
                                    class="btn btn-secondary btn-sm fa fa-archive on_archive_document"
                                    style="width: 43px; padding-top: 9px; padding-left: 9px;
                                    padding-right: 13px; padding-bottom: 7px;
                                    border-radius: 11px; background: #e60023;
                                    color: white; font-size: 23px; height: 36px;"
                                    data-bs-dismiss="toast"
                                    title="Archive/Unarchive"
                                    t-on-click="_onArchiveDocument"
                            />
                            <!-- Delete button -->
                            <button type="button" name="cl"
                                    class="btn btn-secondary fa fa-trash on_delete_button"
                                    title="Delete"
                                    style="width: 43px; padding-top: 10px; padding-left: 11px;
                                    padding-right: 13px; padding-bottom: 8px;
                                    border-radius: 11px; background: #ea4689;
                                    color: white; font-size: 23px;"
                                    t-on-click="_onDelete"
                            />
                            <!-- Create task button -->
                            <button name="create_task" type="button"
                                    title="Create Task"
                                    class="btn btn-secondary btn-sm fa fa-tasks on_create_task"
                                    style="width: 43px; padding-top: 10px; padding-left: 9px;
                                    padding-right: 13px; padding-bottom: 5px;
                                    border-radius: 11px; background: #0e76a8;
                                    color: white; font-size: 23px;"
                                    t-on-click="_onCreateTask"
                                    t-ref="create_task"
                            />
                            <!-- Create lead button -->
                            <button name="create_lead" type="button"
                                    title="Create Lead"
                                    class="btn btn-secondary btn-sm fa fa-level-up on_create_lead"
                                    style="width: 43px; padding-top: 10px; padding-left: 11px;
                                    padding-right: 13px; padding-bottom: 8px;
                                    border-radius: 11px; background: #ea4689;
                                    color: white; font-size: 23px;"
                                    t-on-click="_onCreateLead"
                                    t-ref="create_lead"
                            /></div>
                    </div>
                </t>
            </t>
            <!-- Alternative content if 'canCreate' condition is not met -->
            <t t-else="">
                <xpath expr="//t[@t-set-slot='control-panel-create-button']" position="replace">
                    <xpath expr="//Layout[last()]" position="inside">
                        <t t-if="canCreate" t-set-slot="control-panel-cy-form-cogs">
                            <CogMenuList
                                    t-if="model.env.searchModel.resModel != 'document.file'"
                                    canCreate="!model.root.editedRecord and canCreate and (!model.root.isGrouped or !editable) and !env.inDialog"
                                    canEdit="!!model.root.editedRecord"
                                    isSelected="!!nbSelected"
                                    model="model"
                                    create.bind="createRecord"
                                    onActionExecuted="() => model.load({ resId: model.root.resId, resIds: model.root.resIds })"
                                    isDomainSelected="model.root.isDomainSelected"
                                    getActiveIds="() => model.root.isNew ? [] : [model.root.resId]"
                                    context="props.context"
                                    resModel="model.root.resModel"
                                    domain="props.domain"
                                    items="props.info.actionMenus ? actionMenuItems : {}"/>
                        </t>
                    </xpath>
                </xpath>
            </t>
        </xpath>
    </t>
</templates>
