<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <template id="cyllo_website_sale.brand_promotion" inherit_id="website_sale.brand_promotion">
        <xpath expr="//t[@t-call='web.brand_promotion_message']" position="replace">
            <t t-call="web.brand_promotion_message">
                <t t-set="_message">
                    The #1 <a target="_blank" href="https://www.cyllo.com/">Open Source eCommerce</a>
                </t>
                <t t-set="_utm_medium" t-valuef="website"/>
            </t>
        </xpath>
    </template>
</odoo>