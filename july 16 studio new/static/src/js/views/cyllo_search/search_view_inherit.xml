<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-inherit="cyllo_studio.SearchView" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('cy_search_view')]" position="before">
            <div class="form-check form-switch mx-3 my-3">
            <input class="form-check-input" type="checkbox" name="invisible_elements" t-on-click="onInvisibleClick"
                   t-att-checked="state.visibleSearchElement" id="invisible_elements"/>
                <label for="invisible_elements"
                       class="cy-navbar_label customCheckbox_label">Show Invisible Elements</label>
        </div>
        </xpath>
    </t>
</templates>