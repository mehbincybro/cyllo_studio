<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- form and tree view for fs report-->
    <record id="view_odometer_reading_form" model="ir.ui.view">
        <field name="name">view.odometer.reading.form</field>
        <field name="model">odometer.reading</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <group>
                        <field name="fleet_id"/>
                        <field name="last_odometer"/>
                    </group>
                    <group>
                        <field name="new_reading"/>
                        <field name="field_request_id"/>
                    </group>
                    <footer>
                        <button name="action_save" string="Save"
                                type="object" class="oe_highlight"/>
                        <button special="cancel" data-hotkey="x"
                                string="Cancel" type="object"
                                class="btn btn-secondary oe_inline"/>
                    </footer>
                </group>
            </form>
        </field>
    </record>
    <record id="action_view_odometer_reading" model="ir.actions.act_window">
        <field name="name">action.view.odometer.reading</field>
        <field name="res_model">odometer.reading</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
