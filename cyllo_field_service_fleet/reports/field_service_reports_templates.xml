<?xml version="1.0" encoding="utf-8"?>
<!-- Inherit Template for adding fleet in pdf print reports -->
<odoo>
    <template id="custom_report_field_service_request_form"
              inherit_id="cyllo_field_service.report_field_service_request_form">
        <xpath expr="//div[@id='other_informations']" position="inside">
            <t t-if="fs_request.fleet_id">
                <div class="col-auto col-3 mw-100 mb-2 oe_inline">
                    <strong>Fleet:</strong>
                    <br/>
                    <span class="m-0"
                          t-field="fs_request.fleet_id.name"/>
                </div>
            </t>
        </xpath>
    </template>
</odoo>
