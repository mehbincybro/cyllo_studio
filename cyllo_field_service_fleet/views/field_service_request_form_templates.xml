<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="custom_fs_service_request_details"
              inherit_id="cyllo_field_service.fs_service_request_details"
              name="Custom Field Service Request | My Website">
        <xpath expr="//section[@id='details']" position="inside">
            <div class="col-md-3 mt-2 mb-2"
                 t-if="object.fleet_id">
                <strong>Fleet</strong>
                <br/>
                <span t-field="object.fleet_id"/>
            </div>
        </xpath>
    </template>
</odoo>
