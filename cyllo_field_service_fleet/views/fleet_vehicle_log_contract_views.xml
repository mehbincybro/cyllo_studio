<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--Adding fleet fields to service request form view-->
    <record id="view_vehicle_log_contract_form_inherit_field_service" model="ir.ui.view">
        <field name="name">view.fleet.vehicle.log.contract.form.inherit.field.service</field>
        <field name="model">fleet.vehicle.log.contract</field>
        <field name="inherit_id" ref="fleet.fleet_vehicle_log_contract_view_form"/>
        <field name="arch" type="xml">
            <field name="user_id" position="after">
                <field name="field_service_request_id" invisible="not field_service_request_id"/>
            </field>
        </field>
    </record>
</odoo>
