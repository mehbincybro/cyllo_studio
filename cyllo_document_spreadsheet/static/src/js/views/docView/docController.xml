<?xml version="1.0" encoding="UTF-8" ?>
<templates>
    <t t-name="docControllerView" t-inherit="cyllo_documents.docControllerView" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('doc_btn_container')]/div/ul/li[hasclass('select_document')]" position="before">
            <li class="nav-item create_spreadsheet" t-on-click="handleAddSpreadSheet">
                <div class="cy-navitem-list cursor-pointer"
                     data-hotkey="q">
                    <i class="ri-add-fill"/>
                    <span>Create Spreadsheet</span>
                </div>
            </li>
        </xpath>
    </t>
</templates>