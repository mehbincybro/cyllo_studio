<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!-- Form view of the wizard for creating spreadsheet-->
    <record id="view_create_excel_form" model="ir.ui.view">
        <field name="name">view.create.excel.form</field>
        <field name="model">create.excel</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <field name="name"/>
                </group>
                <footer>
                    <button name="action_create_spreadsheet" type="object"
                            class="btn btn-primary" string="Create"/>
                    <button name="cancel" special="cancel" string="Cancel"/>
                </footer>
            </form>
        </field>
    </record>
    <!--Window action of the wizard for creating spreadsheet -->
    <record id="action_view_create_spreadsheet" model="ir.actions.act_window">
        <field name="name">Create Spreadsheet</field>
        <field name="res_model">create.excel</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
