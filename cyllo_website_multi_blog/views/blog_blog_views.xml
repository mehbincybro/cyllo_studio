<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!-- Inheriting the blog.blog form and tree view from the website_blog module -->
    <record id="view_blog_blog_form" model="ir.ui.view">
        <field name="name">view.blog.blog.form</field>
        <field name="model">blog.blog</field>
        <field name="inherit_id" ref="website_blog.view_blog_blog_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="replace">
                <sheet>
                    <widget name="web_ribbon"
                            title="Archived"
                            bg_color="text-bg-danger"
                            invisible="active"/>
                    <group>
                        <field name="active" invisible="1"/>
                        <field name="name"/>
                        <field name="subtitle"/>
                        <field name="website_ids"
                               widget="many2many_tags"
                               options="{'no_create': True}"
                               groups="website.group_multi_website"/>
                    </group>
                </sheet>
            </xpath>
        </field>
    </record>

    <record id="view_blog_blog_list" model="ir.ui.view">
        <field name="name">view.blog.blog.tree</field>
        <field name="model">blog.blog</field>
        <field name="inherit_id" ref="website_blog.view_blog_blog_list"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='website_id']" position="replace">
                <field name="website_ids"
                       widget="many2many_tags"
                       groups="website.group_multi_website"/>
            </xpath>
        </field>
    </record>
</odoo>