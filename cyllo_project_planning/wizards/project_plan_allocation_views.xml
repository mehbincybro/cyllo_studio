<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_project_plan_allocation_form" model="ir.ui.view">
        <field name="name">view.project.plan.allocation.form</field>
        <field name="model">project.plan.allocation</field>
        <field name="arch" type="xml">
            <form string="Allocation Type">
                <group>
                    <group>
                        <field name="allocation_type_id"/>
                        <field name="description"/>
                    </group>
                    <group>
                        <field name="start_datetime"/>
                        <field name="end_datetime"/>
                        <field name="employee_ids" widget="many2many_tags"/>
                        <field name="is_modifying" invisible="1"/>
                        <span class="alert alert-warning text-warning"
                              style="padding-top: 6px; padding-bottom: 6px;"
                              invisible="not is_modifying"
                              colspan="2"> Are you sure you want to modify the task's assignees?</span>
                        <field name="project_id"/>
                        <field name="task_id"/>
                    </group>
                </group>
                <footer>
                    <button string="Plan Task Allocation" name="action_plan_task_allocations" class="btn-primary"
                            type="object" data-hotkey="q"/>
                    <button string="Cancel" class="btn-default" special="cancel" data-hotkey="x"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>