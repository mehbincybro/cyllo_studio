<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Inherit Form View to Modify it -->
    <record id="view_plan_allocation_form" model="ir.ui.view">
        <field name="name">view.plan.allocation.form</field>
        <field name="model">plan.allocation</field>
        <field name="inherit_id"
               ref="cyllo_planning.view_plan_allocation_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='allocation_info']" position="after">
                <group name="project_info" string="Project Information">
                    <field name="project_id"/>
                    <field name="task_id"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>