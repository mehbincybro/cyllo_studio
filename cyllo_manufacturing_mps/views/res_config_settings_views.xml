<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="res_config_settings_view_form_inherit_custom_mps" model="ir.ui.view">
            <field name="name">res.config.settings.view.form.inherit.custom.mps</field>
            <field name="model">res.config.settings</field>
            <field name="inherit_id" ref="mrp.res_config_settings_view_form"/>
            <field name="arch" type="xml">

                <xpath expr="//setting[@id='mrp_mps']" position="after">

                    <setting id="custom_mps_setting" string="Master Production Scheduler" help="Enable and configuration for MPS" groups="mrp.group_mrp_manager">
                        <field name="is_mps"/>

                        <div class="content-group" invisible="not is_mps">
                            <div class="mt16">
                                <label for="mps_default_timerange" class="o_light_label fw-bold"/>

                                <div class="mt16">
                                    <field name="mps_default_timerange" widget="radio" options="{'horizontal': true}"/>
                                </div>
                            </div>
                        </div>
                    </setting>

                </xpath>

            </field>
        </record>
    </data>
</odoo>
