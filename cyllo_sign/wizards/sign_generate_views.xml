<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_sign_generate_form" model="ir.ui.view">
        <field name="name">view.sign.generate.form</field>
        <field name="model">sign.generate</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <group>
                        <field name="name"/>
                        <field name="template_id" invisible="1"/>
                    </group>
                    <group>
                        <field name="validity" placeholder="MM/DD/YYYY"/>
                    </group>
                </group>
                <notebook>
                    <page string="Signers">
                        <field name="signer_ids" nolabel="1">
                            <tree editable="bottom" create="false" delete="0">
                                <field name="role_id" readonly="1" string="Role"/>
                                <field name="partner_id"
                                       options="{'no_create': True}"
                                       string="Partner"/>
                            </tree>
                        </field>
                    </page>
                    <page string="Contacts in copy">
                        <group>
                            <field name="contact_ids"
                                   widget="many2many_tags"
                                   placeholder="Add contacts..."
                                   nolabel="1"/>
                        </group>
                    </page>
                    <page string="Signature Request">
                        <group>
                            <field name="subject" placeholder="Subject..."/>
                            <field name="message" placeholder="Message..."/>
                        </group>
                    </page>
                </notebook>
                <footer>
                    <button name="action_generate_sign"
                            string="Generate &amp; Sign Now"
                            class="btn-primary" type="object"/>
                    <button name="action_send" string="Send" class="btn-primary"
                            type="object"/>
                    <button string="Cancel" class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
