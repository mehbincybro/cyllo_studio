<?xml version="1.0" encoding="UTF-8" ?>
<templates id="template" xml:space="preserve">
<!--    Adds new button for uploading documents in sign template kanban view-->
    <t t-name="cyllo_sign.KanbanButtons" t-inherit="web.KanbanView.Buttons" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('o_cp_buttons')]" position="inside">
            <t t-if="model.env.searchModel.resModel == 'sign.template'">
                <input type="file" id="fileInput" class="fileInput d-none"
                       t-on-change="onSignDocumentUpload" accept=".pdf"/>
                <button type="button" class="d-md-inline o_button_upload_expense
                btn btn-primary" onclick="$('#fileInput').click()">
                    Upload a PDF &amp; Sign
                </button>
            </t>
        </xpath>
    </t>
</templates>
