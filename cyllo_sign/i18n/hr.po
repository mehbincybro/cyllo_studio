#. module: cyllo_sign
#: model:mail.template,body_html:cyllo_sign.email_template_sign_request
msgid ""
"<table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" style=\"padding-top: 16px; background-color: #9ea700; font-family:Verdana, Arial,sans-serif; color: #454748;border-collapse:separate;\">\n"
"                    <tr>\n"
"                        <td align=\"center\">\n"
"                            <table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"590\" style=\"padding: 16px; background-color: white; color: #454748; border-collapse:separate; margin-bottom: 20px;\">\n"
"                                <tbody>\n"
"                                    <!-- CONTENT-->\n"
"                                    <tr>\n"
"                                        <td align=\"center\" style=\"min-width: 590px;\">\n"
"                                            <table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"590\" style=\"min-width: 590px; background-color: white; padding: 0px 8px 0px 8px; border-collapse:separate;\">\n"
"                                                <tr>\n"
"                                                    <td valign=\"top\" style=\"font-size: 13px;\">\n"
"\n"
"                                                        <p>Dear <t t-esc=\"ctx.get('name')\"></t>\n"
"                                                            ,\n"
"                                                        </p>\n"
"                                                        <t t-if=\"ctx.get('custom_message')\">\n"
"                                                            <div t-raw=\"ctx.get('custom_message')\"></div>\n"
"                                                        </t>\n"
"                                                        <t t-else=\"\">\n"
"                                                            <p>You are requested\n"
"                                                                to sign the\n"
"                                                                document:\n"
"                                                                <strong>\n"
"                                                                    <t t-esc=\"object.name\"></t>\n"
"                                                                </strong>\n"
"                                                                .\n"
"                                                            </p>\n"
"                                                            <p>Please click the\n"
"                                                                button below to\n"
"                                                                review and sign:\n"
"                                                            </p>\n"
"                                                        </t>\n"
"                                                        <a t-att-href=\"object.get_sign_url(ctx.get('signer_id'), ctx.get('role').id)\" style=\"display: inline-block; padding: 5px; font-size: 10px; margin: 10px;                                                             color: #ffffff; background-color: #9ea700; text-decoration: none;                                                             border-radius: 5px;\">\n"
"                                                            Sign Document\n"
"                                                        </a>\n"
"                                                        <span>\n"
"                                                            <div style=\"opacity: 0.7;\">\n"
"                                                                <strong>\n"
"                                                                    Warning\n"
"                                                                </strong>\n"
"                                                                do not forward\n"
"                                                                this email to\n"
"                                                                other people!\n"
"                                                                <br>\n"
"                                                                They will be\n"
"                                                                able to access\n"
"                                                                this document\n"
"                                                                and\n"
"                                                                sign it as\n"
"                                                                yourself.\n"
"                                                                <br>\n"
"                                                            </div>\n"
"                                                        </span>\n"
"                                                        <p>Thank you,</p>\n"
"                                                        <p>\n"
"                                                            <t t-esc=\"object.user_id.name\"></t>\n"
"                                                        </p>\n"
"                                                    </td>\n"
"                                                </tr>\n"
"                                            </table>\n"
"                                        </td>\n"
"                                    </tr>\n"
"                                </tbody>\n"
"                            </table>\n"
"                        </td>\n"
"                    </tr>\n"
"                </table>\n"
"            "
msgstr ""
"<table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" style=\"padding-top: 16px; background-color: #9ea700; font-family:Verdana, Arial,sans-serif; color: #454748;border-collapse:separate;\">\n"
"                    <tr>\n"
"                        <td align=\"center\">\n"
"                            <table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"590\" style=\"padding: 16px; background-color: white; color: #454748; border-collapse:separate; margin-bottom: 20px;\">\n"
"                                <tbody>\n"
"                                    <!-- SADRŽAJ-->\n"
"                                    <tr>\n"
"                                        <td align=\"center\" style=\"min-width: 590px;\">\n"
"                                            <table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"590\" style=\"min-width: 590px; background-color: white; padding: 0px 8px 0px 8px; border-collapse:separate;\">\n"
"                                                <tr>\n"
"                                                    <td valign=\"top\" style=\"font-size: 13px;\">\n"
"\n"
"                                                        <p>Poštovani/a <t t-esc=\"ctx.get('name')\"></t>\n"
"                                                            ,\n"
"                                                        </p>\n"
"                                                        <t t-if=\"ctx.get('custom_message')\">\n"
"                                                            <div t-raw=\"ctx.get('custom_message')\"></div>\n"
"                                                        </t>\n"
"                                                        <t t-else=\"\">\n"
"                                                            <p>Molimo vas da\n"
"                                                                potpišete\n"
"                                                                dokument:\n"
"                                                                <strong>\n"
"                                                                    <t t-esc=\"object.name\"></t>\n"
"                                                                </strong>\n"
"                                                                .\n"
"                                                            </p>\n"
"                                                            <p>Molimo kliknite na\n"
"                                                                gumb ispod da\n"
"                                                                pregledate i potpišete:\n"
"                                                            </p>\n"
"                                                        </t>\n"
"                                                        <a t-att-href=\"object.get_sign_url(ctx.get('signer_id'), ctx.get('role').id)\" style=\"display: inline-block; padding: 5px; font-size: 10px; margin: 10px;                                                             color: #ffffff; background-color: #9ea700; text-decoration: none;                                                             border-radius: 5px;\">\n"
"                                                            Potpišite dokument\n"
"                                                        </a>\n"
"                                                        <span>\n"
"                                                            <div style=\"opacity: 0.7;\">\n"
"                                                                <strong>\n"
"                                                                    Upozorenje\n"
"                                                                </strong>\n"
"                                                                nemojte proslijeđivati\n"
"                                                                ovu e-poštu drugima!\n"
"                                                                <br>\n"
"                                                                Oni će moći pristupiti\n"
"                                                                ovom dokumentu\n"
"                                                                i\n"
"                                                                potpisan kao\n"
"                                                                vi.\n"
"                                                                <br>\n"
"                                                            </div>\n"
"                                                        </span>\n"
"                                                        <p>Hvala vam,</p>\n"
"                                                        <p>\n"
"                                                            <t t-esc=\"object.user_id.name\"></t>\n"
"                                                        </p>\n"
"                                                    </td>\n"
"                                                </tr>\n"
"                                            </table>\n"
"                                        </td>\n"
"                                    </tr>\n"
"                                </tbody>\n"
"                            </table>\n"
"                        </td>\n"
"                    </tr>\n"
"                </table>\n"
"            "

