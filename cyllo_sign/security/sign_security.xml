<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <!-- Application -->
    <record id="ir_module_category_sign" model="ir.module.category">
        <field name="name">Sign</field>
    </record>
    <!-- Access Groups -->
    <record id="group_cyllo_sign_user" model="res.groups">
        <field name="name">User: Own Documents Only</field>
        <field name="category_id" ref="ir_module_category_sign"/>
        <field name="implied_ids" eval="[Command.link(ref('base.group_user'))]"/>
    </record>
    <record id="group_cyllo_sign_manager" model="res.groups">
        <field name="name">User: All Documents</field>
        <field name="category_id" ref="ir_module_category_sign"/>
        <field name="implied_ids" eval="[Command.link(ref('group_cyllo_sign_user'))]"/>
        <field name="users" eval="[Command.link(ref('base.user_root')), Command.link(ref('base.user_admin'))]"/>
    </record>
    <record id="base.default_user" model="res.users">
        <field name="groups_id" eval="[Command.link(ref('cyllo_sign.group_cyllo_sign_user'))]"/>
    </record>
    <!-- Record Rules -->
    <record id="rule_sign_request_user" model="ir.rule">
        <field name="name">Sign Request: Own or Related Requests</field>
        <field name="model_id" ref="model_sign_request"/>
        <field name="domain_force">
            ['|',
                ('create_uid', '=', user.id),
                ('requester_ids.partner_id', 'in', [user.partner_id.id])
            ]
        </field>
        <field name="groups" eval="[Command.link(ref('group_cyllo_sign_user'))]"/>
    </record>
    <record id="rule_sign_request_manager" model="ir.rule">
        <field name="name">Sign Request: Manager Access</field>
        <field name="model_id" ref="model_sign_request"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[Command.link(ref('group_cyllo_sign_manager'))]"/>
    </record>
    <!-- Multi-company record filtration and security group-->
    <record id="rule_sign_template_company" model="ir.rule">
        <field name="name">Sign Template Multi-Company</field>
        <field name="model_id" ref="model_sign_template"/>
        <field name="domain_force">['|',('company_id','=',False),('company_id', 'in', company_ids)]</field>
    </record>
    <record id="rule_sign_request_company" model="ir.rule">
        <field name="name">Sign Request Multi-Company</field>
        <field name="model_id" ref="model_sign_request"/>
        <field name="domain_force">
            ['|',('company_id','=',False),('company_id', 'in', company_ids)]
        </field>
    </record>
    <record id="rule_sign_requester_company" model="ir.rule">
        <field name="name">Sign Requester Access Rule</field>
        <field name="model_id" ref="model_sign_requester"/>
        <field name="domain_force">
            ['|',('partner_id','=',user.partner_id.id),('create_uid','=',user.id)]
        </field>
    </record>
</odoo>