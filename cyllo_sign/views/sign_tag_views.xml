<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="sign_tag_view_tree" model="ir.ui.view">
        <field name="name">sign.tag.view.tree</field>
        <field name="model">sign.tag</field>
        <field name="arch" type="xml">
            <tree editable="bottom">
                <field name="name"/>
            </tree>
        </field>
    </record>

    <record id="action_view_tags" model="ir.actions.act_window">
        <field name="name">Sign Tags</field>
        <field name="res_model">sign.tag</field>
        <field name="view_mode">tree</field>
    </record>

    <menuitem id="menu_tags" name="Tags"
              action="action_view_tags"
              parent="cyllo_sign.menu_configurations_categ"/>
</odoo>