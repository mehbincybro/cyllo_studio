<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <!--Tree view of the Sign Role-->
    <record id="view_sign_role_tree" model="ir.ui.view">
        <field name="name">view.sign.role.tree</field>
        <field name="model">sign.role</field>
        <field name="arch" type="xml">
            <tree string="Role">
                <field name="name"/>
                <field name="domain"/>
                <field name="color" widget="color_picker"/>
            </tree>
        </field>
    </record>
    <!--Form view of the Sign Role-->
    <record id="view_sign_role_form" model="ir.ui.view">
        <field name="name">view.sign.role.form</field>
        <field name="model">sign.role</field>
        <field name="arch" type="xml">
            <form string="sign_role">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="domain" widget="domain"
                                   options="{'model': 'res.partner'}"/>
                        </group>
                        <group>
                            <field name="color" widget="color_picker"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <!--Action specified for the Sign Role-->
    <record id="action_view_roles" model="ir.actions.act_window">
        <field name="name">Roles</field>
        <field name="res_model">sign.role</field>
        <field name="view_mode">tree,form</field>
    </record>
    <menuitem id="menu_roles" name="Roles"
              action="action_view_roles"
              parent="cyllo_sign.menu_configurations_categ"/>
</odoo>
