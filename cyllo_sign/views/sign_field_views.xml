<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <!--Tree view of the Sign Field-->
    <record id="view_sign_field_tree" model="ir.ui.view">
        <field name="name">view.sign.field.tree</field>
        <field name="model">sign.field</field>
        <field name="arch" type="xml">
            <tree string="Sign Field">
                <field name="name" />
                <field name="field_type"/>
                <field name="icon"/>
            </tree>
        </field>
    </record>
    <!--Form view of the Sign Field-->
    <record id="view_sign_field_form" model="ir.ui.view">
        <field name="name">view.sign.field.form</field>
        <field name="model">sign.field</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <label for="name"/>
                        <h1><field name="name"/></h1>
                    <group>
                        <field name="field_type"/>
                        <field name="icon"/>
                    </group>
                    <group>
                        <group>
                            <field name="default_width"/>
                            <field name="default_height"/>
                        </group>
                        <group>
                            <field name="placeholder"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <!--Action specified for the Sign Field-->
    <record id="action_view_fields" model="ir.actions.act_window">
        <field name="name">Fields</field>
        <field name="res_model">sign.field</field>
        <field name="view_mode">tree,form</field>
    </record>
    <menuitem id="menu_configurations_categ" name="Configurations"
              parent="cyllo_sign.menu_cyllo_sign_root"
              sequence='5'/>
    <menuitem id="menu_fields" name="Fields"
              action="action_view_fields"
              parent="cyllo_sign.menu_configurations_categ"/>
</odoo>
