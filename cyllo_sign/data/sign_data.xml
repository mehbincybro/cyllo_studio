<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="sign_field_name" model="sign.field">
        <field name="name">Name</field>
        <field name="field_type">text</field>
        <field name="icon">ri-account-box-line</field>
        <field name="default_width">25</field>
        <field name="default_height">2.5</field>
        <field name="placeholder">Name</field>
    </record>
    <record id="sign_field_sign" model="sign.field">
        <field name="name">Sign</field>
        <field name="field_type">signature</field>
        <field name="icon">ri-sketching</field>
        <field name="default_width">15</field>
        <field name="default_height">5</field>
        <field name="placeholder">Sign</field>
    </record>
    <record id="sign_field_text" model="sign.field">
        <field name="name">Text</field>
        <field name="field_type">text</field>
        <field name="icon">ri-text</field>
        <field name="default_width">30</field>
        <field name="default_height">5</field>
        <field name="placeholder">Text</field>
    </record>
    <record id="sign_field_email" model="sign.field">
        <field name="name">Email</field>
        <field name="field_type">text</field>
        <field name="icon">ri-mail-line</field>
        <field name="default_width">30</field>
        <field name="default_height">2.5</field>
        <field name="placeholder">Email</field>
    </record>
    <record id="sign_field_phone" model="sign.field">
        <field name="name">Phone</field>
        <field name="field_type">text</field>
        <field name="icon">ri-phone-line</field>
        <field name="default_width">25</field>
        <field name="default_height">2.5</field>
        <field name="placeholder">Phone</field>
    </record>
    <record id="sign_field_date" model="sign.field">
        <field name="name">Date</field>
        <field name="field_type">date</field>
        <field name="icon">ri-calendar-event-line</field>
        <field name="default_width">20</field>
        <field name="default_height">2.5</field>
        <field name="placeholder">Date</field>
    </record>
    <record id="sign_role_employee" model="sign.role">
        <field name="name">Employee</field>
        <field name="color">10</field>
    </record>
    <record id="sign_role_user" model="sign.role">
        <field name="name">User</field>
        <field name="domain">[("user_ids", "!=", False)]</field>
        <field name="color">2</field>
    </record>
</odoo>
