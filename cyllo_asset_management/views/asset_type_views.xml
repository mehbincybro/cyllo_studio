<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!--    Tree view of the asset type model-->
    <record id="view_asset_type_tree" model="ir.ui.view">
        <field name="name">view.asset.type.tree</field>
        <field name="model">asset.type</field>
        <field name="arch" type="xml">
            <tree editable="bottom">
                <field name="name"/>
                <field name="brand_ids" widget="many2many_tags"/>
            </tree>
        </field>
    </record>
    <!--    Form view of the asset type model-->
    <record id="view_asset_type_form" model="ir.ui.view">
        <field name="name">view.asset.type.form</field>
        <field name="model">asset.type</field>
        <field name="arch" type="xml">
            <form string="Form Title">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="brand_ids" widget="many2many_tags"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <!--    Action fo the asset type model-->
    <record id="action_view_asset_types" model="ir.actions.act_window">
        <field name="name">Asset Types</field>
        <field name="res_model">asset.type</field>
        <field name="view_mode">tree,form</field>
    </record>
    <!--    Menuitem the asset type -->
    <menuitem id="menu_asset_types"
              name="Asset Types"
              parent="cyllo_asset_management.menu_asset_categ"
              action="action_view_asset_types"
              sequence="21"/>
</odoo>