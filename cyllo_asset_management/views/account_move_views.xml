<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Inherit the invoice search view and add Claim filter -->
    <record id="view_account_move_search_claim_only" model="ir.ui.view">
        <field name="name">account.move.search.claim.only</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_account_invoice_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//search/group/filter[@name='salesperson']" position="before">
                <separator/>
                <filter name="insurance_claim"
                        string="Insurance Claims"
                        domain="[('move_type','=','out_invoice')]"/>
            </xpath>
        </field>
    </record>


    <!--    Inherit the view for adding new fields-->
    <record id="view_account_move_form" model="ir.ui.view">
        <field name="name">view.account.move.form</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='journal_id']" position="before">
                <field name='asset_asset_id' invisible="1"/>
                <field name='repair_id' invisible="1"/>
            </xpath>
            <xpath expr="//div[hasclass('oe_button_box')]" position="inside">
                <button type="object" name="action_view_asset_moves"
                        class="oe_stat_button" icon="fa-book" invisible="asset_asset_count == 0">
                    <field name="asset_asset_count" string="Asset" widget="statinfo"/>
                </button>
                <button type="object" name="action_view_maintenace_request" string="Maintenance Request"
                        class="oe_stat_button" icon="fa-wrench" invisible="not repair_id">
                </button>
            </xpath>
        </field>
    </record>
</odoo>
