<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!--    Tree view of the asset insurance model-->
    <record id="view_asset_booking_tree" model="ir.ui.view">
        <field name="name">view.asset.booking.tree</field>
        <field name="model">asset.booking</field>
        <field name="arch" type="xml">
            <tree create="false">
                <field name="asset_id"/>
                <field name="booking_type"/>
                <field name="date_from"/>
                <field name="date_to"/>
                <field name="state"/>
            </tree>
        </field>
    </record>
    <record id="view_asset_booking_form" model="ir.ui.view">
        <field name="name">view.asset.booking.form</field>
        <field name="model">asset.booking</field>
        <field name="arch" type="xml">
            <form create="false">
                <sheet>
                    <group>
                        <group>
                            <field name="asset_id" readonly="1"/>
                            <field name="booking_type" readonly="1"/>
                            <field name="date_from" readonly="1"/>
                        </group>
                        <group>
                            <field name="partner_id" readonly="1"/>
                            <field name="state" readonly="1"/>
                            <field name="date_to" readonly="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>