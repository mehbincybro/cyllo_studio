<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!--    Tree view of the asset insurance model-->
    <record id="view_asset_asset_insurance_tree" model="ir.ui.view">
        <field name="name">view.asset.asset.insurance.tree</field>
        <field name="model">asset.asset.insurance</field>
        <field name="arch" type="xml">
            <tree editable="bottom">
                <field name="provider"/>
                <field name="type"/>
            </tree>
        </field>
    </record>
        <!--    Action for the asset insurance model-->
    <record id="action_view_asset_insurance" model="ir.actions.act_window">
        <field name="name">Asset Insurance</field>
        <field name="res_model">asset.asset.insurance</field>
        <field name="view_mode">tree</field>
    </record>
    <!--    Menuitem the asset insurance model -->
    <menuitem id="menu_asset_asset_insurance"
              name="Asset Insurance"
              parent="cyllo_asset_management.menu_asset_categ"
              action="action_view_asset_insurance"
              sequence="23"/>
</odoo>