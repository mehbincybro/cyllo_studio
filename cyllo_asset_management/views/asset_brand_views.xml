<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!--    Form view of the asset brand model-->
    <record id="view_asset_brand_form" model="ir.ui.view">
        <field name="name">view.asset.brand.form</field>
        <field name="model">asset.brand</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
        <!--    Tree view of the asset brand model-->
    <record id="view_asset_brand_tree" model="ir.ui.view">
        <field name="name">view.asset.brand.tree</field>
        <field name="model">asset.brand</field>
        <field name="arch" type="xml">
            <tree editable="bottom">
                <field name="name"/>
            </tree>
        </field>
    </record>
        <!--    Action for the asset brand model-->
    <record id="action_view_asset_brand" model="ir.actions.act_window">
        <field name="name">Asset Brand</field>
        <field name="res_model">asset.brand</field>
        <field name="view_mode">tree</field>
    </record>
    <!--    Menuitem the asset type -->
    <menuitem id="menu_asset_brand"
              name="Asset Brands"
              parent="cyllo_asset_management.menu_asset_categ"
              action="action_view_asset_brand"
              sequence="22"/>
</odoo>
