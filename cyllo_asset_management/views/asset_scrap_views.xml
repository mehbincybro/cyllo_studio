<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!--    Tree view of the asset scrap model-->
    <record id="view_asset_scrap_tree" model="ir.ui.view">
        <field name="name">view.asset.scrap.tree</field>
        <field name="model">asset.scrap</field>
        <field name="arch" type="xml">
            <tree create="0">
                <field name="asset_id"/>
                <field name="date"/>
                <field name="status"/>
            </tree>
        </field>
    </record>
    <!--    Search view of the asset scrap model-->
    <record id="view_asset_scrap_search" model="ir.ui.view">
        <field name="name">view.asset.scrap.search</field>
        <field name="model">asset.scrap</field>
        <field name="arch" type="xml">
            <search string="Assigned Asset">
                <field name="asset_id"/>
                <filter name="archived" string="Archived" domain="[('active', '=', False)]"/>
                <group expand="0" string="Group By...">
                    <filter string="Asset" name="asset_item" domain="[]" context="{'group_by':'asset_id'}"/>
                </group>
            </search>
        </field>
    </record>
    <!--   Action for the asset scrap model-->
    <record id="action_view_asset_scrap" model="ir.actions.act_window">
        <field name="name">Asset Scrap</field>
        <field name="res_model">asset.scrap</field>
        <field name="view_mode">tree</field>
    </record>
    <!--   Menuitem for the asset scrap model-->
    <menuitem id="menu_asset_scrap"
              name="Asset Scrap"
              parent="cyllo_asset_management.menu_assets_categ"
              action="action_view_asset_scrap"
              sequence="20"/>
</odoo>
