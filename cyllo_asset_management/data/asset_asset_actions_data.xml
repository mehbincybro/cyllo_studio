<?xml version="1.0" encoding="UTF-8" ?>
<odoo noupdate="1">
        <!--    Server for the asset send mail-->
    <record id="model_asset_asset_request" model="ir.actions.server">
        <field name="name">Send Mail</field>
        <field name="model_id" ref="model_asset_asset"/>
        <field name="binding_model_id" ref="cyllo_asset_management.model_asset_asset"/>
        <field name="binding_view_types">form</field>
        <field name="state">code</field>
        <field name="code">action = records.action_request_assets()</field>
    </record>
        <!--    Server for the asset reservation-->
    <record id="model_asset_asset_reserve" model="ir.actions.server">
        <field name="name">Reserve</field>
        <field name="model_id" ref="model_asset_asset"/>
        <field name="binding_model_id" ref="cyllo_asset_management.model_asset_asset"/>
        <field name="binding_view_types">form</field>
        <field name="state">code</field>
        <field name="code">action = records.action_reserve_assets()</field>
    </record>
        <!--    Server for the asset assign-->
