        <field name="name">Lease</field>
        <field name="model_id" ref="model_asset_asset"/>
        <field name="binding_model_id" ref="cyllo_asset_management.model_asset_asset"/>
        <field name="binding_view_types">form</field>
        <field name="state">code</field>
        <field name="code">action = records.action_lease_assets()</field>
    </record>
        <!--    Server for the asset rental-->
    <record id="model_asset_asset_rental" model="ir.actions.server">
        <field name="name">Rental</field>
        <field name="model_id" ref="model_asset_asset"/>
        <field name="binding_model_id" ref="cyllo_asset_management.model_asset_asset"/>
        <field name="binding_view_types">form</field>
        <field name="state">code</field>
        <field name="code">action = records.action_rent_assets()</field>
    </record>
        <!--    Server for the asset lost-->
    <record id="model_asset_asset_lost_missing" model="ir.actions.server">
        <field name="name">Lost/Missing</field>
        <field name="model_id" ref="model_asset_asset"/>
