    </record>
        <!--    Server for the asset sell or dispose-->
    <record id="model_asset_asset_sell_dispose" model="ir.actions.server">
        <field name="name">Sell/Dispose</field>
        <field name="model_id" ref="model_asset_asset"/>
        <field name="binding_model_id" ref="cyllo_asset_management.model_asset_asset"/>
        <field name="binding_view_types">form</field>
        <field name="state">code</field>
        <field name="code">action = records.action_sell_dispose_assets()</field>
    </record>
</odoo>
