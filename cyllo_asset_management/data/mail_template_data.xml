<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!--        Asset Reservation Mail template -->
    <record id="mail_template_asset_reservation" model="mail.template">
        <field name="name">Asset Reservation</field>
        <field name="model_id" ref="cyllo_asset_management.model_asset_reservation"/>
        <field name="subject">Asset Reservation</field>
        <field name="auto_delete" eval="False"/>
        <field name="body_html" type="html">
            <div>
                <div>
                    Dear
                    <t t-out="ctx.get('employee') or not_available">,</t>,
                    <br/>
                    <br/>
                    I hope this email finds you well.
                    <br/>
                    <br/>
                    This is to confirm that your reservation for the following asset has been successfully processed:
                    <br/>
                    <br/>
                    Asset Name:
                    <t t-out="ctx.get('asset') or not_available"/>
                    <br/>
                    <br/>
                    Reservation start Date:
                    <t t-out="ctx.get('start_date') or not_available"/>
                    <br/>
                    <br/>
                    Reservation End Date:
                    <t t-out="ctx.get('end_date') or not_available"/>
                    <br/>
                    <br/>
                    Please ensure to adhere to the reservation schedule.
                    <br/>
                    <br/>
                    If you have any questions or need further assistance, please don't hesitate to contact us.
                    <br/>
                    <br/>
                    Best regards,
                    <br/>
                    <br/>
                </div>
            </div>
        </field>
    </record>
    <!--Asset Assignment Mail template-->
    <record id="mail_template_asset_assignment" model="mail.template">
        <field name="name">Asset Assignment</field>
        <field name="model_id" ref="cyllo_asset_management.model_asset_assign"/>
        <field name="subject">Asset Assignation</field>
        <field name="auto_delete" eval="False"/>
        <field name="body_html" type="html">
            <div>
                <div>
                    Dear
                    <t t-out="ctx.get('employee') or not_available">,</t>
                    <br/>
                    <br/>
                    I hope this email finds you well.
                    <br/>
                    <br/>
                    I am pleased to inform you that the following asset have been assigned to you:
                    <br/>
                    <br/>
                    Asset Name:
                    <t t-out="ctx.get('asset') or not_available"/>
                    <br/>
                    <br/>
                    Assign Date:
                    <t t-out="ctx.get('assign_date') or not_available"/>
                    <br/>
                    <br/>
                    Please take good care of the assigned asset and ensure they are used responsibly in accordance
                    with our organization's policies and guidelines.
                    <br/>
                    <br/>
                    Should you encounter any issues or have any
                    questions regarding the assigned asset, please feel free to reach out to us for assistance.
                    <br/>
                    <br/>
                    If you have any questions or need further assistance, please don't hesitate to contact us.
                    <br/>
                    <br/>
                    Best regards,
                    <br/>

                </div>
            </div>
        </field>
    </record>
    <!--Asset Leasing Mail template-->
    <record id="mail_template_asset_leasing" model="mail.template">
        <field name="name">Asset Leasing</field>
        <field name="model_id" ref="cyllo_asset_management.model_asset_lease"/>
        <field name="subject">Asset Leasing</field>
        <field name="auto_delete" eval="False"/>
        <field name="body_html" type="html">
            <div style="margin: 0px; padding:0px;">
                <div>
                    Dear
                    <t t-out="ctx.get('customer') or not_available">,</t>
                    <br/>
                    <br/>
                    I hope this email finds you well. We are pleased to confirm the leasing arrangement for the
                    following asset:
                    <br/>
                    <br/>
                    Asset Name:
                    <t t-out="ctx.get('asset') or not_available"/>
                    Lease Start Date:
                    <t t-out="ctx.get('start_date') or not_available"/>
                    <br/>
                    <br/>
                    Lease End Date:
                    <t t-out="ctx.get('end_date') or not_available"/>
                    <br/>
                    <br/>
                    As per the agreement, please ensure timely payment of the lease fees and adhere to the terms
                    outlined therein.
                    <br/>
                    <br/>
                    Should you have any questions or require further clarification regarding the lease
                    agreement, feel free to contact us at your convenience.
                    <br/>
                    <br/>
                    If you have any questions or need further assistance, please don't hesitate to contact us.
                    <br/>
                    <br/>
                    Best regards,
                    <br/>
                </div>
            </div>
        </field>
    </record>
