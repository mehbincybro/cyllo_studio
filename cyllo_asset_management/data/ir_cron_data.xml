<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
<!--    Action for send email for regarding asset rental-->
    <record id="ir_cron_asset_reminder_email_for_asset_rental_invoices" model="ir.cron">
        <field name="name">Asset: Reminder Email For Asset Rental Invoices</field>
        <field name="model_id" ref="model_asset_rental"/>
        <field name="state">code</field>
        <field name="code">model._send_asset_rental_invoice_reminder_mail()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="active">False</field>
    </record>
<!--    Action for send email for regarding asset lease-->
    <record id="ir_cron_asset_reminder_email_for_returning_leased_assets" model="ir.cron">
        <field name="name">Asset: Reminder Email For Returning Leased Assets</field>
        <field name="model_id" ref="model_asset_lease"/>
        <field name="state">code</field>
        <field name="code">model._send_lease_asset_return_reminder_mail()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="active">False</field>
    </record>
</odoo>
