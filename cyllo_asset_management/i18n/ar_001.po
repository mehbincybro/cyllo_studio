#. module: cyllo_asset_management
#: model:mail.template,body_html:cyllo_asset_management.mail_template_asset_leasing
#: model:mail.template,body_html:cyllo_asset_management.mail_template_asset_rental
msgid ""
"<div style=\"margin: 0px; padding:0px;\">\n"
"                <div>\n"
"                    Dear\n"
"                    <t t-out=\"ctx.get('customer') or not_available\">,</t>\n"
"                    <br>\n"
"                    <br>\n"
"                    I hope this email finds you well. We are pleased to confirm the leasing arrangement for the\n"
"                    following asset:\n"
"                    <br>\n"
"                    <br>\n"
"                    Asset Name:\n"
"                    <t t-out=\"ctx.get('asset') or not_available\"></t>\n"
"                    Lease Start Date:\n"
"                    <t t-out=\"ctx.get('start_date') or not_available\"></t>\n"
"                    <br>\n"
"                    <br>\n"
"                    Lease End Date:\n"
"                    <t t-out=\"ctx.get('end_date') or not_available\"></t>\n"
"                    <br>\n"
"                    <br>\n"
"                    As per the agreement, please ensure timely payment of the lease fees and adhere to the terms\n"
"                    outlined therein.\n"
"                    <br>\n"
"                    <br>\n"
"                    Should you have any questions or require further clarification regarding the lease\n"
"                    agreement, feel free to contact us at your convenience.\n"
"                    <br>\n"
"                    <br>\n"
"                    If you have any questions or need further assistance, please don't hesitate to contact us.\n"
"                    <br>\n"
"                    <br>\n"
"                    Best regards,\n"
"                    <br>\n"
"                </div>\n"
"            </div>\n"
"        "
msgstr ""
"<div style=\"margin: 0px; padding:0px;\">\n"
"                <div>\n"
"                    عزيزي\n"
"                    <t t-out=\"ctx.get('customer') or not_available\">،</t>\n"
"                    <br>\n"
"                    <br>\n"
"                    نأمل أن يجدك هذا البريد الإلكتروني بصحة جيدة. يسرنا تأكيد ترتيب التأجير للأصل التالي:\n"
"                    <br>\n"
"                    <br>\n"
"                    اسم الأصل:\n"
"                    <t t-out=\"ctx.get('asset') or not_available\"></t>\n"
"                    تاريخ بدء التأجير:\n"
"                    <t t-out=\"ctx.get('start_date') or not_available\"></t>\n"
"                    <br>\n"
"                    <br>\n"
"                    تاريخ انتهاء التأجير:\n"
"                    <t t-out=\"ctx.get('end_date') or not_available\"></t>\n"
"                    <br>\n"
"                    <br>\n"
"                    وفقاً للاتفاقية، يرجى التأكد من دفع رسوم التأجير في الوقت المحدد والالتزام بالشروط المذكورة فيها.\n"
"                    <br>\n"
"                    <br>\n"
"                    إذا كان لديك أي أسئلة أو تحتاج إلى توضيح إضافي بشأن اتفاقية التأجير، فلا تتردد في الاتصال بنا في أي وقت.\n"
"                    <br>\n"
"                    <br>\n"
"                    إذا كان لديك أي أسئلة أو تحتاج إلى مساعدة إضافية، فلا تتردد في الاتصال بنا.\n"
"                    <br>\n"
"                    <br>\n"
"                    مع أطيب التحيات،\n"
"                    <br>\n"
"                </div>\n"
"            </div>\n"
"        "

#. module: cyllo_asset_management
#: model:mail.template,body_html:cyllo_asset_management.mail_template_leased_assent_return_reminder
msgid ""
"<div style=\"margin: 0px; padding:0px;\">\n"
"                <div>\n"
"                    Dear\n"
"                    <t t-out=\"ctx.get('customer') or not_available\">,</t>\n"
"                    <br>\n"
"                    <br>\n"
"                    This is a friendly reminder regarding the return of the leased asset,\n"
"                    <b>\n"
"                        <t t-out=\"ctx.get('asset') or not_available\">,</t>\n"
"                    </b>\n"
"                    , which is due\n"
"                    for return as per our lease agreement on\n"
"                    <b>\n"
"                        <t t-out=\"ctx.get('end_date') or not_available\">,</t>\n"
"                    </b>\n"
"                    .\n"
"                    <br>\n"
"                    <br>\n"
"                    Please ensure that the asset is returned on or before the specified return date to avoid any\n"
"                    potential late fees or penalties as outlined in our agreement.\n"
"                    <br>\n"
"                    <br>\n"
"                    If you have any questions or need further assistance, please don't hesitate to contact us.\n"
"                    <br>\n"
"                    <br>\n"
"                    Best regards,\n"
"                    <br>\n"
"                </div>\n"
"            </div>\n"
"        "
msgstr ""
"<div style=\"margin: 0px; padding:0px;\">\n"
"                <div>\n"
"                    عزيزي\n"
"                    <t t-out=\"ctx.get('customer') or not_available\">،</t>\n"
"                    <br>\n"
"                    <br>\n"
"                    هذا تذكير ودي بشأن إعادة الأصل المؤجر،\n"
"                    <b>\n"
"                        <t t-out=\"ctx.get('asset') or not_available\">،</t>\n"
"                    </b>\n"
"                    والذي يجب إعادته وفقاً لاتفاقية التأجير في\n"
"                    <b>\n"
"                        <t t-out=\"ctx.get('end_date') or not_available\">،</t>\n"
"                    </b>\n"
"                    .\n"
"                    <br>\n"
"                    <br>\n"
"                    يرجى التأكد من إعادة الأصل في أو قبل تاريخ الإعادة المحدد لتجنب أي رسوم تأخير أو عقوبات محتملة كما هو موضح في الاتفاقية.\n"
"                    <br>\n"
"                    <br>\n"
"                    إذا كان لديك أي أسئلة أو تحتاج إلى مساعدة إضافية، فلا تتردد في الاتصال بنا.\n"
"                    <br>\n"
"                    <br>\n"
"                    مع أطيب التحيات،\n"
"                    <br>\n"
"                </div>\n"
"            </div>\n"
"        "

#. module: cyllo_asset_management
#: model:mail.template,body_html:cyllo_asset_management.mail_template_assent_rental_invoice_due_reminder
msgid ""
"<div style=\"margin: 0px; padding:0px;\">\n"
"                <div>\n"
"                    Dear\n"
"                    <t t-out=\"ctx.get('customer') or not_available\">,</t>\n"
"                    <br>\n"
"                    <br>\n"
"                    This is a friendly reminder regarding the upcoming payment for the rental asset invoice.\n"
"                    <br>\n"
"                    <br>\n"
"                    As per our agreement, the payment for the asset\n"
"                    <b>\n"
"                        <t t-out=\"ctx.get('asset') or not_available\">,</t>\n"
"                    </b>is due on\n"
"                    <b><t t-out=\"ctx.get('due_date') or not_available\">,</t></b>\n"
"                    . However, it appears that\n"
"                    the payment has not yet been received.\n"
"                    <br>\n"
"                    <br>\n"
"                    Please ensure that the payment is made promptly to avoid any late fees or disruptions to your rental\n"
"                    agreement. Your cooperation in this matter is greatly appreciated.\n"
"                    <br>\n"
"                    <br>\n"
"                    If you have already made the payment, please disregard this reminder, and kindly inform us of the\n"
"                    transaction details for our records.\n"
"                    <br>\n"
"                    <br>\n"
"                    If you have any questions or need further assistance, please don't hesitate to contact us.\n"
"                    <br>\n"
"                    <br>\n"
"                    Best regards,\n"
"                    <br>\n"
"                </div>\n"
"            </div>\n"
"        "
msgstr ""
"<div style=\"margin: 0px; padding:0px;\">\n"
"                <div>\n"
"                    عزيزي\n"
"                    <t t-out=\"ctx.get('customer') or not_available\">،</t>\n"
"                    <br>\n"
"                    <br>\n"
"                    هذا تذكير ودي بشأن الدفعة القادمة لفاتورة تأجير الأصل.\n"
"                    <br>\n"
"                    <br>\n"
"                    وفقاً لاتفاقيتنا، فإن دفعة الأصل\n"
"                    <b>\n"
"                        <t t-out=\"ctx.get('asset') or not_available\">،</t>\n"
"                    </b>مستحقة في\n"
"                    <b><t t-out=\"ctx.get('due_date') or not_available\">،</t></b>\n"
"                    . ومع ذلك، يبدو أن الدفعة لم تُستلم بعد.\n"
"                    <br>\n"
"                    <br>\n"
"                    يرجى التأكد من إجراء الدفع فوراً لتجنب أي رسوم تأخير أو انقطاع في اتفاقية التأجير. تعاونك في هذا الأمر محل تقدير كبير.\n"
"                    <br>\n"
"                    <br>\n"
"                    إذا كنت قد قمت بالدفع بالفعل، فيرجى تجاهل هذا التذكير، ويرجى إبلاغنا بتفاصيل المعاملة لسجلاتنا.\n"
"                    <br>\n"
"                    <br>\n"
"                    إذا كان لديك أي أسئلة أو تحتاج إلى مساعدة إضافية، فلا تتردد في الاتصال بنا.\n"
"                    <br>\n"
"                    <br>\n"
"                    مع أطيب التحيات،\n"
"                    <br>\n"
"                </div>\n"
"            </div>\n"
"        "

#. module: cyllo_asset_management
#: model:mail.template,body_html:cyllo_asset_management.mail_template_asset_assignment
msgid ""
"<div>\n"
"                <div>\n"
"                    Dear\n"
"                    <t t-out=\"ctx.get('employee') or not_available\">,</t>\n"
"                    <br>\n"
"                    <br>\n"
"                    I hope this email finds you well.\n"
"                    <br>\n"
"                    <br>\n"
"                    I am pleased to inform you that the following asset have been assigned to you:\n"
"                    <br>\n"
"                    <br>\n"
"                    Asset Name:\n"
"                    <t t-out=\"ctx.get('asset') or not_available\"></t>\n"
"                    <br>\n"
"                    <br>\n"
"                    Assign Date:\n"
"                    <t t-out=\"ctx.get('assign_date') or not_available\"></t>\n"
"                    <br>\n"
"                    <br>\n"
"                    Please take good care of the assigned asset and ensure they are used responsibly in accordance\n"
"                    with our organization's policies and guidelines.\n"
"                    <br>\n"
"                    <br>\n"
"                    Should you encounter any issues or have any\n"
"                    questions regarding the assigned asset, please feel free to reach out to us for assistance.\n"
"                    <br>\n"
"                    <br>\n"
"                    If you have any questions or need further assistance, please don't hesitate to contact us.\n"
"                    <br>\n"
"                    <br>\n"
"                    Best regards,\n"
"                    <br>\n"
"\n"
"                </div>\n"
"            </div>\n"
"        "
msgstr ""
"<div>\n"
"                <div>\n"
"                    عزيزي\n"
"                    <t t-out=\"ctx.get('employee') or not_available\">،</t>\n"
"                    <br>\n"
"                    <br>\n"
"                    نأمل أن يجدك هذا البريد الإلكتروني بصحة جيدة.\n"
"                    <br>\n"
"                    <br>\n"
"                    يسرني إبلاغك بأنه تم تخصيص الأصل التالي لك:\n"
"                    <br>\n"
"                    <br>\n"
"                    اسم الأصل:\n"
"                    <t t-out=\"ctx.get('asset') or not_available\"></t>\n"
"                    <br>\n"
"                    <br>\n"
"                    تاريخ التخصيص:\n"
"                    <t t-out=\"ctx.get('assign_date') or not_available\"></t>\n"
"                    <br>\n"
"                    <br>\n"
"                    يرجى العناية الجيدة بالأصل المخصص والتأكد من استخدامه بمسؤولية وفقاً لسياسات وإرشادات مؤسستنا.\n"
"                    <br>\n"
"                    <br>\n"
"                    إذا واجهت أي مشكلات أو كان لديك أي أسئلة بشأن الأصل المخصص، فلا تتردد في التواصل معنا للحصول على المساعدة.\n"
"                    <br>\n"
"                    <br>\n"
"                    إذا كان لديك أي أسئلة أو تحتاج إلى مساعدة إضافية، فلا تتردد في الاتصال بنا.\n"
"                    <br>\n"
"                    <br>\n"
"                    مع أطيب التحيات،\n"
"                    <br>\n"
"\n"
"                </div>\n"
"            </div>\n"
"        "

#. module: cyllo_asset_management
#: model:mail.template,body_html:cyllo_asset_management.mail_template_asset_reservation
msgid ""
"<div>\n"
"                <div>\n"
"                    Dear\n"
"                    <t t-out=\"ctx.get('employee') or not_available\">,</t>,\n"
"                    <br>\n"
"                    <br>\n"
"                    I hope this email finds you well.\n"
"                    <br>\n"
"                    <br>\n"
"                    This is to confirm that your reservation for the following asset has been successfully processed:\n"
"                    <br>\n"
"                    <br>\n"
"                    Asset Name:\n"
"                    <t t-out=\"ctx.get('asset') or not_available\"></t>\n"
"                    <br>\n"
"                    <br>\n"
"                    Reservation start Date:\n"
"                    <t t-out=\"ctx.get('start_date') or not_available\"></t>\n"
"                    <br>\n"
"                    <br>\n"
"                    Reservation End Date:\n"
"                    <t t-out=\"ctx.get('end_date') or not_available\"></t>\n"
"                    <br>\n"
"                    <br>\n"
"                    Please ensure to adhere to the reservation schedule.\n"
"                    <br>\n"
"                    <br>\n"
"                    If you have any questions or need further assistance, please don't hesitate to contact us.\n"
"                    <br>\n"
"                    <br>\n"
"                    Best regards,\n"
"                    <br>\n"
"                    <br>\n"
"                </div>\n"
"            </div>\n"
"        "
msgstr ""
"<div>\n"
"                <div>\n"
"                    عزيزي\n"
"                    <t t-out=\"ctx.get('employee') or not_available\">،</t>\n"
"                    <br>\n"
"                    <br>\n"
"                    نأمل أن يجدك هذا البريد الإلكتروني بصحة جيدة.\n"
"                    <br>\n"
"                    <br>\n"
"                    هذا تأكيد على أن حجزك للأصل التالي قد تم معالجته بنجاح:\n"
"                    <br>\n"
"                    <br>\n"
"                    اسم الأصل:\n"
"                    <t t-out=\"ctx.get('asset') or not_available\"></t>\n"
"                    <br>\n"
"                    <br>\n"
"                    تاريخ بدء الحجز:\n"
"                    <t t-out=\"ctx.get('start_date') or not_available\"></t>\n"
"                    <br>\n"
"                    <br>\n"
"                    تاريخ انتهاء الحجز:\n"
"                    <t t-out=\"ctx.get('end_date') or not_available\"></t>\n"
"                    <br>\n"
"                    <br>\n"
"                    يرجى الالتزام بجدول الحجز.\n"
"                    <br>\n"
"                    <br>\n"
"                    إذا كان لديك أي أسئلة أو تحتاج إلى مساعدة إضافية، فلا تتردد في الاتصال بنا.\n"
"                    <br>\n"
"                    <br>\n"
"                    مع أطيب التحيات،\n"
"                    <br>\n"
"                    <br>\n"
"                </div>\n"
"            </div>\n"
"        "

