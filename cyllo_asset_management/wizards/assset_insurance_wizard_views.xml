<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!--    Form view for the asset Insurance-->
    <record id="view_asset_insurance_form" model="ir.ui.view">
        <field name="name">view.asset.insurance.form</field>
        <field name="model">asset.insurance</field>
        <field name="arch" type="xml">
            <form string="Maintenance">
                <sheet>
                    <group>
                        <field name="asset_id"/>
                        <field name="total_amount"/>
                        <field name="insurance_percentage"/>
                    </group>
                    <footer>
                        <button name="action_create_bill" type="object" string="Create Invoice"
                                class="btn-primary"/>
                    <button special="cancel" string="Cancel" class="btn-secondary"/>
                    </footer>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
