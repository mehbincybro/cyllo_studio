<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!--    Form view for the asset Insurance-->
    <record id="view_asset_insurance_form" model="ir.ui.view">
        <field name="name">view.asset.insurance.form</field>
        <field name="model">asset.insurance</field>
        <field name="arch" type="xml">
            <form string="Maintenance">
                <sheet>
                    <group>
                        <field name="currency_id" invisible="True"/>
                        <field name="asset_id"/>
                        <field name="total_amount"/>
                        <field name="insurance_amount" options="{'currency_field': 'claiming_currency_id'}"/>
                        <field name="claiming_currency_id"
                               groups="base.group_multi_currency"
                               options="{'no_create': True}"/>
                        <field name="invoiced_amount" Srting="Total invoiced Amount" readonly="True"/>
                    </group>
                    <footer>
                        <button name="action_claim" type="object" string="Claim insurance"
                                class="btn-primary"/>
                        <button special="cancel" string="Cancel" class="btn-secondary"/>
                    </footer>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
