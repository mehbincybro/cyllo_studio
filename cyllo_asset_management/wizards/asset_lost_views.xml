<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!--Form view for the asset lost-->
    <record id="view_asset_lost_form" model="ir.ui.view">
        <field name="name">view.asset.lost.form</field>
        <field name="model">asset.lost</field>
        <field name="arch" type="xml">
            <form string="Lost">
                <sheet>
                    <group>
                        <group>
                            <field name="asset_asset_id" invisible="1"/>
                            <field name="loss_account_id" invisible="is_posted"/>
                            <field name="lost_date"/>
                            <field name="note"/>
                            <field name="is_scrap" invisible="1"/>
                            <field name="is_posted" invisible="1"/>
                        </group>
                    </group>
                </sheet>
                <footer>
                    <button type="object" name="action_submit" string="Submit" class="btn-primary"/>
                    <button special="cancel" string="Cancel" class="btn-secondary"/>

                </footer>
            </form>
        </field>
    </record>
    <!--    Action for the asset lost-->
    <record id="action_view_lost" model="ir.actions.act_window">
        <field name="name">Lost</field>
        <field name="res_model">asset.lost</field>
        <field name="view_mode">form</field>
    </record>
</odoo>
