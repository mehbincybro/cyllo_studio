<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!--
            Scheduled Action: Auto-fetch Google Form Responses
            ====================================================
            Runs every hour for all google.form records that have
            'need_automatic_fetching' set to True.

            'noupdate="1"' means this record is only created on first install
            and is NOT overwritten on module upgrade — preserving any interval
            changes the administrator makes in the UI.
        -->
        <record id="ir_cron_auto_fetch_google_form_responses" model="ir.cron">
            <field name="name">Auto-Fetch Google Form Responses</field>
            <field name="model_id" ref="model_google_form"/>
            <field name="state">code</field>
            <field name="code">model.cron_auto_fetch_responses()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">1</field>
            <field name="interval_type">hours</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
            <field name="priority">10</field>
        </record>

    </data>
</odoo>