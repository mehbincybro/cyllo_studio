<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_res_config_settings_form_google_form" model="ir.ui.view">
        <field name="name">res.config.settings.google.integration.form</field>
        <field name="model">res.config.settings</field>
        <field name="priority" eval="6"/>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">

            <xpath expr="//block[@name='generate_lead_setting_container']" position="after">

                <block title="Google Integration" id="google_integration_settings">

                    <setting id="google_api_credentials_setting"
                             help="Configure Google API credentials for CRM Google Form integration.">

                        <div class="content-group">

                            <div class="mt16">
                                <label for="client_id"/>
                                <field name="client_id" password="True"/>
                            </div>

                            <div class="mt16">
                                <label for="client_secret"/>
                                <field name="client_secret" password="True"/>
                            </div>

                            <div class="mt16">
                                <label for="access_token"/>
                                <field name="access_token" password="True"/>
                            </div>

                            <div class="mt16">
                                <label for="refresh_token"/>
                                <field name="refresh_token" password="True"/>
                            </div>

                        </div>

                    </setting>

                </block>

            </xpath>

        </field>
    </record>
</odoo>



