<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ACTION — defined BEFORE menuitem that references it -->
    <record id="action_google_form" model="ir.actions.act_window">
        <field name="name">Google Forms</field>
        <field name="res_model">google.form</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- TREE VIEW -->
    <record id="view_google_form_tree" model="ir.ui.view">
        <field name="name">google.form.tree</field>
        <field name="model">google.form</field>
        <field name="arch" type="xml">
            <tree string="Google Forms"
                  decoration-success="google_form_id != False"
                  decoration-warning="google_form_id == False">
                <field name="name" string="Form Title"/>
                <field name="google_form_id" string="Google Form ID"/>
                <field name="form_url" widget="url" string="Public URL"/>
                <field name="active" widget="boolean_toggle"/>
            </tree>
        </field>
    </record>

    <!-- FORM VIEW -->
    <record id="view_google_form_form" model="ir.ui.view">
        <field name="name">google.form.form</field>
        <field name="model">google.form</field>
        <field name="arch" type="xml">
            <form string="Google Form">
                <header>
                    <button name="create_google_form"
                            type="object"
                            string="Create / Sync Google Form"
                            class="btn-primary"
                            confirm="Push all questions to Google Forms?"/>
                    <button name="fetch_responses_create_leads"
                            type="object"
                            string="Fetch Responses to CRM"
                            class="btn-secondary"
                            invisible="not google_form_id"/>
                </header>

                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Form title..."/>
                        </h1>
                    </div>

                    <group string="Google Form Info">
                        <group>
                            <field name="google_form_id" readonly="1"/>
                            <field name="form_url" readonly="1" widget="url"/>
                        </group>
                        <group>
                            <field name="active"/>
                            <field name="lead_id"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Questions" name="page_questions">
                            <field name="question_ids"
                                   mode="tree"
                                   context="{'default_google_form_id': active_id}">
                                <tree editable="bottom" string="Questions">
                                    <field name="name"
                                           string="Question"
                                           placeholder="Type your question here..."/>
                                    <field name="question_type" string="Type"/>
                                    <field name="choices"
                                           string="Choices (comma-separated)"
                                           placeholder="e.g. Yes, No, Maybe"
                                           invisible="question_type != 'MULTIPLE_CHOICE'"
                                           required="question_type == 'MULTIPLE_CHOICE'"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>

            </form>
        </field>
    </record>

    <!-- MENUS — always after the action they reference -->
    <menuitem id="menu_google_form_root"
              name="Google Forms"
              parent="crm.crm_menu_root"
              sequence="10"/>

    <menuitem id="menu_google_form_list"
              name="Forms"
              parent="menu_google_form_root"
              action="action_google_form"
              sequence="10"/>

</odoo>