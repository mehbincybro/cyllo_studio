<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- This record extends the view for ir.attachment by adding a new field, public_url. -->
    <record id="view_ir_attachment_instagram" model="ir.ui.view">
        <field name="name">view.ir.attachment.cyllo.instagram</field>
        <field name="model">ir.attachment</field>
        <field name="inherit_id" ref="base.view_attachment_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='mimetype']" position="after">
                <field name="public_url" widget="url" invisible="1"/>
            </xpath>
        </field>
    </record>
</odoo>
