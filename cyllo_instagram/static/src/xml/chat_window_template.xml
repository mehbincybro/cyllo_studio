<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
   <t t-name="cyllo_instagram.ChatWindow.headerContent"
      t-inherit="mail.ChatWindow.headerContent" t-inherit-mode="extension">
       <xpath expr="//div[@t-if='!state.editingName']"
              position="before">
            <img t-if="this.store.instagram"
                 src="cyllo_instagram/static/src/4188690.png"
                 alt="" style="width: 25px;margin-left: 3%;"/>
       </xpath>
   </t>
</templates>