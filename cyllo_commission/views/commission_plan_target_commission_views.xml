<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!--Graph-->
    <record id="view_commission_plan_target_commission_graph"
            model="ir.ui.view">
        <field name="name">view.commission.plan.target.commission.graph</field>
        <field name="model">commission.plan.target.commission</field>
        <field name="arch" type="xml">
            <graph string="Commission Progress">
                <field name="target_rate" type="row" string="Target Rate (%)"/>
                <field name="amount" type="measure" string="Amount"/>
                <field name="currency_id" invisible="1"/>
            </graph>
        </field>
    </record>
    <!--Tree-->
    <record id="view_commission_plan_target_commission_tree" model="ir.ui.view">
        <field name="name">view.commission.plan.target.commission.tree</field>
        <field name="model">commission.plan.target.commission</field>
        <field name="arch" type="xml">
            <tree>
                <field name="target_rate"/>
                <field name="amount"/>
                <field name="amount_rate"/>
            </tree>
        </field>
    </record>
</odoo>