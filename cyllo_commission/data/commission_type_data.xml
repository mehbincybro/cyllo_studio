<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data noupdate="1">
        <record id="commission_plan_type_01" model="commission.type">
            <field name="name">Won Opportunities</field>
            <field name="type">crm</field>
            <field name="crm_rule_to_apply">[("stage_id.is_won", "=", True)]</field>
            <field name="active" eval="True"/>
        </record>
        <record id="commission_plan_type_02" model="commission.type">
            <field name="name">New Customers</field>
            <field name="type">crm</field>
            <field name="crm_rule_to_apply">[("is_new_customer", "=", True)]</field>
            <field name="active" eval="True"/>
        </record>
        <record id="commission_plan_type_03" model="commission.type">
            <field name="name">Closed in 15 Days</field>
            <field name="type">crm</field>
            <field name="crm_rule_to_apply">[('day_close', '&lt;=', 15), ('stage_id.is_won', '=', True)]</field>
            <field name="active" eval="True"/>
        </record>
        <record id="commission_plan_type_04" model="commission.type">
            <field name="name">Closed within Deadline</field>
            <field name="type">crm</field>
            <field name="crm_rule_to_apply">[("is_closed_on_time", "=", True)]</field>
            <field name="active" eval="True"/>
        </record>
        <record id="commission_plan_type_05" model="commission.type">
            <field name="name">All Products</field>
            <field name="type">sale</field>
            <field name="sales_rule_to_apply">[("product_id", "!=", False)]</field>
            <field name="active" eval="True"/>
        </record>
        <record id="commission_plan_type_06" model="commission.type">
            <field name="name">All Category Products</field>
            <field name="type">sale</field>
            <field name="sales_rule_to_apply">[("product_uom_category_id", "!=", False)]</field>
            <field name="active" eval="True"/>
        </record>
        <record id="commission_plan_type_07" model="commission.type">
            <field name="name">High Margin Products</field>
            <field name="type">sale</field>
            <field name="sales_rule_to_apply">[("margin", "&gt;=", 100)]</field>
            <field name="active" eval="True"/>
        </record>
        <record id="commission_plan_type_08" model="commission.type">
            <field name="name">Low Margin Products</field>
            <field name="type">sale</field>
            <field name="sales_rule_to_apply">[("margin", "&lt;", 100)]</field>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>