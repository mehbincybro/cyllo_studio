<odoo>
    <!-- Salesperson: only see their own reports -->
    <record id="commission_report_rule_salesperson" model="ir.rule">
        <field name="name">Commission Report: Salesperson Only</field>
        <field name="model_id" ref="model_commission_report"/>
        <field name="groups" eval="[(4, ref('sales_team.group_sale_salesman'))]"/>
        <field name="domain_force">[('user_id', '=', user.id)]</field>
    </record>

    <!-- Sales Manager: see all reports -->
    <record id="commission_report_rule_manager" model="ir.rule">
        <field name="name">Commission Report: Manager All</field>
        <field name="model_id" ref="model_commission_report"/>
        <field name="groups" eval="[(4, ref('sales_team.group_sale_manager'))]"/>
        <field name="domain_force">[(1,'=',1)]</field>
    </record>
</odoo>
