<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--Adding fleet fields to service request form view-->
    <record id="view_field_service_request_form" model="ir.ui.view">
        <field name="name">view.field.service.request.form</field>
        <field name="model">field.service.request</field>
        <field name="inherit_id" ref="cyllo_field_service.view_field_service_request_form"/>
        <field name="priority" eval="8"/>
        <field name="arch" type="xml">
            <!-- Insert a new page after a specific page -->
            <xpath expr="//page[@name='checklist']" position="after">
                <page name="equipments" string="Equipments">
                    <field name="field_service_equipments_ids"
                           readonly="state not in ['draft', 'submit']">
                        <tree editable="bottom">
                            <field name="display_name"
                                   string="Equipment"/>
                            <field name="category_id"
                                   string="Category"/>
                            <field name="assigned_date"/>
                            <field name="returned_date"/>
                        </tree>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
