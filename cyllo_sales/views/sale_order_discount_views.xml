<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Inherited Sale Order Wizard form To add some fields for discount option -->
    <record id="view_sale_order_discount_form" model="ir.ui.view">
        <field name="name">view.sale.order.discount.form</field>
        <field name="model">sale.order.discount</field>
        <field name="inherit_id" ref="sale.sale_order_line_wizard_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='discount_percentage']" position="after">
                <field name="apply_order_lines" invisible="discount_type == 'sol_discount'"/>
            </xpath>
        </field>
    </record>
</odoo>