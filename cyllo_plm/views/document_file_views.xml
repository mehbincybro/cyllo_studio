<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Inherit document.file form view to add eco_id relation field -->
    <record id="view_document_file_form_inherit" model="ir.ui.view">
        <field name="name">view.document.file.form.inherit</field>
        <field name="model">document.file</field>
        <field name="inherit_id" ref="cyllo_documents.view_document_file_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='workspace_id']" position="after">
                <field name="eco_id" />
            </xpath>
        </field>
    </record>

    <!-- Inherit document.file tree view to add eco_id relation field -->
    <record id="view_document_file_tree_inherit" model="ir.ui.view">
        <field name="name">view.document.file.tree.inherit</field>
        <field name="model">document.file</field>
        <field name="inherit_id" ref="cyllo_documents.view_document_file_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='workspace_id']" position="after">
                <field name="eco_id" string="ECO" />
            </xpath>
        </field>
    </record>
</odoo>
