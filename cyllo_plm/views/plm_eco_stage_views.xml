<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_plm_eco_stage_tree" model="ir.ui.view">
        <field name="name">view.plm.eco.stage.tree</field>
        <field name="model">plm.eco.stage</field>
        <field name="priority" eval="16"/>
        <field name="arch" type="xml">
            <tree string="ECO Stages" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="in_progress"/>
                <field name="done"/>
                <field name="cancelled"/>
                <field name="fold"/>
            </tree>
        </field>
    </record>

    <record id="view_plm_eco_stage_form" model="ir.ui.view">
        <field name="name">view.plm.eco.stage.form</field>
        <field name="model">plm.eco.stage</field>
        <field name="priority" eval="16"/>
        <field name="arch" type="xml">
            <form string="ECO Stage">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="sequence"/>
                        </group>
                        <group>
                            <field name="in_progress"/>
                            <field name="done"/>
                            <field name="cancelled"/>
                            <field name="fold"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>


    <record id="action_view_plm_eco_stage" model="ir.actions.act_window">
        <field name="name">ECO Stages</field>
        <field name="res_model">plm.eco.stage</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Define a new ECO Stage
            </p>
            <p>
                Stages define the progress steps of an ECO from creation to deployment.
            </p>
        </field>
    </record>
</odoo>
