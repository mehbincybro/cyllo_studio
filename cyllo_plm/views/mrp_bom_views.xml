<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_mrp_bom_form_inherit_plm" model="ir.ui.view">
        <field name="name">mrp.bom.form.inherit.plm</field>
        <field name="model">mrp.bom</field>
        <field name="inherit_id" ref="mrp.mrp_bom_form_view"/>
        <field name="priority">110</field>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_plm_ecos" type="object" class="oe_stat_button" icon="fa-gears">
                    <field name="eco_count" string="ECOs" widget="statinfo"/>
                </button>
            </xpath>
            <xpath expr="//page[@name='miscellaneous']//group/group[2]" position="inside">
                <field name="version"/>
            </xpath>
        </field>
    </record>

    <record id="view_mrp_bom_tree_inherit_plm" model="ir.ui.view">
        <field name="name">mrp.bom.tree.inherit.plm</field>
        <field name="model">mrp.bom</field>
        <field name="inherit_id" ref="mrp.mrp_bom_tree_view"/>
        <field name="priority">110</field>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='code']" position="after">
                <field name="version"/>
            </xpath>
        </field>
    </record>
</odoo>
