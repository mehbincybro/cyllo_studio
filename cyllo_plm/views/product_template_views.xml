<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_product_template_form_inherit_plm" model="ir.ui.view">
        <field name="name">product.template.form.inherit.plm</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="priority">110</field>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_plm_ecos" type="object" class="oe_stat_button" icon="fa-gears">
                    <field name="eco_count" string="ECOs" widget="statinfo"/>
                </button>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page string="Miscellaneous" name="miscellaneous_plm">
                    <group>
                        <group>
                            <field name="version"/>
                        </group>
                    </group>
                </page>
            </xpath>
            
        </field>
    </record>
</odoo>
