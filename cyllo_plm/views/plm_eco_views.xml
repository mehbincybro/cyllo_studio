<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_plm_eco_tree" model="ir.ui.view">
        <field name="name">view.plm.eco.tree</field>
        <field name="model">plm.eco</field>
        <field name="priority" eval="16"/>
        <field name="arch" type="xml">
            <tree string="Engineering Change Orders">
                <field name="name"/>
                <field name="product_id"/>
                <field name="bom_id"/>
                <field name="type_id"/>
                <field name="requested_by"/>
                <field name="stage_id"/>
            </tree>
        </field>
    </record>

    <record id="view_plm_eco_form" model="ir.ui.view">
        <field name="name">view.plm.eco.form</field>
        <field name="model">plm.eco</field>
        <field name="priority" eval="16"/>
        <field name="arch" type="xml">
            <form string="Engineering Change Order">
                <header>
                    <button name="action_start_revision" string="Start Revision" type="object" class="oe_highlight" invisible="not is_new_stage"/>
                    <button name="action_apply_revision" string="Apply" type="object" class="oe_highlight" invisible="not is_progress_stage"/>
                    <button name="action_cancel_revision" string="Cancel" type="object" invisible="is_done_stage or is_cancelled_stage"/>
                    <field name="stage_id" widget="statusbar" options="{'clickable': '1'}"/>
                </header>
                <sheet>
                    <field name="is_new_stage" invisible="1"/>
                    <field name="is_progress_stage" invisible="1"/>
                    <field name="is_done_stage" invisible="1"/>
                    <field name="is_cancelled_stage" invisible="1"/>

                    <div class="oe_button_box" name="button_box" >
                        <button type="object"  name="action_show_bom"
                                class="oe_stat_button"
                                icon="fa-flask" invisible="not revised_bom_id">
                            <field name="new_bom_version" string="Version" widget="statinfo" />
                        </button>

                        <button type="object"  name="action_show_product"
                                class="oe_stat_button"
                                icon="fa-flask" invisible="not product_id">
                            <field name="new_product_version" string="Version" widget="statinfo" />
                        </button>

                        <button type="object" name="action_show_documents"
                                class="oe_stat_button"
                                icon="fa-file-text-o">
                            <field name="document_count" string="Documents" widget="statinfo" />
                        </button>

                        <button type="object" name="action_compare_revisions"
                                class="oe_stat_button"
                                icon="fa-columns"
                                string="Compare"
                                >
                        </button>
                    </div>


                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="type_id" options="{'no_create': True}"/>
                            <field name="apply_on"/>
                            <field name="product_id" placeholder="Select Product..." invisible="apply_on != 'product'" required = "apply_on == 'product'"/>
                            <field name="bom_id" placeholder="Select Bill of Materials..." invisible="apply_on != 'bom'" required="apply_on == 'bom'"/>
                            <field name="eco_type" invisible="1"/>
                            <field name="revised_bom_id" invisible="1"/>
                        </group>
                        <group>

                            <field name="requested_by" readonly="1"/>
                            <field name="company_id"/>

                        </group>
                    </group>
                    <notebook>
                        <page string="Description" name="description">
                            <field name="description" placeholder="Describe the reason for the engineering change..."/>
                        </page>

                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_plm_eco_kanban" model="ir.ui.view">
        <field name="name">view.plm.eco.kanban</field>
        <field name="model">plm.eco</field>
        <field name="priority" eval="16"/>
        <field name="arch" type="xml">
            <kanban default_group_by="stage_id" class="o_kanban_small_column" quick_create="false">
                <field name="name"/>
                <field name="product_id"/>
                <field name="type_id"/>
                <field name="stage_id"/>
                <field name="activity_ids"/>
                <field name="activity_state"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click o_kanban_record">
                            <div class="oe_kanban_content">
                                <div class="o_kanban_record_top">
                                    <div class="o_kanban_record_headings">
                                        <strong class="o_kanban_record_title"><field name="name"/></strong>
                                    </div>
                                </div>
                                <div class="o_kanban_record_body">
                                    <div>Product: <field name="product_id"/></div>
                                    <div>Type: <field name="type_id"/></div>
<!--                                    <div t-if="record.version.raw_value">Version: <field name="version"/></div>-->
                                </div>
                                <div class="o_kanban_record_bottom">
                                    <div class="oe_kanban_bottom_left">
                                        <field name="activity_ids" widget="kanban_activity"/>
                                    </div>
                                    <div class="oe_kanban_bottom_right">
                                        <field name="requested_by" widget="many2one_avatar_user"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_plm_eco_search" model="ir.ui.view">
        <field name="name">view.plm.eco.search</field>
        <field name="model">plm.eco</field>
        <field name="priority" eval="16"/>
        <field name="arch" type="xml">
            <search string="Search ECO">
                <field name="name" string="ECO Reference"/>
                <field name="product_id"/>
                <field name="bom_id"/>
                <field name="type_id"/>
<!--                <field name="assigned_to"/>-->
                <filter string="My ECOs" name="my_ecos" />
                <filter string="Draft/New" name="draft_new" domain="[('stage_id.in_progress', '=', False), ('stage_id.done', '=', False), ('stage_id.cancelled', '=', False)]"/>
                <filter string="In Progress" name="progress" domain="[('stage_id.in_progress', '=', True)]"/>
                <filter string="Effective" name="effective" domain="[('stage_id.done', '=', True)]"/>
                <filter string="Cancelled" name="cancelled" domain="[('stage_id.cancelled', '=', True)]"/>
                <group expand="0" string="Group By">
                    <filter string="Stage" name="group_by_stage_id" context="{'group_by': 'stage_id'}"/>
                    <filter string="Type" name="group_by_type_id" context="{'group_by': 'type_id'}"/>
                    <field name="product_id"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_view_plm_eco" model="ir.actions.act_window">
        <field name="name">Engineering Change Orders</field>
        <field name="res_model">plm.eco</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="search_view_id" ref="view_plm_eco_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new Engineering Change Order (ECO)
            </p>
            <p>
                ECOs are used to manage changes to product template attributes or Bill of Materials configurations.
            </p>
        </field>
    </record>

    <!-- Product ECO Graph View -->
    <record id="view_plm_eco_product_graph" model="ir.ui.view">
        <field name="name">view.plm.eco.product.graph</field>
        <field name="model">plm.eco</field>
        <field name="priority" eval="16"/>
        <field name="arch" type="xml">
            <graph string="Product ECO Analysis" type="bar" sample="1">
                <field name="product_id" type="row"/>
                <field name="stage_id" type="col"/>
            </graph>
        </field>
    </record>

    <!-- Product ECO Pivot View -->
    <record id="view_plm_eco_product_pivot" model="ir.ui.view">
        <field name="name">view.plm.eco.product.pivot</field>
        <field name="model">plm.eco</field>
        <field name="priority" eval="16"/>
        <field name="arch" type="xml">
            <pivot string="Product ECO Analysis" sample="1">
                <field name="product_id" type="row"/>
                <field name="stage_id" type="col"/>
            </pivot>
        </field>
    </record>

    <!-- Product ECO Search View for Analysis -->
    <record id="view_plm_eco_product_search" model="ir.ui.view">
        <field name="name">view.plm.eco.product.search</field>
        <field name="model">plm.eco</field>
        <field name="arch" type="xml">
            <search string="Product ECO Analysis Search">
                <field name="product_id"/>
                <field name="type_id"/>
                <field name="requested_by"/>
                <field name="stage_id"/>
                <field name="create_date" string="Date"/>
                <filter string="My ECOs" name="my_ecos" domain="[('requested_by', '=', uid)]"/>
                <group expand="0" string="Group By">
                    <filter string="Product" name="group_by_product" context="{'group_by': 'product_id'}"/>
                    <filter string="ECO Type" name="group_by_type" context="{'group_by': 'type_id'}"/>
                    <filter string="Requested By" name="group_by_requested_by" context="{'group_by': 'requested_by'}"/>
                    <filter string="Stage" name="group_by_stage" context="{'group_by': 'stage_id'}"/>
                    <filter string="Date" name="group_by_date" context="{'group_by': 'create_date'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Product ECO Analysis Action -->
    <record id="action_plm_eco_product_report" model="ir.actions.act_window">
        <field name="name">Product ECO Analysis</field>
        <field name="res_model">plm.eco</field>
        <field name="view_mode">graph,pivot</field>
        <field name="domain">[('apply_on', '=', 'product')]</field>
        <field name="search_view_id" ref="view_plm_eco_product_search"/>
        <field name="context">{'search_default_group_by_product': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No Product ECO analysis data available.
            </p>
        </field>
    </record>

    <!-- BoM ECO Graph View -->
    <record id="view_plm_eco_bom_graph" model="ir.ui.view">
        <field name="name">view.plm.eco.bom.graph</field>
        <field name="model">plm.eco</field>
        <field name="priority" eval="16"/>
        <field name="arch" type="xml">
            <graph string="BoM ECO Analysis" type="bar" sample="1">
                <field name="bom_id" type="row"/>
                <field name="stage_id" type="col"/>
            </graph>
        </field>
    </record>

    <!-- BoM ECO Pivot View -->
    <record id="view_plm_eco_bom_pivot" model="ir.ui.view">
        <field name="name">view.plm.eco.bom.pivot</field>
        <field name="model">plm.eco</field>
        <field name="priority" eval="16"/>
        <field name="arch" type="xml">
            <pivot string="BoM ECO Analysis" sample="1">
                <field name="bom_id" type="row"/>
                <field name="stage_id" type="col"/>
            </pivot>
        </field>
    </record>

    <!-- BoM ECO Search View for Analysis -->
    <record id="view_plm_eco_bom_search" model="ir.ui.view">
        <field name="name">view.plm.eco.bom.search</field>
        <field name="model">plm.eco</field>
        <field name="arch" type="xml">
            <search string="BoM ECO Analysis Search">
                <field name="bom_id"/>
                <field name="product_id"/>
                <field name="type_id"/>
                <field name="stage_id"/>
                <field name="requested_by"/>
                <field name="create_date" string="Date"/>
                <filter string="My ECOs" name="my_ecos" domain="[('requested_by', '=', uid)]"/>
                <group expand="0" string="Group By">
                    <filter string="BoM" name="group_by_bom" context="{'group_by': 'bom_id'}"/>
                    <filter string="Product" name="group_by_product" context="{'group_by': 'product_id'}"/>
                    <filter string="ECO Type" name="group_by_type" context="{'group_by': 'type_id'}"/>
                    <filter string="Stage" name="group_by_stage" context="{'group_by': 'stage_id'}"/>
                    <filter string="Requested By" name="group_by_requested_by" context="{'group_by': 'requested_by'}"/>
                    <filter string="Date" name="group_by_date" context="{'group_by': 'create_date'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- BoM ECO Analysis Action -->
    <record id="action_plm_eco_bom_report" model="ir.actions.act_window">
        <field name="name">BoM ECO Analysis</field>
        <field name="res_model">plm.eco</field>
        <field name="view_mode">graph,pivot</field>
        <field name="domain">[('apply_on', '=', 'bom')]</field>
        <field name="search_view_id" ref="view_plm_eco_bom_search"/>
        <field name="context">{'search_default_group_by_bom': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No BoM ECO analysis data available.
            </p>
        </field>
    </record>
</odoo>
