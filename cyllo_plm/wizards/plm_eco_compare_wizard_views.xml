<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_plm_eco_compare_wizard_form" model="ir.ui.view">
        <field name="name">view.plm.eco.compare.wizard.form</field>
        <field name="model">plm.eco.compare.wizard</field>
        <field name="arch" type="xml">
            <form string="Revision Comparison">
                <sheet style="max-width: 100% !important; width: 100% !important;">
                    <field name="html_diff" widget="html" readonly="1"/>
                </sheet>
                <footer>
                    <button string="Close" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
