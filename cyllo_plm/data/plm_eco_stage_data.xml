<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <data noupdate="1">
        <record id="eco_stage_new" model="plm.eco.stage">
            <field name="name">New</field>
            <field name="sequence">10</field>
        </record>

        <record id="eco_stage_progress" model="plm.eco.stage">
            <field name="name">In Progress</field>
            <field name="sequence">20</field>
            <field name="in_progress" eval="True"/>
        </record>

        <record id="eco_stage_effective" model="plm.eco.stage">
            <field name="name">Effective</field>
            <field name="sequence">50</field>
            <field name="done" eval="True"/>
        </record>

        <record id="eco_stage_cancelled" model="plm.eco.stage">
            <field name="name">Cancelled</field>
            <field name="sequence">60</field>
            <field name="cancelled" eval="True"/>
        </record>
    </data>

</odoo>

