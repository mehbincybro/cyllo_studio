<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Add default_sound field next to default_co2 in fleet.vehicle.model form -->
    <record id="fleet_vehicle_model_form_inherit_sound" model="ir.ui.view">
        <field name="name">fleet.vehicle.model.form.inherit.sound</field>
        <field name="model">fleet.vehicle.model</field>
        <field name="inherit_id" ref="fleet.fleet_vehicle_model_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='default_co2']" position="after">
                <label for="default_sound"/>
                <div class="o_row" name="default_sound">
                    <field name="default_sound"/><span>dB</span>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
