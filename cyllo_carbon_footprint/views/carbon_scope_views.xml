<odoo>
    <record id="view_carbon_scope_tree" model="ir.ui.view">
        <field name="name">carbon.scope.tree</field>
        <field name="model">carbon.scope</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="code"/>
                <field name="sequence"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <record id="view_carbon_scope_form" model="ir.ui.view">
        <field name="name">carbon.scope.form</field>
        <field name="model">carbon.scope</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="sequence"/>
                        <field name="active"/>
                    </group>
                    <group>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_carbon_scope" model="ir.actions.act_window">
        <field name="name">Scopes</field>
        <field name="res_model">carbon.scope</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
