<odoo>
    <record id="view_carbon_rule_tree" model="ir.ui.view">
        <field name="name">carbon.assign.rule.tree</field>
        <field name="model">carbon.assign.rule</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="model_id"/>
                <field name="source_id"/>
                <field name="factor_id"/>
                <field name="method"/>
                <field name="priority"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <record id="view_carbon_rule_form" model="ir.ui.view">
        <field name="name">carbon.assign.rule.form</field>
        <field name="model">carbon.assign.rule</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="model_id"/>
                        <field name="domain"/>
                        <field name="source_id"/>
                        <field name="factor_id"/>
                        <field name="method"/>
                        <field name="priority"/>
                        <field name="active"/>
                    </group>
                    <group>
                        <field name="note"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_carbon_rule" model="ir.actions.act_window">
        <field name="name">Assignation Rules</field>
        <field name="res_model">carbon.assign.rule</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
