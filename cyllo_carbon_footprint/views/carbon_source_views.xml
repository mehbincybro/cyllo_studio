<odoo>
    <record id="view_carbon_source_tree" model="ir.ui.view">
        <field name="name">carbon.source.tree</field>
        <field name="model">carbon.source</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="category"/>
                <field name="activity_unit"/>
                <field name="scope_id"/>
                <field name="factor_count"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <record id="view_carbon_source_form" model="ir.ui.view">
        <field name="name">carbon.source.form</field>
        <field name="model">carbon.source</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="category"/>
                        <field name="activity_unit"/>
                        <field name="scope_id"/>
                        <field name="active"/>
                    </group>
                    <notebook>
                        <page string="Factors">
                            <field name="factor_ids">
                                <tree editable="bottom">
                                    <field name="name"/>
                                    <field name="gas_id"/>
                                    <field name="factor_value"/>
                                    <field name="unit_name"/>
                                    <field name="region"/>
                                    <field name="provider"/>
                                    <field name="valid_from"/>
                                    <field name="valid_to"/>
                                    <field name="active"/>
                                    <field name="note"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Notes">
                            <field name="description"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_carbon_source" model="ir.actions.act_window">
        <field name="name">Emission Sources</field>
        <field name="res_model">carbon.source</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
