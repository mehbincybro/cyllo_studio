<odoo>
    <record id="view_carbon_compute_wizard_form" model="ir.ui.view">
        <field name="name">carbon.compute.wizard.form</field>
        <field name="model">carbon.compute.wizard</field>
        <field name="arch" type="xml">
            <form string="Compute Emissions">
                <group>
                    <field name="calculation_id" readonly="1"/>
                    <field name="apply_rules"/>
                    <field name="mark_done"/>
                </group>
                <footer>
                    <button name="action_run" type="object" string="Run" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_carbon_compute_wizard" model="ir.actions.act_window">
        <field name="name">Compute Emissions</field>
        <field name="res_model">carbon.compute.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'default_calculation_id': active_id}</field>
    </record>
</odoo>
