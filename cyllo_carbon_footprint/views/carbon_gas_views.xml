<odoo>
    <record id="view_carbon_gas_tree" model="ir.ui.view">
        <field name="name">carbon.gas.tree</field>
        <field name="model">carbon.gas</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="code"/>
                <field name="formula"/>
                <field name="gwp"/>
                <field name="unit_name"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <record id="view_carbon_gas_form" model="ir.ui.view">
        <field name="name">carbon.gas.form</field>
        <field name="model">carbon.gas</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="formula"/>
                        <field name="gwp"/>
                        <field name="unit_name"/>
                        <field name="active"/>
                    </group>
                    <group>
                        <field name="note"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_carbon_gas" model="ir.actions.act_window">
        <field name="name">Gases</field>
        <field name="res_model">carbon.gas</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
