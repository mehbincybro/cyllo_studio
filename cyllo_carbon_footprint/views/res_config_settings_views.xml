<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.carbon</field>
        <field name="model">res.config.settings</field>
        <field name="priority" eval="90"/>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="Green Metrics" string="Green Metrics" name="cyllo_green_metrics">
                    <block title="Manufacturing Integration" name="mrp_integration_setting_block">
                        <setting string="MRP Integration" help="Automatically calculate carbon emissions from Work Order operations.">
                            <field name="mrp_integration"/>
                        </setting>
                    </block>
                    <block title="Fleet Integration" name="fleet_integration_setting_block">
                        <setting string="Fleet Integration" help="Integrate fleet odometer readings with green metrics.">
                            <field name="fleet_integration"/>
                        </setting>
                    </block>
                    <block title="Water Metrics Allocation" name="water_allocation_setting_block">
                        <setting string="Water Cap" help="Max allowed water usage for the selected duration." company_dependent="1">
                            <div class="content-group">
                                <div class="row mt16">
                                    <label for="water_duration" class="col-lg-3 o_light_label"/>
                                    <field name="water_duration" class="oe_inline"/>
                                </div>
                                <div class="row mt8">
                                    <label for="water_cap" class="col-lg-3 o_light_label"/>
                                    <field name="water_cap" class="oe_inline"/>
                                </div>
                                <div class="row mt8">
                                    <label for="water_unit" class="col-lg-3 o_light_label"/>
                                    <field name="water_unit" class="oe_inline"/>
                                </div>
                            </div>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>

    <record id="action_carbon_config_settings" model="ir.actions.act_window">
        <field name="name">Settings</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="target">inline</field>
        <field name="context">{'module' : 'cyllo_green_metrics'}</field>
    </record>
</odoo>
