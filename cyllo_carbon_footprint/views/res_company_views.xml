<odoo>
    <record id="view_company_form_inherit_carbon" model="ir.ui.view">
    <field name="name">res.company.form.carbon</field>
    <field name="model">res.company</field>
    <field name="inherit_id" ref="base.view_company_form"/>
    <field name="arch" type="xml">
        <xpath expr="//field[@name='currency_id']" position="after">
            <label for="carbon_cap"/>
            <div class="o_row oe_inline" style="gap:8px; align-items:center;">
                <field name="carbon_cap" nolabel="1"/>
                <field name="carbon_unit" nolabel="1"/>
                <span>/</span>
                <field name="carbon_duration" nolabel="1"/>
            </div>
            <label for="water_cap"/>
            <div class="o_row oe_inline" style="gap:8px; align-items:center;">
                <field name="water_cap" nolabel="1"/>
                <field name="water_unit" nolabel="1"/>
                <span>/</span>
                <field name="water_duration" nolabel="1"/>
            </div>
        </xpath>

    </field>
    </record>
</odoo>