<odoo noupdate="1">
    <record id="carbon_scope_1" model="carbon.scope">
        <field name="name">Scope 1</field>
        <field name="code">S1</field>
        <field name="sequence">10</field>
    </record>
    <record id="carbon_scope_2" model="carbon.scope">
        <field name="name">Scope 2</field>
        <field name="code">S2</field>
        <field name="sequence">20</field>
    </record>
    <record id="carbon_scope_3" model="carbon.scope">
        <field name="name">Scope 3</field>
        <field name="code">S3</field>
        <field name="sequence">30</field>
    </record>

    <record id="carbon_unit_kwh" model="carbon.unit">
        <field name="name">kWh</field>
    </record>
    <record id="carbon_unit_l" model="carbon.unit">
        <field name="name">L</field>
    </record>
    <record id="carbon_unit_km" model="carbon.unit">
        <field name="name">km</field>
    </record>
    <record id="carbon_unit_kg" model="carbon.unit">
        <field name="name">kg</field>
    </record>
    <record id="carbon_unit_kg_co2e" model="carbon.unit">
        <field name="name">kg CO2e</field>
    </record>
    <record id="carbon_unit_kg_co2e_kwh" model="carbon.unit">
        <field name="name">kg CO2e/kWh</field>
    </record>
    <record id="carbon_unit_kg_co2e_l" model="carbon.unit">
        <field name="name">kg CO2e/L</field>
    </record>
    <record id="carbon_unit_kg_co2e_km" model="carbon.unit">
        <field name="name">kg CO2e/km</field>
    </record>
    <record id="carbon_unit_kg_co2e_kg" model="carbon.unit">
        <field name="name">kg CO2e/kg</field>
    </record>

    <record id="carbon_gas_co2" model="carbon.gas">
        <field name="name">Carbon Dioxide</field>
        <field name="code">CO2</field>
        <field name="formula">CO2</field>
        <field name="gwp">1</field>
        <field name="unit_name" ref="carbon_unit_kg_co2e"/>
    </record>
    <record id="carbon_gas_ch4" model="carbon.gas">
        <field name="name">Methane</field>
        <field name="code">CH4</field>
        <field name="formula">CH4</field>
        <field name="gwp">27.2</field>
        <field name="unit_name" ref="carbon_unit_kg_co2e"/>
    </record>
    <record id="carbon_gas_n2o" model="carbon.gas">
        <field name="name">Nitrous Oxide</field>
        <field name="code">N2O</field>
        <field name="formula">N2O</field>
        <field name="gwp">273</field>
        <field name="unit_name" ref="carbon_unit_kg_co2e"/>
    </record>

    <record id="carbon_source_electricity" model="carbon.source">
        <field name="name">Purchased Electricity</field>
        <field name="category">energy</field>
        <field name="activity_unit" ref="carbon_unit_kwh"/>
        <field name="scope_id" ref="carbon_scope_2"/>
    </record>
    <record id="carbon_source_fuel" model="carbon.source">
        <field name="name">Fuel Combustion</field>
        <field name="category">energy</field>
        <field name="activity_unit" ref="carbon_unit_l"/>
        <field name="scope_id" ref="carbon_scope_1"/>
    </record>
    <record id="carbon_source_travel" model="carbon.source">
        <field name="name">Business Travel</field>
        <field name="category">transport</field>
        <field name="activity_unit" ref="carbon_unit_km"/>
        <field name="scope_id" ref="carbon_scope_3"/>
    </record>
    <record id="carbon_source_waste" model="carbon.source">
        <field name="name">Waste Disposal</field>
        <field name="category">waste</field>
        <field name="activity_unit" ref="carbon_unit_kg"/>
        <field name="scope_id" ref="carbon_scope_3"/>
    </record>

    <record id="carbon_factor_electricity_co2" model="carbon.factor">
        <field name="name">Electricity Grid Mix</field>
        <field name="source_id" ref="carbon_source_electricity"/>
        <field name="gas_id" ref="carbon_gas_co2"/>
        <field name="factor_value">0.70</field>
        <field name="unit_name" ref="carbon_unit_kg_co2e_kwh"/>
        <field name="region">Default</field>
        <field name="provider">Demo</field>
    </record>
    <record id="carbon_factor_fuel_co2" model="carbon.factor">
        <field name="name">Diesel Combustion</field>
        <field name="source_id" ref="carbon_source_fuel"/>
        <field name="gas_id" ref="carbon_gas_co2"/>
        <field name="factor_value">2.68</field>
        <field name="unit_name" ref="carbon_unit_kg_co2e_l"/>
        <field name="region">Default</field>
        <field name="provider">Demo</field>
    </record>
    <record id="carbon_factor_travel_co2" model="carbon.factor">
        <field name="name">Air Travel Avg</field>
        <field name="source_id" ref="carbon_source_travel"/>
        <field name="gas_id" ref="carbon_gas_co2"/>
        <field name="factor_value">0.18</field>
        <field name="unit_name" ref="carbon_unit_kg_co2e_km"/>
        <field name="region">Default</field>
        <field name="provider">Demo</field>
    </record>
    <record id="carbon_factor_waste_co2" model="carbon.factor">
        <field name="name">Landfill Avg</field>
        <field name="source_id" ref="carbon_source_waste"/>
        <field name="gas_id" ref="carbon_gas_co2"/>
        <field name="factor_value">1.20</field>
        <field name="unit_name" ref="carbon_unit_kg_co2e_kg"/>
        <field name="region">Default</field>
        <field name="provider">Demo</field>
    </record>

    <record id="carbon_rule_electricity" model="carbon.assign.rule">
        <field name="name">Electricity Activities</field>
        <field name="model_id" ref="cyllo_carbon_footprint.model_carbon_activity"/>
        <field name="domain">[('name', 'ilike', 'Electricity')]</field>
        <field name="source_id" ref="carbon_source_electricity"/>
        <field name="factor_id" ref="carbon_factor_electricity_co2"/>
        <field name="method">factor</field>
        <field name="priority">10</field>
    </record>
    <record id="carbon_rule_fuel" model="carbon.assign.rule">
        <field name="name">Fuel Activities</field>
        <field name="model_id" ref="cyllo_carbon_footprint.model_carbon_activity"/>
        <field name="domain">[('name', 'ilike', 'Fuel')]</field>
        <field name="source_id" ref="carbon_source_fuel"/>
        <field name="factor_id" ref="carbon_factor_fuel_co2"/>
        <field name="method">factor</field>
        <field name="priority">20</field>
    </record>

    <record id="carbon_calc_q1" model="carbon.calc">
        <field name="name">Q1 2026</field>
        <field name="date">2026-03-31</field>
    </record>

    <record id="carbon_activity_electricity" model="carbon.activity">
        <field name="name">Electricity - Office</field>
        <field name="date">2026-01-15</field>
        <field name="calculation_id" ref="carbon_calc_q1"/>
        <field name="source_id" ref="carbon_source_electricity"/>
        <field name="scope_id" ref="carbon_scope_2"/>
        <field name="quantity">12000</field>
        <field name="uom_name" ref="carbon_unit_kwh"/>
        <field name="factor_id" ref="carbon_factor_electricity_co2"/>
        <field name="gas_id" ref="carbon_gas_co2"/>
        <field name="factor_value">0.70</field>
        <field name="state">done</field>
    </record>
    <record id="carbon_activity_fuel" model="carbon.activity">
        <field name="name">Fuel - Fleet</field>
        <field name="date">2026-02-10</field>
        <field name="calculation_id" ref="carbon_calc_q1"/>
        <field name="source_id" ref="carbon_source_fuel"/>
        <field name="scope_id" ref="carbon_scope_1"/>
        <field name="quantity">1500</field>
        <field name="uom_name" ref="carbon_unit_l"/>
        <field name="factor_id" ref="carbon_factor_fuel_co2"/>
        <field name="gas_id" ref="carbon_gas_co2"/>
        <field name="factor_value">2.68</field>
        <field name="state">done</field>
    </record>
    <record id="carbon_activity_travel" model="carbon.activity">
        <field name="name">Travel - Air</field>
        <field name="date">2026-03-05</field>
        <field name="calculation_id" ref="carbon_calc_q1"/>
        <field name="source_id" ref="carbon_source_travel"/>
        <field name="scope_id" ref="carbon_scope_3"/>
        <field name="quantity">4200</field>
        <field name="uom_name" ref="carbon_unit_km"/>
        <field name="factor_id" ref="carbon_factor_travel_co2"/>
        <field name="gas_id" ref="carbon_gas_co2"/>
        <field name="factor_value">0.18</field>
        <field name="state">done</field>
    </record>
    <record id="carbon_activity_waste" model="carbon.activity">
        <field name="name">Waste - Disposal</field>
        <field name="date">2026-03-20</field>
        <field name="calculation_id" ref="carbon_calc_q1"/>
        <field name="source_id" ref="carbon_source_waste"/>
        <field name="scope_id" ref="carbon_scope_3"/>
        <field name="quantity">800</field>
        <field name="uom_name" ref="carbon_unit_kg"/>
        <field name="factor_id" ref="carbon_factor_waste_co2"/>
        <field name="gas_id" ref="carbon_gas_co2"/>
        <field name="factor_value">1.20</field>
        <field name="state">done</field>
    </record>
</odoo>
