<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_incident_category_tree" model="ir.ui.view">
        <field name="name">view.hr.incident.category.tree</field>
        <field name="model">hr.incident.category</field>
        <field name="arch" type="xml">
            <tree string="Incident Categories" multi_edit="1" editable="bottom">
                <field name="name"/>
                <field name="description"/>
            </tree>
        </field>
    </record>

    <record id="action_view_incident_categories" model="ir.actions.act_window">
        <field name="name">Incident Categories</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">hr.incident.category</field>
        <field name="view_mode">tree</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your incident category
            </p>
            <p>
                Use these created incident categories while raising incident
                requests.
            </p>
        </field>
    </record>
    <menuitem id="menu_incident_categories" name="Incident Categories"
              parent="cyllo_hr_incident_management.menu_incident_management_categ"
              action="action_view_incident_categories" sequence="5"/>
</odoo>
