<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--    Record rule for hr manager-->
    <record id="rule_hr_incident_manager" model="ir.rule">
        <field name="name">Incident Request: Manager</field>
        <field name="model_id" ref="model_hr_incident"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[Command.link(ref('hr.group_hr_manager'))]"/>
        <field name="perm_create" eval="1"/>
        <field name="perm_write" eval="1"/>
        <field name="perm_unlink" eval="1"/>
        <field name="perm_read" eval="1"/>
    </record>
    <!--    Record rule for hr user-->
    <record id="rule_hr_incident_user" model="ir.rule">
        <field name="name">Incident Request: User</field>
        <field name="model_id" ref="model_hr_incident"/>
        <field name="domain_force">['|','|',('incident_initiator_id.user_id',
            '=', user.id),('incident_receptor_id.user_id', '=',
            user.id),('incident_handler_id.user_id', '=', user.id)]
        </field>
        <field name="groups" eval="[Command.link(ref('hr.group_hr_user'))]"/>
        <field name="perm_create" eval="1"/>
        <field name="perm_write" eval="1"/>
        <field name="perm_unlink" eval="1"/>
        <field name="perm_read" eval="1"/>
    </record>
    <record id="rule_hr_incident_company" model="ir.rule">
        <field name="name">Incident Request multi-company</field>
        <field name="model_id" ref="model_hr_incident"/>
        <field name="global" eval="True"/>
        <field name="domain_force">['|', ('company_id', 'in', company_ids),
            ('company_id', '=', False)]
        </field>
    </record>
    <!--    Multi company rule for hr incident category-->
    <record id="rule_hr_incident_category_company" model="ir.rule">
        <field name="name">Incident Categories multi-company</field>
        <field name="model_id" ref="model_hr_incident_category"/>
        <field name="global" eval="True"/>
        <field name="domain_force">['|', ('company_id', 'in', company_ids),
            ('company_id', '=', False)]
        </field>
    </record>
</odoo>
