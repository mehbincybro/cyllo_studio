<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_hrincident_document">
        <t t-foreach="docs" t-as="o">
            <t t-call="web.external_layout">
                <div class="page">
                    <div class="oe_structure"/>
                    <div style="text-align:center;">
                        <h2>Incident Management Report</h2>
                        <hr style="width:50%;margin-left:210px"/>
                    </div>
                    <br/>
                    <h1 t-field="o.name" class="mt0"/>
                    <br/>
                    <br/>
                    <strong>Submitted Date :</strong>
                    <br/>
                    <span t-field="o.date"/>
                    <br/>
                    <br/>
                    <strong>Completion Date :</strong>
                    <br/>
                    <span t-field="o.date_done"/>
                    <br/><br/>
                    <br/>
                    <div class="row">
                        <div class="col-4">
                            <strong>INITIATOR'S DETAILS </strong>
                            <hr style="width:50%;text-align:left;margin-left:0"/>
                            <span t-field="o.incident_initiator_id.name"/>
                            <br/>
                            <span t-field="o.incident_initiator_department_id.name"/>
                            <br/>
                            <span t-field="o.incident_initiator_email"/>
                            <br/>
                            <span t-field="o.incident_initiator_phone"/>
                            <br/>
                            <br/>
                        </div>
                        <div class="col-4">
                            <strong>RECEPTOR'S DETAILS</strong>
                            <hr style="width:50%;text-align:left;margin-left:0"/>
                            <span t-field="o.incident_receptor_id.name"/>
                            <br/>
                            <span t-field="o.incident_receptor_department_id.name"/>
                            <br/>
                            <span t-field="o.incident_receptor_email"/>
                            <br/>
                            <span t-field="o.incident_receptor_phone"/>

                            <br/>
                        </div>
                        <div class="col-4">
                            <strong>HANDLER'S DETAILS</strong>
                            <hr style="width:50%;text-align:left;margin-left:0"/>
                            <span t-field="o.incident_handler_id.name"/>
                            <br/>
                            <span t-field="o.incident_handler_department_id.name"/>
                            <br/>
                            <span t-field="o.incident_handler_email"/>
                            <br/>
                            <span t-field="o.incident_handler_phone"/>
                            <br/>
                        </div>
                    </div>
                    <br/>
                    <strong>INCIDENT INFORMATION</strong>
                    <hr style="width:50%;text-align:left;margin-left:0"/>
                    <strong>Incident Category :</strong>
                    <span t-field="o.incident_category_id.name"/>
                    <br/><br/>
                    <strong>Incident Description :</strong>
                    <span t-field="o.incident_description"/>
                    <br/>
                    <strong>Incident Action Description :</strong>
                    <span t-field="o.incident_action_description"/>
                    <br/>
                    <br/>
                </div>
            </t>
        </t>
    </template>
    <template id="report_hrincident">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="cyllo_hr_incident_management.report_hrincident_document"/>
            </t>
        </t>
    </template>
</odoo>
