<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!--    Hr incident demo datas -->
    <record id="hr_incident_demo_1" model="hr.incident">
        <field name="incident_category_id" ref="cyllo_hr_incident_management.hr_incident_category_safety"/>
        <field name="incident_description">Rushing to catch the bus, Maya
            tripped on the uneven sidewalk
        </field>
        <field name="incident_initiator_id" ref="hr.employee_ngh"/>
        <field name="incident_receptor_id" ref="hr.employee_admin"/>
    </record>
    <record id="hr_incident_demo_2" model="hr.incident">
        <field name="incident_category_id" ref="cyllo_hr_incident_management.hr_incident_category_financial"/>
        <field name="incident_description">Sarah's latte money dreams were
            dashed when her debit card declined at the coffee shop, leaving her
            with a sheepish apology and an empty stomach.
        </field>
        <field name="incident_initiator_id" ref="hr.employee_jgo"/>
        <field name="incident_receptor_id" ref="hr.employee_admin"/>
    </record>
    <record id="hr_incident_demo_3" model="hr.incident">
        <field name="incident_category_id" ref="cyllo_hr_incident_management.hr_incident_category_security"/>
        <field name="incident_description">Lisa swiped her ID at the office
            door, but the alarm blared - her temporary badge had expired,
            causing a brief security scramble.
        </field>
        <field name="incident_initiator_id" ref="hr.employee_jth"/>
        <field name="incident_receptor_id" ref="hr.employee_mit"/>
    </record>
    <record id="hr_incident_demo_5" model="hr.incident">
        <field name="incident_category_id" ref="cyllo_hr_incident_management.hr_incident_category_safety"/>
        <field name="incident_description">While watering the plants, David
            clipped the hose with his shears, sending a spray of water shooting
            up and soaking him completely.
        </field>
        <field name="incident_initiator_id" ref="hr.employee_ngh"/>
        <field name="incident_receptor_id" ref="hr.employee_admin"/>
    </record>
    <record id="hr_incident_demo_4" model="hr.incident">
        <field name="incident_category_id" ref="cyllo_hr_incident_management.hr_incident_category_safety"/>
        <field name="incident_description">On a cold morning, Kevin forgot his
            gloves and reached for a metal doorknob, receiving a jolt that sent
            him hopping back with a surprised yelp.
        </field>
        <field name="incident_initiator_id" ref="hr.employee_ngh"/>
        <field name="incident_receptor_id" ref="hr.employee_admin"/>
    </record>
</odoo>