<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="ir_model_filters_view_tree" model="ir.ui.view">
        <field name="name">ir.model.filters.view.tree</field>
        <field name="model">ir.model.filters</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="string"/>
                <field name="is_group_by"/>
                <field name="model_id"  context="{'model': True}"/>
            </tree>
        </field>
    </record>

      <record id="action_ir_model_filters" model="ir.actions.act_window">
        <field name="name">Filters</field>
        <field name="res_model">ir.model.filters</field>
        <field name="view_mode">tree</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face"></p>
        </field>
      </record>
</odoo>
