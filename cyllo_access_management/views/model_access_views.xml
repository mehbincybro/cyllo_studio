<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="model_access_view_tree" model="ir.ui.view">
        <field name="name">model.access.view.tree</field>
        <field name="model">model.access</field>
        <field name="arch" type="xml">
            <tree editable="top">
                <field name="profile_management_id"/>
                <field name="model_id"  context="{'model': True}"/>
                <field name="is_readonly"/>
                <field name="hide_create"/>
                <field name="hide_edit"/>
                <field name="hide_delete"/>
                <field name="hide_archive"/>
                <field name="hide_duplicate"/>
                <field name="hide_export"/>
                <field name="hide_reports"/>
                <field name="hide_actions"/>
             </tree>
        </field>
    </record>

      <record id="action_model_access" model="ir.actions.act_window">
        <field name="name">Model Access</field>
        <field name="res_model">model.access</field>
        <field name="view_mode">tree</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face"></p>
        </field>
      </record>
</odoo>
