<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
<record id="res_users_user_profile_view_form" model="ir.ui.view">
        <field name="name">res.users.view.form.inherit.user.profile</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
                <xpath expr="//div[hasclass('oe_title')]"  position="after">
                    <group>
                        <field name="profile_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
                    </group>
            </xpath>
        </field>
</record>
</odoo>
