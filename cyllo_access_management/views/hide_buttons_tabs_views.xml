<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="hide_buttons_tabs_view_tree" model="ir.ui.view">
        <field name="name">hide.buttons.tabs.view.tree</field>
        <field name="model">hide.buttons.tabs</field>
        <field name="arch" type="xml">
            <tree editable="top">
                <field name="profile_management_id"/>
                <field name="model_id"  context="{'model': True}"/>
                <field name="button_ids" widget="many2many_tags"/>
                <field name="tab_ids" widget="many2many_tags"/>
             </tree>
        </field>
    </record>

      <record id="action_hide_buttons_tabs" model="ir.actions.act_window">
        <field name="name">Hide Buttons Tabs</field>
        <field name="res_model">hide.buttons.tabs</field>
        <field name="view_mode">tree</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face"></p>
        </field>
      </record>
</odoo>
