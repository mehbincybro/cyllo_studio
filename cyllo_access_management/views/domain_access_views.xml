<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="domain_access_view_form" model="ir.ui.view">
        <field name="name">domain.access.view.form</field>
        <field name="model">domain.access</field>
        <field name="arch" type="xml">
            <form>
                <group>
                        <field name="model_id" context="{'model': True}"/>
                        <field name="model_name" invisible="1"/>
                        <field name="domain" widget="domain" options="{'model': 'model_name'}"/>
                </group>
            </form>
        </field>
    </record>

      <record id="action_domain_access" model="ir.actions.act_window">
        <field name="name">Domain Access</field>
        <field name="res_model">domain.access</field>
        <field name="view_mode">tree</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face"></p>
        </field>
      </record>
</odoo>
