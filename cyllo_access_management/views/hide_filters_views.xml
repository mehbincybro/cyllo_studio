<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="hide_filters_view_tree" model="ir.ui.view">
        <field name="name">hide.filters.view.tree</field>
        <field name="model">hide.filters</field>
        <field name="arch" type="xml">
            <tree editable="top">
                <field name="profile_management_id"/>
                <field name="model_id"  context="{'model': True}"/>
                <field name="filter_ids" widget="many2many_tags"/>
                <field name="group_ids" widget="many2many_tags"/>
             </tree>
        </field>
    </record>

      <record id="action_hide_filters" model="ir.actions.act_window">
        <field name="name">Hide Filters</field>
        <field name="res_model">hide.filters</field>
        <field name="view_mode">tree</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face"></p>
        </field>
      </record>
</odoo>
