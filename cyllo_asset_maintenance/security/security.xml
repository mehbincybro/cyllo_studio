<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <record model="ir.module.category" id="module_category_asset_maintenance">
         <field name="name">Asset Maintenance</field>
        <field name="description">Helps you handle your accounting needs, if you are not an accountant, we suggest you to install only the Invoicing.</field>
        <field name="sequence">26</field>
    </record>

<!--    Asset Maintenance User Group-->
    <record id="group_cyllo_asset_maintenance" model="res.groups">
        <field name="name">Asset Maintenance User</field>
        <field name="category_id" ref="cyllo_asset_maintenance.module_category_asset_maintenance"/>
        <field name="implied_ids" eval="[Command.link(ref('account.group_account_invoice'))]"/>
        <field name="users" eval="[Command.link(ref('base.user_root')), Command.link( ref('base.user_admin'))]"/>
    </record>
    <!--Record Rule for Admin-->
    <record id="rule_account_asset_maintenance_all_public" model="ir.rule">
        <field name="name">View All Asset Maintenance</field>
        <field name="model_id" ref="model_account_asset_maintenance"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[Command.link(ref('account.group_account_manager'))]"/>
    </record>
    <!--Record Rule for User-->
    <record id="rule_account_asset_maintenance_user_public" model="ir.rule">
        <field name="name">Asset Maintenance User</field>
        <field name="model_id" ref="model_account_asset_maintenance"/>
        <field name="domain_force">['|', ('user_id', '=', user.id), ('employee_id.user_id', '=', user.id)]</field>
        <field name="groups" eval="[Command.link(ref('cyllo_asset_maintenance.group_cyllo_asset_maintenance'))]"/>
    </record>
</odoo>