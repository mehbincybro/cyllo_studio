<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!--    Tree view for the asset maintenance-->
    <record id="view_account_asset_maintenance_tree" model="ir.ui.view">
        <field name="name">account.asset.maintenance.view.tree</field>
        <field name="model">account.asset.maintenance</field>
        <field name="arch" type="xml">
            <tree>
                <field name="asset_id"/>
                <field name="scheduled_date"/>
                <field name="user_id"/>
                <field name="status"/>
            </tree>
        </field>
    </record>
    <!--    Search view for the asset maintenance-->
    <record id="view_account_asset_maintenance_search" model="ir.ui.view">
        <field name="name">account.asset.maintenance.view.search</field>
        <field name="model">account.asset.maintenance</field>
        <field name="arch" type="xml">
            <search string="Assets">
                <field name="asset_id"/>
                <field name="issue"/>
                <field name="asset_type_id"/>
                <field name="asset_item_id"/>
                <field name="employee_id"/>
                <filter name="archived" string="Archived" domain="[('active', '=', False)]"/>
                <filter name="new" string="New" domain="[('status', '=', 'new')]"/>
                <filter name="confirm" string="Confirm" domain="[('status', '=', 'confirm')]"/>
                <filter name="ongoing" string="Ongoing" domain="[('status', '=', 'ongoing')]"/>
                <filter name="done" string="Done" domain="[('status', '=', 'done')]"/>
                <filter name="scrap" string="Scarp" domain="[('status', '=', 'scrap')]"/>
                <group expand="0" string="Group By...">
                    <filter string="Status" name="status" domain="[]" context="{'group_by':'status'}"/>
                    <filter string="Responsible User" name="responsible_user" domain="[]"
                            context="{'group_by':'user_id'}"/>
                    <filter string="Employee" name="employee" domain="[]" context="{'group_by':'employee_id'}"/>
                </group>
            </search>
        </field>
    </record>
    <!--    Form view for the asset maintenance-->
    <record id="view_account_asset_maintenance_form" model="ir.ui.view">
        <field name="name">account.asset.maintenance.view.form</field>
        <field name="model">account.asset.maintenance</field>
        <field name="arch" type="xml">
            <form string="Asset">
                <header>
                    <field name="status" widget="statusbar"
                           statusbar_visible="new,confirm"/>
                    <button type="object" name="action_confirm" string="Confirm" class="oe_highlight"
                            invisible="status != 'new'"/>
                    <button type="object" name="action_start_maintenance" string="Start Maintenance"
                            class="oe_highlight"
                            invisible="status != 'confirm'"/>
                    <button type="object" name="action_done" string="Done" class="oe_highlight"
                            invisible="status != 'ongoing'"/>
                    <button type="object" name="action_scraped" string="Scrap" class="btn-secondary"
                            invisible="status != 'ongoing'"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <span class="o_form_label">Asset Maintenance</span>
                        <h1>
                            <field name="reference"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="issue"/>
                            <field name="asset_id"
                                   domain="[('is_maintenance','=', False), ('is_repair','=', False), ('status', 'not in', ('sell', 'disposed', 'cancel', 'lost'))]"
                                   readonly="status not in ('new, confirm')"/>
                            <field name="asset_item_id" readonly="status not in ('new, confirm')"/>
                            <field name="asset_type_id" readonly="status not in ('new, confirm')"/>
                            <field name="company_id" readonly="status not in ('new, confirm')"/>
                            <label for="under_warranty" name="warranty_period" string="Under Warranty"/>
                            <div class="o_row">
                                <field name="under_warranty" style="width:25% !important;"/>
                                <label for="warranty_percentage" name="warranty_percentage"
                                       string="Deduction %" invisible="not under_warranty"/>
                                <field name="warranty_percentage" invisible="not under_warranty"/>
                            </div>
                        </group>
                        <group>
                            <field name="date" readonly="status not in ('new, confirm')"/>
                            <field name="employee_id" readonly="status not in ('new, confirm')"/>
                            <field name="department_id" readonly="status not in ('new, confirm')"/>
                            <field name="user_id" readonly="status not in ('new, confirm')"
                                   options="{'no_create': True, 'no_create_edit': True}"/>
                            <field name="scheduled_date" readonly="status not in ('new, confirm') or not asset_id"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="is_scrap" invisible="1"/>
                        </group>
                    </group>
                </sheet>
                <!-- Chatter -->
                <div class="oe_chatter">
                    <field name="message_follower_ids" groups="base.group_user"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>
    <!--    Action for the asset maintenance-->
    <record id="action_view_account_asset_maintenance" model="ir.actions.act_window">
        <field name="name">Asset Maintenance</field>
        <field name="res_model">account.asset.maintenance</field>
        <field name="view_mode">tree,form</field>
    </record>
    <!--    Menuitem for the asset maintenance-->
    <menuitem id="menu_cyllo_asset_maintenance_root" name="Asset Maintenance"
              sequence="10" web_icon="cyllo_asset_maintenance,static/description/asset-maintanence.svg"/>
    <!--    SubMenuitem for the asset maintenance-->
    <menuitem id="menu_assets" name="Asset Maintenance"
              parent="cyllo_asset_maintenance.menu_cyllo_asset_maintenance_root"
              action="action_view_account_asset_maintenance"
              sequence="10"/>
</odoo>
