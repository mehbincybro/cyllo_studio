<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- This record defines the views for social media feed. -->
    <record id="view_social_media_feed_kanban" model="ir.ui.view">
        <field name="name">view.social.media.feed.kanban</field>
        <field name="model">social.media.feed</field>
        <field name="arch" type="xml">
            <kanban create="0">
                <field name="id"/>
                <field name="description"/>
                <field name="author_name"/>
                <field name="posted_date"/>
                <templates>
                    <t t-name="kanban-box">
                        <div>
                            <div class="oe_kanban_details" style="height:auto;">
                                <div class="container">
                                    <div class="column">
                                        <field name="profile_image"/>
                                    </div>
                                    <div class="column">
                                        <field name="author_link"/>
                                    </div>
                                    <div class="column">
                                        <field name="posted_date"/>
                                    </div>
                                    <div class="column">
                                        <field name="company_id" invisible="1"/>
                                    </div>
                                    <br/>
                                    <t t-if="record.posted_image">
                                        <field name="posted_image"/>
                                    </t>
                                </div>
                                <br/>
                                <t t-if="record.posted_image">
                                    <div class="line" style="border-bottom: 1px solid black;"/>
                                    <button type="object" name="action_social_media_comments" class="fa fa-comments" style='font-size:36px' title="Comments">
                                        <field name="comments_count" style="padding:3px;"/>
                                    </button>
                                    <i class="fa fa-heart" title="Likes"/>
                                    <field name="likes_count" style="padding:3px;"/>
                                </t>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>
    <record id="action_view_social_media_feed" model="ir.actions.act_window">
        <field name="name">Feeds</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">social.media.feed</field>
        <field name="view_mode">kanban,tree</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
            </p>
        </field>
    </record>
</odoo>