<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="stock_move_line_tree_view_warranty" model="ir.ui.view">
        <field name="name">stock.move.line.tree.warranty</field>
        <field name="model">stock.move.line</field>
        <field name="inherit_id" ref="stock.view_move_line_tree"/>
        <field name="arch" type="xml">
            <field name="state" position="before">
                <field name="warranty_expiration_date"
                       optional="show"/>
            </field>
        </field>
    </record>

    <record id="stock_move_line_tree_detailed_view_warranty" model="ir.ui.view">
        <field name="name">stock.move.line.tree.detailed.warranty</field>
        <field name="model">stock.move.line</field>
        <field name="inherit_id" ref="stock.view_move_line_tree_detailed"/>
        <field name="arch" type="xml">
            <field name="state" position="before">
                <field name="warranty_expiration_date"
                       optional="show"/>
            </field>
        </field>
    </record>

    <record id="stock_move_line_form_view_warranty" model="ir.ui.view">
        <field name="name">stock.move.line.form.warranty</field>
        <field name="model">stock.move.line</field>
        <field name="inherit_id" ref="stock.view_move_line_form"/>
        <field name="arch" type="xml">
            <field name="origin" position="after">
                <field name="warranty_expiration_date"/>
            </field>
        </field>
    </record>
</odoo>
