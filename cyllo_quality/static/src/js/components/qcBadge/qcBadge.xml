<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

        <t t-name="QcBadgeField">
        <span t-if="props.record.data[props.name] and !state.isBus" class="badge rounded-pill" t-att-class="classFromDecoration" t-esc="formattedValue" />
        <span t-elif="state.isBus and state.value" class="badge rounded-pill" t-att-class="classFromDecorationBus" t-esc="state.value" />
    </t>

</templates>
