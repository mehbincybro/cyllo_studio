<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="ValidateQualityAction">
         <Dialog footer="false" contentClass="'quality-action-container'" size="'md'">
             <t t-set-slot="header">
                 <h4 class="modal-title text-break" t-att-class="{ 'me-auto': fullscreen }">
                    <t t-esc="props.title"/>
                </h4>
                 <button class="btn-close" data-bs-dismiss="modal" aria-label="Close"
                         t-on-click.stop="handleModalClose"/>
             </t>
             <div class="alert alert-warning m-2" role="alert" t-if="state.isBlocked">
                 <i class="ri-error-warning-line me-2"/>
                 This action is blocked by <b><t t-esc="state.blockerName"/></b>. Please complete it first.
             </div>
             <div class="quality-action-body w-80">
                <div class="quality-detail d-flex ms-2 justify-content-between align-items-center"
                     style="margin-left: 10px;">
                    <div class="qc-detail">
                        <t t-log="props,'props'"/>
                        <p class="text-muted mb-2">Quality Control Point: <b><t t-esc="props.quality_check.quality_control_id[1]"/></b></p>
                        <p class="text-muted mb-2">Quality Check: <b><t t-esc="props.quality_check_action.quality_check_id[1]"/></b></p>
                    </div>
                    <div class="qc-team-user">
                        <p class="text-muted mb-2">Quality Team: <b><t t-esc="props.quality_check.quality_team_id"/></b></p>
                        <p class="text-muted mb-2">Responsible User: <b><t t-esc="props.quality_check.user_id"/></b></p>
                    </div>
                </div>
                 <div t-ref="qcInstruction" class="action-instruction" t-if="props.quality_check_action.instruction">
                    <h5 class="text-muted mb-2" style="margin-left: 10px;">Instructions for the Quality Check</h5>
                     <div class="quality-check-instruction mb-3">
                        <div class="form-group d-flex gap-2">
                                <t t-out="getInstruction"/>
                        </div>
                    </div>
                 </div>
                 <div class="quality-type d-flex justify-content-between align-items-center">
                     <div class="d-flex align-items-center gap-2 text-center"
                          t-if="props.quality_check_action.inspection_type_id[1] == 'Measure'">
                        <h6 class="text-muted mb-0 check-type">Add Measurement :</h6>
                         <input type="text" class="form-control w-50 check-value" placeholder="Enter the value..."
                                t-model='state.qcValue'/>
                         <t t-if="props.quality_check_action.unit_id" t-esc="props.quality_check_action.unit_id[1]"/>
                         <t t-elif="props.quality_check_action.unit_value and props.quality_check_action.unit_value.unit" t-esc="props.quality_check_action.unit_value.unit['name']"/>
                         <span class="ms-2 text-muted" t-if="props.quality_check_action.measure_start or props.quality_check_action.measure_end">
                             [<t t-esc="props.quality_check_action.measure_start"/> - <t t-esc="props.quality_check_action.measure_end"/>]
                         </span>
                     </div>
                     <div class="d-flex align-items-center gap-2 text-center"
                          t-if="props.quality_check_action.inspection_type_id[1] == 'Take a picture'">
                        <h6 class="text-muted mb-0 check-type">Add Image :</h6>
                         <input type="file" class="image-uploader check-value" accept="image/*" t-on-change="onImageChange"/>

                     </div>
                     <div class="d-flex align-items-center gap-2 text-center"
                          t-if="props.quality_check_action.inspection_type_id[1] == 'Instructions'">
                        <h6 class="text-muted mb-0 check-type">Add Instruction :</h6>
                         <input type="text" class="o_input w-50  check-value" t-model="state.qcValue" placeholder="Enter the value..."/>
                     </div>
                     <div class="add_notes" t-if="!state.addNote">
                        <button class="btn btn-outline-primary me-2" t-on-click="addNote">
                           <i class="ri-add-line"/>
                            Add Note
                        </button>
                     </div>
                 </div>
                 <div t-if="state.addNote">
                    <textarea t-model="state.qualityCheckNote" class="form-control my-2" placeholder="Add your note"/>
                 </div>
             </div>
             <div class="qc-footer">
                <hr/>
                  <div class="d-flex"
                       t-if="props.quality_check_action.inspection_type_id[1] == 'Pass/Fail' or props.quality_check_action.inspection_type_id[1] == 'Take a picture'">
                        <button class="btn btn-success me-2" t-on-click="passCheck" t-att-disabled="state.isBlocked">Pass</button>
                     <button class="btn btn-danger me-2" t-on-click="failCheck" t-att-disabled="state.isBlocked">Fail</button>
                  </div>
                  <div t-if="props.quality_check_action.inspection_type_id[1] == 'Measure' or props.quality_check_action.inspection_type_id[1] == 'Instructions'">
                      <button class="btn btn-primary mt-3 mb-3"
                              t-on-click="validateQualityCheck" t-att-disabled="state.isBlocked">Validate Quality Check</button>
                  </div>
             </div>
         </Dialog>
    </t>
</templates>