<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="cyllo_quality.InstructionDialog" owl="1">
        <Dialog title="title"
                size="'medium'"
                footer="false">
            <div class="p-3 quality-instruction-editor">
                <div class="form-group">
                    <label t-if="!state.readonly" for="instruction" class="form-label">Instruction</label>
                    <textarea id="instruction" class="form-control" rows="10" t-model="state.instruction" t-att-readonly="state.readonly" placeholder="Enter instructions here..."/>
                </div>
                <div class="modal-footer justify-content-end mt-3">
                    <button class="btn btn-secondary" t-on-click="cancel">
                        <t t-if="state.readonly">Close</t>
                        <t t-else="">Cancel</t>
                    </button>
                    <button t-if="!state.readonly" class="btn btn-primary" t-on-click="onSave">
                        Save
                    </button>
                </div>
            </div>
        </Dialog>
    </t>
</templates>