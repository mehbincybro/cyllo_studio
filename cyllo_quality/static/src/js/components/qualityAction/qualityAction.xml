<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <t t-name="QualityAction">
       <div class="quality-card mb-2" t-att-class="state.isPass !== undefined ? (state.isPass ? 'qc_pass' : 'qc_fail') : ''" t-on-click="onClickQualityAction">
           <h4><t t-out="props.action.inspection_action_id[1]"/></h4>
           <p><t t-out="props.action.quality_check_id[1]"/></p>
       </div>
    </t>
</templates>