<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <t t-name="QualityCheck">
    <div t-ref="root" class="quality_container-main d-flex" t-att-class="{ 'is_inactive' : !state.isActive }">
        <t t-if="state.qualityActions.length">
            <div class="position-relative">
        </div>
            <div class="w-100">
           <h3><b>Quality Check Actions</b></h3>
                <div class="action-container">
                <t t-foreach="state.qualityActions" t-as="qc_action" t-key="qc_action_index">
                    <t t-foreach="qc_action.quality_check_line_ids" t-as="action" t-key="action_index">
                      <QualityAction action="action" quality_check="qc_action"
                                     handleModalToggle.bind="handleModalToggle"/>
                    </t>
                </t>
           </div>
        </div>
        </t>
       </div>
    </t>
</templates>