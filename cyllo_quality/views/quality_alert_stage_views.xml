<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!--    Tree view of the Quality Alert Stages-->
    <record id="view_quality_alert_stage_tree" model="ir.ui.view">
        <field name="name">view.quality.alert.stage.tree</field>
        <field name="model">quality.alert.stage</field>
        <field name="arch" type="xml">
            <tree editable="bottom">
                <field name="name"/>
            </tree>
        </field>
    </record>
    <!-- Action -->
    <record id="action_view_quality_alert_stages" model="ir.actions.act_window">
        <field name="name">Quality Alert Stages</field>
        <field name="res_model">quality.alert.stage</field>
        <field name="view_mode">tree</field>
    </record>
    <!--    MenuItem of the Quality Alert Stages-->
    <menuitem id="menu_quality_alert_stages"
              name="Quality Alert Stages"
              action="action_view_quality_alert_stages"
              parent="cyllo_quality.menu_configuration_categ"
              sequence="20"/>
</odoo>