<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Form View -->
    <record id="view_quality_team_form" model="ir.ui.view">
        <field name="name">view.quality.team.form</field>
        <field name="model">quality.team</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
<!--                    <div class="oe_button_box" name="button_box">-->
<!--                                            <button name="action_view_quality_checks" type="object" class="oe_stat_button" icon="fa-check-square-o">-->
<!--                                                <field name="quality_check_count" widget="statinfo" string="Quality Checks"/>-->
<!--                                            </button>-->
<!--                                            <button name="action_view_quality_alerts" type="object" class="oe_stat_button" icon="fa-warning">-->
<!--                                                <field name="quality_alert_count" widget="statinfo" string="Quality Alerts"/>-->
<!--                                            </button>-->
<!--                    </div>-->
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1>
                            <field name="name" placeholder="Quality Team Name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="leader_id" widget="many2one_avatar_user"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group>
                            <field name="is_mail" widget="boolean_toggle"/>

                        </group>
                    </group>
                    <notebook>
                        <page string="Team Members" name="members">
                            <field name="member_ids">
                                <tree>
                                    <field name="name"/>
                                    <field name="job_title"/>
                                    <field name="department_id"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" groups="base.group_user"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_view_quality_teams" model="ir.actions.act_window">
        <field name="name">Quality Teams</field>
        <field name="res_model">quality.team</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="xml">
            <p class="o_view_nocontent_smiling_face">
                Create your first Quality Team!
            </p>
        </field>
    </record>

    <!-- Menu Item -->
    <menuitem id="menu_quality_teams"
              name="Quality Teams"
              action="action_view_quality_teams"
              parent="cyllo_quality.menu_configuration_categ"
              sequence="10"
    />
</odoo>