<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!--    Tree view of the Inspection Actions-->
    <record id="view_inspection_action_tree" model="ir.ui.view">
        <field name="name">view.inspection.action.tree</field>
        <field name="model">inspection.action</field>
        <field name="arch" type="xml">
            <tree editable="bottom">
                <field name="name"/>
            </tree>
        </field>
    </record>
    <!-- Action -->
    <record id="action_view_inspection_actions" model="ir.actions.act_window">
        <field name="name">Inspection Actions</field>
        <field name="res_model">inspection.action</field>
        <field name="view_mode">tree</field>
    </record>
    <!-- Menu Item -->
    <menuitem id="menu_inspection_actions"
              name="Inspection Actions"
              action="action_view_inspection_actions"
              parent="cyllo_quality.menu_configuration_categ"
              sequence="11"
    />
</odoo>