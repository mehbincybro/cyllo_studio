<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!--    Form for the Alert Warning-->
    <record id="view_alert_warning_form" model="ir.ui.view">
        <field name="name">view.alert.warning.form</field>
        <field name="model">alert.warning</field>
        <field name="arch" type="xml">
            <form string="Instructions">
                <sheet>
                    <field name="quality_check_id" invisible="1"/>
                    <field name="quality_check_line_id" invisible="1"/>
                    <span>Are you sure to create quality alert for the quality check?</span>
                    <br/>
                    <br/>
                    <group>
                        <field name="failure_location_id"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_create_alert" type="object" string="Create"
                            class="btn-primary"/>
                </footer>
            </form>
        </field>
    </record>
    <!--Action for Alert Warning-->
    <record id="action_view_warning_qc" model="ir.actions.act_window">
        <field name="name">Create Alert</field>
        <field name="res_model">alert.warning</field>
        <field name="view_mode">form</field>
    </record>
</odoo>