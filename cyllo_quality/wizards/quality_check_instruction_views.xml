<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!--    Form for the quality check instruction-->
    <record id="view_quality_check_instruction_form" model="ir.ui.view">
        <field name="name">view.quality.check.instruction.form</field>
        <field name="model">quality.check.instruction</field>
        <field name="arch" type="xml">
            <form string="Instructions">
                <sheet>
                    <group>
                        <field name="inspection_id" invisible="1"/>
                        <field name="instruction"/>
                    </group>
                    <group>

                    </group>
                </sheet>
                <footer>
                    <button name="action_add_instruction" type="object" string="Add Instruction"
                            class="btn-primary"/>
                </footer>
            </form>
        </field>
    </record>
    <!--Action for quality check instruction-->
    <record id="action_view_instructions" model="ir.actions.act_window">
        <field name="name">Add Instructions</field>
        <field name="res_model">quality.check.instruction</field>
        <field name="view_mode">form</field>
    </record>
</odoo>