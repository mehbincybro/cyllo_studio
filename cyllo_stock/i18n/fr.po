msgstr "Créer automatiquement une facture fournisseur à partir de la facture client intersociétés correspondante."

#. module: cyllo_stock
#: model_terms:ir.ui.view,arch_db:cyllo_stock.res_config_settings_view_form_cyllo_stock
msgid "Create a corresponding Sales Order for confirmed intercompany Purchase Orders."
msgstr "Créer automatiquement une commande client correspondante pour les commandes fournisseurs intersociétés confirmées."

#. module: cyllo_stock
#: model_terms:ir.ui.view,arch_db:cyllo_stock.res_config_settings_view_form_cyllo_stock
msgid "Create a corresponding Purchase Order for confirmed intercompany Sales Orders."
msgstr "Créer automatiquement une commande fournisseur correspondante pour les commandes clients intersociétés confirmées."

#. module: cyllo_stock
#: model_terms:ir.ui.view,arch_db:cyllo_stock.res_config_settings_view_form_cyllo_stock
msgid "Synchronize intercompany deliveries and receipts."
