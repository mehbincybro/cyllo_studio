<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Form view for SMS Gateway Configuration -->
    <record id="view_sms_gateway_config_form" model="ir.ui.view">
        <field name="name">view.sms.gateway.config.form</field>
        <field name="model">sms.gateway.config</field>
        <field name="arch" type="xml">
            <form create="false" delete="false"
                  string="SMS Gateway Configuration">
                <header>
                    <button name="action_test_connection" type="object"
                            string="Test Connection"
                            invisible="is_active == False"
                            class="oe_highlight"/>
                    <button name="action_activate" type="object"
                            string="Activate"
                            invisible="is_active == True"
                            class="oe_highlight"/>
                            <button name="action_deactivate" type="object"
                            string="Deactivate"
                            invisible="is_active == False"
                            class="oe_highlight"/>
                </header>
                <sheet>
                    <field name="company_id" invisible="1"/>
                    <field name="image_128" widget='image'
                           class="oe_avatar"/>
                    <widget name="web_ribbon" title="Disabled"
                            bg_color="text-bg-danger"
                            invisible="is_active == True"/>
                    <group>
                        <field name="is_active" invisible="1"/>
                        <h1>
                            <field name="name" placeholder="Name"/>
                        </h1>
                    </group>
                    <notebook>
                        <page string="General">
                            <group>
                                <!-- Credentials for Twilio -->
                                <group string="Twilio Credentials"
                                       invisible="name != 'TWILIO'">
                                    <field name="twilio_account_sid"
                                           required="1" password="True"
                                           invisible="name != 'TWILIO'"/>
                                    <field name="twilio_auth_token"
                                           password="True" required="1"
                                           invisible="name != 'TWILIO'"/>
                                    <field name="twilio_phone_number"
                                           required="1"
                                           invisible="name != 'TWILIO'"/>
                                </group>
                                <!-- Credentials for d7 -->
                                <group string="d7 Credentials"
                                       invisible="name != 'D7'">
                                    <field name="d7_api" required="1"
                                           password="True" force_save="1"
                                           invisible="name != 'D7'"/>
                                </group>
                                <!-- Credentials for Click send-->
                                <group string="Click Send Credentials"
                                       invisible="name != 'CLICK SEND'">
                                    <field name="click_send_email" required="1"
                                           invisible="name != 'CLICK SEND'"/>
                                    <field name="click_send_api" password="True"
                                           required="1"
                                           invisible="name != 'CLICK SEND'"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
    <!-- Tree view for SMS Gateway Configuration -->
    <record id="view_sms_gateway_config_kanban" model="ir.ui.view">
        <field name="name">view.sms.gateway.config.kanban</field>
        <field name="model">sms.gateway.config</field>
        <field name="arch" type="xml">
            <kanban create="false" edit="false" delete="false">
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="#{oe_kanban_card oe_kanban_global_click">
                            <div class="o_kanban_record_top mb16 gap-2 d-flex">
                                <img type="open"
                                     t-att-src="kanban_image('sms.gateway.config', 'image_128', record.id.raw_value)"
                                     class="mb-0 o_image_64_max"
                                     alt="provider"/>
                                <div class="d-flex flex-column justify-content-between w-100">
                                    <strong class="o_kanban_record_title">
                                        <widget name="web_ribbon"
                                                title="Enabled"
                                                bg_color="text-bg-success"
                                                invisible="is_active == False"/>
                                        <widget name="web_ribbon"
                                                title="Disabled"
                                                bg_color="text-bg-danger"
                                                invisible="is_active == True"/>
                                        <field name="name"/>
                                        <field name="is_active" invisible="1"/>
                                    </strong>
                                </div>
                            </div>
                            <div class="o_payment_kanban_button text-end">
                                <button string="Activate"
                                        invisible="is_active == True"
                                        class="oe_highlight"/>
                                <button name="action_deactivate" type="object"
                                        string="Deactivate"
                                        invisible="is_active == False"
                                        class="oe_highlight"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>
    <!-- Window action for SMS Gateway Configuration -->
    <record id="action_view_sms_gateway_config" model="ir.actions.act_window">
        <field name="name">SMS Gateway Configuration</field>
        <field name="res_model">sms.gateway.config</field>
        <field name="view_mode">kanban,form</field>
    </record>
</odoo>
