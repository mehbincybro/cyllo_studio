<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!-- Modify the form view website-->
    <record id="view_website_form" model="ir.ui.view">
        <field name="name">view.website.form</field>
        <field name="model">website</field>
        <field name="inherit_id" ref="website.view_website_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='language_ids']" position="after">
                <field name="is_active_sms"/>
                <field name="gateway_id" invisible="not is_active_sms" options="{'no_create': True}"/>
            </xpath>
        </field>
    </record>
</odoo>
