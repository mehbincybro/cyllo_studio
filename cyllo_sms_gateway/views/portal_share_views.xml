<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Customizing the portal.share view form -->
    <record id="view_portal_share_from" model="ir.ui.view">
        <field name="name">view.portal.share.</field>
        <field name="model">portal.share</field>
        <field name="inherit_id" ref="portal.portal_share_wizard"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='action_send_mail']" position="after">
                <button name="action_send_sms" string="Send as sms" type="object" class="btn-primary"/>
            </xpath>
            <xpath expr="//field[@name='partner_ids']" position="after">
                <field name="partner_phone" readonly="1"/>
                <field name="sms_gateway_config_id" widget="image_badge"
                       options="{'horizontal': true',no_create': 1, 'no_edit': 1}"/>
            </xpath>
        </field>
    </record>
</odoo>
