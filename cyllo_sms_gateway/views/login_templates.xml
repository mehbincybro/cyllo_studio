<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!--calling the controller of scanner from login page-->
    <template id="otp_login" inherit_id="web.login" name="OTP Login">
        <xpath expr="//button[hasclass('cy-auth__btn')]" position="after">
            <div class="justify-content-between mt-2 d-flex small">
                <a t-if="is_active_sms" href="/web/otp/login">Login With OTP</a>
            </div>
        </xpath>
    </template>
</odoo>
