<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Form view for SMS History -->
    <record id="view_sms_history_form" model="ir.ui.view">
        <field name="name">view.sms.history.form</field>
        <field name="model">sms.history</field>
        <field name="arch" type="xml">
            <form string="SMS History">
                <sheet>
                    <group>
                        <group>
                            <field name="user_id"/>
                            <field name="sms_gateway_id"/>
                            <field name="sms_date"/>
                        </group>
                        <group>
                            <field name="sms_mobile"/>
                            <field name="sms_status"/>
                        </group>
                        <field name="sms_text"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <!-- Tree view for SMS History -->
    <record id="view_sms_history_tree" model="ir.ui.view">
        <field name="name">view.sms.history.tree</field>
        <field name="model">sms.history</field>
        <field name="arch" type="xml">
            <tree create="0">
                <field name="sms_gateway_id"/>
                <field name="sms_date"/>
                <field name="sms_text"/>
                <field name="sms_mobile"/>
                <field name="sms_status"/>
            </tree>
        </field>
    </record>
    <!-- Window action for SMS History -->
    <record id="action_view_sms_history" model="ir.actions.act_window">
        <field name="name">SMS History</field>
        <field name="res_model">sms.history</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No History.
            </p>
        </field>
    </record>
</odoo>
