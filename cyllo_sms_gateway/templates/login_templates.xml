<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!--calling the controller of scanner from login page-->
    <template id="otp_login" inherit_id="web.login" name="OTP Login">
        <xpath expr="//a[contains(text(),'Forgot Password?')]" position="after">
            <a t-if="is_active_sms" href="/web/otp/login"
               class="click">Login with OTP
            </a>
        </xpath>
    </template>
</odoo>
