<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!--calling the controller of scanner from login page-->
    <template id="verify_otp" name="OTP Login">
        <t t-call="web.login_layout">
            <form class="oe_login_form" role="form"
                  t-attf-action="/web/login/verify_otp"
                  method="post">
                <p class="alert alert-success" t-if="otp_success" role="alert">
                    <t t-esc="otp_success"/>
                </p>
                <div class="mb-3 field-login">
                    <label for="otp" class="form-label">OTP</label>
                    <input type="otp" placeholder="Enter OTP" name="otp"
                           t-att-value="otp" id="otp"
                           t-attf-class="form-control #{'form-control-sm' if form_small else ''}"
                           required="required" autofocus="autofocus"
                           autocapitalize="off"/>
                </div>
                <p class="alert alert-danger" t-if="error" role="alert">
                    <t t-esc="error"/>
                </p>
                <div t-attf-class="clearfix oe_login_buttons text-center gap-1 d-grid mb-1 {{'pt-2' if form_small else 'pt-3'}}">
                    <button type="submit" class="btn btn-primary">Login
                    </button>
                </div>
                <a href="/web/login">Login with password</a>
            </form>
        </t>
    </template>
</odoo>
