<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <!-- Template for ImageBadge component -->
    <div t-name="cyllo_sms_gateway.ImageBadge" class="d-flex flex-wrap gap-1 mb-3">
        <t t-if="props.readonly">
            <span t-esc="string" t-att-raw-value="value"/>
        </t>
        <t t-else="">
            <t t-foreach="options" t-as="option" t-key="option[0]">
                <t t-foreach="image" t-as="img" t-key="img['id']">
                    <t t-if="option[0] == img['id']">
                        <img class="o_image_badge cy_provider_badge btn btn-secondary mb-1"
                             style="max-width: 15%;max-height: 19%;"
                             t-att-class="{ active: value === option[0] }"
                             t-att-src="'data:image/png;base64,' + img['image_128'].toString('base64')"
                             t-att-value="stringify(option[0])"
                             t-on-click="() => this.onChange(option[0])"/>
                    </t>
                </t>
            </t>
        </t>
    </div>
</templates>
