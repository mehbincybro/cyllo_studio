<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
     <!-- Define the SendSMS component using the Owl notation -->
    <t t-name="SendSMS" owl="1">
        <div class="cy-systray-parent-class" t-on-click="onClickAction">
            <div>
                <i class="ri-chat-4-line cy-icons cy-stray-icon-sp" role="img"/>
            </div>
            <span t-if="props.nameShow" class="cy-systray-label">
                Sms Gateway
            </span>
        </div>
    </t>
</templates>
