<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Inject Field Service toggle into Project Settings tab -->
    <record id="project_project_view_form_fsm" model="ir.ui.view">
        <field name="name">project.project.view.form.inherit.cyllo.project.base.fsm</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.edit_project"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='settings']//group[@name='group_tasks_managment']/div" position="inside">
                <setting id="field_service_setting" help="Manage tasks in the Field Service module">
                    <field name="is_fsm"/>
                </setting>
            </xpath>
        </field>
    </record>
</odoo>