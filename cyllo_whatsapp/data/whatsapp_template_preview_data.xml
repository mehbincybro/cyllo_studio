<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!--    Whatsapp template preview -->
    <template id="whatsapp_template_preview_templates" t-name="WhatsApp Template Preview">
        <div class="whatsapp_preview preview">
            <div class="whatsapp_message">
                <div class="p-2 position-relative">
                    <div class="bg-opacity-60" t-if="header_type != 'none' and header_type != 'text'">
                        <div t-attf-class="bg-400 p-4 d-block text-center rounded-2">
                            <a aria-label="Download" download="" t-attf-href="/web/content/#{attachment.id}?download=true">
                                <img t-if="header_type == 'document'" class="m-2 img-fluid" src="cyllo_whatsapp/static/images/pdf.png" t-att-alt="header_type"/>
                                <br/>
                                <span class="text-black" t-out="attachment.name"/>
                            </a>
                            <img t-if="header_type == 'image'" class="m-2 img-fluid" t-attf-src="cyllo_whatsapp/static/images/image.png" t-att-alt="header_type"/>
                        </div>
                    </div>
                    <div t-if="header_type == 'text'">
                        <t t-out="header_text"/>
                    </div>
                    <div class="px-1 mt-2">
                        <t t-out="body"/>
                    </div>
                    <div t-if="footer_text">
                        <span class="whatsapp_footer" t-out="footer_text"/>
                        <span class="mx-3 d-inline-block"/>
                    </div>
                    <span class="whatsapp-foot_time" area-hidden="true">02:00
                    </span>
                </div>
            </div>
        </div>
    </template>
</odoo>