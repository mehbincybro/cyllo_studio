<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!--    Whatsapp template preview -->
    <template id="whatsapp_template_preview_templates"
              t-name="WhatsApp Template Preview">
        <div class="whatsapp_preview preview">
            <div class="whatsapp_message">
                <div class="p-2 position-relative">
                    <div class="bg-opacity-60 preview-img-div"
                         t-if="header_type != 'none' and header_type != 'text'">
                        <img t-if="header_type == 'image'"
                             class="preview-image"
                             t-attf-src="data:image/png;base64,#{attachment.datas}"
                             t-att-alt="header_type"/>
                    </div>
                    <div t-if="header_type == 'text'">
                        <t t-out="header_text"/>
                    </div>
                    <div class="px-1 mt-2">
                        <t t-out="body"/>
                    </div>
                    <div t-if="footer_text">
                        <span class="whatsapp_footer" t-out="footer_text"/>
                        <span class="mx-3 d-inline-block"/>
                    </div>
                    <span class="whatsapp-foot_time" area-hidden="true">02:00
                    </span>
                </div>
                <div t-if="button"
                     style="padding: 0.8rem 0.5rem;text-align: center;border-top: 1px solid #e4e3e3;display: flex;justify-content: center;">
                    <span style="color: #0000EE;">
                        <i class="ri-external-link-line"/><span t-esc="button_name"/>
                    </span>
                </div>
            </div>
        </div>
    </template>
</odoo>