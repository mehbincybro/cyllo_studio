<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Inheriting Employee View  to add smart button for payroll count-->
    <record id="view_portal_share_form" model="ir.ui.view">
        <field name="name">view.portal.share.form</field>
        <field name="model">portal.share</field>
        <field name="inherit_id" ref="portal.portal_share_wizard"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='note']" position="after">
                <field name="share_whatsapp"/>
            </xpath>
        </field>
    </record>
</odoo>