<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!-- Whatsapp template preview form-->
    <record id="view_whatsapp_template_preview_form" model="ir.ui.view">
        <field name="name">view.whatsapp.template.preview.form</field>
        <field name="model">whatsapp.template.preview</field>
        <field name="arch" type="xml">
            <form string="Template Preview">
                <sheet>
                    <field name="wa_template_preview"/>
                    <field name="template_id" invisible="1"/>
                </sheet>
                <footer>
                    <button name="cancel" special="cancel" string="Close" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>