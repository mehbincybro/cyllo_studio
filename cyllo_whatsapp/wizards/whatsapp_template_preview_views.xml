<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!-- Whatsapp template preview form-->
    <record id="view_whatsapp_template_preview_form" model="ir.ui.view">
        <field name="name">view.whatsapp.template.preview.form</field>
        <field name="model">whatsapp.template.preview</field>
        <field name="arch" type="xml">
            <form string="Template Preview">
                <style>
                    .modal-header{
                    border-bottom:0px;
                    }
                    .modal-body{
                        border-radius: 10px;
                    }
                    .o_form_renderer .o_form_sheet_bg{
                    padding:0px
                    }
                    .modal-footer {
                    display:none;
                    }
                    .o-dropdown{
                    display:none; }
                    .o_form_view .o_field_widget {
                    margin-bottom:0px;
                    }
                    .modal-title{
                    display:none; }
                    .modal-content{
                    background-color:transparent;
                    border: 0;}
                    .modal-dialog .modal-content .modal-header {
                    background-color: transparent;
                    }
                    .modal-dialog {
                    height: -1% !important;
                    width: 25% !important;
                    }
                    .o_form_label {
                    padding-bottom: 4px !important;
                    padding-top: 6px !important;
                    }
                    .main-field-toggle .o_wrap_label {
                    width: 60px !important;
                    }
                    .main-field-toggle .o_wrap_input {
                    max-width: 35px !important;
                    padding-top:8px !important;
                    }
                    .o_group_wa {
                    margin-left: 75px;
                    display: inline-flex;
                    }
                    .o_img .img{
                    border-radius: 100px;
                    }
                    .btn-close {
                    opacity:1;
                    background-color:white;
                    }
                </style>
                <sheet>
                    <field name="wa_template_preview"/>
                    <field name="template_id" invisible="1"/>
                </sheet>
            </form>
        </field>
    </record>
</odoo>