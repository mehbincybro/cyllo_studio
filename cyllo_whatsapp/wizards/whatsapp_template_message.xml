<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- XML view definition for the 'whatsapp.template.message' model -->
    <record id="view_whatsapp_template_message_form" model="ir.ui.view">
        <field name="name">view.whatsapp.template.message.form</field>
        <field name="model">whatsapp.template.message</field>
        <field name="arch" type="xml">
            <form string="Share Template">
                <group name="share_link">
                    <field name="partner_id"/>
                    <field name="res_id" invisible="1"/>
                    <field name="model_id" invisible="1"/>
                    <field name="header_type" invisible="1"/>
                    <field name="body"/>
                </group>
                <group>
                    <field name="attachment_id" invisible="header_type not in ['document','image']" readonly="1"/>
                    <field name="wa_template_id"/>
                </group>
                <footer>
                    <button string="Send" name="action_send_template" type="object" class="btn-primary" data-hotkey="q"/>
                    <button string="Cancel" class="btn-default" special="cancel" data-hotkey="x"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>