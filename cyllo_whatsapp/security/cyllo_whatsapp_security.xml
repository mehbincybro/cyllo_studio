<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="rule_whatsapp_template_user_own" model="ir.rule">
        <field name="name">Whatsapp Template - Own Records Only</field>
        <field name="model_id" ref="model_whatsapp_template"/>
        <field name="domain_force">
            [('create_uid', '=', user.id)]
        </field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="rule_whatsapp_channel_user_own" model="ir.rule">
        <field name="name">Whatsapp Channel - Own Records Only</field>
        <field name="model_id" ref="model_whatsapp_channel"/>
        <field name="domain_force">
            [('create_uid', '=', user.id)]
        </field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <!-- Company rule for whatsapp template-->
    <record id="rule_whatsapp_template_company" model="ir.rule">
        <field name="name">Whatsapp Template Multi Company</field>
        <field name="model_id" ref="model_whatsapp_template"/>
        <field name="global" eval="True"/>
        <field name="domain_force">['|', ('company_ids', '=', False),
            ('company_ids', 'in', company_ids)]
        </field>
    </record>

    <!-- Company rule for whatsapp channel-->
    <record id="rule_whatsapp_channel_company" model="ir.rule">
        <field name="name">Whatsapp Channel Multi Company</field>
        <field name="model_id" ref="model_whatsapp_channel"/>
        <field name="global" eval="True"/>
        <field name="domain_force">[('company_id', 'in', company_ids +
            [False])]
        </field>
    </record>
</odoo>