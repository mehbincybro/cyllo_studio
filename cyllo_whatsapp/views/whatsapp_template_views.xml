<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!--  Whatsapp template form view  -->
    <record id="view_whatsapp_template_form" model="ir.ui.view">
        <field name="name">view.whatsapp.template.form</field>
        <field name="model">whatsapp.template</field>
        <field name="arch" type="xml">
            <form string="Whatsapp Template">
                <header>
                    <button name="action_create_template" type="object" string=" Send For Approval" invisible="state != 'draft'"/>
                    <button name="action_get_template" type="object" string="Validate" invisible="state in ['deleted','draft','rejected']"/>
                    <button name="action_wa_template_preview" string="Preview" type="object"/>
                    <button name="action_delete_template" type="object" string="Delete" invisible="state not in ['pending','approved']"
                            confirm="Are you certain you want to delete the template?"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,pending,approved"/>
                </header>
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="active" invisible="1"/>
                            <field name="user_id" options='{"no_create": True}'/>
                            <field name="lang_id" options='{"no_create": True}'/>
                            <field name="company_ids" widget="many2many_tags" groups="base.group_multi_company"/>
                            <field name="template_uid"/>
                            <field name="model_id" options='{"no_open": True, "no_create": True}'/>
                            <field name="quality" widget="priority" invisible="quality == 'none'" readonly="1"/>
                        </group>
                        <group>
                            <field name="template_name"/>
                            <field name="category"/>
                            <field name="header_type" readonly="state != 'draft'"/>
                            <field name="attachment_ids" widget="many2many_binary" invisible="header_type not in  ['document','image']"/>
                            <field name="binary_field_path" invisible="header_type not in  ['image']" readonly="state != 'draft'"/>
                            <field name="report_id" invisible="header_type != 'document'" required="header_type == 'document'"/>
                            <field name="header_text" invisible="header_type != 'text'" required="header_type == 'text'" readonly="state != 'draft'" placeholder="e.g.Our {{1}} is on!"/>
                            <field name="footer_text" readonly="state != 'draft'"/>
                            <field name="is_button"/>
                            <field name="is_reason_update" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page id="body" name="Body">
                            <field name="body" readonly="state != 'draft'"
                                   placeholder="Your whatsapp message, use {{1}}, {{2}} as placeholders for dynamic variable"/>
                        </page>
                        <page id="variables" name="Variables">
                            <field name="variable_ids">
                                <tree editable='bottom' create="false" delete="false">
                                    <field name="display_name" required="1"/>
                                    <field name="type" required="1"/>
                                    <field name="sample_value" required="1"/>
                                    <field name="variable_value"/>
                                    <field name="model_id" optional="hide"/>
                                </tree>
                            </field>
                        </page>
                        <page id="button" name="Button"
                      invisible="not is_button">
                    <group>
                        <field name="button_name" required="is_button"/>
                        <field name="button_url" required="is_button"/>
                    </group>
                </page>
                        <page id="reason" name="Rejection" invisible="not is_reason_update">
                            <field name="reason" readonly="True"/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>
    <!--  Whatsapp template tree view  -->
    <record id="view_whatsapp_template_tree" model="ir.ui.view">
        <field name="name">view.whatsapp.template.tree</field>
        <field name="model">whatsapp.template</field>
        <field name="arch" type="xml">
            <tree string="Whatsapp Template">
                <field name="name"/>
                <field name="user_id" widget="many2one_avatar"/>
                <field name="model_id"/>
                <field name="header_type"/>
                <field name="footer_text" optional="hide"/>
                <field name="quality" widget="priority" optional="hide" readonly="1"/>
                <field name="lang_id" optional="hide"/>
                <field name="state" decoration-success="state == 'approved'" decoration-danger="state == 'rejected'" widget="badge"/>
            </tree>
        </field>
    </record>
    <record id="view_whatsapp_template_search" model="ir.ui.view">
        <field name="name">view.whatsapp.template.search</field>
        <field name="model">whatsapp.template</field>
        <field name="arch" type="xml">
            <search string="Templates">
                <field name="name"/>
                <field name="model_id"/>
                <separator/>
                <filter string="Archived" name="filter_archived" domain="[('active', '=', False)]"/>
                <separator/>
                <filter string="Approved" name="approved" domain="[('state', '=', 'approved')]"/>
                <separator/>
                <filter string="Pending" name="pending" domain="[('state', '=', 'pending')]"/>
                <separator/>
                <filter string="Rejected" name="rejected" domain="[('state', '=', 'rejected')]"/>
                <group expand="0" string="Group By">
                    <filter string="Model" name="model_id" domain="[]" context="{'group_by': 'model_id'}"/>
                    <filter string="Status" name="state" domain="[]" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>
    <record id="view_whatsapp_template_kanban" model="ir.ui.view">
        <field name="name">view.whatsapp.template.kanban</field>
        <field name="model">whatsapp.template</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile">
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_content oe_kanban_global_click">
                            <div class="oe_module_desc">
                                <h3 class="o_kanban_record_title">
                                    <field name="name"/>
                                </h3>
                                <p class="oe_module_name">
                                    <field name="model_id"/>
                                </p>
                                <p class="oe_module_name">
                                    <field name="lang_id"/>
                                </p>
                                <div>
                                    <span class="pull-right float-end">
                                        <field name="state" widget="label_selection" options="{'classes': {'draft': 'primary', 'approved': 'success', 'rejected': 'default'}}"/>
                                    </span>
                                    <span class="pull-left">
                                        <field name="header_type" widget="badge"/>
                                    </span>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>
    <!-- Action window for whatsapp template -->
    <record id="action_view_whatsapp_template" model="ir.actions.act_window">
        <field name="name">Template</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">whatsapp.template</field>
        <field name="view_mode">tree,form,kanban</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new whatsapp template
            </p>
            <p>
                You can create whatsapp template.
            </p>
        </field>
    </record>
</odoo>