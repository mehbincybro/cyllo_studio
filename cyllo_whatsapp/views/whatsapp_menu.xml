<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!-- Define a client action for Whatsapp -->
    <record id="whatsapp_action" model="ir.actions.client">
        <field name="name">Whatsapp</field>
        <field name="tag">whatsapp_tags</field>
    </record>
    <!--  Menu root for Whatsapp -->
    <menuitem id="menu_cyllo_whatsapp_root" name="Whatsapp" sequence="6"/>
    <!-- Submenu item for Whatsapp Template under the Whatsapp menu -->
    <menuitem id="menu_whatsapp_chat" name="Whatsapp Chat" sequence="1"
              action="whatsapp_action" parent="menu_cyllo_whatsapp_root"/>
    <menuitem id="menu_configuration_categ" name="Configuration"
              parent="menu_cyllo_whatsapp_root" sequence="2"/>
    <menuitem id="menu_template" name="Template" sequence="1"
              parent="menu_configuration_categ" action="cyllo_whatsapp.action_view_whatsapp_template"/>
    <menuitem id="menu_channels" name="Channels" sequence="2"
              parent="menu_configuration_categ" action="cyllo_whatsapp.action_view_whatsapp_channel"/>
</odoo>