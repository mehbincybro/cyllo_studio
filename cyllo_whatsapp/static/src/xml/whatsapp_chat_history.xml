<?xml version="1.0" encoding="utf-8" ?>
<templates id="template">
    <!-- Chat History Template -->
    <t t-name="WhatsappChatHistory" owl="1">
        <div t-if="props.history.length" class="chatting-container overflow-auto d-flex flex-column-reverse pb-4" t-ref="chatter_history">
            <div class="chat-list-container mb-0">
                <t t-foreach="props.history" t-as="data" t-key="data.id">
                    <div class="d-flex align-items-center fw-bolder w-100">
                        <t t-if="previousMessageDate != data.date">
                            <hr class="ms-3 flex-grow-1"/>
                            <span class="px-3 text-muted">
                                <t t-esc="props.today === data.date ? 'Today' : data.date"/>
                            </span>
                            <hr class="me-3 flex-grow-1"/>
                        </t>
                    </div>
                    <t t-set="user_message" t-value="data.flag"/>
                    <div t-att-class="{'chat-reply': user_message }">
                        <div class="msg-lists">
                            <div class="text-mg-wrapper position-relative">
                                <div class="mg-wrapper-content">
                                    <div class="d-flex align-items-end justify-content-between ps-1 pb-1">
                                        <div class="mb-0" t-if="!data.is_template">
                                            <t t-call="ImageAttachment" t-if="data.message_type == 'image'"/>
                                            <t t-call="VoiceMessage" t-if="data.message_type == 'audio'"/>
                                            <t t-call="DocumentAttachment" t-if="data.message_type == 'document'"/>
                                            <div style=" width: 100%; word-wrap: break-word; text-align: left;" class="cy_whatsapp_message">
                                                <t t-if="data.message" t-esc="data.message"/>
                                            </div>
                                        </div>
                                        <div style="width: 200px;display: block;text-align: center; padding-top:5px;" t-if="data.is_template">
                                            <t t-call="DocumentAttachment" t-if="data.message_type == 'document'"/>
                                            <t t-call="ImageAttachment" t-if="data.message_type == 'image'"/>
                                            <div style="padding: 0px 2px;width:100%; word-wrap: break-word;">
                                                <t t-if="data.template_body" t-out="getMarkup(data.template_body)"/>
                                            </div>
                                        </div>
                                        <div class="d-flex justify-content-end gap-1">
                                            <div class="d-flex justify-content-end gap-1 align-items-center">
                                                <t t-call="MessageStatus" t-if="data.flag"/>
                                            </div>
                                        </div>
                                        <t t-set="previousMessageDate" t-value="data.date"/>
                                        <ChatOption message="data"/>
                                    </div>
                                </div>
                            </div>
                            <span class="conv-time">
                                <t t-esc="data.time"/>
                            </span>
                        </div>
                    </div>
                </t>
            </div>
        </div>
    </t>
    <!-- VoiceMessage Template -->
    <t t-name="VoiceMessage" owl="1">
        <div>
            <audio controls="">
                <source t-attf-src="/web/content/{{data.attachment_id[0]}}" type="audio/mp3"/>
            </audio>
        </div>
    </t>
    <!-- DocumentAttachment Template -->
    <t t-name="DocumentAttachment" owl="1">
        <div class="bg-400 bg-opacity-10 p-1" style="display: grid;grid-template-columns: 50px auto;"
             t-on-click="() => this.viewDocument(data.attachment_id)">
            <t t-set='fileType' t-value="getFileExtension(data.attachment_id[1])"/>
            <img t-attf-src="/cyllo_whatsapp/static/images/{{fileType}}" style="width: 100%; padding-right: 5px;object-fit: contain;">
            </img>
            <div class="pt-2" style="text-align:left;">
                <t t-esc="data.attachment_id[1]"/>
            </div>
        </div>
    </t>
    <!-- ImageAttachment Template -->
    <t t-name="ImageAttachment" owl="1">
        <img class="bg-white" t-attf-src="/web/image/whatsapp.message/{{data.id}}/image"
             style="object-fit: cover;" t-on-click="() => this.viewDocument(data.attachment_id)"/>
        <br/>
    </t>
    <!-- MessageStatus Template -->
    <t t-name="MessageStatus" owl="1">
        <i class="ri-check-double-line" t-if="data.state == 'delivered'"/>
        <i class="ri-check-double-line ri-double-line-read" t-if="data.state == 'read'"/>
        <i class="ri-check-line" t-if="data.state == 'sent'"/>
    </t>
</templates>