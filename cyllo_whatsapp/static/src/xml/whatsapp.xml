<?xml version="1.0" encoding="utf-8" ?>
<!--Whatsapp web view-->
<templates id="template">
    <t t-name="Whatsapp" owl="1">
        <div class="chatbox-main-container" t-ref="root">
            <div class="chatbox-left">
                <WhatsappSidebar t-props="sideBarProps"/>
            </div>
            <div class="chatbox-right w-100">
                <div class="chat_whatsapp">
                    <WhatsappChatTop t-if="state.activeChannel" t-props="currentChatProps"/>
                    <WhatsappWelcome t-if="!state.id"/>
                    <WhatsappChatHistory t-if="!state.imagePreview" t-props="whatsappChatHistory"/>
                    <WhatsappImagePreview t-if="state.imagePreview" t-props="whatsappImagePreviewProps"/>
                    <WhatsappChatInput t-if="state.id" t-props="currentChatProps"/>
                </div>
            </div>
        </div>
    </t>
</templates>