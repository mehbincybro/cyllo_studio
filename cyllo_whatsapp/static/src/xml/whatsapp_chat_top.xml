<?xml version="1.0" encoding="utf-8" ?>
<templates id="template">
    <!-- WhatsappChatTop Template -->
    <t t-name="WhatsappChatTop" owl="1">
        <div class="p-3 px-lg-4 border-bottom cy-whatsapp-top-container">
            <a class="d-flex align-items-center w-100 justify-space-between">
                <div class="flex-shrink-0">
                    <img class="img-fluid border avatar-img me-3"
                         t-attf-src="/web/image/res.partner/{{props.channel.partner_id[0]}}/image_1920"
                         alt="loading..."/>
                </div>
                <div class="flex-grow-1 d-flex flex-column justify-content-center">
                    <h5 class="chat-content m-0 text-truncate">
                        <a class="h5" t-attf-href="/web#id=#{props.channel.partner_id[0]}&amp;view_type=form&amp;model=res.partner">
                            <t t-out="props.channel.partner_id[1]"/>
                        </a>
                    </h5>
                </div>
            </a>
        </div>
    </t>
</templates>