<?xml version="1.0" encoding="utf-8" ?>
<templates id="template">
    <!-- WhatsappWelcome Template -->
    <t t-name="WhatsappWelcome" owl="1">
        <div class="whatsapp_welcome" style="height: 100vh;">
            <div style="display: grid;">
                <i class="ri-whatsapp-fill"
                   style="color:var(--primary);font-size: 75px;"/>
                <span class="cy-welcome-whatsapp">Welcome to Whatsapp</span>
                <div t-if="!state.checkWhatsappConfiguration"
                     t-on-click="onClickConfiguration"
                     class="cy-configure-whatsapp d-flex justify-content-center align-items-center gap-1">
                    Configure you Whatsapp account
                    <i class="ri-arrow-right-line"/>
                </div>
            </div>
        </div>
    </t>
</templates>