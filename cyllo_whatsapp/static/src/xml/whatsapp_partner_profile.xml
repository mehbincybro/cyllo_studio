<?xml version="1.0" encoding="utf-8" ?>
<templates id="template">
    <!-- WhatsappPartnerProfile Template -->
    <t t-name="WhatsappPartnerProfile" owl="1">
        <div class="d-flex py-2 border-bottom px-2 align-items-center whatsapp-partner-profile"
             t-ref="root" t-on-click="clickPartner">
            <div class="flex-shrink-0 align-self-center mx-2 ps-2">
                <img class="img-fluid rounded-circle border border-dark avatar-img"
                     t-attf-src="/web/image/res.partner/{{props.channel.partner_id[0]}}/image_1920"
                     alt="loading..."/>
            </div>
            <div class="flex-grow-1 text-start">
                <div t-out="props.channel.name" t-att-value="props.channel.id"
                     class="flex-grow-1 overflow-hidden py-2"/>
                <div class="flex-grow-1 text-start">
                    <span t-if="props.channel.last_message">
                        <t t-esc="props.channel.last_messenger"/>
                        :
                    </span>
                    <span t-if="props.channel.last_message"
                          t-esc="props.channel.last_message"/>
                </div>
            </div>
            <div t-if="!state.countVisible and props.channel.message_count != 0"
                 class="wa_message_count">
                <span t-out="props.channel.message_count"/>
            </div>
        </div>
    </t>
</templates>