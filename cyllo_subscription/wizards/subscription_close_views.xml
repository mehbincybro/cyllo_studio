<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
<!--    Subscription close action-->
    <record id="action_view_subscription_close_reason" model="ir.actions.act_window">
        <field name="name">Close reason</field>
        <field name="res_model">subscription.close</field>
        <field name="view_mode">form</field>
    </record>
<!--    Subscription close form view-->
    <record id="view_subscription_close_form" model="ir.ui.view">
        <field name="name">view.subscription.close.form</field>
        <field name="model">subscription.close</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <field name="close_reason_id"/>
                    <field name="subscription_order_id" invisible="True"/>
                </group>
                <footer>
                    <button name="action_close" type="object" class="btn-primary" string="Close Subscription"/>
                    <button special="cancel" string="Cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
