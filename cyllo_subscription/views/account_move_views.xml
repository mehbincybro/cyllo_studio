<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_account_move_form" model="ir.ui.view">
        <field name="name">view.account.move.form</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@id='header_right_group']" position="inside">
                <field name="is_subscription" invisible="1"/>
                <field name="renewal_date" invisible="not is_subscription"/>
                <field name="trial_period"
                       invisible="not is_subscription or trial_period == '0 False'"/>
            </xpath>
        </field>
    </record>
</odoo>
