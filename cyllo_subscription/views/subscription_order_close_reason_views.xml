<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
<!--    Subscription close tree view-->
    <record id="view_subscription_order_close_reason_tree" model="ir.ui.view">
        <field name="name">view.subscription.order.close.reason.tree</field>
        <field name="model">subscription.order.close.reason</field>
        <field name="arch" type="xml">
            <tree editable="bottom">
                <field name="reason"/>
                <field name="available_in_portal"/>
            </tree>
        </field>
    </record>
<!--    Action for subscription close model-->
    <record id="action_view_close_reasons" model="ir.actions.act_window">
        <field name="name">Close Reason</field>
        <field name="res_model">subscription.order.close.reason</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
