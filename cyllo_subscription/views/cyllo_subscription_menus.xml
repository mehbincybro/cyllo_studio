<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!-- Subscription main menu-->
    <menuitem id="menu_cyllo_subscription_root" name="Subscriptions"
              web_icon="cyllo_subscription,static/description/cyllo_subscription.svg"
              sequence="30"/>
    <!-- Subscriptions menu -->
    <menuitem id="menu_subscriptions_categ" name="Subscriptions"
              parent="menu_cyllo_subscription_root" sequence="5"/>
    <!-- Products menu -->
    <menuitem id="menu_products_categ" name="Products"
              parent="menu_cyllo_subscription_root"/>
    <!-- Reporting menu -->
    <menuitem id="menu_reporting_categ" name="Reporting"
              parent="menu_cyllo_subscription_root"/>
    <!-- Configurations menu -->
    <menuitem id="menu_configurations_categ" name="Configurations"
              parent="menu_cyllo_subscription_root" sequence="20"/>

    <!-- Menu: Subscriptions -> Orders -->
    <menuitem id="menu_orders" name="Orders"
              parent="menu_subscriptions_categ"
              action="action_view_orders"/>
    <!-- Menu: Subscriptions -> Subscription Order -->
    <menuitem id="menu_subscription_order" name="Subscription Order"
              parent="menu_subscriptions_categ"
              action="action_view_subscription_order"/>
    <!-- Menu: Subscriptions -> To Renew -->
    <menuitem id="menu_to_renew" name="To Renew"
              parent="menu_subscriptions_categ"
              action="action_view_to_renew"/>

    <!-- Menu: Products -> Products -->
    <menuitem id="menu_products" name="Products"
              action="action_view_products"
              parent="menu_products_categ"/>

    <!-- Menu: Products -> Pricelists -->
    <menuitem id="menu_subscription_pricelist" name="Pricelists"
              action="product.product_pricelist_action2"
              parent="menu_products_categ"
              sequence="10"/>

    <!-- Menu: Reporting -> Reporting -->
    <menuitem id="menu_reporting" name="Reporting"
              parent="menu_reporting_categ"
              action="action_view_reporting"/>

    <!-- Menu: Configuration -> Settings -->
    <menuitem id="menu_settings" name="Settings"
              action="sale.action_sale_config_settings"
              parent="menu_configurations_categ" sequence="0"/>
    <!-- Menu: Configuration -> Recurrence periods -->
    <menuitem id="menu_recurrence_periods_categ" name="Recurrence periods"
              parent="menu_configurations_categ" sequence="5"/>
    <!-- Menu: Configuration -> Subscription Plan -->
    <menuitem id="menu_subscription_plan" name="Subscription Plan"
              action="action_view_subscription_plan"
              parent="menu_configurations_categ"/>
    <!-- Menu: Configuration -> Close Reasons -->
    <menuitem id="menu_close_reasons" name="Close Reasons"
              action="action_view_close_reasons"
              parent="menu_configurations_categ"/>
    <!-- Menu: Configuration -> Alert -->
    <menuitem id="menu_alert" name="Alert"
              action="action_view_alert"
              parent="menu_configurations_categ"/>
</odoo>