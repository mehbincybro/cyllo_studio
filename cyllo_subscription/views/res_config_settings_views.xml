<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_res_config_settings_form_inherit_sale_subscription" model="ir.ui.view">
        <field name="name">view.res.config.settings.form.inherit.sale.subscription</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="sale.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@name='invoicing_setting_container']"
                   position="after">
                <block title="Subscription"
                       id="sales_subscription_container">
                    <setting id="sale_subscription_setting"
                             help="Install the Cyllo website Subscription module to sell products with time based  payment plans.">
                        <field name="module_cyllo_website_subscription"/>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>
</odoo>