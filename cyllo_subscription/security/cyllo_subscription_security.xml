<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!-- Company rule for subscription order model -->
    <record id="rule_subscription_order_company" model="ir.rule">
        <field name="name">Subscription Order</field>
        <field name="model_id" ref="model_subscription_order"/>
        <field name="domain_force">['|',('company_id','=',False), ('company_id',
            'in',company_ids)]
        </field>
    </record>
</odoo>