#. module: cyllo_subscription
#: model:mail.template,body_html:cyllo_subscription.cyllo_subscription_invoices
msgid ""
"<div style=\"margin: 0px; padding: 0px;\">\n"
"                <div style=\"justify-content: center;background-color: #714B67; padding:0.6rem;padding-left: 35px;text-decoration: none; color: #fff; border-radius: 5px; font-size:13px;width:40%\">\n"
"                <h2>\n"
"                    Hi, <t t-out=\"object.partner_id.name\"></t>\n"
"                </h2>\n"
"                <div>\n"
"                    <h3>\n"
"                        Thank you so much for choosing our subscription service!\n"
"                        We are truly grateful for your trust and excited to provide\n"
"                        you with exceptional value. Your decision means a lot to us,\n"
"                        and we look forward to exceeding your expectations!\n"
"                    </h3>\n"
"                </div>\n"
"                <div>\n"
"                    <h3>\n"
"                        Find your Invoice for the subscription of <t t-out=\"object.invoice_line_ids.product_id.name\"></t>\n"
"                    </h3>\n"
"                </div>\n"
"                    </div>\n"
"                <br>\n"
"                <div style=\"display: flex;justify-content: center;background-color: #714B67; padding:0.6rem;padding-left: 35px;text-decoration: none; color: #fff; border-radius: 5px; font-size:13px;width:7%\">\n"
"                    <a t-attf-href=\"/my/invoices/{{object.id}}\" style=\"text-decoration:none;color:#fff;\">\n"
"                        Invoice\n"
"                    </a>\n"
"                </div>\n"
"            </div>\n"
"        "
msgstr ""
"<div style=\"margin: 0px; padding: 0px;\">\n"
"                <div style=\"justify-content: center;background-color: #714B67; padding:0.6rem;padding-left: 35px;text-decoration: none; color: #fff; border-radius: 5px; font-size:13px;width:40%\">\n"
"                <h2>\n"
"                    Zdravo, <t t-out=\"object.partner_id.name\"></t>\n"
"                </h2>\n"
"                <div>\n"
"                    <h3>\n"
"                        Puno vam hvala što ste odabrali našu uslugu pretplate!\n"
"                        Zaista smo zahvalni na vašem povjerenju i uzbuđeni što možemo pružiti\n"
"                        ti s izuzetnom vrijednošću. Vaša odluka nam puno znači,\n"
"                        i radujemo se što ćemo premašiti vaša očekivanja.!\n"
"                    </h3>\n"
"                </div>\n"
"                <div>\n"
"                    <h3>\n"
"                        Pronađite fakturu za svoju pretplatu na <t t-out=\"object.invoice_line_ids.product_id.name\"></t>\n"
"                    </h3>\n"
"                </div>\n"
"                    </div>\n"
"                <br>\n"
"                <div style=\"display: flex;justify-content: center;background-color: #714B67; padding:0.6rem;padding-left: 35px;text-decoration: none; color: #fff; border-radius: 5px; font-size:13px;width:7%\">\n"
"                    <a t-attf-href=\"/my/invoices/{{object.id}}\" style=\"text-decoration:none;color:#fff;\">\n"
"                        Dostavnica\n"
"                    </a>\n"
"                </div>\n"
"            </div>\n"
"        "

