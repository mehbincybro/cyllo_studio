#. module: cyllo_subscription
#: model:mail.template,body_html:cyllo_subscription.mail_template_invoice_for_subscription
msgid ""
"<div id=\"invoice_html\" style=\"margin: 0px; padding: 0px;\">\n"
"                <div id=\"wrapwrap\" style=\"align-items:center;justify-content: center;border: 2px solid; border-color:#9ea700; padding:0.6rem;padding-left: 35px;text-decoration: none; border-radius: 5px; font-size:13px;width:40%\">\n"
"                    <h2>\n"
"                        Hi,\n"
"                        <t t-out=\"object.partner_id.name\"></t>\n"
"                    </h2>\n"
"                    <div>\n"
"                        <h3>\n"
"                            Thank you so much for choosing our subscription\n"
"                            service!\n"
"                            We are truly grateful for your trust and\n"
"                            excited to provide\n"
"                            you with exceptional value. Your decision means\n"
"                            a lot to us,\n"
"                            and we look forward to exceeding your\n"
"                            expectations!\n"
"                        </h3>\n"
"                    </div>\n"
"                    <div>\n"
"                        <h3>\n"
"                            Find your Invoice for the subscription of\n"
"                            <t t-out=\"object.invoice_line_ids.product_id.name\"></t>\n"
"                        </h3>\n"
"                    </div>\n"
"                </div>\n"
"                <br>\n"
"                <div style=\"display: flex;justify-content: center;align-items:center; background-color: #9ea700; padding:0.6rem;padding-left: 15px;text-decoration: none; color: #fff; border-radius: 5px; font-size:13px;width:7%\">\n"
"                    <a t-attf-href=\"/my/invoices/{{object.id}}\" style=\"text-decoration:none;color:#fff;\">\n"
"                        Invoice\n"
"                    </a>\n"
"                </div>\n"
"            </div>\n"
"        "
msgstr ""
"<div id=\"invoice_html\" style=\"margin: 0px; padding: 0px;\">\n"
"                <div id=\"wrapwrap\" style=\"align-items:center;justify-content: center;border: 2px solid; border-color:#9ea700; padding:0.6rem;padding-left: 35px;text-decoration: none; border-radius: 5px; font-size:13px;width:40%\">\n"
"                    <h2>\n"
"                        مرحباً،\n"
"                        <t t-out=\"object.partner_id.name\"></t>\n"
"                    </h2>\n"
"                    <div>\n"
"                        <h3>\n"
"                            شكرًا جزيلاً لاختيارك خدمة الاشتراك الخاصة بنا!\n"
"                            نحن نقدر ثقتك كثيرًا ونتطلع لتقديم\n"
"                            قيمة مميزة لك. قرارك يعني لنا الكثير،\n"
"                            ونتطلع دائمًا لتجاوز توقعاتك.\n"
"                        </h3>\n"
"                    </div>\n"
"                    <div>\n"
"                        <h3>\n"
"                            يرجى العثور على فاتورة الاشتراك الخاصة بـ\n"
"                            <t t-out=\"object.invoice_line_ids.product_id.name\"></t>\n"
"                        </h3>\n"
"                    </div>\n"
"                </div>\n"
"                <br>\n"
"                <div style=\"display: flex;justify-content: center;align-items:center; background-color: #9ea700; padding:0.6rem;padding-left: 15px;text-decoration: none; color: #fff; border-radius: 5px; font-size:13px;width:7%\">\n"
"                    <a t-attf-href=\"/my/invoices/{{object.id}}\" style=\"text-decoration:none;color:#fff;\">\n"
"                        الفاتورة\n"
"                    </a>\n"
"                </div>\n"
"            </div>\n"
"        "

