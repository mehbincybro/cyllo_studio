"</h3>\n"
"</div>\n"
"</div>\n"
"<br>\n"
"<div style = \"Display: flex; justify-content: Centre; Align-Items: Center; Background-Color: # 9EA700; Padding: 0.6rem; Padding-Left: 35px; Text-Decoration: Aucun; Couleur: #fff;Border-Radius: 5px;\n"
"<a T-ATTF-HREF = \"/ Détails / {{object.id}}\" style = \"Text-Decoration: Aucun; Color: #fff;\">\n"
"Cliquez ici\n"
"</a>\n"
"</div>\n"
"</div>"

