"</div>\n"
"</div>\n"
"<br>\n"
"<div style = \"Display: flex; Justify-Content: Center; Align-Items: Center; Background-Color: # 9EA700; padding: 0.6rem; padding-left: 15px; text-décoration: Aucun; couleur: #fff;Border-Radius: 5px;\n"
