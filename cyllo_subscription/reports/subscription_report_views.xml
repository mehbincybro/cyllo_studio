<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!-- Pivot view in the report -->
    <record id="view_subscription_report_pivot" model="ir.ui.view">
        <field name="name">view.subscription.report.pivot</field>
        <field name="model">subscription.report</field>
        <field name="arch" type="xml">
            <pivot string="Sales Analysis" sample="1">
                <field name="partner_id" type="row"/>
                <field name="recurring_revenue" type="measure"/>
                <field name="arr" type="measure"/>
                <field name="weekly_price_sum" type="measure"/>
                <field name="monthly_price_sum" type="measure"/>
                <field name="yearly_price_sum" type="measure"/>
                <field name="subscription_count" type="measure"/>
                <field name="active_subscription_count" type="measure"/>
                <field name="trial_subscription_count" type="measure"/>
                <field name="renewal_count" type="measure"/>
                <field name="churned_subscription_count" type="measure"/>
            </pivot>
        </field>
    </record>
    <!-- Graph View -->
    <record id="view_subscription_report_graph" model="ir.ui.view">
        <field name="name">view.subscription.report.graph</field>
        <field name="model">subscription.report</field>
        <field name="arch" type="xml">
            <graph string="Sales Analysis" type="line" sample="1">
                <field name="start_date" interval="month"/>
                <field name="recurring_revenue" type="measure"/>
                <field name="arr" type="measure"/>
                <field name="subscription_count" type="measure"/>
                <field name="renewal_count" type="measure"/>
                <field name="active_subscription_count" type="measure"/>
            </graph>
        </field>
    </record>
    <!-- Pie graph view -->
    <record id="view_subscription_report_graph_pie" model="ir.ui.view">
        <field name="name">view.subscription.report.graph.pie</field>
        <field name="model">subscription.report</field>
        <field name="mode">primary</field>
        <field name="inherit_id" ref="view_subscription_report_graph"/>
        <field name="arch" type="xml">
            <graph position="attributes">
                <attribute name="type">pie</attribute>
            </graph>
        </field>
    </record>
    <!-- Bar graph view -->
    <record id="view_subscription_report_graph_bar" model="ir.ui.view">
        <field name="name">view.subscription.report.graph.bar</field>
        <field name="model">subscription.report</field>
        <field name="mode">primary</field>
        <field name="inherit_id" ref="view_subscription_report_graph"/>
        <field name="arch" type="xml">
            <graph position="attributes">
                <attribute name="type">bar</attribute>
                <attribute name="order">DESC</attribute>
            </graph>
        </field>
    </record>
    <!-- Tree View -->
    <record id="view_subscription_report_tree" model="ir.ui.view">
        <field name="name">view.subscription.report.tree</field>
        <field name="model">subscription.report</field>
        <field name="arch" type="xml">
            <tree create="false" string="Subscription Analysis">
                <field name="partner_id"/>
                <field name="product_name"/>
                <field name="plan_name"/>
                <field name="state_subscription"/>
                <field name="recurrence_name"/>
                <field name="start_date"/>
                <field name="next_invoice_date"/>
                <field name="end_date" optional="hide"/>
                <field name="trial_end_date" optional="hide"/>
                <field name="subscription_count"/>
                <field name="recurring_revenue" sum="Total MRR"/>
                <field name="arr" sum="Total ARR"/>
            </tree>
        </field>
    </record>
    <!-- Search view -->
    <record id="view_subscription_report_search" model="ir.ui.view">
        <field name="name">view.subscription.report.search</field>
        <field name="model">subscription.report</field>
        <field name="arch" type="xml">
            <search string="Subscription Analysis">
                <!-- Search Fields -->
                <field name="state_subscription"/>
                <field name="partner_id"/>
                <field name="product_name"/>
                <field name="plan_name"/>
                <field name="recurrence_name"/>

                <!-- Date Filters -->
                <filter string="This Month" name="this_month"
                    domain="[('start_date', '&gt;=', (context_today() - relativedelta(day=1)).strftime('%Y-%m-%d')),
                            ('start_date', '&lt;', (context_today() + relativedelta(months=1, day=1)).strftime('%Y-%m-%d'))]"/>
                <filter string="Last Month" name="last_month"
                    domain="[('start_date', '&gt;=', (context_today() - relativedelta(months=1, day=1)).strftime('%Y-%m-%d')),
                            ('start_date', '&lt;', (context_today() - relativedelta(day=1)).strftime('%Y-%m-%d'))]"/>
                <filter string="This Quarter" name="this_quarter"
                    domain="[('start_date', '&gt;=', (context_today() - relativedelta(day=1, month=((context_today().month-1)//3)*3+1)).strftime('%Y-%m-%d')),
                            ('start_date', '&lt;', (context_today() + relativedelta(months=3 - ((context_today().month-1) % 3), day=1)).strftime('%Y-%m-%d'))]"/>
                <filter string="Last Quarter" name="last_quarter"
                    domain="[('start_date', '&gt;=', (context_today() - relativedelta(months=3 + ((context_today().month-1) % 3), day=1)).strftime('%Y-%m-%d')),
                            ('start_date', '&lt;', (context_today() - relativedelta(day=1, month=((context_today().month-1)//3)*3+1)).strftime('%Y-%m-%d'))]"/>
                <filter string="This Year" name="this_year"
                    domain="[('start_date', '&gt;=', context_today().strftime('%Y-01-01')),
                            ('start_date', '&lt;', (context_today() + relativedelta(years=1, month=1, day=1)).strftime('%Y-%m-%d'))]"/>
                <filter string="Last Year" name="last_year"
                    domain="[('start_date', '&gt;=', (context_today() - relativedelta(years=1, month=1, day=1)).strftime('%Y-%m-%d')),
                            ('start_date', '&lt;', context_today().strftime('%Y-01-01'))]"/>

                <separator/>

                <!-- State Filters -->
                <filter string="Active Subscriptions" name="active"
                    domain="[('state_subscription', '=', 'active')]"/>
                <filter string="Trial Subscriptions" name="trial"
                    domain="[('state_subscription', '=', 'trial')]"/>
                <filter string="Churned Subscriptions" name="churned"
                    domain="[('state_subscription', '=', 'churned')]"/>
                <filter string="Renewing Subscriptions" name="renew"
                    domain="[('state_subscription', '=', 'renew')]"/>
                <filter string="Quotations" name="quotation"
                    domain="[('state_subscription', '=', 'quotation')]"/>

                <separator/>

                <!-- Revenue Filters -->
                <filter string="High Value (MRR &gt; 1000)" name="high_value"
                    domain="[('recurring_revenue', '&gt;', 1000)]"/>
                <filter string="Medium Value (MRR 100-1000)" name="medium_value"
                    domain="[('recurring_revenue', '&gt;=', 100), ('recurring_revenue', '&lt;=', 1000)]"/>
                <filter string="Low Value (MRR &lt; 100)" name="low_value"
                    domain="[('recurring_revenue', '&lt;', 100)]"/>

                <separator/>

                <!-- Group By Options -->
                <group expand="0" string="Group By">
                    <!-- Date Groupings -->
                    <filter string="Start Date: Day" name="group_start_date_day"
                        context="{'group_by': 'start_date:day'}"/>
                    <filter string="Start Date: Week" name="group_start_date_week"
                        context="{'group_by': 'start_date:week'}"/>
                    <filter string="Start Date: Month" name="group_start_date_month"
                        context="{'group_by': 'start_date:month'}"/>
                    <filter string="Start Date: Quarter" name="group_start_date_quarter"
                        context="{'group_by': 'start_date:quarter'}"/>
                    <filter string="Start Date: Year" name="group_start_date_year"
                        context="{'group_by': 'start_date:year'}"/>

                    <separator/>

                    <filter string="Next Invoice Date: Day" name="group_invoice_date_day"
                        context="{'group_by': 'next_invoice_date:day'}"/>
                    <filter string="Next Invoice Date: Week" name="group_invoice_date_week"
                        context="{'group_by': 'next_invoice_date:week'}"/>
                    <filter string="Next Invoice Date: Month" name="group_invoice_date_month"
                        context="{'group_by': 'next_invoice_date:month'}"/>

                    <separator/>

                    <!-- Other Groupings -->
                    <filter string="Product" name="group_product"
                        context="{'group_by': 'product_name'}"/>
                    <filter string="Plan" name="group_plan"
                        context="{'group_by': 'plan_name'}"/>
                    <filter string="Customer" name="group_customer"
                        context="{'group_by': 'partner_id'}"/>
                    <filter string="State" name="group_state"
                        context="{'group_by': 'state_subscription'}"/>
                    <filter string="Recurrence" name="group_recurrence"
                        context="{'group_by': 'recurrence_name'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action to show the report -->
    <record id="action_view_reporting" model="ir.actions.act_window">
        <field name="name">Subscriptions Analysis</field>
        <field name="res_model">subscription.report</field>
        <field name="view_mode">pivot,tree,graph</field>
        <field name="search_view_id" ref="view_subscription_report_search"/>
    </record>
</odoo>