<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_appointment_form_inherit_crm" model="ir.ui.view">
        <field name="name">appointment.appointment.form.crm</field>
        <field name="model">appointment.appointment</field>
        <field name="inherit_id" ref="cyllo_appointment.view_appointment_form"/>
        <field name="arch" type="xml">
            <!-- 1. Opportunity smart-button -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button
                    name="action_view_opportunity"
                    type="object"
                    class="oe_stat_button"
                    icon="fa-usd"
                    groups="sales_team.group_sale_salesman"
                    invisible="not opportunity_id">
                    <div class="o_field_widget o_stat_info">
                        <span class="o_stat_text">Opportunity</span>
                    </div>
                </button>
            </xpath>
            <xpath expr="//field[@name='sale_order_id']" position="after">
                <field
                    name="opportunity_id"
                    readonly="1"
                    groups="sales_team.group_sale_salesman"
                    invisible="not opportunity_id"/>
            </xpath>
        </field>
    </record>
</odoo>
