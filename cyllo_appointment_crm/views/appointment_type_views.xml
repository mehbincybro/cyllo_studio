<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="appointment_type_form_inherit_crm" model="ir.ui.view">
        <field name="name">appointment.type.form.crm</field>
        <field name="model">appointment.type</field>
        <field name="inherit_id" ref="cyllo_appointment.view_appointment_type_form"/>
        <field name="arch" type="xml">
            <!-- 1. Leads smart-button -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button
                    name="action_appointment_leads"
                    type="object"
                    class="oe_stat_button"
                    icon="fa-usd"
                    groups="sales_team.group_sale_salesman"
                    invisible="lead_count == 0">
                    <div class="o_field_widget o_stat_info">
                        <span class="o_stat_value">
                            <field name="lead_count"/>
                        </span>
                        <span class="o_stat_text">Leads</span>
                    </div>
                </button>
                <field name="lead_ids" invisible="1"/>
            </xpath>
            <xpath expr="//page[@name='rescheduling']" position="inside">
                <group string="CRM Lead Creation">
                    <field name="lead_create"/>
                </group>
            </xpath>

        </field>
    </record>

</odoo>
