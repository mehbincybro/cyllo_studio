<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!--        Inherited delivery carrier model-->
    <record id="view_delivery_carrier_form" model="ir.ui.view">
        <field name="name">view.delivery.carrier.form</field>
        <field name="model">delivery.carrier</field>
        <field name="inherit_id" ref="delivery.view_delivery_carrier_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='pricing']" position="after">
                 <page name="pricing" string="DHL Configuration" invisible="delivery_type != 'dhl'">
                     <group>
                         <group>
                             <field name="site_id" required="delivery_type == 'dhl'"/>
                             <field name="password" required="delivery_type == 'dhl'"/>
                             <field name="account_no" required="delivery_type == 'dhl'"/>
                             <field name="region" string="Region"/>
                             <field name="dutiable" string="Dutiable"/>
                         </group>
                         <group>
                             <field name="service_type" sting="Service Type"/>
                             <field name="weight_uom"/>
                             <field name="label_format" string="Label Format"/>
                             <field name="label_template" string="Label Template"/>
                             <field name="package_type_id"/>
                             <field name="dimension_unit"/>
                             <field name="insured_value" string="Insured Value" widget="percentage" class="oe_inline"/>
                         </group>
                     </group>
                 </page>
            </xpath>
        </field>
    </record>
</odoo>
