<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_res_config_settings_form_inherit_sale_commission" model="ir.ui.view">
        <field name="name">view.res.config.settings.form.inherit.sale.commission</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="sale.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@name='invoicing_setting_container']"
                   position="after">
                <block title="Sales Commissions"
                       id="sales_commission_container">
                    <setting id="sale_commission_setting"
                             help="Enable commission management for salespeople. Team managers or administrators can create commission plans.">
                        <field name="module_cyllo_commission"/>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>

</odoo>
