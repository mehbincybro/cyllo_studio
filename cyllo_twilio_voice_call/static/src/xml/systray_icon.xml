<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
	<t t-name="dial_button" owl="1">
		<button class="btn ri-phone-line" style="color:black;font-size:20px;margin-top:2px;"
                t-on-click="() => this.state.showKeypad = !this.state.showKeypad"
                type="button"
                />
        <t t-if="this.state.showKeypad">
			<DialPad/>
		</t>
        <FetchIncomingCall parent_this="this"/>
	</t>
</templates>
