<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
<t t-name="cyllo_twilio_voice_call.FormPhoneField"
   t-inherit="web.FormPhoneField"
   t-inherit-mode="extension">
     <xpath expr="//a[hasclass('o_phone_form_link')]" position="replace">
        <t t-log="hello"/>
        <a
            t-if="props.record.data[props.name]"
            t-on-click.stop.prevent="callOption"
            href="#"
            class="o_phone_form_link ms-3 d-inline-flex align-items-center"
            title="Open DialPad"
        >
             <i class="fa fa-phone"></i><small class="fw-bold ms-1">Call</small>
        </a>
    </xpath>
</t>
</templates>
<!--"()=>{env.bus.trigger('CALL_ACTION',{number: props.record.data[props.name]})}"-->