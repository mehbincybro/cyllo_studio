<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="cyllo_twilio_voice_call.CallOptionModal">



    <div class="modal d-flex align-items-center justify-content-center" style="min-height: 100vh;">
        <div class="modal-dialog modal-dialog-centered" style="max-width: 360px; width: 100%;">
            <div class="modal-content shadow-lg rounded-3 border-0">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold">Select Call Option</h5>
                    <button type="button" class="btn-close"
                            aria-label="Close"
                            t-on-click="closeModal"
                            style="font-size: 12px;">
                    </button>
                </div>

                <div class="modal-body pt-3 pb-4 px-4 text-center">
                    <p class="text-muted mb-4">
                        Call to: <strong t-esc="props.phoneNumber"/>
                    </p>

                    <div class="d-flex flex-column gap-2">
                        <button type="button" class="btn btn-primary"
                                t-on-click="() => this.select('twilio')">
                             Call with Twilio
                        </button>
                        <button type="button" class="btn btn-outline-secondary"
                                t-on-click="() => this.select('regular')"
                                style="font-size:13px">
                             Call with other app
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
    </t>

</templates>