<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
	<t t-name="dial_button" owl="1">
		<div class="cy-systray-parent-class" t-ref="root"
             t-on-click.stop.prevent="() => this.env.toggle_keypad()">
			<button class="btn ri-phone-line p-0 cy-systray-icon"
                    style="color:black;font-size:20px; padding-left:5px !important;"
                    type="button"
            />
            <span t-if="props.nameShow" class="cy-systray-label">
               	Twilio
            </span>
        </div>
	</t>
</templates>