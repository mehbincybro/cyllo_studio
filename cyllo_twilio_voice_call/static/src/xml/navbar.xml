<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <t t-inherit="web.NavBar" t-inherit-mode="extension">
        <xpath expr="//header[hasclass('o_navbar')]" position="inside">
            <t t-if="this.state.showKeypad and (this.isAdmin || this.isUser)">
                <DialPad/>
            </t>
            <FetchIncomingCall parent_this="this"/>
        </xpath>
    </t>
</templates>