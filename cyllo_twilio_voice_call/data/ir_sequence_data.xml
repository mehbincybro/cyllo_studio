<?xml version="1.0" encoding="UTF-8" ?>
<odoo noupdate="1">
    <!--    Sequence number for voice call list  -->
    <record id="ir_sequence_voice_call_list" model="ir.sequence">
        <field name="name">Voice Call List</field>
        <field name="code">out.going.call.list</field>
        <field name="active">TRUE</field>
        <field name="prefix">OG</field>
        <field name="padding">4</field>
        <field name="number_next">1</field>
        <field name="number_increment">1</field>
    </record>
    <!--    Sequence number for Twilio voice call   -->
    <record id="ir_sequence_twilio_voice_call" model="ir.sequence">
        <field name="name">Twilio Voice Call</field>
        <field name="code">incoming.call.list</field>
        <field name="active">TRUE</field>
        <field name="prefix">IN</field>
        <field name="padding">4</field>
        <field name="number_next">1</field>
        <field name="number_increment">1</field>
    </record>
</odoo>