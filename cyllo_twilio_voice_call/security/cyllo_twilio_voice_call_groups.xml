<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!--    Access rights for the twilio voice call-->
    <!--    Access Groups-->
    <record id="ir_module_category_twilio_voice_call" model="ir.module.category">
        <field name="name">Twilio Voice Call</field>
        <field name="description">Access for Twilio Voice Call module
        </field>
        <field name="sequence">10</field>
    </record>
    <record id="group_cyllo_twilio_voice_call_user" model="res.groups">
        <field name="name">User</field>
        <field name="category_id" ref="cyllo_twilio_voice_call.ir_module_category_twilio_voice_call"/>
    </record>
    <record id="group_cyllo_twilio_voice_call_admin" model="res.groups">
        <field name="name">Admin</field>
        <field name="category_id" ref="cyllo_twilio_voice_call.ir_module_category_twilio_voice_call"/>
        <field name="implied_ids"
               eval="[Command.link(ref('group_cyllo_twilio_voice_call_user'))]"/>
    </record>

    <!--Access for the users to their records only-->
    <record id="rule_incoming_call_list_public" model="ir.rule">
        <field name="name">Current User Only For Incoming</field>
        <field name="model_id" ref="model_incoming_call_list"/>
        <field name="domain_force">[('user_id', '=', user.id)]</field>
        <field name="groups"
               eval="[Command.link(ref('cyllo_twilio_voice_call.group_cyllo_twilio_voice_call_user'))]"/>
    </record>

    <record id="rule_out_going_call_list_public" model="ir.rule">
        <field name="name">Current User Only For Outgoing</field>
        <field name="model_id" ref="model_out_going_call_list"/>
        <field name="domain_force">[('user_id', '=', user.id)]</field>
        <field name="groups" eval="[Command.link(ref('cyllo_twilio_voice_call.group_cyllo_twilio_voice_call_user'))]"/>
    </record>
    <!--Admin access to all records-->
    <record id="rule_incoming_call_list_admin_public" model="ir.rule">
        <field name="name">Admin Access to user</field>
        <field name="model_id" ref="model_incoming_call_list"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[Command.link(ref('group_cyllo_twilio_voice_call_admin'))]"/>
    </record>

    <record id="rule_out_going_call_list_admin_public" model="ir.rule">
        <field name="name">Admin Access to user</field>
        <field name="model_id" ref="model_out_going_call_list"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups"
               eval="[(4, ref('group_cyllo_twilio_voice_call_admin'))]"/>
    </record>
    <!--Multy Company Rule-->
    <record id="rule_incoming_call_list_company" model="ir.rule">
        <field name="name">Twilio Voice Call Multy Company Rule</field>
        <field name="model_id" ref="model_incoming_call_list"/>
        <field name="domain_force">[('company_id','in', company_ids)]</field>
    </record>

    <record id="rule_out_going_call_list_company" model="ir.rule">
        <field name="name">Twilio Voice Call Multy Company Rule</field>
        <field name="model_id" ref="model_out_going_call_list"/>
        <field name="domain_force">[('company_id','in', company_ids)]</field>
    </record>
</odoo>