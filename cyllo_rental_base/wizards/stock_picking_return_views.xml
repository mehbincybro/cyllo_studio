<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!-- Inherit Form View to Modify it -->
    <record id="view_stock_return_picking_form" model="ir.ui.view">
        <field name="name">view.stock.return.picking.form</field>
        <field name="model">stock.return.picking</field>
        <field name="inherit_id" ref="stock.view_stock_return_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='picking_id']" position="after">
                <field name="picking_ids" invisible="1"/>
            </xpath>
            <xpath expr="//field[@name='picking_id']" position="attributes">
                 <attribute name="invisible">not picking_ids</attribute>
                 <attribute name="domain">[('id', 'in', picking_ids)]</attribute>
                 <attribute name="required">1</attribute>
                 <attribute name="options">{'no_create_edit': True, 'no_open': True, 'no_quick_create': True}</attribute>
            </xpath>
        </field>
    </record>
</odoo>