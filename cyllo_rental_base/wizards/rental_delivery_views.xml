<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!-- Order return form view -->
    <record id="view_rental_delivery_form" model="ir.ui.view">
        <field name="name">view.rental.delivery.form</field>
        <field name="model">rental.delivery</field>
        <field name="arch" type="xml">
            <form string="Delivery">
                <field name="rental_line_ids">
                    <tree editable="bottom" create="0" delete="1">
                        <field name="product_id"/>
                        <field name="quantity"/>
                        <field name="product_uom_id"/>
                        <field name="product_location_id"/>
                    </tree>
                </field>
                <footer>
                    <button name="action_create_delivery" type="object" string="Create Delivery" class="btn btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>