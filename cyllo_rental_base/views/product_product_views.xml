<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!-- Adding rental info in product form -->
    <record id="view_product_product_form" model="ir.ui.view">
        <field name="name">view.product.product.form</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_normal_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='options']" position="inside">
                <field name="current_rented_quantity" invisible="1"/>
                <field name="is_rental"/>
                <label for="is_rental"/>
            </xpath>
            <xpath expr="//page[@name='purchase']" position="after">
                <!-- === Rental Charges === -->
                <page string="Rental" name="rental_charges" invisible="is_rental == False">
                    <group string="Price Details"/>
                    <field name="rental_charging_ids" mode="tree" widget="one2many">
                        <tree editable="bottom" colspan="2" class="table table-bordered">
                            <field name="rental_period" colspan="2"/>
                            <field name="currency_id" column_invisible="1"/>
                            <field name="price" widget="monetary" colspan="2"/>
                        </tree>
                    </field>
                    <group>
                        <group string="Location">
                            <field name="rental_location_id" required="is_rental"/>
                            <field name="is_extra_cost"/>
                        </group>
                        <group string="Rental Minimum Quantity">
                            <field name="min_quantity"/>
                            <field name="min_qty_amt"/>
                        </group>
                        <!-- === Extra Costs for late returns === -->
                        <group string="Extra Cost" name="extra_costs" invisible="not is_extra_cost">
                            <group>
                                <field name="extra_hourly_price" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                <field name="currency_id" invisible="1"/>
                                <field name="apply_after"/>
                            </group>
                            <group>
                                <field name="delay_product_id"/>
                            </group>
                        </group>
                    </group>
                    <!-- === Rental Checklist === -->
                    <group string="Rental Checklist" name="rental_checklist"/>
                    <field name="rental_checklist_ids" mode="tree" widget="one2many" nolabel="1">
                        <tree editable="bottom" class="table table-bordered">
                            <field name="name" class="w-50"/>
                            <field name="is_available" class="text-center"/>
                            <field name="remarks" class="w-50"/>
                        </tree>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
    <!-- Adding filter for rental products in product search view -->
    <record id="view_product_product_search" model="ir.ui.view">
        <field name="name">view.product.product.</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_search_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='filter_to_purchase']" position="after">
                <filter string="Rental" name="filter_to_rent" domain="([('is_rental','=', True)])"/>
            </xpath>
        </field>
    </record>
</odoo>