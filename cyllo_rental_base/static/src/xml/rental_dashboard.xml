<?xml version="1.0" encoding="UTF-8" ?>
<!--Rental Dashboard template-->
<templates id="rental_dashboard_template" xml:space="preserve">
    <t t-name="RentalDashboard" owl="1">
        <div style="height:100%; overflow-y: scroll; overflow-x: hidden;background:#e8e8e8;">
            <section class="dashboard_main_section" id="main_section_manager">
                <div class="dashboard-heading shadow-sm">
                    <nav class="navbar navbar-main navbar-expand-lg shadow-none border-radius-xl" id="navbarBlur" data-scroll="true">
                        <div class="container-fluid py-1 px-3">
                            <h2 class="font-weight-bolder mb-0">
                                Rental Dashboard
                            </h2>
                            <div class="col-4 col-sm-4 col-md-4" style="float: right;color:#000;">
                                <form class="form-group">
                                    <div class="d-flex date_select">
                                        <div id="date_start" class="date_select_div">
                                            <span style="position:absolute; top:24px; left:781px">Start Date:</span>
                                            <input class="date_filter form-control" type="date" id="start_date"
                                                   name="start_date" widget="daterange" t-on-change="filter_date"
                                                   style="position:absolute; left:869px; top:18px; width:8%;"/>
                                        </div>
                                        <div id="date_end" class="date_select_div">
                                            <span style="position:absolute; left:1038px; top:24px;">End Date:</span>
                                            <input class="date_filter form-control" type="date" id="end_date"
                                                   name="end_date" widget="daterange" t-on-change="filter_date"
                                                   style="position:absolute; left:1117px; top:18px; width:8%;"/>
                                        </div>
                                    </div>
                                </form>
                            </div>
                        </div>
                        <div class="col-4 col-sm-8 col-md-8" style="float: right;color:#000; width:375px; margin:10px;">
                            <form class="form-group">
                                <select id="rental_filter_values" class="form-control" t-on-click="onClickFilter">
                                    <option id="select_date" value=""> Select Date </option>
                                    <option id="this_week" value="this_week">This Week </option>
                                    <option id="this_month" value="this_month">This Month </option>
                                    <option id="this_year" value="this_year">This Year </option>
                                </select>
                            </form>
                        </div>
                    </nav>
                    <!-- End of Navbar -->
                    <!-- Tiles -->
                    <div class="container-fluid py-4" style="margin: 3px 136px;">
                        <div class="row main-section">
                            <div class="col-md-4 col-sm-6 orders oh-order-draft" id="order_draft" style=" overflow: hidden; padding-top: 30px;" t-on-click="onClickDraftOrder">
                                <div class="oh-card" style="box-shadow:2px 4px 8px 2px rgba(0,0,0.3,0.2); display: flex; justify-content: center;" role="button">
                                    <div class="oh-card-body" style="padding: 5px 5px; float: left; width: 100%; height: auto; box-sizing: border-box; margin: 0;">
                                        <div class="stat-widget-one">
                                            <div class="stat-icon cy-mauve-light d-flex justify-content-left align-items-left">
                                                <div style="background:#ff4d94; width:65px; text-align: center;">
                                                    <i class="fa fa-tasks text-mauve" style="font-size:50px;"/>
                                                </div>
                                                <div class="stat_content" style="text-align: center; font-weight: bold; padding-top: 20px; padding-left: 80px;">
                                                    <div class="stat_count_order_draft" style="font-size: 17px;">
                                                        <t t-esc="state.draft"/>
                                                    </div>
                                                    <div class="stat-head" style="font-size: 14px;">Draft Orders</div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <!-- Rented Orders tile -->
                            <div class="col-xl-3 col-sm-6 mb-xl-0 mb-4" id="order_rented" style=" overflow: hidden; padding-top: 30px; margin-left:7px;" t-on-click="onClickRentedOrder">
                                <div class="oh-card" style="box-shadow:2px 4px 8px 2px rgba(0,0,0.3,0.2); display: flex; justify-content: center;" role="button">
                                    <div class="oh-card-body" style="padding: 5px 5px; float: left; width: 100%; height: auto; box-sizing: border-box; margin: 0;">
                                        <div class="stat-widget-one">
                                            <div class="stat-icon cy-mauve-light d-flex justify-content-left align-items-left">
                                                <div style="background:#ff4d94; width:65px; text-align: center;">
                                                    <i class="fa fa-tasks text-mauve" style="font-size:50px;"/>
                                                </div>
                                                <div class="stat_content" style="text-align: center; font-weight: bold; padding-top: 20px; padding-left: 80px;">
                                                    <div class="stat_count_order_rented" style="font-size: 17px;">
                                                        <t t-esc="state.rented"/>
                                                    </div>
                                                    <div class="stat-head" style="font-size: 14px;">Rented Orders</div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <!-- Returned Orders tile -->
                            <div class="col-xl-3 col-sm-6 mb-xl-0 mb-4" id="order_returned"
                            style=" overflow: hidden; padding-top: 30px; margin-left:7px;" t-on-click="onClickReturnedOrder">
                               <div class="oh-card" style="box-shadow:2px 4px 8px 2px rgba(0,0,0.3,0.2); display: flex; justify-content: center;" role="button">
                                    <div class="oh-card-body" style="padding: 5px 5px; float: left; width: 100%; height: auto; box-sizing: border-box; margin: 0;">
                                        <div class="stat-widget-one">
                                            <div class="stat-icon cy-mauve-light d-flex justify-content-left align-items-left">
                                                <div style="background:#ff4d94; width:65px; text-align: center;">
                                                    <i class="fa fa-tasks text-mauve" style="font-size:50px;"/>
                                                </div>
                                                <div class="stat_content" style="text-align: center; font-weight: bold; padding-top: 20px; padding-left: 80px;">
                                                    <div class="stat_count_order_return" style="font-size: 17px;">
                                                        <t t-esc="state.returned"/>
                                                    </div>
                                                    <div class="stat-head" style="font-size: 14px;">Returned Orders</div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- Dashboard Charts -->
                    <div class="col-xs-12 col-sm-12 col-lg-12 col-md-12">
                        <div class="row" style="margin:0px; padding-top: 50px;">
                            <!-- Doughnut chart -->
                            <div class="col-sm-6 col-lg-6 order_graph_view">
                                <div class="oh-card text-color">
                                    <div class="oh-card-body pb-0">
                                        <div class="order_state_div card-shadow" style="text-align: center;">
                                            <h2>Rental Orders</h2> <hr/>
                                        </div>
                                    </div>
                                    <canvas id="orders_by_state" class="state_wise_orders" style="margin-top: 46px;"/>
                                </div>
                            </div>
                            <!-- Pie chart -->
                            <div class="col-sm-6 col-lg-6 pickup_graph_view2">
                                <div class="oh-card text-color">
                                    <div class="oh-card-body pb-0">
                                        <div class="pickup_div card-shadow" style="text-align: center;">
                                            <h2>Pickup and Return</h2>
                                            <hr/>
                                        </div>
                                        <canvas class="pickup_and_return" id="pick_and_return" style="margin-top: 46px;"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <!-- Revenue bar chart -->
                        <div class="row" style="margin:0px; padding-top: 50px;">
                             <div class="col-sm-6 col-lg-6 orders_graph_view">
                                 <div class="oh-card text-color">
                                     <div class="oh-card-body pb-0">
                                         <div class="pickup_div card-shadow" style="text-align: center;">
                                            <h2>Orders Revenue</h2>
                                            <hr/>
                                         </div>
                                         <canvas class="orders_details" id="order_details" style="margin-top: 46px; width: 717px;"/>
                                     </div>
                                 </div>
                             </div>
                        </div>
                    </div>
                </div>
            </section>
        </div>
    </t>
</templates>