<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!-- Restricts users to access only their own documents based on the 'user_id' field within the rental order model. -->
    <record id="rule_cyllo_rental_base_rental_order_own" model="ir.rule">
        <field name="name">User Own documents rule</field>
        <field name="model_id" ref="cyllo_rental_base.model_rental_order"/>
        <field name ="groups" eval ="[(ref ('group_cyllo_rental_base_group_user_own_documents'))]" />
        <field name="domain_force">[('user_id', '=', user.id)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>
    <!-- Grants users to access all documents within the rental order model. -->
    <record id="rule_cyllo_rental_base_rental_order_public" model="ir.rule">
        <field name="name">User All documents rule</field>
        <field name="model_id" ref="cyllo_rental_base.model_rental_order"/>
        <field name="groups" eval="[(ref ('group_cyllo_rental_base_group_user_all_documents'))]" />
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>
    <!-- It grants full read, write, create, and delete permissions to users belonging to the "Manager" group within the rental order model. -->
    <record id="rule_cyllo_rental_base_rental_order_manager" model="ir.rule">
        <field name="name">Manager rule</field>
        <field name="model_id" ref="cyllo_rental_base.model_rental_order"/>
        <field name="groups" eval="[(ref ('group_cyllo_rental_base_group_manager'))]" />
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>
    <!-- Restricts users to access only their own documents based on the 'create_uid' field within the rental contract model. -->
    <record id="rule_cyllo_rental_base_rental_contract_own" model="ir.rule">
        <field name="name">User Own documents rule</field>
        <field name="model_id" ref="cyllo_rental_base.model_rental_contract" />
        <field name ="groups" eval="[(ref ('group_cyllo_rental_base_group_user_own_documents'))]" />
        <field name="domain_force">[('create_uid', '=', user.id)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>
    <!-- Grants users to access all documents within the rental contract model. -->
    <record id="rule_cyllo_rental_base_rental_contract_public" model="ir.rule">
        <field name="name">User All documents rule</field>
        <field name="model_id" ref="cyllo_rental_base.model_rental_contract"/>
        <field name ="groups" eval="[(ref('group_cyllo_rental_base_group_user_all_documents'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>
    <!-- It grants full read, write, create, and delete permissions to users belonging to the "Manager" group within the rental contract model. -->
    <record id="rule_cyllo_rental_base_rental_contract_manager" model="ir.rule">
        <field name="name">Manager rule</field>
        <field name="model_id" ref="cyllo_rental_base.model_rental_contract" />
        <field name ="groups" eval="[(ref ('group_cyllo_rental_base_group_manager'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>
    <!-- Rule to access the records in the "Rental Order" model within a multi-company environment -->
    <record id="rule_rental_order_company" model="ir.rule">
        <field name="name">Rental Order Multi-Company</field>
        <field name="model_id" ref="model_rental_order"/>
        <field name="domain_force">['|',('company_id','=',False), ('company_id', 'in',company_ids)]
        </field>
    </record>
    <!-- Rule to access the rental products within a multi-company environment -->
     <record id="rule_product_product_company" model="ir.rule">
        <field name="name" >Product multi-company</field>
        <field name="model_id" ref="model_product_product"/>
        <field name="domain_force"> ['|', ('company_id', 'parent_of', company_ids), ('company_id', '=', False)]</field>
    </record>
    <!-- Rule to access the records in the "Rental Contract" model within a multi-company environment -->
    <record id="rule_rental_contract_company" model="ir.rule">
        <field name="name">Rental Contract Multi-Company</field>
        <field name="model_id" ref="model_rental_contract"/>
        <field name="domain_force">['|',('company_id','=',False), ('company_id', 'in',company_ids)]
        </field>
    </record>
    <record id="rule_rental_contract_template_company" model="ir.rule">
        <field name="name">Rental Contract Template Multi-Company</field>
        <field name="model_id" ref="model_rental_contract_template"/>
        <field name="domain_force">['|',('company_id','=',False), ('company_id', 'in',company_ids)]
        </field>
    </record>
</odoo>