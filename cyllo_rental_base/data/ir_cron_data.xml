<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Scheduler for creating recurring invoice -->
    <record id="ir_cron_check_rental_contract_expiry" model="ir.cron">
        <field name="name">Check Rental Contract Expiry</field>
        <field name="model_id" ref="model_rental_contract"/>
        <field name="state">code</field>
        <field name="code">model.check_contract_expired()</field>
        <field name="user_id" ref="base.user_root"/>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
    </record>
</odoo>