<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Sequence for rental order -->
    <record id="ir_sequence_rental_order" model="ir.sequence">
        <field name="name">Rental Order</field>
        <field name="code">rental.order</field>
        <field name="prefix">RO</field>
        <field name="padding">4</field>
        <field name="company_id" eval="False"/>
    </record>
    <record id="ir_sequence_rental_contract" model="ir.sequence">
        <field name="name">Rental Contract</field>
        <field name="code">rental.contract</field>
        <field name="prefix">RC</field>
        <field name="padding">4</field>
        <field name="company_id" eval="False"/>
    </record>
</odoo>
