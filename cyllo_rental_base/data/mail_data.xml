<?xml version="1.0" encoding="UTF-8" ?>
<!-- mail template for contract expiration and pickup notification-->
<odoo>
    <record id="mail_template_pickup_mail_notify" model="mail.template">
        <field name="name">Pickup Mail Notify</field>
        <field name="model_id" ref="cyllo_rental_base.model_rental_order"/>
        <field name="subject">Pickup Done</field>
        <field name="body_html" type="html">
            <br/>
            <h4>Dear<t t-out="object.partner_id.name"/>,
                <br/>
                Your rental order<t t-out="object.name"/>,
                has been picked up.
            </h4>
        </field>
    </record>
    <record id="mail_template_contract_expiration_notify" model="mail.template">
        <field name="name">Contract Expiration Notify</field>
        <field name="model_id" ref="cyllo_rental_base.model_rental_contract"/>
        <field name="subject">Contract Expired</field>
        <field name="body_html" type="html">
            <br/>
            <h4>Dear<t t-out="object.partner_id.name"/>,
                <br/>
                Your rental order<t t-out="object.name"/>,
                has been expired.
            </h4>
        </field>
    </record>
</odoo>
