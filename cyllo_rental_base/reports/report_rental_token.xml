<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!-- Action to generate a PDF Rental token. -->
    <record id="report_action_rental_token" model="ir.actions.report">
       <field name="name">Rental Token</field>
       <field name="model">rental.order</field>
       <field name="report_type">qweb-pdf</field>
       <field name="report_name">cyllo_rental_base.report_rental_token</field>
       <field name="report_file">cyllorental_base.report_rental_token</field>
       <field name="paperformat_id" ref="cyllo_rental_base.report_paperformat_custom" />
    </record>
</odoo>
