<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!-- Action to generate a PDF Rental Report. -->
    <record id="report_action_rental_order" model="ir.actions.report">
       <field name="name">Print Rental Order</field>
       <field name="model">rental.order</field>
       <field name="report_type">qweb-pdf</field>
       <field name="report_name">cyllo_rental_base.report_rental_order</field>
       <field name="report_file">cyllo_rental_base.report_rental_order</field>
        <field name="binding_model_id" ref="model_rental_order"/>
        <field name="binding_type">report</field>
    </record>
</odoo>
