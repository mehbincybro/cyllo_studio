<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!-- Layout for the rental order report. -->
    <template id="report_rental_order">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page">
                        <div class="oe_structure">
                            <h2 t-field="doc.name"/>
                            <h5>
                                <div>
                                    <span>
                                        <b>Invoicing and Shipping Address</b>
                                    </span>
                                    <span t-field="doc.partner_id"
                                          t-options="{&quot;widget&quot;: &quot;contact&quot;, &quot;fields&quot;: [&quot;address&quot;,
                                    &quot;name&quot;, &quot;phone&quot;], &quot;no_marker&quot;: True}"/>
                                </div>
                                <br/>
                                <br/>
                                <div>
                                    <span>
                                        <b>Order Date :<![CDATA[&nbsp;]]></b>
                                    </span>
                                    <span t-field="doc.date_order"/>
                                </div>
                                <br/>
                                <br/>
                            </h5>
                            <table class="table table-condensed" t-if="doc.order_line_ids">
                                <thead>
                                    <tr>
                                        <th>Product</th>
                                        <th>Quantity</th>
                                        <th>Pickup Date</th>
                                        <th>Return Date</th>
                                        <th>Duration</th>
                                        <th>Unit Price</th>
                                        <th>Taxes</th>
                                        <th>Tax excl.</th>
                                        <th>Tax incl.</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr t-foreach="doc.order_line_ids"
                                   t-as="line">
                                        <td>
                                            <span t-field="line.product_id"/>
                                        </td>
                                        <td>
                                            <span t-field="line.product_uom_qty"/>
                                        </td>
                                        <td>
                                            <span t-field="line.pickup_date"/>
                                        </td>
                                        <td>
                                            <span t-field="line.return_date"/>
                                        </td>
                                        <td>
                                            <span t-field="line.duration"/>
                                        </td>
                                        <td>
                                            <span t-field="line.price_unit"/>
                                        </td>
                                        <td>
                                            <span t-field="line.tax_ids"/>
                                        </td>
                                        <td>
                                            <span t-field="line.price_subtotal"/>
                                        </td>
                                        <td>
                                            <span t-field="line.price_total"/>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                            <div class="clearfix">
                                <div id="total" class="row">
                                    <div class="col-6 ms-auto">
                                        <table class="table table-sm table-borderless"
                                               style="page-break-inside: avoid; position:relative;"  t-if="doc.order_line_ids">
                                            <tbody>
                                                <tr class="border-black o_subtotal"
                                                    style="">
                                                    <td>
                                                        <strong>Untaxed Amount:
                                                        </strong>
                                                    </td>
                                                    <td class="text-end">
                                                        <span>
                                                            <span t-field="doc.currency_id.symbol"/>
                                                            <![CDATA[&nbsp;]]>
                                                            <span t-esc="doc.amount_untaxed"/>
                                                        </span>
                                                    </td>
                                                </tr>
                                                <tr style="">
                                                    <td>
                                                        <span class="text-nowrap">
                                                            Tax:
                                                        </span>
                                                    </td>
                                                    <td class="text-end o_price_total">
                                                        <span class="text-nowrap">
                                                            <span t-field="doc.currency_id.symbol"/>
                                                            <![CDATA[&nbsp;]]>
                                                            <span t-esc="doc.amount_tax"/>
                                                        </span>
                                                    </td>
                                                </tr>
                                                <tr class="border-black o_total">
                                                    <td>
                                                        <strong>Total:
                                                        </strong>
                                                    </td>
                                                    <td class="text-end">
                                                        <span class="text-nowrap">
                                                            <span t-field="doc.currency_id.symbol"/>
                                                            <![CDATA[&nbsp;]]>
                                                            <span t-esc="doc.amount_total"/>
                                                        </span>
                                                    </td>
                                                </tr>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
