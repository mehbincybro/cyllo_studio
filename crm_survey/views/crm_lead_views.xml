<?xml version="1.0"?>
<odoo>
    <record id="view_crm_lead_view_form_inherit_crm_survey" model="ir.ui.view">
        <field name="name">crm.lead.form.inherit.crm.survey</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='action_sale_quotations_new']" position="after">
                <button name="action_create_survey" type="object"
                        string="Create Survey" class="oe_highlight"
                        />
            </xpath>
        </field>
    </record>
</odoo>
