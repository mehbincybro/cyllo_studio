<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="survey_question_form_inherit_crm_survey" model="ir.ui.view">
        <field name="name">survey.question.form.inherit.crm.survey</field>
        <field name="model">survey.question</field>
        <field name="inherit_id" ref="survey.survey_question_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='triggering_answer_ids']" position="after">
                <field name="lead_field_id" options="{'no_create': True, 'no_open': True}"/>
            </xpath>
        </field>
    </record>
</odoo>
