<?xml version="1.0" encoding="UTF-8" ?>
<!--  This is a template for a systray theme menu  -->
<templates id="template">
    <t t-name="systrayThemeMenu" owl="1">
        <div t-ref="root" class="systray_dark_root">
            <!--  Switch for Day / Night Mode  -->
            <label class="cy_switch" title="Day / Night Mode" t-on-click.stop.prevent="onToggleClick">
                <div class="cy_image-checkbox">
                    <label class="cy_switch">
                        <input type="checkbox" id="cy_check"/>
                        <span class="cy_slider cy_round" t-att-class="state.checked ? 'cy_apply':'cy_not_apply'"/>
                        <div class="cy_picture cy_moon" t-att-class="state.checked ? 'cy_checked':'cy_not_checked'"/>
                    </label>
                </div>
            </label>
        </div>
    </t>
</templates>