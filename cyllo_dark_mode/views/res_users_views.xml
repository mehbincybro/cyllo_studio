<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!--Inherits users form view-->
    <record id="view_res_users_form" model="ir.ui.view">
        <field name="name">view.res.users.form</field>
        <field name="model">res.users</field>
        <field name="priority" eval="0"/>
        <field name="inherit_id" ref="hr.res_users_view_form_profile"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='tz']" position="before">
                <field name="dark_mode_selection"/>
                <field name="start_time" widget="timepicker" invisible="dark_mode_selection == 'none'"/>
                <field name="end_time" widget="timepicker" invisible="dark_mode_selection == 'none'"/>
            </xpath>
        </field>
    </record>
</odoo>