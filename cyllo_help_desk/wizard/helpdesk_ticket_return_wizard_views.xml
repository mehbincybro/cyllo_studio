<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="helpdesk_ticket_return_wizard_view_form" model="ir.ui.view">
        <field name="name">helpdesk.ticket.return.wizard.view.form</field>
        <field name="model">helpdesk.ticket.return.wizard</field>
        <field name="arch" type="xml">
            <form string="Select Delivery to Return">
                <group>
                    <field name="ticket_id" invisible="1"/>
                    <field name="sale_order_id" invisible="1"/>
                    <field name="picking_id" domain="[('sale_id', '=', sale_order_id), ('state', '=', 'done'), ('picking_type_code', '=', 'outgoing')]"/>
                </group>
                <footer>
                    <button name="action_confirm" string="Return Selection" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_helpdesk_ticket_return_wizard" model="ir.actions.act_window">
        <field name="name">Select Delivery for Return</field>
        <field name="res_model">helpdesk.ticket.return.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
