<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <record model="ir.module.category" id="cyllo_help_desk_groups">
        <field name="name">Help Desk</field>
        <field name="description">User access level for Helpdesk module
        </field>
        <field name="sequence">10</field>
    </record>
    <record id="cyllo_help_desk_user" model="res.groups">
        <field name="name">User</field>
        <field name="category_id" ref="cyllo_help_desk_groups"/>
    </record>
    <record id="cyllo_help_desk_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="category_id" ref="cyllo_help_desk_groups"/>
        <field name="implied_ids" eval="[(4, ref('cyllo_help_desk_user'))]"/>
    </record>

    <record id="helpdesk_ticket_portal_rule" model="ir.rule">
        <field name="name">Portal Ticket Access</field>
        <field name="model_id" ref="model_helpdesk_ticket"/>
        <field name="domain_force">[('customer_id', '=', user.partner_id.id)]</field>
        <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

</odoo>
