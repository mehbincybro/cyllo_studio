<?xml version="1.0" encoding="UTF-8" ?>
<odoo noupdate="1">
    <record model="helpdesk.stage" id="new_ticket">
        <field name="name">New</field>
        <field name="sequence">1</field>
    </record>
    <record model="helpdesk.stage" id="in_progress_ticket">
        <field name="name">In Progress</field>
        <field name="sequence">2</field>
    </record>
    <record model="helpdesk.stage" id="on_hold_ticket">
        <field name="name">On Hold</field>
        <field name="sequence">3</field>
    </record>
    <record model="helpdesk.stage" id="solved_ticket">
        <field name="name">Solved</field>
        <field name="is_closed" eval="True"/>
        <field name="sequence">4</field>
    </record>
    <record model="helpdesk.stage" id="canceled_ticket">
        <field name="name">Canceled</field>
        <field name="is_closed" eval="True"/>
        <field name="fold" eval="False"/>
        <field name="sequence">5</field>
    </record>
</odoo>