<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="1">
        <!-- ONBOARDING STEPS -->
        <record id="onboarding_onboarding_step_helpdesk_ticket_confirmation" model="onboarding.onboarding.step">
            <field name="title">Ticket Confirmation</field>
            <field name="description">step 2</field>
            <field name="button_text">step 3</field>
            <field name="panel_step_open_action_name">action_open_step_helpdesk_ticket_confirmation</field>
            <field name="step_image" type="base64" file="base/static/img/onboarding_default.png"/>
            <field name="step_image_filename">onboarding_default.png</field>
            <field name="step_image_alt">Onboarding Ticket Confirmation</field>
            <field name="sequence">6</field>
        </record>
        <record id="onboarding_onboarding_step_sample_ticket" model="onboarding.onboarding.step">
            <field name="title">Sample Ticket</field>
            <field name="description">step 2</field>
            <field name="button_text">step 3</field>
            <field name="panel_step_open_action_name">action_open_step_sample_ticket</field>
            <field name="step_image" type="base64" file="base/static/img/onboarding_sample-quotation.png"/>
            <field name="step_image_filename">onboarding_sample-quotation.png</field>
            <field name="step_image_alt">Onboarding Sample Ticket</field>
            <field name="sequence">7</field>
        </record>
        <!-- ONBOARDING PANEL -->
        <record id="onboarding_onboarding_helpdesk_ticket" model="onboarding.onboarding">
            <field name="name">Helpdesk Ticket Onboarding</field>
            <field name="step_ids" eval="[
            Command.link(ref('cyllo_help_desk.onboarding_onboarding_step_helpdesk_ticket_confirmation')),
            Command.link(ref('cyllo_help_desk.onboarding_onboarding_step_sample_ticket')),
            ]"/>
            <field name="route_name">helpdesk_ticket</field>
            <field name="panel_close_action_name">action_close_panel_helpdesk_ticket</field>
        </record>
    </data>
</odoo>