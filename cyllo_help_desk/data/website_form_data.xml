<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="model_helpdesk_ticket" model="ir.model">
            <field name="website_form_key">create_ticket</field>
            <field name="website_form_default_field_id" ref="cyllo_help_desk.field_helpdesk_ticket__description"/>
            <field name="website_form_access">True</field>
            <field name="website_form_label">Create a Ticket</field>
        </record>

        <function model="ir.model.fields" name="formbuilder_whitelist">
            <value>helpdesk.ticket</value>
            <value eval="[
                'name',
                'description',
                'email',
                'phone',
                'team_id',
                'attachment_ids',
            ]"/>
        </function>
    </data>
</odoo>
