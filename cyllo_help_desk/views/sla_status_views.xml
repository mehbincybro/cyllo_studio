<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="1">
        <record id="ir_cron_scheduler_status_update_action" model="ir.cron">
            <field name="name">SLA Status</field>
            <field name="model_id" ref="model_sla_status"/>
            <field name="state">code</field>
            <field name="code">model.status_update()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">1</field>
            <field name="nextcall" eval="DateTime.now()"/>
            <field name="interval_type">hours</field>
            <field name="numbercall">-1</field>
        </record>
    </data>
</odoo>