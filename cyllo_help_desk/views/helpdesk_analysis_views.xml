<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!-- Action for helpdesk analysis -->
    <record id="helpdesk_analysis_action" model="ir.actions.act_window">
        <field name="name">HelpDesk Analysis</field>
        <field name="res_model">helpdesk.ticket</field>
        <field name="view_mode">pivot,graph</field>
    </record>
    <!-- Graph view for helpdesk analysis -->
    <record id="helpdesk_analysis_view_graph" model="ir.ui.view">
        <field name="name">helpdesk.analysis.view.graph</field>
        <field name="model">helpdesk.ticket</field>
        <field name="arch" type="xml">
            <graph>
            </graph>
        </field>
    </record>
    <!-- Pivot view for helpdesk analysis -->
    <record id="helpdesk_analysis_view_pivot" model="ir.ui.view">
        <field name="name">helpdesk.analysis.view.pivot</field>
        <field name="model">helpdesk.ticket</field>
        <field name="arch" type="xml">
            <pivot sample="1">
                <field name="open_ticket_average_hours" type="measure"/>
                <field name="high_priority_ticket_average_hours" type="measure"/>
                <field name="urgent_ticket_average_hours" type="measure"/>
            </pivot>
        </field>
    </record>
</odoo>