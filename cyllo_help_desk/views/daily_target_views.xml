<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="daily_target_action" model="ir.actions.act_window">
        <field name="name">Daily Targets</field>
        <field name="res_model">daily.target</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="daily_target_view_tree" model="ir.ui.view">
        <field name="name">daily.target.view.tree</field>
        <field name="model">daily.target</field>
        <field name="arch" type="xml">
            <tree default_order="date desc">
                <field name="date"/>
                <field name="user_id"/>
                <field name="team_id"/>
                <field name="ticket_count"/>
                <field name="success_rate"/>
                <field name="average_rating"/>
                <field name="achieved_ticket_count"/>
                <field name="achieved_success_rate"/>
                <field name="achieved_average_rating"/>
            </tree>
        </field>
    </record>

    <record id="daily_target_view_form" model="ir.ui.view">
        <field name="name">daily.target.view.form</field>
        <field name="model">daily.target</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="date"/>
                            <field name="user_id"/>
                            <field name="team_id"/>
                        </group>
                        <group string="Targets">
                            <field name="ticket_count"/>
                            <field name="success_rate"/>
                            <field name="average_rating"/>
                        </group>
                        <group string="Achieved">
                            <field name="achieved_ticket_count" readonly="1"/>
                            <field name="achieved_success_rate" readonly="1"/>
                            <field name="achieved_average_rating" readonly="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
