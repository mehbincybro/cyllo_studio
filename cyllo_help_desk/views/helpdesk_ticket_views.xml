<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!-- Action for helpdesk ticket -->
    <record id="helpdesk_ticket_action" model="ir.actions.act_window">
        <field name="name">Tickets</field>
        <field name="res_model">helpdesk.ticket</field>
        <field name="view_mode">tree,form,kanban,activity,pivot</field>
    </record>
    <record id="helpdesk_ticket_sequence" model="ir.sequence">
        <field name="name">Ticket ID</field>
        <field name="code">helpdesk.ticket</field>
        <field name="prefix">HT</field>
        <field name="padding">5</field>
    </record>
    <!-- Tree view for helpdesk ticket -->
    <record id="helpdesk_ticket_view_tree" model="ir.ui.view">
        <field name="name">helpdesk.ticket.view.tree</field>
        <field name="model">helpdesk.ticket</field>
        <field name="arch" type="xml">
            <tree default_order="priority desc" class="o_helpdesk_list">
                <field name="stage_name" invisible="1"/>
                <field name="priority" widget="priority"/>
                <field name="name"/>
                <field name="team_id"/>
                <field name="customer_id"/>
                <field name="date"/>
                <field name="source"/>
                <field name="user_id"/>
                <field name="company_id"/>
                <field name="stage_id" widget="badge"
                       decoration-success="stage_name == 'Solved'"
                       decoration-info="stage_name == 'New'"
                       decoration-primary="stage_name == 'In Progress'"
                       decoration-muted="stage_name == 'Canceled'"/>
                <field name="sla_failed" invisible="1"/>
                <field name="sla_status_label" widget="badge" decoration-danger="sla_failed"
                       invisible="not sla_failed" string="SLA Status"/>
            </tree>
        </field>
    </record>
    <!-- Kanban view for helpdesk tickets -->
    <record id="helpdesk_ticket_view_kanban" model="ir.ui.view">
        <field name="name">helpdesk.ticket.view.kanban</field>
        <field name="model">helpdesk.ticket</field>
        <field name="arch" type="xml">
            <kanban default_group_by="stage_id" quick_create="True"
                    default_order="stage_id" groups_draggable="True"
                    records_draggable="1" group_create="True"
                    class="o_slide_kanban o_helpdesk_kanban" sample="1">
                <field name="name"/>
                <field name="team_id"/>
                <field name="customer_id"/>
                <field name="user_id"/>
                <field name="stage_id"/>
                <field name="sla_failed"/>
                <progressbar field="activity_state"
                             colors='{"planned": "success", "today": "warning", "overdue": "danger"}'/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_global_click">
                            <div class="row mb4">
                                <div>
                                    <h3>
                                        <field name="name"/>
                                        <span t-if="record.sla_failed.raw_value" class="badge rounded-pill text-bg-danger float-end" style="font-size: 10px;">SLA Failed</span>
                                    </h3>
                                </div>
                            </div>
                            <div>
                                <span>
                                    <field name="team_id"/>
                                </span>
                            </div>
                            <div class="row">
                                <div class="col-12">
                                    <div>
                                        <field name="customer_id"/>
                                    </div>
                                    <div>
                                        <field name="user_id"/>
                                    </div>
                                    <div>
                                        <field name="activity_ids"
                                               widget="kanban_activity"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>
    <record id="helpdesk_ticket_view_form" model="ir.ui.view">
        <field name="name">helpdesk.ticket.view.form</field>
        <field name="model">helpdesk.ticket</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_toggle_sla_pause" type="object" string="Pause SLA" class="btn-warning" invisible="not sla_flag or sla_paused"/>
                    <button name="action_toggle_sla_pause" type="object" string="Resume SLA" class="oe_highlight" invisible="not sla_flag or not sla_paused"/>
                    <button name="action_create_sale_order" type="object" string="Create Sales Order" invisible="not customer_id or not use_sale_order"/>
                    <button name="action_create_refund" type="object" string="Create Refund" invisible="not customer_id or not use_credit_notes"/>
                    <button name="action_create_coupon" type="object" string="Create Coupon" invisible="not customer_id or not use_coupons"/>
                    <button name="action_create_field_service_request" type="object" string="Create Field Service" invisible="not customer_id or not use_field_service"/>
                    <button name="action_create_repair" type="object" string="Create Repair Order" invisible="not customer_id or not use_repairs"/>
                    <button name="action_create_return" type="object" string="Create Return / Replacement" invisible="not customer_id or (not use_returns and not use_replacements)"/>
                    <button name="action_create_crm_lead" type="object" string="Create CRM Lead" invisible="not customer_id"/>
                    <field name="stage_id" widget="statusbar"
                           options="{'clickable': '1'}"/>
                </header>
                <sheet>
                    <widget name="web_ribbon" title="SLA Failed" bg_color="bg-danger" invisible="not sla_failed"/>
                    <widget name="web_ribbon" title="Under Warranty" bg_color="bg-success" invisible="warranty_status != 'under_warranty'"/>
                    <widget name="web_ribbon" title="Warranty Expired" bg_color="bg-danger" invisible="warranty_status != 'expired'"/>
                    <widget name="web_ribbon" title="No Warranty" bg_color="bg-info" invisible="warranty_status != 'none'"/>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_sale_orders" type="object" class="oe_stat_button" icon="fa-usd" invisible="not use_sale_order or sale_order_count == 0">
                            <field name="sale_order_count" widget="statinfo" string="Sales Orders"/>
                        </button>
                        <button name="action_view_refunds" type="object" class="oe_stat_button" icon="fa-reply" invisible="not use_credit_notes or refund_count == 0">
                            <field name="refund_count" widget="statinfo" string="Refunds"/>
                        </button>
                        <button name="action_view_coupons" type="object" class="oe_stat_button" icon="fa-ticket" invisible="not use_coupons or coupon_count == 0">
                            <field name="coupon_count" widget="statinfo" string="Coupons"/>
                        </button>
                        <button name="action_view_field_service_requests" type="object" class="oe_stat_button" icon="fa-tasks" invisible="not use_field_service and field_service_request_count == 0">
                            <field name="field_service_request_count" widget="statinfo" string="Field Service"/>
                        </button>
                        <button name="action_view_repairs" type="object" class="oe_stat_button" icon="fa-wrench" invisible="not use_repairs or repair_count == 0">
                            <field name="repair_count" widget="statinfo" string="Repairs"/>
                        </button>
                        <button name="action_view_pickings" type="object" class="oe_stat_button" icon="fa-truck" invisible="not use_returns or picking_count == 0">
                            <field name="picking_count" widget="statinfo" string="Returns"/>
                        </button>
                        <button name="action_view_crm_leads" type="object" class="oe_stat_button" icon="fa-bullseye" invisible="crm_lead_count == 0">
                            <field name="crm_lead_count" widget="statinfo" string="CRM Leads"/>
                        </button>
                        <button name="action_view_customer_sale_orders" type="object" class="oe_stat_button" icon="fa-usd" invisible="not use_sale_order or customer_sale_order_count == 0">
                            <field name="customer_sale_order_count" widget="statinfo" string="Customer Sales"/>
                        </button>
                        <button name="action_view_customer_purchase_orders" type="object" class="oe_stat_button" icon="fa-shopping-cart" invisible="customer_purchase_order_count == 0">
                            <field name="customer_purchase_order_count" widget="statinfo" string="Customer Purchases"/>
                        </button>
                        <button name="action_view_customer_invoices" type="object" class="oe_stat_button" icon="fa-file-text-o" invisible="customer_invoice_count == 0">
                            <field name="customer_invoice_count" widget="statinfo" string="Customer Invoices"/>
                        </button>
                        <button name="action_view_customer_subscriptions" type="object" class="oe_stat_button" icon="fa-refresh" invisible="customer_subscription_count == 0">
                            <field name="customer_subscription_count" widget="statinfo" string="Customer Subscriptions"/>
                        </button>
                    </div>
                    <div class="alert alert-warning text-center o_form_header" role="alert" invisible="not has_duplicates">
                        <strong>Warning!</strong> Potential duplicate tickets found for this customer.
                        <button name="action_view_duplicates" type="object" class="btn btn-link py-0" string="View Duplicates"/>
                    </div>
                    <group>
                        <field name="name" placeholder="Eg: Product arrived damaged"/>
                        <field name="sla_flag" invisible="1"/>
                        <field name="sla_paused" invisible="1"/>
                        <field name="stage_name" invisible="1"/>
                        <field name="sla_ids" widget="many2many_tags" invisible="not sla_flag"/>
                        <field name="sla_progress" widget="progressbar" invisible="not sla_flag or stage_name == 'Solved'"/>
                        <field name="sla_deadline" invisible="not sla_flag or not sla_ids"/>
                        <field name="sla_reached_date" invisible="not sla_flag or not sla_reached_date"/>
                        <field name="sla_failed" invisible="1"/>
                        <field name="has_duplicates" invisible="1"/>
                        <field name="use_sale_order" invisible="1"/>
                        <field name="use_sla" invisible="1"/>
                        <field name="use_credit_notes" invisible="1"/>
                        <field name="use_coupons" invisible="1"/>
                        <field name="use_returns" invisible="1"/>
                        <field name="use_replacements" invisible="1"/>
                        <field name="use_repairs" invisible="1"/>
                        <field name="use_timesheet" invisible="1"/>
                    </group>
                    <group invisible="1">
                        <field name="use_field_service"/>
                        <field name="timesheet_bool"/>
                        <field name="sale_order_ids"/>
                        <field name="refund_ids"/>
                        <field name="field_service_request_ids"/>
                        <field name="task_ids"/>
                        <field name="repair_ids"/>
                        <field name="crm_lead_ids"/>
                    </group>
                    <group col="2">
                        <group>
                            <separator string="Customer Details"/>
                            <field name="date"/>
                            <field name="closed_date" invisible="1"/>
                            <field name="customer_id"/>
                            <field name="email"/>
                            <field name="phone"/>
                            <field name="source" readonly="1"/>
                            <field name="company_id"/>
                            <field name="invoice_id" domain="[
                                ('move_type', '=', 'out_invoice'),
                                ('partner_id', 'child_of', customer_id),
                                ('state', 'not in', ('draft', 'cancel'))
                            ]"/>
                            <field name="invoice_line_ids" widget="many2many_tags" domain="[('move_id', '=', invoice_id), ('display_type', '=', 'product')]"/>
                            <field name="sale_order_id" domain="[
                                ('partner_id', 'child_of', customer_id),
                                ('state', 'in', ['sale', 'done'])
                            ]"/>
                            <field name="sale_order_line_id"
                                   domain="[('order_id', '=', sale_order_id)]"
                                   invisible="not sale_order_id or not use_product_warranty"/>
                            <field name="use_product_warranty" invisible="1"/>
                            <field name="warranty_status" invisible="1"/>
                        </group>
                        <group>
                            <separator string="Ticket Details"/>
                            <field name="sequence" invisible="1"/>
                            <field name="team_id"/>
                            <field name="priority" widget="priority"/>
                            <field name="team_member_ids" invisible="1"/>
                            <field name="user_id" domain="[('id', 'in', team_member_ids)]"/>
                            <field name="category_id"/>
                            <field name="tag_ids" widget="many2many_tags"/>
                            <field name="canned_response_ids" widget="many2many_tags"/>
                            <field name="skill_ids" widget="many2many_tags"/>
                            <field name="parent_id" domain="[('id', '!=', active_id)]"/>

                        </group>
                    </group>
                    <notebook>
                        <page string="Description">
                            <field name="description"/>
                        </page>
                        <page string="Internal Notes" groups="cyllo_help_desk.cyllo_help_desk_user">
                            <field name="internal_notes"/>
                        </page>
                        <page string="Timesheet" invisible="not timesheet_bool or not use_timesheet">
                            <field name="timesheet_ids"/>
                        </page>
                        <page string="Sub-tickets">
                            <field name="child_ids">
                                <tree editable="bottom">
                                    <field name="ticket"/>
                                    <field name="name"/>
                                    <field name="user_id"/>
                                    <field name="customer_id"/>
                                    <field name="stage_id"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Dependencies">
                            <field name="dependency_ids" widget="many2many">
                                <tree editable="bottom">
                                    <field name="ticket"/>
                                    <field name="name"/>
                                    <field name="stage_id"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Attachments">
                            <field name="attachment_ids" widget="many2many_binary" string="Attach Files"/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>
    <record id="helpdesk_ticket_view_search" model="ir.ui.view">
        <field name="name">helpdesk.ticket.view.search</field>
        <field name="model">helpdesk.ticket</field>
        <field name="arch" type="xml">
            <search>
                <filter string="My Tickets" name="user_id"
                        domain="[('user_id','=', uid)]"/>
                <separator/>
                <filter string="Open Tickets" name="stage_id"
                        domain="[('stage_id.is_closed','=', False)]"/>
                <filter string="Closed Tickets" name="closed_tickets"
                        domain="[('stage_id.is_closed','=', True)]"/>
                <separator/>
                <filter string="High Priority Tickets" name="high_priority"
                        domain="[('priority','=', '2')]"/>
                <filter string="Urgent Tickets" name="urgent"
                        domain="[('priority','=', '3')]"/>
                <filter string="SLA Success"
                        name="sla_success"
                        domain="[('sla_failed','=', False)]"/>
                <separator/>
                <filter string="Team Tickets" name="team"
                            domain="[('team_member_ids', 'in', [uid])]"/>
                <separator/>
                <filter string="Unassigned Tickets" name="unassigned"
                        domain="[('user_id','=', False)]"/>
                <filter string="Failed Tickets" name="failed"
                        domain="[('sla_failed','=', True)]"/>
                <filter string="Closed Last 7 Days"
                        name="closed_last_seven_days"
                        domain="[('closed_date','>', (datetime.datetime.now() - datetime.timedelta(days=6)))]"/>
<!--                <filter string="Closed Today" name="closed_today"-->
<!--                        domain="[('is_closed_today','=', True)]"/>-->
                <group expand="0" string="Group By">
                    <filter string="Team" name="group_by_team" context="{'group_by': 'team_id'}"/>
                    <filter string="User" name="group_by_user" context="{'group_by': 'user_id'}"/>
                    <filter string="Stage" name="group_by_stage" context="{'group_by': 'stage_id'}"/>
                    <filter string="Source" name="group_by_source" context="{'group_by': 'source'}"/>
                    <filter string="Priority" name="group_by_priority" context="{'group_by': 'priority'}"/>
                </group>
            </search>
        </field>
    </record>
