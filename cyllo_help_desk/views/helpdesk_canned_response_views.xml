<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="helpdesk_canned_response_action" model="ir.actions.act_window">
        <field name="name">Canned Responses</field>
        <field name="res_model">helpdesk.canned.response</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="helpdesk_canned_response_view_tree" model="ir.ui.view">
        <field name="name">helpdesk.canned.response.view.tree</field>
        <field name="model">helpdesk.canned.response</field>
        <field name="arch" type="xml">
            <tree editable="bottom">
                <field name="source"/>
                <field name="substitution"/>
            </tree>
        </field>
    </record>

    <record id="helpdesk_canned_response_view_form" model="ir.ui.view">
        <field name="name">helpdesk.canned.response.view.form</field>
        <field name="model">helpdesk.canned.response</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="source"/>
                        <field name="substitution"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
