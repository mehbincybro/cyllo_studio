<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Action for helpdesk tag -->
    <record id="helpdesk_tag_action" model="ir.actions.act_window">
        <field name="name">Tag</field>
        <field name="res_model">helpdesk.tag</field>
        <field name="view_mode">tree,form</field>
    </record>
    <!-- Tree view for helpdesk tag -->
    <record id="helpdesk_tag_view_tree" model="ir.ui.view">
        <field name="name">helpdesk.tag.view.tree</field>
        <field name="model">helpdesk.tag</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
            </tree>
        </field>
    </record>
    <!-- Form view for helpdesk tag -->
    <record id="helpdesk_tag_view_form" model="ir.ui.view">
        <field name="name">helpdesk.tag.view.form</field>
        <field name="model">helpdesk.tag</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="description"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
