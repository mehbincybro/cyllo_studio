<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Action for helpdesk stage -->
    <record id="helpdesk_stage_action" model="ir.actions.act_window">
        <field name="name">Stage</field>
        <field name="res_model">helpdesk.stage</field>
        <field name="view_mode">tree,form</field>
    </record>
    <!-- Tree view for helpdesk stage -->
    <record id="helpdesk_stage_view_tree" model="ir.ui.view">
        <field name="name">helpdesk.stage.view.tree</field>
        <field name="model">helpdesk.stage</field>
        <field name="arch" type="xml">
            <tree default_order="sequence">
                <field name="name"/>
                <field name="fold"/>
                <field name="is_closed"/>
            </tree>
        </field>
    </record>
    <!-- Form view for helpdesk stage -->
    <record id="helpdesk_stage_view_form" model="ir.ui.view">
        <field name="name">helpdesk.stage.view.form</field>
        <field name="model">helpdesk.stage</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="sequence"/>
                        <field name="fold"/>
                        <field name="is_closed"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
