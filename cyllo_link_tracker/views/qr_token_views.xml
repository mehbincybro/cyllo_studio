<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ══════════════════════════════════════════════════════════
         QR CODES (OPTIMISED VIEW)
         Model: qr.download.token
         Purpose: One single screen for all QR logic. Kanban by default.
         Inside the form view, you see Scanned Records and Raw Events.
         ══════════════════════════════════════════════════════════ -->

    <!-- Kanban View: Default view showing all QR codes -->
    <record id="view_qr_token_overview_kanban" model="ir.ui.view">
        <field name="name">qr.download.token.overview.kanban</field>
        <field name="model">qr.download.token</field>
        <field name="arch" type="xml">
            <kanban default_group_by="tracking_status" class="o_kanban_small_column" create="0">
                <field name="name"/>
                <field name="report_id"/>
                <field name="tracking_status"/>
                <field name="is_scanned"/>
                <field name="scan_count"/>
                <field name="last_scanned_at"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click o_kanban_record"
                             t-attf-style="border-left: 4px solid #{record.tracking_status.raw_value == 'tracked_scanned' ? '#28a745' : record.tracking_status.raw_value == 'tracked_unscanned' ? '#ffc107' : '#6c757d'}">
                            <div class="oe_kanban_content p-2">
                                <!-- Status Badge -->
                                <div class="mb-2">
                                    <t t-if="record.tracking_status.raw_value == 'tracked_scanned'">
                                        <span class="badge badge-success py-1 px-2">✓ Tracked &amp; Scanned</span>
                                    </t>
                                    <t t-elif="record.tracking_status.raw_value == 'tracked_unscanned'">
                                        <span class="badge badge-warning py-1 px-2">⏳ Tracked — Not Scanned</span>
                                    </t>
                                    <t t-else="">
                                        <span class="badge badge-secondary py-1 px-2">✗ Not Tracked</span>
                                    </t>
                                </div>
                                <strong class="o_kanban_record_title"><field name="name"/></strong>
                                <div class="text-muted small mt-1">
                                    <i class="fa fa-file-text-o mr-1"/>
                                    <field name="report_id"/>
                                </div>
                                <div class="mt-2 d-flex justify-content-between align-items-center">
                                    <span class="text-muted small">
                                        Scans: <strong><field name="scan_count"/></strong>
                                    </span>
                                    <span t-if="record.last_scanned_at.raw_value" class="text-muted small">
                                        <field name="last_scanned_at" widget="date"/>
                                    </span>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Form View: See Scanned Records inside the QR code -->
    <record id="view_qr_token_overview_form" model="ir.ui.view">
        <field name="name">qr.download.token.overview.form</field>
        <field name="model">qr.download.token</field>
        <field name="arch" type="xml">
            <form string="QR Code Detail" create="0">
                <sheet>
                    <field name="track_analytics" invisible="1"/>
                    <field name="is_scanned" invisible="1"/>
                    <field name="report_model" invisible="1"/>
                    
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>

                    <!-- Tracked + Scanned -->
                    <div class="alert alert-success mb-3" role="alert"
                         invisible="not track_analytics or not is_scanned">
                        <span>
                            <i class="fa fa-check-circle fa-lg mr-2"/>
                            <strong>Tracked &amp; Scanned</strong> — Analytics are ON and this QR has been scanned.
                        </span>
                    </div>
                    <!-- Tracked but NOT scanned -->
                    <div class="alert alert-warning mb-3" role="alert"
                         invisible="not track_analytics or is_scanned">
                        <i class="fa fa-clock-o fa-lg mr-2"/>
                        <strong>Tracked — Not Yet Scanned</strong> — Analytics are ON but no scans recorded yet.
                    </div>
                    <!-- Not tracked -->
                    <div class="alert alert-secondary mb-3" role="alert"
                         invisible="track_analytics">
                        <i class="fa fa-times-circle fa-lg mr-2"/>
                        <strong>Not Tracked</strong> — Analytics are OFF for this QR code.
                    </div>

                    <group>
                        <group>
                            <field name="report_id" readonly="1"/>
                            <field name="track_analytics" readonly="1" string="Analytics Enabled"/>
                        </group>
                        <group>
                            <field name="scan_count" readonly="1" string="Total Scans"/>
                            <field name="last_scanned_at" readonly="1"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Scanned Records" name="scanned_records">
                            <field name="record_status_ids" readonly="1" nolabel="1">
                                <tree create="0" edit="0" delete="0" 
                                      decoration-success="is_scanned">
                                    <field name="record_name" string="Record Reference"/>
                                    <field name="is_scanned" string="Scanned?" widget="boolean"/>
                                    <field name="scan_count" string="Times Scanned"/>
                                    <field name="last_scanned_at" string="Last Scanned At"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Raw Scan Events" name="scan_events">
                            <field name="scan_event_ids" readonly="1" nolabel="1">
                                <tree create="0" edit="0" delete="0">
                                    <field name="scanned_at" string="Scanned At"/>
                                    <field name="record_reference" string="Record"/>
                                    <field name="ip_address" string="IP"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Tree View: fallback -->
    <record id="view_qr_token_overview_tree" model="ir.ui.view">
        <field name="name">qr.download.token.overview.tree</field>
        <field name="model">qr.download.token</field>
        <field name="arch" type="xml">
            <tree string="QR Codes" create="0">
                <field name="name"/>
                <field name="report_id"/>
                <field name="tracking_status" widget="badge"
                       decoration-success="tracking_status == 'tracked_scanned'"
                       decoration-warning="tracking_status == 'tracked_unscanned'"
                       decoration-danger="tracking_status == 'not_tracked'"/>
                <field name="scan_count"/>
                <field name="last_scanned_at"/>
            </tree>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_qr_token_overview_search" model="ir.ui.view">
        <field name="name">qr.download.token.overview.search</field>
        <field name="model">qr.download.token</field>
        <field name="arch" type="xml">
            <search string="Search QR Codes">
                <field name="name" string="QR Code"/>
                <field name="report_id"/>
                <filter string="Tracked ✓" name="filter_tracked" domain="[('track_analytics','=',True)]"/>
                <filter string="Not Tracked ✗" name="filter_not_tracked" domain="[('track_analytics','=',False)]"/>
                <separator/>
                <filter string="Scanned ✓" name="filter_scanned" domain="[('is_scanned','=',True)]"/>
                <group expand="0" string="Group By">
                    <filter string="Report" name="group_by_report" context="{'group_by': 'report_id'}"/>
                    <filter string="Status" name="group_by_status" context="{'group_by': 'tracking_status'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Window Action: KANBAN first -->
    <record id="action_qr_token_overview" model="ir.actions.act_window">
        <field name="name">QR Codes</field>
        <field name="res_model">qr.download.token</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="search_view_id" ref="view_qr_token_overview_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No QR codes generated yet.</p>
            <p>Generate a QR code from a report in Cyllo Studio.</p>
        </field>
    </record>

</odoo>
