<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="product_template_form_view_warranty" model="ir.ui.view">
        <field name="name">product.template.form.warranty</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <field name="categ_id" position="after">
                <label for="warranty_period"/>
                <div class="o_row">
                    <field name="warranty_period" class="oe_inline" nolabel="1"/>
                    <field name="warranty_period_unit" class="oe_inline ms-2" nolabel="1"/>
                </div>
            </field>
        </field>
    </record>

    <record id="product_category_form_view_warranty" model="ir.ui.view">
        <field name="name">product.category.form.warranty</field>
        <field name="model">product.category</field>
        <field name="inherit_id" ref="product.product_category_form_view"/>
        <field name="arch" type="xml">
            <field name="parent_id" position="after">
                <label for="warranty_period"/>
                <div class="o_row">
                    <field name="warranty_period" class="oe_inline" nolabel="1"/>
                    <field name="warranty_period_unit" class="oe_inline ms-2" nolabel="1"/>
                </div>
            </field>
        </field>
    </record>
</odoo>
