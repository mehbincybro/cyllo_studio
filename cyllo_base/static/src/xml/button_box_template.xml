<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="cyllo_base.button_box" owl="1">
        <t t-set="allButtons" t-value="getButtons()"/>
        <t t-set="visibleButtons" t-value="allButtons['visible']"/>
        <t t-set="additionalButtons" t-value="allButtons['additional']"/>
        <t t-if="visibleButtons[0]">
            <nav class="col-md-3 col-lg-2 d-md-block w-100 cy-right-sidebar"
                 t-ref="cy_right_sidebar">
                <t t-slot="{{ button_value }}" t-foreach="visibleButtons"
                   t-as="button" t-key="button_value"/>
                <t t-if="additionalButtons.length">
                    <t t-slot="{{ button_value }}" t-foreach="additionalButtons"
                       t-as="button" t-key="button_value"/>
                </t>
            </nav>
        </t>
    </t>
</templates>
