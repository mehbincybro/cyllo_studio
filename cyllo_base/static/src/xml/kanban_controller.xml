<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <!-- Inherits KanbanView to modify the view.-->
    <t t-name="cyllo_web.KanbanView" t-inherit="web.KanbanView"
       t-inherit-mode="extension" owl="1">
        <xpath expr="//t[@t-set-slot='control-panel-create-button']"
               position="replace">
            <button type="button" class="btn btn-primary o-kanban-button-new"
                    accesskey="c" t-on-click="() => this.createRecord()"
                    data-bounce-button="" hidden="True">New</button>
            <xpath expr="//Layout[last()]" position="inside">
                <t t-if="canCreate" t-set-slot="control-panel-cy-form-cogs">
                    <CogMenuList
                            canCreate="!model.root.editedRecord and canCreate and (!model.root.isGrouped or !editable) and !env.inDialog"
                            canEdit="!!model.root.editedRecord"
                            isSelected="!!nbSelected"
                            model="model"
                            create.bind="createRecord"
                            onActionExecuted="() => model.load({ resId: model.root.resId, resIds: model.root.resIds })"
                            isDomainSelected="model.root.isDomainSelected"
                            getActiveIds="() => model.root.isNew ? [] : [model.root.resId]"
                            context="props.context"
                            resModel="model.root.resModel"
                            domain="props.domain"
                            items="props.info.actionMenus ? actionMenuItems : {}"/>
                </t>
                <t t-if="env.searchModel.resModel == 'ir.module.module' or canCreate"
                   t-set-slot="control-panel-cy-form-cogs">
                    <CogMenuList
                            canCreate="!model.root.editedRecord and canCreate and (!model.root.isGrouped or !editable) and !env.inDialog"
                            canEdit="!!model.root.editedRecord"
                            isSelected="!!nbSelected"
                            model="model"
                            create.bind="createRecord"
                            onActionExecuted="() => model.load({ resId: model.root.resId, resIds: model.root.resIds })"
                            isDomainSelected="model.root.isDomainSelected"
                            getActiveIds="() => model.root.isNew ? [] : [model.root.resId]"
                            context="props.context"
                            resModel="model.root.resModel"
                            domain="props.domain"
                            items="props.info.actionMenus ? actionMenuItems : {}"/>
                </t>
            </xpath>
        </xpath>
    </t>
    <t t-inherit="web.ListView" t-inherit-mode="extension" owl="1">
        <xpath expr="//t[@t-set-slot='control-panel-create-button']"
               position="replace"/>
    </t>
</templates>