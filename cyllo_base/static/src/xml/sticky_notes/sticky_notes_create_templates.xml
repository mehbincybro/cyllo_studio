<?xml version="1.0" encoding="UTF-8" ?>
<template xml:space="preserve">
    <!-- Create sticky note template from systray-->
    <t t-name="StickyNotesCreate" owl="1">
        <div class="sticky o_create_note pt-2 shadow-sm" id="note_create"
             t-att-style="'background-color: ' + this.state.note_color + ';height: 300px;position: relative;border-radius: 10px;word-wrap: break-word;'">
            <div class="note-title"
                 t-att-style="'position: absolute; top: 25px; left: 10px; right: 10px;'">
                <input type="text" id="note_title"
                       class="form-control note-title-input border"
                       t-ref="noteTitle" placeholder="Title"
                       t-on-keydown="onKeydown"
                       aria-describedby="to-do-button"/>
            </div>
            <div class="note-description"
                 t-att-style="'position: absolute; top: 70px; left: 10px; right: 10px;'">
                <textarea type="text" id="note_description"
                          class="form-control note-title-input border"
                          rows="4" t-ref="noteDescription"
                          placeholder="Write your note here..."
                          aria-describedby="to-do-button"
                          style="resize:unset;"/>
            </div>
            <div class="d-flex p-3 text-white color_pallets" t-ref="colorRef"
                 t-att-style="'position: absolute; bottom: 60px; left: 2px;right: 2px;'">
                <div class="p-2 o_pallet_block" role="button"
                     style="background-color: #fddcb4;"
                     t-on-click="(ev) => this.click_pallet(ev)"/>
                <div class="p-2 o_pallet_block" role="button"
                     style="background-color: #a1ef9b;"
                     t-on-click="(ev) => this.click_pallet(ev)"/>
                <div class="p-2 o_pallet_block" role="button"
                     style="background-color: #ffafdf;"
                     t-on-click="(ev) => this.click_pallet(ev)"/>
                <div class="p-2 o_pallet_block" role="button"
                     style="background-color: #d7afff;"
                     t-on-click="(ev) => this.click_pallet(ev)"/>
                <div class="p-2 o_pallet_block" role="button"
                     style="background-color: #9edfff;"
                     t-on-click="(ev) => this.click_pallet(ev)"/>
                <div class="p-2 o_pallet_block" role="button"
                     style="background-color: #e0e0e0;"
                     t-on-click="(ev) => this.click_pallet(ev)"/>
                <div class="p-2 o_pallet_block" role="button"
                     style="background-color: #bc7bf5;"
                     t-on-click="(ev) => this.click_pallet(ev)"/>
            </div>
            <div class="note-save-update d-flex"
                 t-att-style="'position: absolute; bottom: 10px; left: 2px; right: 2px;'">
                <button class="btn btn-secondary btn-save"
                        t-on-click="_note_cancel" type="button">Cancel</button>
                <button class="btn btn-primary btn-save" type="button"
                        data-update="0" t-on-click="_note_save">Save</button>
            </div>
        </div>
    </t>
</template>