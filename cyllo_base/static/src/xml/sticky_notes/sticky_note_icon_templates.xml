<?xml version="1.0" encoding="UTF-8" ?>
<template xml:space="preserve">
    <!-- Create sticky note template from systray -->
    <t t-name="StickyNotesSystray" owl="1">
        <div class="o_sticky_icon cy-systray-parent-class me-1" style="gap: 30px;" t-on-click="sticky_note">
             <div class="toggle-icon o_icon" >
                 <i id="create_sticky" class="ri-edit-line cy-icons cy-stray-icon-sp" aria-label="Sticky Notes"/>
             </div>
            <span t-if="props.nameShow" class="cy-systray-label">
                Sticky Notes
            </span>
        </div>
        <StickyNotes t-if="this.state.isOpen"/>
    </t>
</template>