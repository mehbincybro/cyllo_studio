<?xml version="1.0" encoding="UTF-8" ?>
<template xml:space="preserve">
    <!-- Create sticky note template from systray-->
    <t t-name="StickyNotesUpdate" owl="1">
        <div class="box_update"
             style="margin-top: 10px; width: 99%; height: 250px; margin-left: 2px; border: 1px solid black; display: none;">
            <div class="d-flex p-3 bg-secondary text-white">
                <div class="p-2 select" role="button"
                     style="background-color: #a2cffe;" t-on-click="pallet"/>
                <div class="p-2 o_pallet_block" role="button"
                     style="background-color: #cff6f4;" t-on-click="pallet"/>
                <div class="p-2 o_pallet_block" role="button"
                     style="background-color: #efc5b5;" t-on-click="pallet"/>
                <div class="p-2 o_pallet_block" role="button"
                     style="background-color: #bfafb2;" t-on-click="pallet"/>
                <div class="p-2 o_pallet_block" role="button"
                     style="background-color: #fdee73;" t-on-click="pallet"/>
                <div class="p-2 o_pallet_block" role="button"
                     style="background-color: #95e3c0;" t-on-click="pallet"/>
                <div class="p-2 o_pallet_block" role="button"
                     style="background-color: #f3c775;" t-on-click="pallet"/>
            </div>
            <div class="note-title border-bottom border-primary">
                <input type="text" id="note_title_update"
                       class="form-control note-title-input border-0"
                       placeholder="Note a title"
                       aria-describedby="to-do-button"/>
            </div>
            <div class="note-description mt-3">
                 <input type="textarea" id="note_description_update"
                        class="form-control note-title-input border-0"
                        placeholder="Note a description"
                        aria-describedby="to-do-button"/>
            </div>
            <div class="note-save-update mt-3 d-flex justify-content-end">
                 <button class="btn btn-link note-add" type="button"
                         data-update="0"
                         t-on-click="_note_update">Update</button>
            </div>
        </div>
    </t>
</template>