<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-inherit="web.LabelSelectionField" t-inherit-mode="extension" owl="1">
        <xpath expr="//span" position="replace">
            <div class="d-flex align-items-center gap-2 justify-content-between cy-o_field_label_selection">
                <div>
                    <div t-attf-class="cy-dot cy-{{className}}"/>
                </div>
                <span t-attf-class="badge text-bg-{{className}} pe-0"
                      t-esc="string"
                      t-att-raw-value="props.record.data[props.name]"/>
            </div>
        </xpath>
    </t>
</templates>