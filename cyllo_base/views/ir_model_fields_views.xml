<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--    Ir model dynamic fields search view    -->
    <record id="view_ir_model_fields_search" model="ir.ui.view">
        <field name="name">view.ir.model.fields.search</field>
        <field name="model">ir.model.fields</field>
        <field name="inherit_id" ref="base.view_model_fields_search"/>
        <field name="arch" type="xml">
            <xpath expr="//search/filter[@name='translate']" position="after">
                <separator/>
                <filter string="Dynamic Fields" name="dynamic_field"
                        domain="[('is_dynamic_field', '=', True)]"/>
            </xpath>
        </field>
    </record>
</odoo>