<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Replaced the about in settings-->
    <record id="view_res_config_settings_form" model="ir.ui.view">
        <field name="name">view.res.config.settings.form</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <!-- About section in general settings goes here -->
            <xpath expr="//block[@name='about_setting_container']"
                   position="replace"/>
            <xpath expr="//block[@name='integration']" position="inside">
                <setting id="open_ai_key">
                    <field name="open_ai_key"/>
                </setting>
            </xpath>
        </field>
    </record>
</odoo>