<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="cyllo_web.NotificationPanel">
        <div class="o_notification_panel"
             t-att-class="{ 'o_animating': state.isAnimating, 'o_shaking': state.isShaking, ['o_' + props.type]: true }"
             t-on-mouseenter="onMouseEnter"
             t-on-mouseleave="onMouseLeave">
            <div class="o_notification_container">
                <div class="o_notification_icon">
                    <i t-att-class="getIconClass()" style="font-size:24px"></i>
                </div>
                <div class="o_notification_content">
                    <h3 class="o_notification_title"><t t-esc="props.title"/></h3>
                    <p class="o_notification_message"><t t-esc="props.message"/></p>
                    <p t-if="props.description" class="o_notification_description"><t t-esc="props.description"/></p>
                </div>
                <button class="o_notification_close" t-on-click="props.close">×</button>
            </div>
            <div class="o_notification_progress" t-attf-style="width: {{props.animation?state.progress:'100'}}%;"/>
        </div>
    </t>
</templates>
