<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <!-- Add new language switching option in systray -->
    <t t-name="cyllo_web.SwitchLanguageMenu" owl="1">
        <!-- Current user's language displayed in systray -->
        <Dropdown class="'cy_lang_systray_container'"
              position="'bottom-end'">
            <t t-set-slot="toggler" >
                <div class="cy-systray-parent-class" style="gap: 25px">
                    <div class="cy_lang_systray">
                        <t t-out="selectedLanguage" t-att-alt="language" class="cy-icons"/>
                    </div>
                    <span t-if="props.nameShow" class="cy-systray-label">
                        Language Switcher
                    </span>
                </div>
            </t>
            <t t-foreach="langs" t-as="lang" t-key="lang.id">
                <t t-call="cyllo_web.SwitchLanguageItem"/>
            </t>
        </Dropdown>
    </t>
    <!-- Dropdown list of available active languages, user can switch language -->
    <t t-name="cyllo_web.SwitchLanguageItem" owl="1">
        <DropdownItem class="'p-0 bg-white'">
            <t t-set="isCurrentLang" t-value="lang.code == userLang"/>
            <div class="cy_lang_dropdown d-flex" data-menu="lang"
                 t-att-data-lang-id="lang.id">
                <div role="button" t-on-click="() => this.switchLanguage(lang)">
                    <div>
                        <t t-if="lang.flag_image">
                        <img t-attf-src="data:image/png;base64,{{lang.flag_image}}"
                             class="cy_lang_flag"
                             t-att-alt="language"/>
                        </t>
                        <span class='ps-2'>
                            <t t-esc="lang.name"/>
                        </span>
                    </div>
                </div>
                <br/>
            </div>
        </DropdownItem>
    </t>
</templates>