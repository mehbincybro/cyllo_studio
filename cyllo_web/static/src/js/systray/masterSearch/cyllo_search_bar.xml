<?xml version="1.0" encoding="UTF-8"?>
<!-- Template for the Search Bar in the Systray -->
<templates xml:space="preserve">
    <t t-name="cyllo_web.SearchBarSystray" owl="1">
        <div class="o_search_bar_systray cy-systray-parent-class"
             t-on-click="onSearchIconClick" >
            <div class="master_searchview_input_container d-flex flex-wrap gap-1">
                <div class="o_search_icon" data-hotkey="m">
                    <i class="ri-search-line pe-2 cy-icons cy-stray-icon-sp" style="padding-left:1.5px !important;"/>
                </div>
            </div>
            <span t-if="props.nameShow" class="cy-systray-label">
                Master Search
            </span>
        </div>
    </t>
</templates>
