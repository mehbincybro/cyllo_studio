<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="FieldTimePicker" owl="1">
        <!-- FieldTimePicker template to add input field-->
        <div class="cy_input-group cy_timepicker-component">
            <input type="text"
                   t-ref="input_time"
                   value="00:00"
                   t-on-click="_onClickTimeField"
                   t-on-blur="onBlur"
                   class="cy_timepicker-input form-control ui-timepicker-input"
            />
        </div>
    </t>
</templates>