<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <!-- Inherits X2ManyField in web to Add input for search records -->
    <t t-name="O2MSearchTemplate" t-inherit-mode="primary" t-inherit="web.X2ManyField" owl="1">
        <t t-if="displayControlPanelButtons" position="replace">
            <input type="text" class="search_box form-control pl-3" placeholder="Search the records..."
                   t-ref="search_keyword" t-on-keyup="onInputKeyUp"/>
            <t t-if="displayControlPanelButtons">
                <div class="o_cp_buttons" role="toolbar" aria-label="Control panel buttons" t-ref="buttons">
                    <t t-foreach="creates" t-as="create" t-key="create_index">
                        <button t-if="create.type === 'create'" type="button" class="btn btn-secondary"
                                t-att-class="create.class"
                                t-on-click.stop.prevent="() => this.onAdd({ context: create.context })">
                            <t t-esc="create.string"/>
                        </button>
                        <ViewButton t-if="create.type === 'button'" className="`${create.className}`"
                                    clickParams="create.clickParams"
                                    icon="create.icon" record="props.record.data[props.name]" string="create.string"
                                    title="create.title"/>
                    </t>
                </div>
            </t>
        </t>
        <div t-att-class="className" position="attributes">
            <attribute name="t-ref">X2ManyFieldRoot</attribute>
        </div>
    </t>
    <!-- One2Many delete button template -->
    <t t-name="O2mMultiDelete" t-inherit-mode="primary" t-inherit="web.X2ManyField" owl="1">
        <xpath expr="//div[hasclass('o_x2m_control_panel')]" position="before">
            <div class="dlt_btn">
                <button t-if="Selected" t-on-click="DltSelected" class="btn btn-primary">Delete</button>
            </div>
        </xpath>
    </t>
    <!-- One2Many search and delete widget template -->
    <t t-name="O2mSearchDelete" t-inherit-mode="primary" t-inherit="web.X2ManyField" owl="1">
        <t t-if="displayControlPanelButtons" position="replace">
            <div class="search_input">
                <input type="text" class="search_box form-control pl-3" placeholder="Search the records..."
                       t-ref="search_keyword" t-on-keyup="onInputKeyUp"/>
                <button t-if="Selected" t-on-click="DltSelected" class="btn btn-primary">Delete</button>
            </div>
            <t t-if="displayControlPanelButtons">
                <div class="o_cp_buttons" role="toolbar" aria-label="Control panel buttons" t-ref="buttons">
                    <t t-foreach="creates" t-as="create" t-key="create_index">
                        <button t-if="create.type === 'create'" type="button" class="btn btn-secondary"
                                t-att-class="create.class"
                                t-on-click.stop.prevent="() => this.onAdd({ context: create.context })">
                            <t t-esc="create.string"/>
                        </button>
                        <ViewButton t-if="create.type === 'button'" className="`${create.className}`"
                                    clickParams="create.clickParams"
                                    icon="create.icon" record="props.record.data[props.name]" string="create.string"
                                    title="create.title"/>
                    </t>
                </div>
            </t>
        </t>
        <div t-att-class="className" position="attributes">
            <attribute name="t-ref">X2ManyFieldRoot</attribute>
        </div>
    </t>
</templates>