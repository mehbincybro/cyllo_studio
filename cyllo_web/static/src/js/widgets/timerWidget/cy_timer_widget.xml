<?xml version="1.0" encoding="UTF-8" ?>
<templates>
    <t t-name="cyTimerWidget" owl="1">
        <div class="cy_timer_widget-root" t-ref="root">
            <div t-attf-id="timer-{{timerId.id}}" t-att-data-name="timerId.model" class="cy-timer">
                <span t-attf-id="hours-{{timerId.id}}" t-att-data-name="timerId.model" class="cy-hours">00:</span>
                <span t-attf-id="mins-{{timerId.id}}" t-att-data-name="timerId.model" class="cy-mins">00:</span>
                <span t-attf-id="seconds-{{timerId.id}}" t-att-data-name="timerId.model" class="cy-seconds">00</span>
                <i class="fa fa-play cy-start" t-attf-id="start-{{timerId.id}}" t-att-data-name="timerId.model" t-on-click="start" title="Start Timer"/>
                <i class="fa fa-pause cy-pause" t-attf-id="stop-{{timerId.id}}" t-att-data-name="timerId.model" t-on-click="stop" title="Pause Timer"/>
                <i class="fa fa-refresh cy-reset" t-attf-id="reset-{{timerId.id}}" t-att-data-name="timerId.model" t-on-click="reset" title="Reset Timer"/>
            </div>
        </div>
    </t>
</templates>
