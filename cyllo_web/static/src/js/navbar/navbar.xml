<?xml version="1.0" encoding="UTF-8" ?>
<templates>
    <t t-inherit="web.NavBar" t-inherit-mode="extension">
        <xpath expr="//header" position="attributes">
            <attribute name="t-attf-style">display: {{ styleState.display }};</attribute>
        </xpath>
        <xpath expr="//div[hasclass('o_menu_systray')]" position="attributes">
            <attribute name="t-if">!cylloSystray.show</attribute>
        </xpath>
        <xpath expr="//div[hasclass('o_menu_systray')]" position="after">
            <Systray t-if="cylloSystray.show"/>
        </xpath>
    </t>
</templates>
