<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="cyllo_web.GraphView.Buttons" t-inherit="web.GraphView.Buttons" t-inherit-mode="extension" owl="1">
        <xpath expr="//div[@class='btn-group' and @role='toolbar' and @aria-label='Change graph']" position="replace">
            <div class="btn-group cyllo_graph_buttons" role="toolbar" aria-label="Change graph">
                <button t-if="model.metaData.modes.includes('bar')" class="btn btn-secondary fa fa-bar-chart o_graph_button" data-tooltip="Bar Chart" aria-label="Bar Chart" data-mode="bar"
                    t-on-click="() => this.onModeSelected('bar')"
                    t-att-class="{ active: model.metaData.mode === 'bar' }"
                />
                <button t-if="model.metaData.modes.includes('line')" class="btn btn-secondary fa fa-line-chart o_graph_button" data-tooltip="Line Chart" aria-label="Line Chart" data-mode="line"
                    t-on-click="() => this.onModeSelected('line')"
                    t-att-class="{ active: model.metaData.mode === 'line' }"
                />
                <button t-if="model.metaData.modes.includes('pie')" class="btn btn-secondary fa fa-pie-chart o_graph_button" data-tooltip="Pie Chart" aria-label="Pie Chart" data-mode="pie"
                    t-on-click="() => this.onModeSelected('pie')"
                    t-att-class="{ active: model.metaData.mode === 'pie' }"
                />
                <button t-if="model.metaData.modes.includes('doughnut')" class="btn btn-secondary ri-donut-chart-fill o_graph_button" data-tooltip="Donut Chart" aria-label="Donut Chart" data-mode="doughnut"
                    t-on-click="() => this.onModeSelected('doughnut')"
                    t-att-class="{ active: model.metaData.mode === 'doughnut' }"
                />
                 <button t-if="model.metaData.modes.includes('scatter')" class="btn btn-secondary ri-bubble-chart-line o_graph_button" data-tooltip="Scatter Chart" aria-label="Scatter Chart" data-mode="scatter"
                    t-on-click="() => this.onModeSelected('scatter')"
                    t-att-class="{ active: model.metaData.mode === 'scatter' }"
                />
                 <button t-if="model.metaData.modes.includes('bubble')" class="btn btn-secondary ri-bubble-chart-fill o_graph_button" data-tooltip="Bubble Chart" aria-label="Bubble Chart" data-mode="bubble"
                    t-on-click="() => this.onModeSelected('bubble')"
                    t-att-class="{ active: model.metaData.mode === 'bubble' }"
                />
                 <button t-if="model.metaData.modes.includes('radar')" class="btn btn-secondary ri-bar-chart-horizontal-fill o_graph_button" data-tooltip="Radar Chart" aria-label="Radar Chart" data-mode="radar"
                    t-on-click="() => this.onModeSelected('radar')"
                    t-att-class="{ active: model.metaData.mode === 'radar' }"
                />
                <button t-if="model.metaData.modes.includes('polarArea')" class="btn btn-secondary ri-pie-chart-box-fill o_graph_button" data-tooltip="Polar Area Chart" aria-label="Polar Area Chart" data-mode="polarArea"
                    t-on-click="() => this.onModeSelected('polarArea')"
                    t-att-class="{ active: model.metaData.mode === 'polarArea' }"
                />
            </div>
        </xpath>
    </t>
</templates>