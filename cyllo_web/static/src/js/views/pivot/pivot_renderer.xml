<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="cyllo_web.PivotRenderer" t-inherit="web.PivotRenderer" t-inherit-mode="extension" owl="1">
        <xpath expr="//div[hasclass('o_pivot')]" position="attributes">
            <attribute name="t-att-style">model.metaData.sticky ? 'overflow-y: unset;' : ''</attribute>
        </xpath>
        <xpath expr="//thead" position="attributes">
            <attribute name="t-att-class">model.metaData.sticky ? 'cy_sticky' : ''</attribute>
        </xpath>
        <xpath expr="//thead/tr/t/th[contains(@t-att-colspan, 'cell.width')]" position="attributes">
            <attribute name="t-att-class">model.metaData.sticky ? 'position-sticky' : ''</attribute>
        </xpath>
    </t>
    <t t-name="cyllo_web.PivotHeader" t-inherit="web.PivotHeader" t-inherit-mode="extension" owl="1">
        <xpath expr="//th" position="attributes">
            <attribute name="t-att-class">model.metaData.sticky and !isInHead ? 'position-sticky' : ''</attribute>
            <attribute name="t-att-style">'border-top: 1px solid #dfdfdf;'</attribute>
        </xpath>
    </t>
    <t t-name="cyllo_web.PivotView.Buttons" t-inherit="web.PivotView.Buttons" t-inherit-mode="extension" owl="1">
        <xpath expr="//div[hasclass('o_pivot_buttons')]" position="attributes">
            <attribute name="t-att-class">model.metaData.sticky  ? 'sticky_cogMenu' : ''</attribute>
        </xpath>
    </t>
</templates>