<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <!--  Template for color picker widget -->
    <t t-name="cyllo_color_picker_widget.CylloColorPicker" owl="1">
        <div class="input-group colorpicker-component">
            <input t-if="!isReadonly" type="text" class="o_input" id="colorCode" t-ref="ColorCode"
                   t-on-change="changeColor" t-att-value="value"/>
            <span t-else="" t-esc="value" style="width: 100%;"/>
            <input class="colour-picker-square" type="color" t-att-id="props.id" t-ref="ColorChar" t-att-value="value"
                   t-on-change="changeColorCode" t-on-click="clickColorPicker" autocomplete="off"/>
        </div>
    </t>
</templates>