<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!-- Inherits ir.model to add more fields.-->
    <record id="view_ir_model_form" model="ir.ui.view">
        <field name="name">view.ir.model.form</field>
        <field name="model">ir.model</field>
        <field name="inherit_id" ref="base.view_model_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='modules']" position="after">
                <field name="quick_create_show"/>
                <field name="fa_icon" invisible="quick_create_show != True"/>
                <field name="categories" invisible="quick_create_show !=  True" required="quick_create_show"/>
            </xpath>
        </field>
    </record>
</odoo>