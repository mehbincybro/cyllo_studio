<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <template id="signup_fields" name="Auth Signup form fields">
        <div class="floating-label-group mt-4">
            <input type="text" name="login" class="form-control" t-att-value="login"
                   id="login" t-att-readonly="'readonly' if only_passwords else None"
                   required="required" autofocus="autofocus" autocapitalize="off"
                   t-attf-style="border-color: #{'red' if error else ''};"
                   placeholder=" " style="padding: 13px 12px;"/>
            <label for="login">Email</label>
        </div>
        <p t-if="error" class="cy-input-error">
            <t t-esc="error"/>
        </p>
        <div class="floating-label-group mt-4">
            <input type="text" class="form-control" name="name" id="name"
                   placeholder=" " required="required" t-att-value="name"
                   t-att-readonly="'readonly' if only_passwords else None"
                   t-att-autofocus="'autofocus' if login and not only_passwords else None"
                   style="padding: 13px 12px;"/>
            <label for="name">Your Name</label>
        </div>

        <div class="floating-label-group mt-4">
            <input type="password" class="form-control" name="password" id="password"
                   placeholder=" " required="required" style="padding: 13px 12px;"
                   t-att-autofocus="'autofocus' if only_passwords else None"/>
            <label for="password">Password</label>
        </div>

        <div class="floating-label-group mt-4">
            <input type="password" class="form-control" name="confirm_password" id="confirm_password"
                   placeholder=" " required="required" style="padding: 13px 12px;"/>
            <label for="confirm_password">Confirm Password</label>
        </div>
        <p class="cy-password-error"/>
    </template>
</odoo>