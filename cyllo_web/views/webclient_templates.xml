<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <template id="login_layout" inherit_id="web.login_layout">
        <xpath expr='//t[@t-call="web.frontend_layout"]' position="replace">
            <t t-call="web.frontend_layout">
                <t t-set="html_data" t-value="{'style': 'height: 100%;'}"/>
                <t t-set="body_classname" t-value="'bg-100'"/>
                <t t-set="no_header" t-value="True"/>
                <t t-set="no_footer" t-value="True"/>
                <div class="cy-auth" style="max-width:900px;">
                    <div class="cy-auth__left">
                        <div class="cy-auth__left_content" style="width: 430px;">
                            <h2 class="cy-auth__left_title">Sign Up</h2>
                            <p class="cy-auth__left_text">
                                Sign up your Cyllo account
                            </p>
                        </div>
                        <div class="">
                            <img src="/cyllo_web/static/src/img/logo.svg"/>
                        </div>
                    </div>
                    <form class="oe_signup_form" role="form" method="post" t-if="not message">
                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                        <div class="cy-auth__right">
                            <div class="cy-auth-right-title">
                                <h2>Sign Up</h2>
                            </div>
                            <t t-out="0"/>
                        </div>
                    </form>
                </div>
            </t>
        </xpath>
    </template>
</odoo>