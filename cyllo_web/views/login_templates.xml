<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!--        Login page template-->
    <template id="login" inherit_id="web.login" name="Login">
        <xpath expr="//t[@t-call='web.login_layout']" position="replace">
            <t t-call="web.frontend_layout">
                <t t-set="html_data" t-value="{'style': 'height: 100%;'}"/>
                <t t-set="body_classname" t-value="'bg-100'"/>
                <t t-set="no_header" t-value="True"/>
                <t t-set="no_footer" t-value="True"/>
                <div class="cy-auth">
                    <div class="cy-auth__left">
                        <div class="cy-auth__left_content">
                            <h2 class="cy-auth__left_title">Login</h2>
                            <p class="cy-auth__left_text">
                                Select a database and login to your account
                            </p>
                        </div>
                        <div class="">
                            <img src="/cyllo_web/static/src/img/logo.svg"/>
                        </div>
                    </div>
                    <form role="form" t-attf-action="/web/login" method="post"
                          onsubmit="this.action = '/web/login' + location.hash">
                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                        <div class="cy-auth__right">
                            <div class="cy-auth-right-title">
                                <h2>Login</h2>
                            </div>
                            <div class="cy-auth__form-group" t-if="databases and len(databases) &gt; 1">
                                <label class="cy-auth__label" for="email">Database
                                    <sup class="cy-auth__required">*</sup>
                                </label>
                                <div t-attf-class="input-group {{'input-group-sm' if form_small else ''}}">
                                    <input type="text" name="db"
                                           t-att-value="request.db" id="db"
                                           t-attf-class="form-control #{'form-control-sm' if form_small else ''} cy-auth__input"
                                           required="required"
                                           readonly="readonly"/>
                                    <a role="button"
                                       href="/web/database/selector"
                                       class="btn btn-secondary d-flex align-items-center gap-2">Select
                                        <i class="fa fa-database" role="img"
                                           aria-label="Database"
                                           title="Database"/>
                                    </a>
                                </div>
                            </div>
                            <div class="cy-auth__form-group">
                                <label class="cy-auth__label" for="login">Username/E-mail
                                    <sup class="cy-auth__required">*</sup>
                                </label>
                                <input class="cy-auth__input input-text" type="text" name="login"
                                       t-att-value="login" id="login"
                                       required="required" autofocus="autofocus"
                                       autocapitalize="off"/>
                            </div>
                            <div class="cy-auth__form-group">
                                <label class="cy-auth__label" for="email">Password
                                    <sup class="cy-auth__required">*</sup>
                                </label>
                                <div class="cy-password-field">
                                    <input type="password" class="cy-auth__input cy-auth-input-password"
                                           name="password" id="password"
                                           required="required"
                                           t-att-autofocus="'autofocus' if login else None"/>
                                </div>
                            </div>
                            <div class="cy-auth__footer">
                                <button type="submit" class="cy-auth__btn">Log in</button>
                                <div t-attf-class=" d-flex mt-2 {{'justify-content-between' if debug else 'justify-content-center'}}">
                                    <a t-if="reset_password_enabled" class="cy-auth__btn_reset text-center"
                                       t-attf-href="/web/reset_password?{{ keep_query() }}">Reset Password
                                    </a>
                                    <t t-if="debug">
                                        <button type="submit" name="redirect" value="/web/become"
                                                class="btn btn-link btn-sm">Log in as superuser
                                        </button>
                                    </t>
                                </div>
                                <p class="alert alert-danger mt-3" t-if="error" role="alert">
                                    <t t-esc="error"/>
                                </p>
                                <p class="alert alert-success mt-3" t-if="message" role="status">
                                    <t t-esc="message"/>
                                </p>
                                <p t-if="signup_enabled" class="small text-muted mt-3">Don't have account?
                                    <a t-attf-href="/web/signup?{{ keep_query() }}">Sign Up</a>
                                </p>
                            </div>
                        </div>
                        <input type="hidden" name="redirect" t-att-value="redirect"/>
                    </form>
                </div>
            </t>
        </xpath>
    </template>
</odoo>
