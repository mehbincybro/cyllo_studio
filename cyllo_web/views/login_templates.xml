<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
	<!--        Login page template-->
	<template id="login" inherit_id="web.login" name="Login">
		<xpath expr="//t[@t-call='web.login_layout']" position="replace">
			<t t-call="web.frontend_layout">
				<t t-set="html_data" t-value="{'style': 'height: 100%;'}"/>
				<t t-set="body_classname" t-value="'bg-100'"/>
				<t t-set="no_header" t-value="True"/>
				<t t-set="no_footer" t-value="True"/>
				<section class="cy-instance cy-instance-login">
					<div style="min-height: 500px; max-height: 610px; height: 100%;">
						<div class="cy-instance_content">
							<div class="cy-instance_bg"
                                 style="z-index: 0; top: -30px; bottom: unset; width: 100%; left: -2px;">
								<img src="/cyllo_web/static/src/img/bg-instance1.svg" alt="" style="width: 100%;"/>
							</div>
							<div class="cy-step4 cy-form">
								<form role="form" t-attf-action="/web/login" method="post"
                                      onsubmit="this.action = '/web/login' + location.hash">
									<input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
									<h2 class="cy-instance-title"
                                        style="font-size: 24px; text-align: center; font-weight: 700;">
                                        Log in with Cyllo
                                    </h2>
									<p class="text-center mb-3">Please login to your account to continue</p>
									<div class="floating-label-group mt-4">
										<input type="text" name="login" class="form-control cy-input"
                                               t-att-value="login"
                                               id="login" style="padding: 13px 12px;"
                                               required="required" autofocus="autofocus" autocapitalize="off"
                                               placeholder=" "/>
										<label for="login">Email</label>
									</div>
									<p class="email-error"/>
									<div class="floating-label-group mt-4"
                                         t-attf-style="display: #{'none' if not error else 'block'};"
                                         id="password_group">
										<input type="password" class="form-control" name="password" id="password"
                                               t-attf-style="border-color: #{'red' if error else ''};"
                                               placeholder=" " required="required" style="padding: 13px 12px;"/>
										<label for="password">Password</label>
									</div>
									<p t-if="error" class="cy-input-error">Wrong password</p>
									<div class="pb-12 mb-12 sec-m">
										<div class="sec mb-4">
											<button type="button" id="continue_button"
                                                    class="btn btn1">
                                                Continue
                                            </button>
											<button type="submit" id="login_button" class="btn btn1"
                                                    style=" display: none;">
                                                Login
                                            </button>
											<t t-if="debug == '1'">
												<button type="submit" name="redirect" value="/web/become"
                                                        class="btn btn2">Log in as superuser
                                                </button>
											</t>
										</div>
										<div class="d-flex justify-content-center mb-0">
											<p t-if="signup_enabled" class="para">Don't have an account?
												<a t-attf-href="/web/signup?{{ keep_query() }}" class="click"
                                                   style="color: #9EA700 !important;">Sign Up
                                                </a>
											</p>
										</div>
                                        <div class="d-flex justify-content-center gap-3 mb-3">
                                            <a t-if="reset_password_enabled" class="click"
                                               t-attf-href="/web/reset_password?{{ keep_query() }}">Forgot Password?
                                            </a>
                                        </div>
									</div>
									<input type="hidden" name="redirect" t-att-value="redirect"/>
									<div class="o_login_auth d-none"/>
								</form>
							</div>
							<div class="cy-instance_bg" style="z-index: 0;">
								<img src="/cyllo_web/static/src/img/bg-instance.svg" alt="" style="width: 100%;"/>
							</div>
							<p class="para"
                               style="position: absolute; bottom: 0; left: 50%; transform: translateX(-50%); width: 100%; display: flex; justify-content: center;">
                                Looking to organize your database?


								<a class="click db-click" href="/web/database/selector">Click Here
                                </a>
							</p>
						</div>
					</div>
					<script>
                        localStorage.setItem('mainMenuVisibility', 'true');
                        localStorage.setItem("cy_selected_app", false);
                        localStorage.setItem("isSidebarOn", true);
                    </script>
				</section>
			</t>
		</xpath>
	</template>
</odoo>
