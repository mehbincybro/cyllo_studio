<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="res_config_settings_view_form_inherit_cyllo" model="ir.ui.view">
            <field name="name">res.config.settings.view.form.inherit.cyllo</field>
            <field name="model">res.config.settings</field>
            <field name="inherit_id" ref="mrp.res_config_settings_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//setting[@id='mrp_byproduct']" position="after">
                    <setting id="cyllo_shopfloor_setting"
                             string="Shopfloor"
                             help="Enable or disable Shopfloor module"
                             groups="mrp.group_mrp_manager">
                        <field name="module_cyllo_shopfloor"/>
                    </setting>
                </xpath>
            </field>
        </record>
    </data>
</odoo>