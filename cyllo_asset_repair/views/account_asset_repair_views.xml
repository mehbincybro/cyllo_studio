<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!--    Tree view for the asset repair-->
    <record id="view_account_asset_repair_tree" model="ir.ui.view">
        <field name="name">view.account.asset.repair.tree</field>
        <field name="model">account.asset.repair</field>
        <field name="arch" type="xml">
            <tree>
                <field name="asset_id"/>
                <field name="scheduled_date"/>
                <field name="user_id"/>
                <field name="status"/>
            </tree>
        </field>
    </record>
    <!--    Search view for the asset repair-->
    <record id="view_account_asset_repair_search" model="ir.ui.view">
        <field name="name">view.account.asset.repair.search</field>
        <field name="model">account.asset.repair</field>
        <field name="arch" type="xml">
            <search string="Assets">
                <field name="asset_id"/>
                <field name="issue"/>
                <field name="asset_type_id"/>
                <field name="asset_item_id"/>
                <field name="employee_id"/>
                <filter name="archived" string="Archived" domain="[('active', '=', False)]"/>
                <filter name="new" string="New" domain="[('status', '=', 'new')]"/>
                <filter name="confirm" string="Confirm" domain="[('status', '=', 'confirm')]"/>
                <filter name="repairing" string="Repairing" domain="[('status', '=', 'repairing')]"/>
                <filter name="scrap" string="Scarped" domain="[('status', '=', 'scrap')]"/>
                <group expand="0" string="Group By...">
                    <filter string="Status" name="status" domain="[]" context="{'group_by':'status'}"/>
                    <filter string="Responsible User" name="responsible_user" domain="[]"
                            context="{'group_by':'user_id'}"/>
                    <filter string="Employee" name="employee" domain="[]" context="{'group_by':'employee_id'}"/>
                </group>
            </search>
        </field>
    </record>
    <!--    Form view for the asset repair-->
    <record id="view_account_asset_repair_form" model="ir.ui.view">
        <field name="name">view.account.asset.repair.form</field>
        <field name="model">account.asset.repair</field>
        <field name="arch" type="xml">
            <form string="Asset">
                <header>
                    <field name="status" widget="statusbar"
                           statusbar_visible="new,confirm"/>
                    <button type="object" name="action_confirm" string="Confirm" class="oe_highlight"
                            invisible="status != 'new'"/>
                    <button type="object" name="action_start_repair" string="Start Repair" class="oe_highlight"
                            invisible="status != 'confirm'"/>
                    <button type="object" name="action_complete_repair" string="Repaired" class="oe_highlight"
                            invisible="status != 'repairing'"/>
                    <button type="object" name="action_scraped" string="Scrap" class="btn-secondary"
                            invisible="status != 'repairing'"/>
                    <button type="object" name="action_create_invoice" string="Create Invoice" class="oe_highlight"
                            invisible="not repair_line_ids or is_invoice == True or status != 'repaired'"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" name="action_view_invoice"
                                invisible="status != 'repaired' and not repair_line_ids or is_invoice != True"
                                type="object"><i class="ri-draft-line"/>Invoice
                        </button>
                    </div>
                    <div class="oe_title">
                        <span class="o_form_label">Asset Repair</span>
                        <h1>
                            <field name="reference"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="issue"/>
                            <field name="asset_id"
                                   domain="[('is_maintenance','=', False), ('is_repair','=', False), ('status', 'not in', ('sell', 'disposed', 'cancel', 'lost'))]"
                                   readonly="status not in ('new, confirm')"/>
                            <field name="asset_item_id" readonly="status not in ('new, confirm')"/>
                            <field name="asset_type_id" readonly="status not in ('new, confirm')"/>
                            <field name="company_id" readonly="status not in ('new, confirm')"/>
                        </group>
                        <group>
                            <field name="date" readonly="status not in ('new, confirm')"/>
                            <field name="employee_id" readonly="status not in ('new, confirm')"/>
                            <field name="department_id" readonly="status not in ('new, confirm')"/>
                            <field name="user_id" readonly="status not in ('new, confirm')" options="{'no_create': True, 'no_create_edit': True}"/>
                            <field name="scheduled_date" readonly="status not in ('new, confirm') or not asset_id"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="is_invoice" invisible="1"/>
                            <field name="is_scrap" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page name="add_product" string="Add Products">
                            <field name="repair_line_ids" readonly="status not in ('new, confirm')">
                                <tree editable="bottom">
                                    <field name="repair_id" column_invisible="1"/>
                                    <field name="repair_action"/>
                                    <field name="product_id"/>
                                    <field name="product_qty"/>
                                    <field name="unit_price"/>
                                    <field name="price_subtotal"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <!-- Chatter -->
                <div class="oe_chatter">
                    <field name="message_follower_ids" groups="base.group_user"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>
    <!--   Action the asset repair-->
    <record id="action_view_assets_repair" model="ir.actions.act_window">
        <field name="name">Repair Assets</field>
        <field name="res_model">account.asset.repair</field>
        <field name="view_mode">tree,form</field>
    </record>
    <!--    Menuitem for the asset repair-->
    <menuitem id="menu_cyllo_asset_repair_root" name="Asset Repair"
              sequence="10" web_icon="cyllo_asset_repair,static/description/asset-repair.svg"/>
    <!--    Menuitem for the asset -->
    <menuitem id="menu_assets" name="Repair Assets"
              parent="cyllo_asset_repair.menu_cyllo_asset_repair_root"
              action="action_view_assets_repair"
              sequence="10"/>
</odoo>
