<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Inherit Appointment Form View to add station_id -->
    <record id="view_appointment_form_inherit_station" model="ir.ui.view">
        <field name="name">appointment.appointment.form.inherit.station</field>
        <field name="model">appointment.appointment</field>
        <field name="inherit_id" ref="cyllo_appointment.view_appointment_form"/>
        <field name="arch" type="xml">
            <field name="resource_id" position="after">
                <field name="station_id" options="{'no_create': True}"/>
            </field>
        </field>
    </record>

    <!-- Inherit Appointment Type Form View to add default station_id -->
    <record id="view_appointment_type_form_inherit_station" model="ir.ui.view">
        <field name="name">appointment.type.form.inherit.station</field>
        <field name="model">appointment.type</field>
        <field name="inherit_id" ref="cyllo_appointment.view_appointment_type_form"/>
        <field name="arch" type="xml">
            <field name="location" position="after">
                <field name="station_id" options="{'no_create': True}"/>
            </field>
        </field>
    </record>
</odoo>
