<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Inherit Front Desk Station Form View to add appointment_type_id -->
    <record id="frontdesk_frontdesk_view_form_inherit_appointment" model="ir.ui.view">
        <field name="name">frontdesk.frontdesk.view.form.inherit.appointment</field>
        <field name="model">frontdesk.frontdesk</field>
        <field name="inherit_id" ref="cyllo_front_desk.frontdesk_frontdesk_view_form"/>
        <field name="arch" type="xml">
            <field name="company_id" position="after">
                <field name="appointment_type_id" options="{'no_create': True}"/>
            </field>
        </field>
    </record>
</odoo>
