<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
<!--    Inheriting sale_order form view-->
    <record id="view_sale_order_form" model="ir.ui.view">
        <field name="name">view.sale.order.form</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='action_quotation_send']" position="after">
                <button name="action_send_by_whatsapp" string="Send By Whatsapp"
                            type="object"/>
                <field name="whatsapp_order" invisible="1"/>
            </xpath>
                        <xpath expr="//div[hasclass('oe_button_box')]" position="inside">
                <div class="oe_button_box" name="button_box">
                    <button name="action_view_wa_template"
                            type="object"
                            class="oe_stat_button"
                            string="Template"
                            invisible=""
                            icon="fa-whatsapp text-primary">
                    </button>
                </div>
            </xpath>
        </field>
    </record>
</odoo>