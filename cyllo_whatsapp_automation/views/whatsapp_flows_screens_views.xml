<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
<!--    whatsapp_flows_screens form view-->
    <record id="whatsapp_flows_screens_view_form" model="ir.ui.view">
        <field name="name">whatsapp.flows.screens.view.form</field>
        <field name="model">whatsapp.flows.screens</field>
        <field name="priority" eval="8"/>
        <field name="arch" type="xml">
            <form string="Create Screens">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                        </group>
                        <group>
                            <field name="button_name"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Contents">
                            <field name="content_ids">
                                <tree>
                                    <field name="content_type"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
</odoo>