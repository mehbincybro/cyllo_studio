<?xml version="1.0" encoding="utf-8"?>
<odoo>
<!--    Inheriting whatsapp_template form view-->
    <record id="view_whatsapp_template_form" model="ir.ui.view">
        <field name="name">whatsapp.template.view.form.inherit.cyllo.whatsapp.automation</field>
        <field name="model">whatsapp.template</field>
        <field name="inherit_id" ref="cyllo_whatsapp.view_whatsapp_template_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='lang_id']" position="before">
                <field name="template_type"/>
                <field name="flows_id"
                       invisible="template_type != 'flows'"
                       options="{'no_create': True, 'no_create_edit':True}"/>
            </xpath>
            <xpath expr="//field[@name='is_button']" position="attributes">
                <attribute name="invisible">template_type != 'custom'</attribute>
            </xpath>
            <xpath expr="//field[@name='footer_text']" position="after">
                <field name="button_name"
                       required="template_type == 'flows'"
                       invisible="template_type != 'flows'"/>
            </xpath>
        </field>
    </record>
<!--    Custom view of whatsapp template-->
    <record id="view_whatsapp_template_form_custom" model="ir.ui.view">
        <field name="name">view.whatsapp.template.form</field>
        <field name="model">whatsapp.template</field>
        <field name="arch" type="xml">
            <form string="Whatsapp Template">
                <header>
                    <button name="action_create_template" type="object"
                            string=" Send For Approval"
                            invisible="state != 'draft'"/>
                    <button name="action_get_template" type="object"
                            string="Validate"
                            invisible="state in ['deleted','draft','rejected']"/>
                    <button name="action_delete_template" type="object"
                            string="Delete"
                            invisible="state not in ['pending','approved']"
                            confirm="Are you certain you want to delete the template?"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,pending,approved"/>
                </header>
                <sheet>
                    <widget name="web_ribbon" title="Archived"
                            bg_color="text-bg-danger" invisible="active"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="active" invisible="1"/>
                            <field name="template_type" invisible="1"/>
                            <field name="flows_id" readonly="1"  options="{'no_create': True, 'no_create_edit':True}"/>
                            <field name="user_id"
                                   options='{"no_create": True}' invisible="1"/>
                            <field name="lang_id"
                                   options='{"no_create": True}'/>
                            <field name="company_ids"
                                   groups="base.group_multi_company" widget="many2many_tags"/>
                            <field name="template_uid" invisible="1"/>
                            <field name="model_id"
                                   options='{"no_open": True, "no_create": True}' invisible="1"/>
                            <field name="quality" widget="priority"
                                   invisible="quality == 'none'" readonly="1"/>
                        </group>
                        <group>
                            <field name="template_name" invisible="1"/>
                            <field name="action" invisible="1"/>
                            <field name="category" invisible="1"/>
                            <field name="header_type"
                                   readonly="state != 'draft'"/>
                            <field name="attachment_ids"
                                   widget="many2many_binary"
                                   invisible="header_type not in  ['document','image']"/>
                            <field name="binary_field_path"
                                   invisible="header_type not in  ['image']"
                                   readonly="state != 'draft'"/>
                            <field name="report_id"
                                   invisible="header_type != 'document'"
                                   required="header_type == 'document'"/>
                            <field name="header_text"
                                   invisible="header_type != 'text'"
                                   required="header_type == 'text'"
                                   readonly="state != 'draft'"
                                   placeholder="e.g.Our {{1}} is on!"/>
                            <field name="footer_text"
                                   readonly="state != 'draft'"/>
                            <field name="is_button" invisible="template_type != 'custom'"/>
                            <field name="button_name" required="template_type == 'flows'" invisible="template_type != 'flows'"/>
                            <field name="is_reason_update" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page id="body" name="Body">
                            <field name="body" readonly="state != 'draft'"
                                   placeholder="Your whatsapp message, use {{1}}, {{2}} as placeholders for dynamic variable"/>
                        </page>
                        <page id="reason" name="Rejection"
                              invisible="not is_reason_update">
                            <field name="reason" readonly="True"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
