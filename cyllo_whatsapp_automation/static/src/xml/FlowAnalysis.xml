<templates>
    <t t-name="cyllo_whatsapp_automation.FlowAnalysis">
        <div class="d-flex justify-content-center main" t-ref="root">
            <div class="o_container_small o_survey_result">
                <h2 class="mt-3" id="flow_name" t-esc="state.data.flow_name"/>
                <div class="d-flex justify-content-end">
                    <div class="p-2">
                        <button type="button" class="btn bg-primary" t-on-click="download_pdf_report">
                            <i class="fa fa-file-pdf-o fa-lg" aria-hidden="true" style="color:white"/>
                        </button>
                    </div>
                    <div class="p-2">
                        <button type="button" class="btn bg-primary" t-on-click="download_excel_report">
                            <i class="fa fa-file-excel-o fa-lg" aria-hidden="true" style="color:white"/>
                        </button>
                    </div>
                </div>
                <hr class="my-2 mt-3"/>
                <div class="row">
                    <div class="col-3">
                        <h4 class="text-primary"
                            t-esc="(state.data.screens).length"/>
                        <h6 class="list-name">Screens</h6>
                    </div>
                    <div class="col-3">
                        <h4 class="text-primary"
                            t-esc="state.data.label_count"/>
                        <h6 class="list-name">Labels</h6>
                    </div>
                    <div class="col-3">
                        <h4 class="text-primary"
                            t-esc="state.data.response_count"/>
                        <h6 class="list-name">Responses</h6>
                    </div>
                    <div class="col-3">
                        <h4 class="text-primary"
                            t-esc="state.data.leads_generated"/>
                        <h6 class="list-name">Leads</h6>
                    </div>
                </div>
                <hr class="my-2"/>
                <t t-foreach="state.data.screens" t-as="screen"
                   t-key="screen_index">
                    <h3 class="mt16 text-uppercase screen_name"
                        t-esc="screen.screen_name"/>
                    <hr class="my-2"/>
                    <t t-foreach="screen.contents" t-as="content"
                       t-key="content_index">
                        <t t-if="['text', 'media'].includes(content.type)">
                        </t>
                        <t t-else="">
                            <div class="px-3 my-3">
                                <h5 class="mb-1 content_label">
                                    <i class="fa fa-caret-right d-none"
                                       t-on-click="() => this.show_response(content.id)"
                                       t-att-id="'right-button-' + content.id"/>
                                    <i class="fa fa-caret-down"
                                       t-on-click="() => this.hide_response(content.id)"
                                       t-att-id="'down-button-' + content.id"/>
                                    <apan style="margin-left: 20px"
                                          t-esc="content.label"/>
                                </h5>
                                <div class="p-2 text-primary d-flex justify-content-between" t-att-id="'view-container-' + content.id">
                                    <div class="">
                                        <span class=""
                                              t-esc="(content.user_responses).length"/>
                                        <span style="margin-left: 5px">
                                            Responses
                                        </span>
                                    </div>
                                    <div t-if="content.selection_type == 'single_choice'">
                                        <div class="d-flex">
                                            <div class="p-1">
                                                <a t-on-click="() => this.toggleGraphView(content.id)"
                                                   t-att-class="{'btn-primary': state.contentViews[content.id] === 'graph'}"
                                                   class="btn">
                                                    <i class="fa fa-pie-chart"/>
                                                </a>
                                            </div>
                                            <div class="p-1">
                                                <a t-on-click="() => this.toggleListView(content.id)"
                                                   t-att-class="{'btn-primary': state.contentViews[content.id] === 'list'}"
                                                   class="btn">
                                                    <i class="fa fa-bars"/>
                                                </a>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="graph">
                                    <div t-att-id="'input_graph-' + content.id"/>
                                </div>
                                <table class="table table-hover table-sm"
                                       t-att-id="'input_table-' + content.id">
                                    <thead>
                                        <tr>
                                            <th scope="col">#</th>
                                            <th scope="col">Customer Response
                                            </th>
                                            <th scope="col">Customer</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="content.user_responses"
                                           t-as="response"
                                           t-key="response.response_id">
                                            <tr>
                                                <td style="color: rgba(1, 117, 139, 1)"
                                                    scope="row">
                                                    <t t-esc="response_index + 1"/>
                                                </td>
                                                <td>
                                                    <t t-esc="response.user_input"/>
                                                </td>
                                                <td style="color: rgba(1, 117, 139, 1);cursor: pointer;"
                                                    t-on-click="() => this.open_partner(response.partner_id)">
                                                    <t t-esc="response.partner"/>
                                                </td>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                            </div>
                        </t>
                    </t>
                </t>
            </div>
        </div>
    </t>
</templates>
