<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Company rule for whatsapp floes-->
    <record id="rule_whatsapp_flows_company" model="ir.rule">
        <field name="name">Whatsapp Flows Multi Company</field>
        <field name="model_id" ref="model_whatsapp_flows"/>
        <field name="global" eval="True"/>
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
    </record>
</odoo>