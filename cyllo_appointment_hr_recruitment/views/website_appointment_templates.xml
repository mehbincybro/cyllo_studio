<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="appointment_selection_applicant_code"
              name="Appointment Selection: Applicant Code"
              inherit_id="cyllo_appointment.appointment_selection">
        <xpath expr="//input[@name='csrf_token']" position="after">
            <t t-if="applicant_code">
                <input type="hidden" name="applicant_code" t-att-value="applicant_code"/>
            </t>
        </xpath>
    </template>
</odoo>
