<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="appointment_type_interviews" model="appointment.type">
        <field name="name">Interviews Availabilities</field>
        <field name="category">interview</field>
        <field name="scheduling_type">predefined</field>
        <field name="duration">0.5</field>
        <field name="slot_interval">30</field>
        <field name="min_booking_notice">1</field>
        <field name="max_booking_days">60</field>
        <field name="location_type">physical</field>
        <field name="require_staff">False</field>
        <field name="is_published">True</field>
    </record>

    <!-- Attach the scheduling-interview template to the Initial Qualification stage -->
    <record model="hr.recruitment.stage" id="hr_recruitment.stage_job1">
        <field name="template_id" ref="email_template_applicant_schedule_interview"/>
    </record>
</odoo>
