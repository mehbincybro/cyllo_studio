<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="product_template_form_view_inherit_green" model="ir.ui.view">
        <field name="name">product.template.form.inherit.green</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='standard_price_uom']" position="after">
                <field name="is_credit_product"/>
            </xpath>
        </field>
    </record>

    <record id="product_product_form_view_inherit_green" model="ir.ui.view">
        <field name="name">product.product.form.inherit.green</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_normal_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='standard_price_uom']" position="after">
                <field name="is_credit_product"/>
            </xpath>
        </field>
    </record>
</odoo>
