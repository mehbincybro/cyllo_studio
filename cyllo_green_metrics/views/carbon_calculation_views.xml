<odoo>
    <record id="view_carbon_calc_tree" model="ir.ui.view">
        <field name="name">carbon.calc.tree</field>
        <field name="model">carbon.calc</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="date"/>
                <field name="total_emissions"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <record id="view_carbon_calc_form" model="ir.ui.view">
        <field name="name">carbon.calc.form</field>
        <field name="model">carbon.calc</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="%(action_carbon_compute_wizard)d" type="action" string="Compute Emissions" class="btn-primary" invisible="state != 'draft'"/>
                    
                    <button name="action_submit" type="object" string="Submit" class="btn-primary" invisible="state != 'draft'"/>
                    
                    <button name="action_approve" type="object" string="Approve" class="btn-primary" 
                            groups="cyllo_green_metrics.group_carbon_manager" 
                            invisible="state != 'submitted'"/>
                    
                    <button name="action_done" type="object" string="Mark Done" class="btn-primary" 
                            groups="cyllo_green_metrics.group_carbon_manager" 
                            invisible="state != 'approved'"/>
                            
                    <button name="action_draft" type="object" string="Reset to Draft" class="btn-secondary" 
                            groups="cyllo_green_metrics.group_carbon_manager" 
                            invisible="state not in ['submitted', 'approved']"/>

                    <field name="state" widget="statusbar" statusbar_visible="draft,submitted,approved,done"/>
                </header>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="date"/>
                        <field name="total_emissions" readonly="1"/>
                    </group>
                    <notebook>
                        <page string="Activities">
                            <field name="activity_ids" context="{'default_calculation_id': active_id}">
                                <tree editable="bottom">
                                    <field name="name"/>
                                    <field name="date"/>
                                    <field name="source_id"/>
                                    <field name="scope_id"/>
                                    <field name="quantity"/>
                                    <field name="uom_name"/>
                                    <field name="factor_id" domain="[('source_id', '=', source_id)]"/>
                                    <field name="emission_total" readonly="1"/>
                                    <field name="state"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Notes">
                            <field name="note"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_carbon_calc" model="ir.actions.act_window">
        <field name="name">Calculations</field>
        <field name="res_model">carbon.calc</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
