<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_task_form2_inherit_green" model="ir.ui.view">
        <field name="name">project.task.form.inherit.green</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_form2"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='user_ids']" position="after">
                <field name="is_green_project" invisible="1"/>
                <field name="is_water_project" invisible="1"/>
                <field name="reduced_emissions" invisible="not is_green_project"/>
                <field name="recycled_water" invisible="not is_water_project"/>
                <field name="scope_id"/>
            </xpath>
        </field>
    </record>
</odoo>
