<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="mrp_production_workorder_form_view_inherit_green" model="ir.ui.view">
        <field name="name">mrp.workorder.form.inherit.green</field>
        <field name="model">mrp.workorder</field>
        <field name="inherit_id" ref="mrp.mrp_production_workorder_form_view_inherit"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Emissions" name="emissions">
                    <field name="carbon_activity_ids" readonly="1">
                        <tree>
                            <field name="date"/>
                            <field name="source_id"/>
                            <field name="factor_id"/>
                            <field name="quantity"/>
                            <field name="uom_name"/>
                            <field name="emission_total"/>
                            <field name="state"/>
                        </tree>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
