#. module: cyllo_analytics
#. odoo-javascript
#: code:addons/cyllo_analytics/static/src/xml/cyllo_sheet.xml:0
#, python-format
msgid ""
"A dimension refers to a qualitative\n"
"                                    attribute or category used to categorize and\n"
"                                    organize data. Dimensions are typically\n"
"                                    non-numeric fields that provide context to\n"
"                                    the measures in the database.Examples of\n"
"                                    dimensions in Cyllo could include \"Product\n"
"                                    Category,\" \"Customer Type,\" or \"Location.\""
msgstr ""
"يشير البُعد إلى سمة نوعية\n"
"                                    أو فئة تُستخدم لتصنيف البيانات وتنظيمها.\n"
"                                    تكون الأبعاد عادةً حقولًا غير رقمية توفر\n"
"                                    سياقًا للمقاييس داخل قاعدة البيانات. ومن\n"
"                                    أمثلة الأبعاد في Cyllo: \"فئة المنتج،\"\n"
"                                    \"نوع العميل،\" أو \"الموقع.\""

#. module: cyllo_analytics
#. odoo-javascript
#: code:addons/cyllo_analytics/static/src/xml/cyllo_sheet.xml:0
#, python-format
msgid ""
"A measure in an Cyllo database represents a\n"
"                                    quantitative, numeric value that can be\n"
"                                    subjected to mathematical operations or\n"
"                                    statistical analysis. Measures are fields\n"
"                                    that store numerical data, such as\n"
"                                    quantities, amounts, or other numeric\n"
"                                    indicators related to business processes.\n"
"                                    Examples of measures in Cyllo may include\n"
"                                    \"Total Sales Amount,\" \"Quantity Sold,\" or\n"
"                                    \"Average Unit Price.\""
msgstr ""
"يمثل المقياس في قاعدة بيانات Cyllo\n"
"                                    قيمة رقمية كمية يمكن إخضاعها للعمليات\n"
"                                    الحسابية أو التحليل الإحصائي. تُعد المقاييس\n"
"                                    حقولًا تخزن بيانات رقمية مثل الكميات،\n"
"                                    والمبالغ، أو غيرها من المؤشرات الرقمية\n"
"                                    المرتبطة بالعمليات التجارية.\n"
"                                    ومن أمثلة المقاييس في Cyllo:\n"
"                                    \"إجمالي مبلغ المبيعات،\" \"الكمية المباعة،\"\n"
"                                    أو \"متوسط سعر الوحدة.\""

