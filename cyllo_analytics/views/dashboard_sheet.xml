<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_dashboard_sheet_tile" model="ir.ui.view">
        <field name="name">view.dashboard.sheet.tile</field>
        <field name="model">dashboard.sheet</field>
        <field name="arch" type="xml">
            <tile string="Dashboard Sheet" editable="top">
                <field name="image_1920"/>
                <field name="name"/>
            </tile>
        </field>
    </record>
    <record id="action_view_sheets" model="ir.actions.act_window">
        <field name="name">Dashboard Sheet</field>
        <field name="res_model">dashboard.sheet</field>
        <field name="view_mode">tile,form</field>
    </record>

    <!-- Menu: Sheets under Cyllo Analytics -->
    <menuitem id="menu_sheets"
              name="Sheets"
              parent="menu_cyllo_analytics_root"
              action="action_view_sheets"
              groups="cyllo_analytics.group_cyllo_analytics_admin"/>
</odoo>