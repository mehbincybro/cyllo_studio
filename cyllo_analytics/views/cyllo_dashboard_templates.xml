<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!-- Client action record for the dashboard menu-->
    <record id="cyllo_dashboard_action" model="ir.actions.client">
        <field name="name">Cyllo Dashboard</field>
        <field name="tag">cy_analytic_dashboard</field>
        <field name="target">current</field>
    </record>

    <!-- Menu item for the main dashboard-->
    <menuitem id="menu_dashboard"
              name="Dashboard"
              sequence="0"
              parent="menu_cyllo_analytics_root"
              action="cyllo_dashboard_action"/>
</odoo>