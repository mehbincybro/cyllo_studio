<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- View Data Action -->
    <record id="action_custom_imported_table" model="ir.actions.act_window">
        <field name="name">Manage Imported Tables</field>
        <field name="res_model">custom.imported.table</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- Tree View -->
    <record id="view_custom_imported_table_tree" model="ir.ui.view">
        <field name="name">custom.imported.table.tree</field>
        <field name="model">custom.imported.table</field>
        <field name="arch" type="xml">
            <tree string="Imported Tables" default_order="import_date desc, id desc" create="false" edit="false" js_class="imported_table_list">
                <field name="name"/>
                <field name="model_name"/>
                <field name="import_date"/>
                <field name="record_count"/>
                <button name="action_view_data" type="object" string="View Data" icon="fa-eye" class="btn-primary"/>
                <button name="action_drop_table" type="object" string="Drop Table" icon="fa-trash" class="btn-danger" confirm="Are you sure you want to completely delete this table, its fields, and all its records? This cannot be undone."/>
            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_custom_imported_table_form" model="ir.ui.view">
        <field name="name">custom.imported.table.form</field>
        <field name="model">custom.imported.table</field>
        <field name="arch" type="xml">
            <form string="Imported Table" create="false" edit="false">
                <header>
                    <button name="action_view_data" type="object" string="View Data" class="btn-primary"/>
                    <button name="action_drop_table" type="object" string="Drop Table" class="btn-danger" confirm="Are you sure you want to completely delete this table, its fields, and all its records? This cannot be undone."/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="model_id" readonly="1"/>
                            <field name="model_name" readonly="1"/>
                        </group>
                        <group>
                            <field name="import_date" readonly="1"/>
                            <field name="record_count" readonly="1"/>
                            <field name="action_id" readonly="1" invisible="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Menu Item (assumes menu_imported_data_root exists/created dynamically) -->
    <!-- We link it here if it exists, otherwise we'll create the sub-menu dynamically as well. 
         But since we created menu_imported_data_root in the wizard, we can reference it here using noupdate or catching error -->
    <menuitem id="menu_manage_imported_tables"
              name="Manage Imported Tables"
              parent="menu_cyllo_analytics_root"
              action="action_custom_imported_table"
              sequence="100"/>
</odoo>
