<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="ir_cron_dashboard_alert_evaluate" model="ir.cron">
            <field name="name">Dashboard: Evaluate Alerts</field>
            <field name="model_id" ref="model_dashboard_alert"/>
            <field name="state">code</field>
            <field name="code">model._evaluate_all_alerts()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">hours</field>
            <field name="numbercall">-1</field>
            <field name="doall" eval="False"/>
        </record>

        <record id="ir_cron_dashboard_share_link_purge" model="ir.cron">
            <field name="name">Dashboard Sharing: Purge Expired Links</field>
            <field name="model_id" ref="model_dashboard_share_link"/>
            <field name="state">code</field>
            <field name="code">model.purge_expired_links()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="doall" eval="False"/>
        </record>
    </data>
</odoo>
