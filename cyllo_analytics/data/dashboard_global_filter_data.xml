<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="dashboard_global_filter_start_date"
            model="dashboard.global.filter">
        <field name="name">Start Date</field>
        <field name="type">datetime</field>
        <field name="code">start-date</field>
        <field name="operator">>=</field>
    </record>
    <record id="dashboard_global_filter_end_date"
            model="dashboard.global.filter">
        <field name="name">End Date</field>
        <field name="type">datetime</field>
        <field name="code">end-date</field>
        <field name="operator"><![CDATA[<=]]></field>
    </record>
    <record id="dashboard_global_filter_company"
            model="dashboard.global.filter">
        <field name="name">Company</field>
        <field name="type">many2one</field>
        <field name="code">company</field>
        <field name="relation">res.company</field>
        <field name="operator">in</field>
    </record>
    <record id="dashboard_global_filter_user"
            model="dashboard.global.filter">
        <field name="name">User</field>
        <field name="type">many2one</field>
        <field name="code">user</field>
        <field name="operator">in</field>
        <field name="relation">res.users</field>
    </record>
</odoo>