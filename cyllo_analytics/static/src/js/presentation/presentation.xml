<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <t t-name="PresentationSelectionMode">
        <div class="oys cy_presentation w-100" t-ref="rootRef" t-att-style="isNoData ? 'overflow: hidden;': ''" style="position: relative;">
            <div class="container-fluid o_pj_dashboard  control-panel"
                 style="display: flex; justify-content: space-between; align-items: center;">
                <div class="title_presentation d-flex gap-1 justify-content: space-between; align-items: center;" style="width: 25%;">
                    <i class="ri-arrow-left-s-line" t-on-click="goBack"
                       style="cursor: pointer;padding-left: 1%; margin-top: 1px;" title="Go Back"/>
                    <h3 class="my-0 ps-0 mt-1 title_presentation">Presentation Preview
                        <div class="presentation-tooltip" style="cursor: pointer;">
                            <span style="font-size: 9px;" class="filter-info">?</span>
                        </div>
                        <div class="tooltip-content justify-content-around modal_background" style="width: 35%;">
                            <span class="title_presentation" t-out="filterContent" style="text-align: center; padding: unset;"/>
                            <div class="demo_video d-flex justify-content-center" style="margin-bottom: 10px;">
                                  <img src="/cyllo_analytics/static/src/img/presentation_help.gif" class="presentation_helper"/>
                            </div>
                        </div>
                    </h3>
                </div>
                <div class="save d-flex justify-content-between align-items-center m-1 p-2"
                     style="margin-right: 1% !important">
                    <div class="d-flex">
                        <div class="btn-group cy_present_btn_grp">
                            <span t-if="state.autoSlide" t-on-click="() => this.handlePresentation('play')">
                                <label data-hotkey="a" class="btn btn-primary_present o_documents_kanban_upload presentation-btn">Play</label>
                            </span>
                            <span t-else="" t-on-click="() => this.handlePresentation('start')">
                                <label data-hotkey="a" class="btn btn-primary_present o_documents_kanban_upload presentation-btn">Start</label>
                            </span>
                            <div class="d-flex align-items-center cy-present-gear-container gap-3 mx-1 justify-content-end flex-wrap">
                                <FilterDropdown name="'Settings'" display_name="''" footer="false" class="'ri-settings-5-line'">
                                    <t t-set-slot="contents">
                                        <div class="col-12">
                                            <div class="additional-options-content">
                                                <div class="d-flex gap-2">
                                                    <label class="form-check-label  cy-modal-form_label presentation-label"
                                                           style="color: unset !important;">Auto Slide</label>
                                                    <input type="checkbox" class="form-check-input" t-model="state.autoSlide"/>
                                                </div>
                                                <div t-if="state.autoSlide" id="slideDuration" class="mt-2 slideDuration">
                                                    <label for="slideDuration">Slide Duration (In Seconds):</label>
                                                    <input class="px-2 mt-1 input_border" type="number" min="3" name="slideDuration" t-model="state.autoSlideTime"/>
                                                </div>
                                                <br/>
                                                <label class="form-check-label  cy-modal-form_label presentation-label"
                                                       style="color: unset !important;">Title Page</label>
                                                <div id="titlePageDetails" class="titlePageDetails mt-2">
                                                    <label for="heading">Heading:</label>
                                                    <input class="px-2 mt-1 input_border" type="text" name="heading" t-model="state.heading" t-on-blur="addHeading"/>
                                                    <label for="subheading" class="mt-2">Subheading:</label>
                                                    <input class="px-2 mt-1 input_border" type="text" name="subheading" t-model="state.subheading"/>
                                                </div>
                                            </div>
                                        </div>
                                    </t>
                            </FilterDropdown>
                        </div>
                        </div>
                    </div>
                </div>
            </div>
            <div t-ref="containerRef" class="d-flex justify-content-center">
                <div class="row mt-3 mb-3 d-flex container-fluid">
                    <div class="col-12">
                        <div class="card-collection" t-ref="collection">
                            <t t-foreach="ChartData.data" t-as="data" t-key="data_index" t-if="data.data.length">
                                <GraphTile t-if="data.type != 'kpi' and data.type != 'table'"
                                           value="data" theme="themeState.currentTheme"
                                           themeColor="themeState.theme.theme_color"
                                           onClickChart.bind="onClickChart" style="style"
                                           toggleClass="'cy_db_presentation_select'"/>
                                <Table t-elif="data.type == 'table'" onClickTable.bind="onClickChart"
                                       data="data" style="style" theme="themeState.currentTheme"
                                       toggleClass="'cy_db_presentation_select'"/>
                            </t>
                        </div>
                    </div>
                </div>
            </div>
            <t t-if="isNoData">
                <t t-call="PresentationNoData"/>
            </t>
        </div>
    </t>
    <t t-name="PresentationNoData">
        <div class="no-data-container">
            <div class="no-data-icon"><i class="ri-close-circle-fill"/></div>
            <div class="no-data-message">
                <h1>No data available at this moment.</h1>
            </div>
        </div>
    </t>
</templates>