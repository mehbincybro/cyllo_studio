<?xml version="1.0" encoding="UTF-8" ?>
<templates>
    <t t-name="SheetDomainSelector" t-inherit="web.DomainSelector"
       t-inherit-mode="primary">
        <xpath expr="//TreeEditor" position="replace">
            <SheetTreeEditor resModel="props.resModel"
                             tree="tree"
                             update.bind="update"
                             modelName="props.modelName"
                             readonly="props.readonly"
                             isDebugMode="props.isDebugMode"
                             defaultCondition="domainDefaultCondition"
                             defaultConnector="props.defaultConnector"
                             getOperatorEditorInfo.bind="getOperatorEditorInfo"
                             getDefaultOperator.bind="getDefaultOperator"
                             getPathEditorInfo.bind="getPathEditorInfo"
            >
                <t t-set-slot="default">
                    <div class="pe-1 cursor-pointer">
                        <div class="remove-group-domain"
                             t-on-click="() => this.props.handleDeleteDomain(props.resModel)"
                        >Remove Group
                        </div>
                    </div>
                </t>
            </SheetTreeEditor>
        </xpath>
    </t>
</templates>