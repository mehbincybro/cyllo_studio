<?xml version="1.0" encoding="UTF-8" ?>
<templates>
    <t t-name="FilterDialog" owl="1">
        <div class="cy-onboard_modal-container cy_sheet_filter_container cy-kpi_modal-container">
            <div class="modal-dialog  cy-dashboard_modal-box">
                <div class="modal-content cy-modal_content w-75">
                    <div class="modal-header  cy-social_commentHead d-flex  pt-4">
                        <h5 class="cy-dashboard_modal-heading">Sheet Filter</h5>
                        <span id="sheet_filter_close" class="cy-icons cy-social_cmnt-closebtn" t-on-click="props.close">
                            <i class="ri-close-line"/></span>
                    </div>
                    <div class="modal-body py-0">
                        <form class="p-4">
                            <div class="row py-2">
                                <div class="col-12  mb-3 px-2">
                                    <input type="text" class="form-control cy-button-stroke" t-model="state.name" placeholder="Filter Name"/>
                                </div>
                                <div class="col-12  mb-3">
                                    <div class="form-check">
                                        <input type="checkbox" class="form-check-input" t-model="state.active"/>
                                        <label class="form-check-label  cy-modal-form_label">
                                            Active
                                        </label>
                                    </div>
                                </div>
                                <div class="col-12  mb-3 px-2">
                                    <FieldAutoComplete options="fields" filterData="props.filterData" filterDomain="props.filterDomain" placeholder="'Fields'" addToDomain.bind="addToDomain" onClickRemove.bind="onClickRemove"/>
                                </div>
                            </div>
                        </form>
                    </div>
                    <div class="cy-modal_footer cy-social_cmnt-footer">
                        <div class="d-flex justify-content-end gap-2">
                            <button class="btn cy-button-primary-stroke" t-on-click="onClickConfirm">
                                <t t-if="props.edit">Save</t>
                                <t t-else="">Confirm</t>
                            </button>
                            <button class="btn cy-button-stroke" t-on-click="props.close">Close</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </t>
    <t t-name="FieldAutoComplete" owl="1">
        <div class="o-autocomplete" t-ref="root">
            <input type="text" class="o-autocomplete--input o_input" autocomplete="off"
                   t-att-placeholder="props.placeholder" t-model="state.value" t-on-input="onInput"
                   t-on-blur="onInputBlur" t-on-focus="onInput" t-ref="input"/>
            <ul t-if="state.open" class="o-autocomplete--dropdown-menu ui-widget show dropdown-menu ui-autocomplete"
                t-on-mousedown.prevent="" t-ref="sourcesList">
                <t t-foreach="state.data" t-as="option" t-key="option_index">
                    <li class="o-autocomplete--dropdown-item ui-menu-item d-block"
                        t-on-click="() => this.onOptionClick(option)">
                        <a href="#" class="dropdown-item ui-menu-item-wrapper text-truncate">
                            <t t-esc="option.label"/>
                        </a>
                    </li>
                </t>
            </ul>
        </div>
        <t t-foreach="state.domain" t-as="domain" t-key="domain.id">
             <DomainCreator domain="domain" index="domain_index" addToDomain="props.addToDomain" remove.bind="onClickRemove"/>
        </t>
    </t>
    <t t-inherit="FieldAutoComplete" t-inherit-mode="primary" t-name="FieldAutoCompleteGlobal" owl="1">
        <xpath expr="//t[@t-foreach='state.domain']" position="replace"/>
    </t>
    <t t-name="DomainCreator" owl="1">
        <div class="d-flex">
            <span t-esc="field.label"/>
            <div class="operator">
                <select class="form-select" t-on-change="onChangeOperator" t-model="state.operator">
                    <t t-foreach="this.getOptions(field.field_type)" t-as="option" t-key="option_index">
                        <option t-att-selected="state.operator == option ? 'selected': ''" t-att-value="option" t-esc="option"/>
                    </t>
                </select>
            </div>
            <t t-if="['IN', 'NOT IN'].includes(state.operator)">
                <t t-call="DomainCreator.Multi.{{ field.field_type }}"/>
            </t>
            <t t-elif="special.includes(field.field_type)">
                <t t-call="DomainCreator.{{ field.field_type }}"/>
            </t>
            <t t-else="">
                <input type="text" t-model="state.value"/>
            </t>
            <button type="button" class="btn btn-secondary" t-on-click="onDeleteDomain" style="height: 35px;">
                <i class="ri-close-line"/>
            </button>
        </div>
    </t>
    <t t-name="DomainCreator.selection" owl="1">
        <select class="form-select" t-on-change="selectionChange">
            <t t-foreach="field.selection" t-as="option" t-key="option_index">
                <option t-att-selected="state.value == option[0] ? 'selected': ''" t-att-value="option[0]" t-esc="option[1]"/>
            </t>
        </select>
    </t>
    <t t-name="DomainCreator.date" owl="1">
        <DateTimeInput type="'datetime'" value="state.value"
                       onChange="(date) => this.setValue(date)" placeholder="field.label"/>
    </t>
    <t t-name="DomainCreator.datetime" owl="1">
        <DateTimeInput type="'datetime'" value="state.value"
                       onChange="(datetime) => this.setValue(datetime)" placeholder="field.label"/>
    </t>
    <t t-name="DomainCreator.boolean" owl="1">
        <select class="form-select" t-on-change="boolChange">
            <t t-foreach="[['FALSE', false], ['TRUE', true]]" t-as="option" t-key="option_index">
                <option t-att-selected="eval(state.value) == option[1] ? 'selected': ''"
                        t-att-value="option[1]" t-esc="option[0]"/>
            </t>
        </select>
    </t>
    <t t-name="DomainCreator.Multi.selection">
        <MultiSelection value="state.multiValue" options="field.selection" onClick.bind="onAddValue"/>
    </t>
    <t t-name="MultiSelection">
        <div class="cy_analytic_d input_tags input_tags_row w-100 cy-sheet_preview-input" style="margin: 5px">
            <div class="d-flex tags" style="margin: 0 !important">
                <div class="d-flex" style="margin: 0 !important" t-foreach="state.selectedOptions" t-as="value" t-key="value_index">
                    <div class="badge rounded-pill o_tag d-flex" style="margin: 0 !important">
                        <t t-out="value"/><span style="cursor: pointer; margin-left:5px;" t-on-click="() => this.removeSelection(value)">x</span>
                    </div>
                </div>
            </div>
            <input type="text" class="o-autocomplete--input o_input" autocomplete="off" t-model="state.value"
                   t-on-input="onInput" t-on-blur="onInputBlur" t-on-focus="onInput" t-ref="input"/>
            <ul t-if="state.open" class="o-autocomplete--dropdown-menu ui-widget show dropdown-menu ui-autocomplete"
                t-on-mousedown.prevent="" t-ref="sourcesList">
                <t t-foreach="state.options" t-as="option" t-key="option_index">
                    <li class="o-autocomplete--dropdown-item ui-menu-item d-block"
                        t-on-click="() => this.onOptionClick(option)">
                        <a href="#" class="dropdown-item ui-menu-item-wrapper text-truncate">
                            <t t-esc="option[1]"/>
                        </a>
                    </li>
                </t>
            </ul>
        </div>
    </t>
</templates>