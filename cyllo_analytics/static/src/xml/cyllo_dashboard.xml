<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <t t-name="cyllo_analytics.CylloDashboard" owl="1">
        <div t-ref="dashboard" class="scroll" t-if="ui.size > 4" style="width: 100%;">
            <div class="container-fluid o_pj_dashboard background-image-banner control-panel"
                 style="display: flex; justify-content: space-between; align-items: center; height: 75px;">
                <div class="dashbd-info d-flex justify-content-center"
                     style="flex-direction: column; width: 100%; align-items: baseline;">
                    <div class="heading"><span style="font-size: 1.5rem; font-weight: 550;" t-esc="state.name" /></div>
                    <div class="info-content gap-1 mb-1">
                        <i class="ri-information-line cy-icons"/>
                        <p class="info-message d-flex cy-template-title mb-0">
                            <span class="info-hover-msg info-message mb-0 px-1"> This Dashboard Shows Information From </span>
                            <t t-esc="filterData?.date_0"/>
                            to
                            <t t-esc="filterData?.date_1"/>
                        </p>
                    </div>
                </div>
                <div class="date_records d-flex justify-content-end align-items-center" t-on-click="closeFilterSidebar"
                     style="margin-right: 10px; width: fit-content;">
                    <div class="position-relative d-flex gap-2">
                        <div class="nav-item d-flex dash_searchbar">
                            <input class="search_input_main" type="text" placeholder="Search..."
                                   t-model="state.search" t-on-focus="closeFilter"/>
                            <div class="icon" data-hotkey="s" t-on-click="onClickSearch" style="cursor: pointer;">
                                <i class="ri-search-2-line cy_analytic_i"/>
                            </div>
                        </div>
                        <t t-if="state.sources.length > 1">
                            <div class="nav-item dropdown d-flex" t-if="!is_subAction">
                                <button class="btn cy-button-primary-stroke cy-active-btn dropdown-toggle cy-dbselection_dropdowm-btn cy-select_board"
                                        type="button" id="dashboardDropdown" role="button" data-bs-toggle="dropdown"
                                        aria-expanded="false">
                                    <i class="ri-dashboard-line cy_analytic_i"/>
                                    <t t-out="state.name"/>
                                </button>
                                <ul class="dropdown-menu cy-dashboard_selection-dropdown"
                                    aria-labelledby="dashboardDropdown" style="width: fit-content; cursor: pointer;">
                                    <t t-foreach="state.sources" t-as="source" t-key="source_index">
                                        <li><a class="dropdown-item" t-on-click="()=> this.sourceDashboard(source)">
                                                <t t-out="source.name"/>
                                            </a></li>
                                    </t>
                                </ul>
                            </div>
                        </t>
                        <div class="d-flex gap-2 cy-filter-dropdown-container" t-on-blur="onFilterBlur">
                            <button id="cydialogBtn" t-ref="filterButton"
                                    class="btn cy-button-primary-stroke cy-active-btn cy-churn-filter-btn dropdown-toggle cy-dash-filter-btn"
                                    type="button" t-att-title="timFrameDisplayName" t-on-click="onClickFilter">
                                <i class="cy_icons ri-filter-line cy-filter-line-top"/>
                                Filters
                            </button>
                            <div class="cy-marketing-auto_add-parent-container cy_filter_toggler" t-ref="filter_dropdown"
                                 id="cy-dialogcontainer" data-bs-auto-close="true">
                                <div class="cy-market-dialog-header p-3 cy-border-btm">
                                    <div class="d-flex justify-content-between">
                                        <div class="cy-marketing-auto-dialog-head d-flex position-relative cy-filter-drop-head-text"> Filters
                                            <div id="custom-tooltip" style="cursor: pointer;">
                                                <span style="font-size: 9px;" class="filter-info">?</span>
                                                <div id="tooltip-content" class="custom-tooltip-content">
                                                    <div class="tooltip-inner-content" t-out="filterInfo"/>
                                                </div>
                                            </div>
                                        </div>
                                        <i class="ri-close-fill" style="cursor: pointer;" t-on-click="onClickFilter"/>
                                    </div>
                                </div>
                                <form action="" class="p-3">
                                    <div class="col-12">
                                        <label for="date" style="margin-right: 5px;">Period</label>
                                        <select id="time_frames" name="time" t-att-value="timFrameState.selected"
                                                class="form-control" t-on-change="(ev) => this.timeFrameChange(ev)">
                                            <option t-foreach="Object.keys(TimeFrame)" t-as="time" t-key="time_index"
                                                    t-att-value="TimeFrame[time]" t-out="time"
                                                    t-attf-style="{{TimeFrame[time] === 'custom' and 'display:none;' }}"/>
                                        </select>
                                    </div>
                                    <t t-foreach="state.globalFilters" t-as="filter" t-key="filter_index">
                                        <div class="date-inputs col-12 my-3" t-on-click="closeFilterSidebar">
                                            <label for="date" style="margin-right: 5px;">
                                                <t t-esc="filter.name"/>
                                            </label>
                                            <t t-if="filter.type == 'datetime'">
                                                <input type="date" t-attf-id="date_{{filter_index}}" class="date w-100"
                                                       name="date" t-att-value="getDate(filter_index)"
                                                       t-on-change="(ev) => this.onSelect(ev, filter)"
                                                       style="padding: 5px 10px; border-radius: 5px; margin-right: 10px;"
                                                       placeholder="Start Date"/>
                                            </t>
                                            <t t-if="filter.type == 'many2one'">
                                                <div class="cy_analytic_d input_tags cy_filter_input_tags input_tags_row w-100 col-4  mb-3">
                                                    <div class="d-flex tags" style="flex-direction: column;">
                                                        <t t-foreach="timFrameState[filter.code]" t-as="rec"
                                                           t-key="rec.id">
                                                            <div class="badge rounded-pill o_tag d-flex gap-1"
                                                                 style="width: fit-content;">
                                                                <t t-esc="rec.display_name"/>
                                                                <i t-on-click="() => this.onRemoveFilter(rec, filter)"
                                                                   class="ri-close-line"/>
                                                            </div>
                                                        </t>
                                                    </div>
                                                    <Many2XAutocomplete resModel="filter.relation"
                                                                        getDomain.bind="() => this.getDomain(filter)"
                                                                        fieldString="filter.display_name"
                                                                        activeActions="{}"
                                                                        update.bind="(ev) => this.onSelect(ev, filter)"
                                                                        isToMany="true" autoSelect="true"/>
                                                </div>
                                            </t>
                                        </div>
                                    </t>
                                    <div class="d-flex gap-2 mt-3 apply-filter-btn">
                                        <a href="#" class="cy-button-primary-stroke py-2 px-4 cy-active-btn w-100 "
                                           t-on-click="applyFilter" data-bs-target="#cy-dialogcontainer">
                                            Apply Filter
                                        </a>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                    <div class="d-flex border-box-tools">
                        <button class="cy-add-graph" t-if="hasAccess and !is_subAction" t-on-click="addGraph"
                                title="Add Graph">
                            <i class="ri-file-add-line inner-box"/>
                        </button>
                        <Dropdown togglerClass="'nav-link dropdown-toggle cy-dropdown-arrow'" beforeOpen.bind="closeFilter">
                            <t t-set-slot="toggler">
                                <i class="ri-printer-line cy-icons inner-box" title="Print"/>
                            </t>
                            <DropdownItem onSelected.bind="() => this.exportPDF('p')">
                                Portrait
                            </DropdownItem>
                            <DropdownItem onSelected.bind="() => this.exportPDF('l')">
                                Landscape
                            </DropdownItem>
                        </Dropdown>
                        <button class="cy-add-graph" t-on-click="onPresent" title="Presentation">
                            <i class="ri-slideshow-2-line inner-box" t-att-class="opacityClass"/>
                        </button>
                    </div>
                    <div class="dash-conf" t-on-click="closeFilter">
                        <Dropdown togglerClass="'nav-link dropdown-toggle cy-dropdown-arrow'" beforeOpen.bind="closeFilter">
                            <t t-set-slot="toggler">
                                <i class="ri-more-2-fill" style="font-size: 20px;"/>
                            </t>
                            <DropdownItem t-if="hasAccess and !is_subAction" onSelected.bind="onConfig">
                                <i class="ri-settings-4-line"/>Configuration
                            </DropdownItem>
                            <DropdownItem t-if="hasAccess and !is_subAction" onSelected.bind="onAddToMenu">
                                <i class="ri-menu-add-fill"/>Add to Menu
                            </DropdownItem>
                            <t t-if="this.id">
                                <DropdownItem t-if="hasAccess and !is_subAction" onSelected.bind="onDelete">
                                    <i class="ri-delete-bin-4-line"/>Delete
                                </DropdownItem>
                            </t>
                            <DropdownItem t-if="hasAccess" onSelected.bind="onJsonExport">
                                <i class="ri-braces-line"/>Export as JSON
                            </DropdownItem>
                            <DropdownItem class="opacityClass" t-if="hasAccess and !is_subAction" onSelected.bind="onEdit">
                                <i class="ri-dashboard-line"/>Edit Layout
                            </DropdownItem>
                            <Dropdown>
                                <t t-set-slot="toggler">
                                    <i class="ri-palette-line"/>Themes
                                </t>
                                <t t-foreach="themes" t-as="theme" t-key="theme.id">
                                    <DropdownItem parentClosingMode="'none'"
                                                  onSelected.bind="() => this.OnSelectTheme(theme.id)">
                                        <div t-att-id="theme.id">
                                            <t t-out="theme.name"/>
                                            <i t-att-class="themeState.currentTheme == theme.name and 'ri-check-line'"
                                               style="margin-left: 5%;"/>
                                        </div>
                                    </DropdownItem>
                                </t>
                            </Dropdown>
                        </Dropdown>
                    </div>
                </div>
            </div>
            <div class="row h-100 cy-graph_filter justify-content-between position-relative"
                 t-att-class="state.optionClass" style="padding-left: 5px;">
                <div class="col-md-6 col-lg-12 cy-dashboard-graph" t-ref="graph">
                    <div class="stack-item cy_dash-card_container" t-on-click="closeFilterSidebar"
                         style="position: relative;overflow-y: scroll;height: 91vh;" t-ref="chart-container">
                        <t t-if="state.showInfo">
                            <div class="mt-5 d-flex justify-content-center align-items-center">
                                <div class="col-4 cy_dash_info_how_to">
                                    <h3 class="dashboard_info_text dashboard_info_head">
                                        No sheets here! Let's whip up a new one!
                                    </h3>
                                    <ul>
                                        <li class="dashboard_info_text">Click on the <i class="ri-file-add-line"/>
                                            "Add Graph" on the top right corner</li>
                                        <li class="dashboard_info_text">Or If you already have charts in the sheets model you can go to the sheets,</li>
                                        <li class="dashboard_info_text">And add this dashboard from the top right corner of the sheet</li>
                                    </ul>
                                </div>
                            </div>
                        </t>
                        <t t-foreach="state.sortedItems" t-as="item" t-key="item.id" t-if="container.el">
                            <t t-set="data" t-value="this.computeStyle(item)"/>
                            <t t-if="item.type == 'kpi'">
                                <t t-set="kpi" t-value="this.getKpi(item)"/>
                                <KpiSheetChart query="item" kpi="kpi" style="data.style" name="item.name"
                                               model="kpi.model">
                                    <t t-if="hasAccess" t-set-slot="footer">
                                        <div class="cy_options_container-tile">
                                            <Dropdown t-if="item.filter_ids.length and !isSearchMode">
                                                <t t-set-slot="toggler">
                                                    <i class="ri-filter-2-line" title="Filter"/>
                                                </t>
                                                <DropdownItem parentClosingMode="'none'" t-foreach="item.filter_ids" t-as="filter" t-key="filter.id" onSelected.bind="() => this.filterChange(filter, item_index)">
                                                    <t t-out="filter.name"/> <i t-att-class="filter.is_active and 'ri-check-line'" style="margin-left: 5%;"/>
                                                </DropdownItem>
                                            </Dropdown>
                                            <Dropdown>
                                                <t t-set-slot="toggler"><i class="ri-more-2-fill"/></t>
                                                <DropdownItem t-if="!is_subAction" onSelected.bind="() => this.onEditSheet(item)">
                                                    <i class="ri-edit-circle-line"/>Edit</DropdownItem>
                                                <DropdownItem t-if="kpi.redirect" onSelected.bind="() => this.openRecord(kpi, item)">
                                                    <i class="ri-arrow-go-forward-line"/>View Records</DropdownItem>
                                                <DropdownItem t-if="!is_subAction" onSelected.bind="() => this.onDeleteSheet(item)">
                                                    <i class="ri-delete-bin-4-line"/>Delete</DropdownItem>
                                                <DropdownItem t-if="!is_subAction" onSelected.bind="() => this.onHideSheet(item)">
                                                    <i class="ri-rest-time-line"/>Hide</DropdownItem>
                                            </Dropdown>
                                        </div>
                                    </t>
                                </KpiSheetChart>
                            </t>
                            <t t-elif="item.type == 'table'">
                                <Table item="item" style="data.style" toggleClass="'chart-container-absolute'" theme="themeState.currentTheme">
                                    <t t-if="hasAccess" t-set-slot="footer">
                                         <div class="cy_options_container-tile cy-graph-option-container cy-table-container">
                                             <Dropdown t-if="item.filter_ids.length and !isSearchMode">
                                                <t t-set-slot="toggler">
                                                    <i class="ri-filter-2-line" title="Filter"/>
                                                </t>
                                                 <DropdownItem parentClosingMode="'none'" t-foreach="item.filter_ids" t-as="filter" t-key="filter.id" onSelected.bind="() => this.filterChange(filter, item_index)">
                                                    <t t-out="filter.name"/> <i t-att-class="filter.is_active and 'ri-check-line'" style="margin-left: 5%;"/>
                                                </DropdownItem>
                                            </Dropdown>
                                             <Dropdown>
                                                <t t-set-slot="toggler"><i class="ri-more-2-fill"/></t>
                                                 <DropdownItem t-if="!is_subAction" onSelected.bind="() => this.onEditSheet(item)">
                                                    <i class="ri-edit-circle-line"/>Edit</DropdownItem>
                                                 <DropdownItem t-if="!is_subAction" onSelected.bind="() => this.onDeleteSheet(item)">
                                                    <i class="ri-delete-bin-4-line"/>Delete</DropdownItem>
                                                 <DropdownItem t-if="!is_subAction" onSelected.bind="() => this.onHideSheet(item)">
                                                    <i class="ri-rest-time-line"/>Hide</DropdownItem>
                                            </Dropdown>
                                         </div>
                                    </t>
                                </Table>
                            </t>
                            <t t-else="">
                                <GraphTile item="item" theme="themeState.currentTheme" style="data.style"
                                           toggleClass="data.toggleClass" setImage.bind="setImage"
                                           themeColor="themeState.theme.theme_color" footer="true">
                                    <t t-set-slot="footer">
                                        <div class="cy_options_container-tile cy-graph-option-container">
                                             <Dropdown t-if="item.filter_ids.length and !isSearchMode">
                                                <t t-set-slot="toggler">
                                                    <i class="ri-filter-2-line" title="Filter"/>
                                                </t>
                                                 <DropdownItem parentClosingMode="'none'" t-foreach="item.filter_ids" t-as="filter" t-key="filter.id" onSelected.bind="() => this.filterChange(filter, item_index)">
                                                    <t t-out="filter.name"/> <i t-att-class="filter.is_active and 'ri-check-line'" style="margin-left: 5%;"/>
                                                </DropdownItem>
                                            </Dropdown>
                                            <Dropdown>
                                                <t t-set-slot="toggler">
                                                    <i class="ri-more-2-fill"/>
                                                </t>
                                                <DropdownItem t-if="hasAccess and !is_subAction" onSelected.bind="() => this.onEditSheet(item)">
                                                    <i class="ri-edit-circle-line"/>Edit</DropdownItem>
                                                <DropdownItem t-if="hasAccess and !is_subAction" onSelected.bind="() => this.onDeleteSheet(item)">
                                                    <i class="ri-delete-bin-4-line"/>Delete</DropdownItem>
                                                <DropdownItem t-if="hasAccess and !is_subAction" onSelected.bind="() => this.onHideSheet(item)">
                                                    <i class="ri-rest-time-line"/>Hide</DropdownItem>
                                                <DropdownItem onSelected.bind="() => this.exportAsPNG(item)">
                                                    <i class="ri-image-add-line"/> Export as PNG</DropdownItem>
                                            </Dropdown>
                                        </div>
                                    </t>
                                    <t t-set-slot="ai-footer">
                                        <button class="btn btn-ai-insights" t-on-click="() => this.explainWithAI(item)">
                                            <i class="ri-sparkling-line"/>
                                            AI Insights
                                        </button>
                                    </t>
                                </GraphTile>
                            </t>
                        </t>
                    </div>
                </div>
                <div class="dashboard_filters col-md-6 col-lg-2 cy-dashboard-graph-filter position-absolute">
                    <span class="cy-sale-analysis-title">
                        Filters
                    </span>
                    <div class="cy-sheet-selection_box cy_filter_selection_box cy-button-stroke mb-3 mt-3 p-2">
                        <div t-foreach="state.options" t-as="option" t-key="option.id"
                             class="cy-sales-filters_list cy-sidebar-nav">
                            <input type="checkbox" t-att-checked="option.is_active"
                                   t-on-change="() => this.filterChange(option)"/>
                            <span t-esc="option.name"/>
                        </div>
                    </div>
                    <div class="collapse-icon text-center cy-sidebar-collapse" t-on-click="closeFilterSidebar">
                        <a href="#sidebarCollapse" data-bs-toggle="collapse" role="button" aria-expanded="false"
                           aria-controls="sidebarCollapse">Collapse Filter
                            <i class="ri-arrow-right-s-line cy-icons  cy-collapse-icon"/>
                        </a>
                    </div>
                </div>
            </div>
        </div>
        <t t-else="">
            <div t-ref="dashboard" class="d-flex justify-content-center align-items-center">
                <h3>
                    The dashboard is not supported in smaller devices yet
                </h3>
            </div>
        </t>
    </t>
</templates>