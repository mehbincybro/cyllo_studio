<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <t t-name="cyllo_analytics.EditDashboard"
       t-inherit="cyllo_analytics.CylloDashboard" t-inherit-mode="primary">
        <xpath expr="//div[hasclass('date_records')]" position="replace">
            <div class="save d-flex justify-content-end align-items-center m-1 p-2 gap-2"
                 style="width: 35%">
                <div class="d-flex gap-1">
                    <button class="btn-secondary btn cy_edit_dash_btn"
                            t-if="state.change"
                            t-on-click="onSave">Save</button>
                    <button class="btn-secondary btn cy_edit_dash_btn"
                            t-if="state.change"
                            t-on-click="onDiscard">Discard</button>
                    <button class="btn-secondary btn cy_edit_dash_btn"
                            t-if="state.rearrange" t-on-click="rearrange">Rearrange</button>
                    <button class="btn-secondary btn cy_edit_dash_btn"
                            t-on-click="onBack">Back</button>
                </div>
            </div>
        </xpath>
        <xpath expr="//div[hasclass('stack-item')]" position="replace">
            <div class="cy-edit-grid-items"
                 style="overflow-y: scroll;height: 91vh;">
                <div t-ref="chart-container" class="grid_stack_item"/>
            </div>
        </xpath>
    </t>
</templates>
