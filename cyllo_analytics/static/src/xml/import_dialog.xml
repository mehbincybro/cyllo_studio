<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <t t-name="cyllo_analytics.ImportDialog" owl="1">
        <Dialog size="'md'" title="'Import'">
            <label for="file" class="form-label">File</label>
            <input t-on-focus="onFocus" type="file" name="file" id="file" class="form-control" t-on-change="onChangeFileInput" t-ref="root"/>
            <t t-set-slot="footer">
                <button class="btn btn-primary" t-on-click="onFileUpload">Upload File</button>
                <button class="btn" t-on-click="cancel">Cancel</button>
            </t>

        </Dialog>
    </t>
</templates>