<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <t t-name="PresetApplyDialog" owl="1">
        <Dialog size="'lg'" title="'Apply Preset Calculation'">
            <t t-set-slot="header">
                <div class="d-flex w-100 align-items-center justify-content-between"
                     style="border-bottom: 2px solid #ebedb7; padding-bottom: 10px;">
                    <div class="d-flex align-items-center gap-2">
                        <i class="ri-star-fill" style="color: #9ea700; font-size: 20px;"/>
                        <h5 class="mb-0"
                            style="font-size: 17px; font-weight: 600; color: #0E3A5D; font-family: 'Inter', sans-serif;">
                            <t t-if="state.viewMode === 'apply'">Apply Preset</t>
                            <t t-else="">Create Preset</t>
                        </h5>
                    </div>
                    <button class="btn-close" t-on-click="onCancel" aria-label="Close"/>
                </div>
            </t>

            <div class="cy-preset-apply-body" style="max-height: 70vh; overflow-y: auto;">

                <!-- ╔══ VIEW MODE: APPLY ══╗ -->
                <t t-if="state.viewMode === 'apply'">

                    <!-- ── Preset Selector ── -->
                    <div class="mb-3">
                        <div class="d-flex align-items-center justify-content-between mb-2">
                            <label class="cy-modal-form_label" style="font-size: 14px;">Select Preset Template</label>
                        </div>
                        <div class="cy-preset-search-container" style="position: relative;">
                            <AutoComplete
                                value="state.selectedPresetLabel"
                                sources="presetSources"
                                onSelect.bind="onPresetSelect"
                                placeholder="'Search or select a preset...'"
                                autoSelect="true"
                            />
                            <i class="ri-arrow-down-s-line" style="position: absolute; right: 10px; top: 50%; transform: translateY(-50%); color: #9ea700; pointer-events: none;"/>
                        </div>
                    </div>
                    <div class="mt-3">
                        <button class="btn btn-link btn-sm p-0 text-decoration-none"
                                t-on-click="switchToCreate">
                                    <i class="ri-add-line" style="font-size: 14px;"/>Create Preset
                        </button>
                     </div>

                    <!-- ── Config panel (after selection) ── -->
                    <t t-if="state.selectedPresetId">

                        <hr style="border-color: #DFDFDF;"/>

                        <!-- Calculation Method -->
                        <div class="mb-3">
                            <label class="cy-modal-form_label mb-2" style="font-size: 14px;">Calculation Method</label>
                            <div class="d-flex gap-2">
                                <div t-attf-class="flex-fill d-flex align-items-center gap-2 p-3 rounded-2 border {{state.calculationType === 'row' ? 'shadow-sm' : ''}}"
                                     t-att-style="state.calculationType === 'row' ? 'background: #ebedb7; border-color: #9ea700 !important;' : 'background: #f7f7f7; border-color: #DFDFDF; opacity: 0.7;'"
                                     style="transition: all 0.15s;">
                                    <i class="ri-list-check" style="font-size: 18px; color: #9ea700;"/>
                                    <span style="font-size: 13px; font-weight: 600; color: #0E3A5D;">Row-level</span>
                                </div>
                                <div t-attf-class="flex-fill d-flex align-items-center gap-2 p-3 rounded-2 border {{state.calculationType === 'aggregate' ? 'shadow-sm' : ''}}"
                                     t-att-style="state.calculationType === 'aggregate' ? 'background: #ebedb7; border-color: #9ea700 !important;' : 'background: #f7f7f7; border-color: #DFDFDF; opacity: 0.7;'"
                                     style="transition: all 0.15s;">
                                    <i class="ri-functions" style="font-size: 18px; color: #9ea700;"/>
                                    <span style="font-size: 13px; font-weight: 600; color: #0E3A5D;">Aggregated</span>
                                </div>
                            </div>
                        </div>

                        <!-- Field Name -->
                        <div class="mb-3">
                            <label class="cy-modal-form_label" style="font-size: 14px;">Field Name <span
                                    class="text-danger">*</span></label>
                            <input type="text" class="form-control cy-button-stroke mt-1"
                                   placeholder="e.g. Sales Margin %"
                                   t-model="state.fieldName"
                                   style="font-size: 13px;"/>
                        </div>

                        <!-- ╔══ Variable Configuration ══╗ -->
                        <div t-if="state.variables.length" class="mb-3">
                            <div class="d-flex align-items-center gap-2 mb-2">
                                <i class="ri-settings-3-line" style="color: #9ea700; font-size: 17px;"/>
                                <span class="cy-preset-apply-subtitle"
                                      style="font-size: 14px;">Configure Variables</span>
                                <span class="cy-preset-func-badge" style="font-size: 11px;">
                                    <t t-esc="state.variables.length"/>
                                </span>
                            </div>

                            <t t-foreach="state.variables" t-as="variable" t-key="variable_index">
                                <div class="mb-2 !important; overflow: hidden;">
                                    <!-- Variable config row: Field | Aggregate | Filter inline -->
                                    <div class="d-flex align-items-end gap-3 px-3 py-2 flex-nowrap"
                                         style="background: #fff; overflow-x: auto;">
                                        <div class="d-flex align-items-center gap-2 px-3 py-2"
                                             style="background: #f9f9f0;">
                                            <span class="cy-preset-var-type-badge"
                                                  style="font-size: 11px; padding: 2px 8px;">
                                                <t t-esc="variable.name"/>
                                            </span>
                                        </div>

                                        <!-- Field selector (Searchable) -->
                                        <div class="flex-grow-1" style="min-width: 250px;">
                                            <div class="cy-variable-autocomplete-container" style="position: relative;">
                                                <AutoComplete
                                                    value="getVarLabel(variable.name)"
                                                    sources="variableSources(variable.name)"
                                                    onSelect="(selected) => this.onVarSelect(variable.name, selected)"
                                                    placeholder="'Search field...'"
                                                    autoSelect="true"
                                                />
                                                <i class="ri-arrow-down-s-line" style="position: absolute; right: 10px; top: 50%; transform: translateY(-50%); color: #9ea700; pointer-events: none;"/>
                                            </div>
                                        </div>

                                        <!-- Aggregate selector (Aggregated mode only) -->
                                        <t t-if="state.calculationType === 'aggregate'">
                                            <div style="width: 130px; flex-shrink: 0;">
                                                <select class="form-select cy-button-stroke"
                                                        t-on-change="(ev) => this.setVarAggregate(variable.name, ev.target.value)"
                                                        style="font-size: 13px; height: 38px;">
                                                    <t t-foreach="aggOptions" t-as="agg" t-key="agg_index">
                                                        <option t-att-value="agg"
                                                                t-att-selected="state.variableConfigs[variable.name]?.aggregate === agg">
                                                            <t t-if="agg" t-esc="agg"/>
                                                            <t t-else="">None</t>
                                                        </option>
                                                    </t>
                                                </select>
                                            </div>
                                        </t>

                                        <!-- Filter -->
                                        <div style="flex-shrink: 0;">
                                            <t t-if="state.variableConfigs[variable.name]?.filter_name">
                                                <div class="d-flex align-items-center gap-1">
                                                    <span class="d-inline-flex align-items-center gap-1 px-3 rounded-1"
                                                          style="font-size: 12px; height: 38px; background: #ebedb7; color: #505050; border: 1px solid #d4d600;">
                                                        <i class="ri-filter-3-line" style="color: #9ea700;"/>
                                                        <t t-esc="state.variableConfigs[variable.name].filter_name"/>
                                                        <button class="btn-close ms-2"
                                                                style="font-size: 8px;"
                                                                t-on-click="() => this.clearFilter(variable.name)"/>
                                                    </span>
                                                    <button class="btn btn-link btn-sm p-0 text-decoration-none ms-1"
                                                            style="color: #9ea700; font-size: 16px;"
                                                            title="Edit filter"
                                                            t-on-click="() => this.openFilterDialog(variable.name)">
                                                        <i class="ri-pencil-line"/>
                                                    </button>
                                                </div>
                                            </t>
                                            <t t-else="">
                                                <button class="btn btn-sm d-flex align-items-center justify-content-center gap-1"
                                                        style="height: 38px; min-width: 110px; font-size: 12px; color: #505050; background: #f7f7f7; border: 1px dashed #DFDFDF; border-radius: 5px; padding: 4px 15px;"
                                                        t-on-click="() => this.openFilterDialog(variable.name)">
                                                    <i class="ri-filter-3-line"
                                                       style="color: #9ea700; font-size: 14px;"/>Add Filter
                                                </button>
                                            </t>
                                        </div>
                                    </div>
                                </div>
                            </t>
                        </div>
                        <div t-elif="state.variables.length === 0"
                             class="cy-preset-no-vars-msg mb-3 d-flex align-items-center gap-2 px-3 py-2 rounded-2"
                             style="background: #f7f7f7; border: 1px solid #DFDFDF;">
                            <i class="ri-information-line" style="color: #888;"/>
                            <span style="color: #888; font-size: 13px;">No variables required for this preset.</span>
                        </div>

                        <!-- Formula Toggle -->
                        <div class="mt-3">
                            <button class="btn btn-link btn-sm p-0 text-decoration-none d-flex align-items-center gap-1"
                                    style="color: #9ea700; font-size: 13px;"
                                    t-on-click="() => this.state.showFormula = !this.state.showFormula">
                                <t t-if="!state.showFormula"><i class="ri-eye-line"/>Show Formula</t>
                                <t t-else=""><i class="ri-eye-off-line"/>Hide Formula</t>
                            </button>
                            <div t-if="state.showFormula" class="mt-2">
                                <textarea class="form-control cy-button-stroke font-monospace"
                                          style="height: 70px; font-size: 13px; background: #f3f3e0;"
                                          t-model="state.rawFormula"
                                          t-on-input="onFormulaChange"/>
                            </div>
                        </div>
                    </t>
                </t>

                <!-- ╔══ VIEW MODE: CREATE ══╗ -->
                <t t-else="">
                    <!-- Template Name -->
                    <div class="mb-3">
                        <label class="cy-modal-form_label" style="font-size: 14px;">Template Name <span
                                class="text-danger">*</span></label>
                        <input type="text" class="form-control cy-button-stroke mt-1"
                               placeholder="e.g. Sales Margin %"
                               t-model="state.fieldName"
                               style="font-size: 13px; height: 38px;"/>
                    </div>

                    <!-- Formula -->
                    <div class="mb-3">
                        <label class="cy-modal-form_label" style="font-size: 14px;">Formula <span
                                class="text-danger">*</span></label>
                        <textarea class="form-control cy-button-stroke font-monospace mt-1"
                                  style="height: 80px; font-size: 13px; background: #f3f3e0;"
                                  placeholder="e.g. ({a} - {b}) / {b} * 100"
                                  t-model="state.rawFormula"
                                  t-on-input="onFormulaChange"/>
                        <div class="mt-2 p-3 rounded-2"
                             style="font-size: 12px; line-height: 1.6; background: #f9f9f0; border: 1px solid #DFDFDF;">
                            <div><i class="ri-information-line me-1" style="color: #9ea700; font-size: 14px;"/>
                                <b style="color: #505050;">Syntax:</b>
                                Use <code
                                        style="background: #ebedb7; padding: 2px 5px; border-radius: 3px; color: #505050;">{var_name}</code> for
                                values.</div>
                            <div class="mt-2" style="color: #333;"><b>Examples:</b></div>
                            <ul class="mb-0 ps-3" style="color: #333;">
                                <li><code>{qty}*{price}</code>
                                    —
                                    <small style="font-size: 11px;">Row-level</small></li>
                                <li><code>{current}/{previous} * 100</code>
                                    —
                                    <small style="font-size: 11px;">Aggregated</small></li>
                            </ul>
                        </div>
                    </div>

                    <!-- Calculation Method -->
                    <div class="mb-3">
                        <label class="cy-modal-form_label" style="font-size: 14px;">Calculation Method <span
                                class="text-danger">*</span></label>
                        <div class="d-flex gap-2 mt-2">
                            <div t-attf-class="flex-fill p-2 border rounded-2 text-center {{state.calculationType === 'row' ? 'shadow-sm' : ''}}"
                                 t-att-style="state.calculationType === 'row' ? 'cursor: pointer; background: #ebedb7; border-color: #9ea700 !important;' : 'cursor: pointer; background: #f7f7f7; border-color: #DFDFDF; opacity: 0.7;'"
                                 style="transition: all 0.15s;"
                                 t-on-click="() => this.state.calculationType = 'row'">
                                <i class="ri-list-check d-block mb-2" style="font-size: 1.1rem; color: #9ea700;"/>
                                <div style="font-size: 13px; font-weight: 600; color: #0E3A5D;">Row-level</div>
                                <div style="font-size: 11px; color: #333; margin-top: 3px;">Calculates the formula for each individual record.</div>
                            </div>
                            <div t-attf-class="flex-fill p-2 border rounded-2 text-center {{state.calculationType === 'aggregate' ? 'shadow-sm' : ''}}"
                                 t-att-style="state.calculationType === 'aggregate' ? 'cursor: pointer; background: #ebedb7; border-color: #9ea700 !important;' : 'cursor: pointer; background: #f7f7f7; border-color: #DFDFDF; opacity: 0.7;'"
                                 style="transition: all 0.15s;"
                                 t-on-click="() => this.state.calculationType = 'aggregate'">
                                <i class="ri-functions d-block mb-2" style="font-size: 1.1rem; color: #9ea700;"/>
                                <div style="font-size: 13px; font-weight: 600; color: #0E3A5D;">Aggregated</div>
                                <div style="font-size: 11px; color: #333; margin-top: 3px;">Calculates the formula using aggregated values to produce a single summarized result.</div>
                            </div>
                        </div>
                    </div>

                    <!-- Save / Back -->
                    <div class="mt-4">
                        <button class="btn cy-preset-save-btn w-100 d-flex align-items-center justify-content-center gap-1"
                                style="padding: 12px; font-size: 14px;"
                                t-on-click="onSaveAsTemplate">
                            <i class="ri-save-line"/>Save Template
                        </button>
                        <button class="btn btn-link btn-sm w-100 mt-2 text-decoration-none"
                                style="color: #333; font-size: 13px;"
                                t-on-click="switchToApply">
                            <i class="ri-arrow-left-s-line me-1"/>Back to Selection
                        </button>
                    </div>
                </t>

                <!-- Error -->
                <div t-if="state.error" t-ref="errorRef" class="alert alert-danger py-2 mt-3 d-flex align-items-center gap-2"
                     style="font-size: 13px; border-radius: 5px;">
                    <i class="ri-error-warning-line"/>
                    <t t-esc="state.error"/>
                </div>
            </div>

            <t t-set-slot="footer">
                <button class="btn btn-secondary px-4 py-2" style="font-size: 14px;" t-on-click="onCancel">
                    <i class="ri-close-line me-1"/>Cancel
                </button>
                <button class="btn cy-preset-apply-confirm-btn d-flex align-items-center gap-1 px-4 py-2"
                        t-on-click="onApply"
                        t-if="state.selectedPresetId and state.viewMode === 'apply'"
                        style="font-size: 14px;">
                    <i class="ri-check-line me-1"/>Apply to Sheet
                </button>
            </t>
        </Dialog>

    </t>
    
    <t t-name="PresetApplyDialog.AutoCompleteOption" owl="1">
        <div class="d-flex align-items-center justify-content-between w-100">
            <span t-esc="option.label"/>
            <i t-if="option.isSelected" class="ri-check-line ms-2" style="color: #9ea700;"/>
        </div>
    </t>
</templates>
