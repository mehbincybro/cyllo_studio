<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="cyllo_analytics.AlertConfigurationDialog" owl="1">
        <Dialog size="'md'" title="'Set Smart Alert'">
            <t t-set-slot="header">
                <div class="d-flex w-100 align-items-center justify-content-between"
                     style="border-bottom: 2px solid #ebedb7; padding-bottom: 10px;">
                    <div class="d-flex align-items-center gap-2">
                        <i class="ri-notification-3-line" style="color: #9ea700; font-size: 20px;"/>
                        <h5 class="mb-0"
                            style="font-size: 17px; font-weight: 600; color: #0E3A5D; font-family: 'Inter', sans-serif;">
                            Set Smart Alert
                        </h5>
                    </div>
                </div>
            </t>

            <div class="cy-alert-dialog p-3" style="max-height: 75vh; overflow-y: auto;">
                <!-- ── Alert Name ── -->
                <div class="mb-3">
                    <label class="cy-modal-form_label mb-1" style="font-size: 13px;">Alert Name</label>
                    <input type="text" class="form-control cy-button-stroke"
                           t-model="state.name"
                           placeholder="e.g. Sales Target Alert"
                           style="font-size: 13px; height: 38px;"/>
                </div>

                <!-- ── Measure Conditions (only when chart has measures) ── -->
                <t t-if="hasMeasures">
                    <div class="mb-3">
                        <div class="d-flex align-items-center mb-2">
                            <span class="fw-semibold">Measure-Specific Conditions</span>
                            <small class="text-muted ms-2">Set individual thresholds for multiple measures</small>
                        </div>

                        <t t-foreach="state.measureConditions" t-as="row" t-key="row_index">
                            <div class="border rounded-2 p-3 mb-2"
                                 t-att-style="row.enabled ? 'background: #fff; border-color: #9ea700 !important; box-shadow: 0 2px 8px rgba(158, 167, 0, 0.08);' : 'background: #fcfcfc; border-color: #e0e0e0;'">

                                <!-- Measure toggle row -->
                                <div class="d-flex align-items-center">
                                    <div class="form-check form-switch mb-0 me-3">
                                        <input class="form-check-input" type="checkbox"
                                               t-att-id="'msr_' + row_index"
                                               t-att-checked="row.enabled"
                                               t-on-change="() => this.toggleMeasure(row_index)"
                                               style="cursor: pointer;"/>
                                    </div>
                                    <label t-att-for="'msr_' + row_index"
                                           class="mb-0 fw-bold me-auto"
                                           style="font-size: 13px; color: #0E3A5D;"
                                           t-esc="row.label"/>
                                    <span t-if="row.enabled" class="badge rounded-pill" style="background: #ebedb7; color: #9ea700; font-size: 10px;">Active</span>
                                    <span t-if="!row.enabled" class="badge rounded-pill bg-light text-muted" style="font-size: 10px;">Off</span>
                                </div>

                                <!-- Condition + Value (visible only when measure is enabled) -->
                                <t t-if="row.enabled">
                                    <div class="row g-3 mt-1">
                                        <div class="col-7 mt-2">
                                            <label class="form-label small text-muted mb-1" style="font-size: 11px;">Condition</label>
                                            <div class="position-relative">
                                                <AutoComplete
                                                    value="getConditionLabel(row)"
                                                    sources="conditionSources(row)"
                                                    onSelect="(selected) => this.onConditionSelect(row, selected)"
                                                    placeholder="'Select Condition...'"
                                                />
                                                <i class="ri-arrow-down-s-line" style="position: absolute; right: 10px; top: 50%; transform: translateY(-50%); color: #9ea700; pointer-events: none;"/>
                                            </div>
                                        </div>
                                        <div class="col-5 mt-2">
                                            <label class="form-label small text-muted mb-1" style="font-size: 11px;">Threshold Value</label>
                                            <input type="number" class="form-control form-control-sm cy-button-stroke"
                                                   t-model.number="row.value"
                                                   style="font-size: 12.5px; height: 36px;"/>
                                        </div>
                                    </div>
                                </t>
                            </div>
                        </t>
                    </div>
                </t>

                <!-- No measures fallback -->
                <t t-if="!hasMeasures">
                    <div class="alert alert-warning mb-3">
                        <i class="fa fa-exclamation-triangle me-1"/>
                        No numeric measures found in this chart. Open the sheet editor and add a measure to use alerts.
                    </div>
                </t>

                <!-- ── Dimension-based Filter (Domain-Wise) ── -->
                <t t-if="hasDimension">
                    <div class="border rounded-2 p-3 mb-3"
                         t-att-style="state.dimension_filter ? 'background: #fff; border-color: #ebedb7 !important; border-left: 4px solid #9ea700 !important;' : 'background: #fcfcfc; border-color: #e0e0e0;'">

                        <div class="d-flex align-items-center">
                            <div class="form-check form-switch mb-0 me-3">
                                <input class="form-check-input" type="checkbox"
                                       id="dimensionFilterToggle"
                                       t-model="state.dimension_filter"
                                       style="cursor: pointer;"/>
                            </div>
                            <label for="dimensionFilterToggle" class="fw-bold mb-0 me-auto" style="font-size: 13px; color: #0E3A5D;">
                                Filter by <t t-esc="dimensionAxisName"/>
                            </label>
                            <i t-if="!state.dimension_filter" class="ri-filter-off-line text-muted" style="font-size: 14px;"/>
                            <i t-if="state.dimension_filter" class="ri-filter-3-line" style="color: #9ea700; font-size: 14px;"/>
                        </div>

                        <t t-if="state.dimension_filter">
                            <div class="mt-2 p-2 rounded-1 mb-2" style="background: rgba(158, 167, 0, 0.05); border: 1px dashed rgba(158, 167, 0, 0.2);">
                                <small class="text-muted" style="font-size: 11px;">
                                    <i class="ri-information-line me-1" style="color: #9ea700;"/>
                                    Alert will only trigger when values for this specific <t t-esc="dimensionAxisName"/> meet the conditions.
                                </small>
                            </div>
                            <div>
                                <label class="form-label small fw-bold mb-1" style="font-size: 11px; color: #555;">
                                    Target <t t-esc="dimensionAxisName"/> Value
                                </label>
                                <div class="position-relative">
                                    <AutoComplete
                                        value="state.dimension_value"
                                        sources="dimensionSources"
                                        onSelect.bind="onDimensionSelect"
                                        placeholder="'Search or select a value...'"
                                    />
                                    <i class="ri-arrow-down-s-line" style="position: absolute; right: 10px; top: 50%; transform: translateY(-50%); color: #9ea700; pointer-events: none;"/>
                                </div>
                            </div>
                        </t>
                    </div>
                </t>

                <!-- ── Notifications ── -->
                <div class="mb-3">
                    <label class="cy-modal-form_label mb-2" style="font-size: 13px;">Notifications</label>
                    <div class="p-3 rounded-2 border" style="background: #fcfcfc;">
                        <div class="form-check form-switch mb-2">
                            <input class="form-check-input" type="checkbox"
                                   id="notifyScreen" t-model="state.screen_notification" style="cursor: pointer;"/>
                            <label class="form-check-label fw-semibold" for="notifyScreen" style="font-size: 12.5px; color: #444;">Real-time Screen Warning</label>
                        </div>
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox"
                                   id="notifyEmail" t-model="state.send_email" style="cursor: pointer;"/>
                            <label class="form-check-label fw-semibold" for="notifyEmail" style="font-size: 12.5px; color: #444;">Send Email to Group</label>
                        </div>

                        <!-- ── Recipients (M2M style) ── -->
                        <t t-if="state.send_email">
                            <div class="mt-3 p-2 border rounded-2" style="background: #fff; border-style: dashed !important; border-color: #9ea700 !important;">
                                <label class="form-label small fw-bold mb-1" style="font-size: 11px; color: #555;">Recipients</label>
                                
                                <div class="d-flex flex-wrap gap-1 mb-2" t-if="state.notify_users.length > 0">
                                    <t t-foreach="state.notify_users" t-as="user" t-key="user.id">
                                        <span class="badge rounded-pill d-flex align-items-center gap-1" 
                                              style="background: #ebedb7; color: #9ea700; border: 1px solid #9ea700; padding: 4px 10px; font-size: 11px;">
                                            <t t-esc="user.display_name"/>
                                            <i class="ri-close-circle-line ms-1" style="cursor: pointer; font-size: 14px;" 
                                               t-on-click="() => this.removeUser(user.id)"/>
                                        </span>
                                    </t>
                                </div>

                                <div class="position-relative">
                                    <AutoComplete
                                        sources="userSources"
                                        onSelect.bind="onUserSelect"
                                        placeholder="'Search and add users...'"
                                    />
                                </div>
                                <small class="text-muted mt-1 d-block" style="font-size: 10px;">Select users to receive email alerts when conditions are met.</small>
                            </div>
                        </t>
                    </div>
                </div>

                <!-- ── Notify User ── -->
                <div class="mb-1 p-2 bg-light rounded-2 d-flex align-items-center gap-2">
                    <i class="ri-user-follow-line text-muted" style="font-size: 16px;"/>
                    <span class="fw-bold" style="font-size: 12.5px; color: #0E3A5D;"><t t-esc="state.userName"/></span>
                    <small class="text-muted ms-auto">Odoo inbox &amp; activities on trigger</small>
                </div>

            </div>

            <t t-set-slot="footer">
                <div class="d-flex justify-content-between w-100 px-2 py-1">
                    <div>
                        <button t-if="state.alertId" class="btn btn-outline-danger btn-sm border-0"
                                t-on-click="onDelete" style="font-size: 12.5px;">
                            <i class="ri-delete-bin-line me-1"/>Delete Alert
                        </button>
                    </div>
                    <div class="d-flex gap-2">
                        <button class="btn btn-secondary px-4 py-2" t-on-click="props.close" style="font-size: 14px; background: #fff; border: 1px solid #DFDFDF; color: #666;">
                            Cancel
                        </button>
                        <button class="btn cy-preset-save-btn px-4 py-2" t-on-click="onSave" style="font-size: 14px;">
                            <i class="ri-save-line me-1"/>Save Alert
                        </button>
                    </div>
                </div>
            </t>
        </Dialog>
    </t>
</templates>
