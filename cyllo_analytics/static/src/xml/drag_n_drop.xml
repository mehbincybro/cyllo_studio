<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <t t-name="DragItem" owl="1">
        <div class="draggable-item" t-att-data-type="props.type"
             t-att-draggable="props.draggable"
             t-attf-class="{{props.type}} {{state.isDragging ? 'dragging' : ''}}"
             t-att-value="props.value"
             t-att-data-field_type="props.field_type"
             t-att-data-column="props.column"
             t-on-dragstart="e => this.setDragging(e, true)"
             t-on-dragend="e => this.setDragging(e, false)">
            <t t-esc="props.value"/>
            <button t-if="props.onRemove" class="btn btn-secondary"
                    t-on-click="props.onRemove">
            <i t-if="props.onRemove" class="ri-close-line"/></button>
            <i t-if="props.options">
                <Dropdown togglerClass="'btn btn-secondary'">
                    <t t-set-slot="toggler">
                        <i class="ri-more-2-fill"/>
                    </t>
                    <DropdownItem t-foreach="options" t-as="option"
                                  t-key="option_index"
                                  onSelected.bind="() => this.props.setOptionValue(option, this.mode)">
                        <t t-esc="option"/>
                    </DropdownItem>
                </Dropdown>
            </i>
        </div>
    </t>
    <t t-name="DropZone" owl="1">
        <div t-if="props.show"
             t-ref="drop"
             class="drop-zone"
             t-att-data-limit="state.limit"
             t-attf-class="{{state.type}}-drop-zone {{state.highlight}}"
             t-on-dragover="onDragOver"
             t-on-drop="onItemDrop"
             style="min-height: 50px">
            <t t-esc="props.string"/>
            <div class="d-flex flex-wrap gap-2">
                <t t-foreach="state.children"
                   t-as="dropItem"
                   t-key="dropItem_index">
                    <DragItem t-props="dropItem"
                              draggable="false"
                              onRemove="() => this.onItemRemove(dropItem_index, state.type)"
                              options="state.type == 'measure'"
                              setOptionValue.bind="(val, mode) => this.setFunctions(val, mode, dropItem_index)"/>
                </t>
            </div>
            <div class="d-flex justify-content-center">
                <div t-if="props.info.condition" class="info-panel"
                     t-att-class="props.info.className" style="width: 25%;">
                    <div><i class="ri-information-line"/>
                        <span t-out="props.info.message"/></div>
                </div>
            </div>
        </div>
    </t>
</templates>