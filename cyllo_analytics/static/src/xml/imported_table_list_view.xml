<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="cyllo_analytics.ImportedTableListView" t-inherit="web.ListView" t-inherit-mode="extension">
        <xpath expr="//t[@t-set-slot='control-panel-additional-actions']" position="inside">
            <t t-if="env.config.viewType === 'list' and props.resModel === 'custom.imported.table'">
                <button type="button" class="btn btn-link o_list_button_add o_import_table_button" t-on-click="env.openImportWizard">
                    + Import New Table
                </button>
            </t>
        </xpath>
    </t>
</templates>
