<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <t t-name="cyllo_analytics.MenuDialog" owl="1">
        <Record t-props="recordProps" t-slot-scope="data">
            <div class="cy-onboard_modal-container cy-kpi_modal-container">
                <div class="modal-dialog  cy-dashboard_modal-box">
                    <div class="modal-content cy-modal_content">
                        <div class="modal-header  cy-social_commentHead d-flex  pt-4">
                            <h5 class="cy-dashboard_modal-heading">Add To Menu
                            <div class="field-tooltip" style="cursor: pointer;">
                                <span style="font-size: 13px;"
                                      class="add-menu-info">?
                                </span>
                            </div>
                                <div class="tooltip-content justify-content-around modal_background"
                                     style="background-color: #fff;">
                                The dashboard menu will be displayed as a sub-menu
                                of the selected parent menu with the given name.
                            </div>
                            </h5>
                            <span id="sheet_filter_close"
                                  class="cy-icons cy-social_cmnt-closebtn"
                                  t-on-click="_cancel">
                                <i class="ri-close-line"/>
                            </span>
                        </div>
                        <div class="modal-body py-0">
                            <form class="p-4">
                                <div class="row py-2">
                                    <div class="col-12  mb-3 px-2">
                                        <label for="name"
                                               class="form-label  cy-modal-form_label">Name</label>
                                        <CharField name="'name'"
                                                   record="data.record"
                                                   id="'name'"/>
                                    </div>
                                    <div class="col-12  mb-3 px-2">
                                        <label for="menu_id"
                                               class="form-label cy-modal-form_label">Parent Menu</label>
                                        <Many2OneField id="'menu_id'"
                                                       name="'menu_id'"
                                                       record="data.record"
                                                       domain.bind="domain"
                                                       t-props="defaultProps"/>
                                    </div>
                                </div>
                            </form>
                        </div>
                        <div class="cy-modal_footer cy-social_cmnt-footer">
                            <div class="d-flex justify-content-end gap-2">
                                <button class="btn cy-button-primary-stroke"
                                        t-on-click="handleConfirm">Confirm</button>
                                <button class="btn cy-button-stroke"
                                        t-on-click="_cancel">Cancel</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </Record>
    </t>
</templates>