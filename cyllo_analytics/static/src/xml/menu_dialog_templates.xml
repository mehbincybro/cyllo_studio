<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <t t-name="cyllo_analytics.MenuDialog" owl="1">
        <Record t-props="recordProps" t-slot-scope="data">
            <div class="cy-onboard_modal-container cy-kpi_modal-container">
                <div class="modal-dialog  cy-dashboard_modal-box">
                    <div class="modal-content cy-modal_content">
                        <div class="modal-header  cy-social_commentHead d-flex  pt-4">
                            <h5 class="cy-dashboard_modal-heading">Add To Menu
                            <div class="field-tooltip" style="cursor: pointer;">
                                <span style="font-size: 13px;"
                                      class="add-menu-info">?
                                </span>
                            </div>
                                <div class="tooltip-content justify-content-around modal_background"
                                     style="background-color: #fff;">
                                The dashboard menu will be displayed as a sub-menu
                                of the selected parent menu with the given name.
                            </div>
                            </h5>
                            <span id="sheet_filter_close"
                                  class="cy-icons cy-social_cmnt-closebtn"
                                  t-on-click="_cancel">
                                <i class="ri-close-line"/>
                            </span>
                        </div>
                        <div class="modal-body py-0">
                            <form class="p-4">
                                <div class="row py-2">
                                    <div class="col-12  mb-3 px-2">
                                        <label for="name"
                                               class="form-label  cy-modal-form_label">Name</label>
                                        <CharField name="'name'"
                                                   record="data.record"
                                                   id="'name'"/>
                                    </div>
                                    <div class="col-12  mb-3 px-2">
                                        <label class="form-label cy-modal-form_label">App (Top-Level Menu)</label>
                                        <!-- Custom Standard HTML Dropdown to prevent Odoo portal escaping -->
                                        <div class="position-relative w-100" t-on-click.stop="">
                                            <div class="form-select text-start d-flex justify-content-between align-items-center w-100 bg-white"
                                                 style="cursor: pointer;"
                                                 t-on-click="toggleAppDropdown">
                                                <span t-if="state.selectedAppId" class="text-dark text-truncate me-2"><t t-esc="state.selectedAppName"/></span>
                                                <span t-else="" class="text-muted text-truncate me-2">Select an App...</span>
                                            </div>
                                            <!-- The Dropdown List -->
                                            <div t-if="state.isDropdownOpen"
                                                 class="dropdown-menu show w-100 shadow-sm mt-1"
                                                 style="position: absolute; top: 100%; left: 0; max-height: 250px; overflow-y: auto; overflow-x: hidden; border-radius: 6px; padding: 4px; border: 1px solid #ced4da; z-index: 1050;">
                                                <div class="dropdown-item px-3 py-2 border-bottom"
                                                     style="cursor: pointer;"
                                                     t-on-click="() => this.onAppChangeDropdown('', '')">
                                                    <span class="text-muted fst-italic">Select an App...</span>
                                                </div>
                                                <t t-foreach="state.apps" t-as="app" t-key="app.id">
                                                    <div class="dropdown-item px-3 py-2"
                                                         style="cursor: pointer;"
                                                         t-on-click="() => this.onAppChangeDropdown(app.id, app.name)">
                                                        <span t-att-class="state.selectedAppId == app.id ? 'fw-bold' : ''"
                                                              t-att-style="state.selectedAppId == app.id ? 'color: #aabc14;' : ''">
                                                            <t t-esc="app.name"/>
                                                        </span>
                                                    </div>
                                                </t>
                                    </div>
                                        </div>
                                    </div>
                                    <div class="col-12 px-2" t-if="state.selectedAppId">
                                        <label class="form-label cy-modal-form_label">Menu Position</label>
                                        <div class="text-muted small mb-2">Drag the "New Menu" pill and drop it in the desired location.</div>
                                        <div class="menu-tree-container p-3 border rounded" style="max-height: 400px; overflow-y: auto; background: #f8f9fa;">
                                            <!-- The draggable pill -->
                                            <div t-if="!state.isDropped" class="d-flex justify-content-center mb-4">
                                                <div class="draggable-new-menu shadow"
                                                     draggable="true"
                                                     t-on-dragstart="onDragStartNewMenu"
                                                     t-on-dragend="onDragEndNewMenu"
                                                     style="background: #aabc14; color: white; padding: 8px 20px; border-radius: 20px; cursor: grab; user-select: none; font-weight: 500; font-size: 14px;">
                                                    <i class="ri-drag-move-2-fill me-2"/> <t t-esc="data.record.data.name || 'New Dashboard Menu'"/>
                                                </div>
                                            </div>
                                            <!-- The nested tree -->
                                            <t t-if="state.appTree">
                                                <MenuTreeNode node="state.appTree" level="0" parentId="state.appTree.id" comp="this"/>
                                            </t>
                                            <div t-else="" class="text-center text-muted py-4">Loading menu structure...</div>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                        <div class="cy-modal_footer cy-social_cmnt-footer">
                             <div class="d-flex justify-content-between align-items-center w-100">
                                <div class="text-muted small px-3">
                                    <t t-if="state.targetParentId">
                                        Will be added under: <strong><t t-esc="state.targetParentName"/></strong> (Sequence: <t t-esc="state.targetSequence"/>)
                                    </t>
                                </div>
                                <div class="d-flex gap-2">
                                <button class="btn cy-button-primary-stroke"
                                            t-on-click="handleConfirm"
                                            t-att-disabled="!state.targetParentId">Confirm</button>
                                <button class="btn cy-button-stroke"
                                        t-on-click="_cancel">Cancel</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            </div>
        </Record>
    </t>
    <!-- Recursive Sub-Template for Menu Tree -->
    <t t-name="cyllo_analytics.MenuTreeNode" owl="1">
        <div class="menu-tree-node" t-att-style="'margin-left: ' + (props.level * 25) + 'px;'">
            <!-- Drop zone before this item (disabled for the root app node) -->
            <div t-if="!props.node.isTemp and props.level > 0" class="drop-zone-indicator"
                 t-att-data-parent-id="props.parentId"
                 t-att-data-before-seq="props.node.sequence"
                 t-att-data-before-id="props.node.id"
                 t-on-dragover="onDragOver"
                 t-on-dragleave="onDragLeave"
                 t-on-drop="onDrop"
                 style="height: 0px; margin: 0; transition: all 0.2s; border-radius: 4px; opacity: 1;"></div>

            <div class="menu-item p-2 bg-white border rounded shadow-sm d-flex align-items-center"
                 t-att-class="{
                     'is-temp-node': props.node.isTemp,
                     'drop-into-zone': !props.node.isTemp
                 }"
                 t-att-draggable="props.node.isTemp ? 'true' : 'false'"
                 t-on-dragstart="onDragStartNewMenu"
                 t-on-dragend="onDragEndNewMenu"
                 t-att-data-into-parent-id="!props.node.isTemp ? props.node.id : null"
                 t-att-data-into-parent-name="!props.node.isTemp ? props.node.name : null"
                 t-on-dragover="onDragOverInto"
                 t-on-dragleave="onDragLeaveInto"
                 t-on-drop="onDropInto"
                 t-att-style="props.node.isTemp ? 'background: #aabc14 !important; color: white !important; cursor: grab;' : 'transition: border 0.3s ease;'">

                <t t-if="props.node.isTemp">
                    <i class="ri-drag-move-2-fill me-2 text-white"/>
                    <span class="fw-medium text-white"><t t-esc="props.node.name"/></span>
                </t>
                <t t-else="">
                    <i class="ri-folder-2-line text-muted me-2" t-if="props.node.children and props.node.children.length > 0"/>
                    <i class="ri-file-list-3-line text-muted me-2" t-else=""/>
                    <span class="fw-medium text-dark"><t t-esc="props.node.name"/></span>
                </t>
            </div>
            <!-- Children -->
            <t t-if="props.node.children and props.node.children.length > 0">
                <div class="children-container mt-1">
                    <t t-foreach="props.node.children" t-as="child" t-key="child.id">
                        <MenuTreeNode node="child" level="props.level + 1" parentId="props.node.id" comp="props.comp" isLast="child_last"/>
                    </t>
                </div>
            </t>
            <!-- Drop zone after the LAST item in a list (handled at the parent level, disabled for level 0) -->
            <t t-if="props.isLast and !props.node.isTemp and props.level > 0">
                 <div class="drop-zone-indicator"
                      t-att-data-parent-id="props.parentId"
                      t-att-data-after-seq="props.node.sequence"
                      t-att-data-after-id="props.node.id"
                      t-on-dragover="onDragOver"
                      t-on-dragleave="onDragLeave"
                      t-on-drop="onDrop"
                      style="height: 0px; margin: 0; transition: all 0.2s; border-radius: 4px; opacity: 1;"></div>
            </t>
        </div>
    </t>
</templates>