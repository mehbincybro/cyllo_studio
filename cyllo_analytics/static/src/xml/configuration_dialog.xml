<?xml version="1.0" encoding="UTF-8" ?>
<templates>
    <t t-name="cyllo_analytics.ConfigurationDialog" owl="1">
        <Record t-props="recordProps" t-slot-scope="data">
            <div class="cy-onboard_modal-container cy-kpi_modal-container">
                <div class="modal-dialog  cy-dashboard_modal-box">
                    <div class="modal-content cy-modal_content">
                        <div class="modal-header  cy-social_commentHead d-flex  pt-4">
                            <h5 class="cy-dashboard_modal-heading">Dashboard
                                Configuration
                            </h5>
                            <span class="cy-icons cy-social_cmnt-closebtn"
                                  t-on-click="props.close">
                                <i class="ri-close-line"></i>
                            </span>
                        </div>
                        <div class="modal-body cy-modal-body py-0 overflow-auto">
                            <form class="p-4 cy_dash_conf">
                                <div class="row py-2">
                                    <div class="col-sm-6 px-2">
                                        <div class="col-12  mb-2">
                                            <label for="name"
                                                   class="form-label  cy-modal-form_label">
                                                Name
                                            </label>
                                            <CharField name="'name'"
                                                       record="data.record"
                                                       id="'name'"/>
                                        </div>
                                        <div class="col-12  mb-2">
                                            <label for="group_ids"
                                                   class="form-label cy-modal-form_label">
                                                Groups
                                            </label>
                                            <div class="o_field_widget d-block">
                                                <Many2ManyTagsField
                                                        id="'group_ids'"
                                                        name="'group_ids'"
                                                        record="data.record"
                                                        t-props="defaultConfProps"/>
                                            </div>
                                        </div>
                                        <div class="col-12  mb-2">
                                            <label for="banner_id"
                                                   class="form-label cy-modal-form_label">
                                                Banner
                                            </label>
                                            <Many2OneField id="'banner_id'"
                                                           name="'banner_id'"
                                                           record="data.record"
                                                           t-props="defaultConfProps"/>
                                        </div>
                                    </div>
                                    <div class="col-sm-6 px-2">
                                        <div class="col-12  mb-2">
                                            <label for="company_id" class="form-label cy-modal-form_label">
                                                Company
                                            </label>
                                            <div class="o_field_widget d-block">
                                                <Many2OneField
                                                    name="'company_id'"
                                                    record="data.record"
                                                    t-props="defaultConfProps"/>
                                            </div>
                                        </div>
                                        <div class="col-12  mb-2">
                                            <label for="users"
                                                   class="form-label cy-modal-form_label">
                                                Users
                                            </label>
                                            <div class="o_field_widget d-block">
                                                <Many2ManyTagsField
                                                        id="'user_ids'"
                                                        name="'user_ids'"
                                                        record="data.record"
                                                        t-props="defaultConfProps"/>
                                            </div>
                                        </div>
                                        <div class="col-12  mb-2 ">
                                            <label for="theme_id"
                                                   class="form-label cy-modal-form_label">
                                                Theme
                                            </label>
                                            <Many2OneField id="'theme_id'"
                                                           name="'theme_id'"
                                                           record="data.record"
                                                           t-props="defaultConfProps"/>
                                        </div>
                                    </div>
                                    <div class="col-sm-6 px-2 d-flex"
                                         style="gap: 15px;">
                                        <div t-if="hasLinkedMenu.length"
                                             class="col-12  mb-2 ">
                                            <label for="ir_menu_ids"
                                                   class="form-label cy-modal-form_label"
                                                   title="This Menu shows all the Menus that are linked to this dashboard">
                                                Linked Menus
                                            </label>
                                            <div class="o_field_widget d-block delete_field_widget">
                                                <DeleteOnlyMany2ManyTagsField
                                                        id="'ir_menu_ids'"
                                                        name="'ir_menu_ids'"
                                                        record="data.record"
                                                        t-props="defaultConfProps"
                                                        readonly="true"/>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-12 px-2 mt-4">
                                        <label class="form-label cy-modal-form_label">Live Sharing Links</label>
                                        <div class="share-links-container p-3 rounded" style="background: #f8fafc; border: 1px solid #e2e8f0;">
                                            <t t-if="state.links and state.links.length">
                                                <div class="d-flex flex-column gap-2">
                                                    <t t-foreach="state.links" t-as="link" t-key="link.id">
                                                        <div class="d-flex justify-content-between align-items-center p-2 bg-white rounded border shadow-sm">
                                                            <div class="d-flex flex-column flex-grow-1 overflow-hidden">
                                                                <div class="small text-truncate fw-bold text-primary" t-att-title="link.access_url">
                                                                    <t t-esc="link.access_url"/>
                                                                </div>
                                                                <div class="d-flex align-items-center mt-1" style="font-size: 11px;">
                                                                    <span class="text-muted me-2">Expires:</span>
                                                                    <input type="date" 
                                                                           class="form-control form-control-sm p-0 px-1 border-0 bg-transparent"
                                                                           style="font-size: 11px; width: 110px; height: auto;"
                                                                           t-att-value="link.expiry_date ? link.expiry_date.split(' ')[0] : ''"
                                                                           t-on-change="(ev) => this.onExpiryChange(link, ev)"/>
                                                                </div>
                                                            </div>
                                                            <button class="btn btn-sm btn-link text-danger p-0 ms-2" 
                                                                    title="Revoke This Link"
                                                                    t-on-click="() => this.onRevokeLink(link)">
                                                                <i class="ri-close-circle-line fs-5"></i>
                                                            </button>
                                                        </div>
                                                    </t>
                                                </div>
                                            </t>
                                            <t t-else="">
                                                <div class="text-center py-3 text-muted small">
                                                    <i class="ri-links-line d-block fs-4 mb-1"></i>
                                                    No active sharing links found.
                                                </div>
                                            </t>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                        <div class="cy-modal_footer cy-social_cmnt-footer">
                            <div class="d-flex justify-content-end gap-2">
                                <button class="btn cy-button-primary-stroke"
                                        t-on-click="onConfigSave">Save
                                </button>
                                <button class="btn cy-button-stroke"
                                        t-on-click="props.close">Cancel
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </Record>
    </t>
</templates>