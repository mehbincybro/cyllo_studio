<?xml version="1.0" encoding="UTF-8" ?>
<templates>
    <t t-name="cyllo_analytics.ConfigurationDialog" owl="1">
        <Record t-props="recordProps" t-slot-scope="data">
            <div class="cy-onboard_modal-container cy-kpi_modal-container">
                <div class="modal-dialog  cy-dashboard_modal-box">
                    <div class="modal-content cy-modal_content">
                        <div class="modal-header  cy-social_commentHead d-flex  pt-4">
                            <h5 class="cy-dashboard_modal-heading">Dashboard
                                Configuration
                            </h5>
                            <span class="cy-icons cy-social_cmnt-closebtn"
                                  t-on-click="props.close">
                                <i class="ri-close-line"></i>
                            </span>
                        </div>
                        <div class="modal-body cy-modal-body py-0 overflow-auto">
                            <form class="p-4 cy_dash_conf">
                                <div class="row py-2">
                                    <div class="col-sm-6 px-2">
                                        <div class="col-12  mb-2">
                                            <label for="name"
                                                   class="form-label  cy-modal-form_label">
                                                Name
                                            </label>
                                            <CharField name="'name'"
                                                       record="data.record"
                                                       id="'name'"/>
                                        </div>
                                        <div class="col-12  mb-2">
                                            <label for="group_ids"
                                                   class="form-label cy-modal-form_label">
                                                Groups
                                            </label>
                                            <div class="o_field_widget d-block">
                                                <Many2ManyTagsField
                                                        id="'group_ids'"
                                                        name="'group_ids'"
                                                        record="data.record"
                                                        t-props="defaultConfProps"/>
                                            </div>
                                        </div>
                                        <div class="col-12  mb-2">
                                            <label for="banner_id"
                                                   class="form-label cy-modal-form_label">
                                                Banner
                                            </label>
                                            <Many2OneField id="'banner_id'"
                                                           name="'banner_id'"
                                                           record="data.record"
                                                           t-props="defaultConfProps"/>
                                        </div>
                                    </div>
                                    <div class="col-sm-6 px-2">
                                        <div class="col-12  mb-2">
                                            <label for="company_id" class="form-label cy-modal-form_label">
                                                Company
                                            </label>
                                            <div class="o_field_widget d-block">
                                                <Many2OneField
                                                    name="'company_id'"
                                                    record="data.record"
                                                    t-props="defaultConfProps"/>
                                            </div>
                                        </div>
                                        <div class="col-12  mb-2">
                                            <label for="users"
                                                   class="form-label cy-modal-form_label">
                                                Users
                                            </label>
                                            <div class="o_field_widget d-block">
                                                <Many2ManyTagsField
                                                        id="'user_ids'"
                                                        name="'user_ids'"
                                                        record="data.record"
                                                        t-props="defaultConfProps"/>
                                            </div>
                                        </div>
                                        <div class="col-12  mb-2 ">
                                            <label for="theme_id"
                                                   class="form-label cy-modal-form_label">
                                                Theme
                                            </label>
                                            <Many2OneField id="'theme_id'"
                                                           name="'theme_id'"
                                                           record="data.record"
                                                           t-props="defaultConfProps"/>
                                        </div>
                                    </div>
                                    <div class="col-sm-6 px-2 d-flex"
                                         style="gap: 15px;">
                                        <div t-if="hasLinkedMenu.length"
                                             class="col-12  mb-2 ">
                                            <label for="ir_menu_ids"
                                                   class="form-label cy-modal-form_label"
                                                   title="This Menu shows all the Menus that are linked to this dashboard">
                                                Linked Menus
                                            </label>
                                            <div class="o_field_widget d-block delete_field_widget">
                                                <DeleteOnlyMany2ManyTagsField
                                                        id="'ir_menu_ids'"
                                                        name="'ir_menu_ids'"
                                                        record="data.record"
                                                        t-props="defaultConfProps"
                                                        readonly="true"/>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                        <div class="cy-modal_footer cy-social_cmnt-footer">
                            <div class="d-flex justify-content-end gap-2">
                                <button class="btn cy-button-primary-stroke"
                                        t-on-click="onConfigSave">Save
                                </button>
                                <button class="btn cy-button-stroke"
                                        t-on-click="props.close">Cancel
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </Record>
    </t>
</templates>