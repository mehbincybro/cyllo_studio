<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="cyllo_analytics.TileRenderer">
        <div tabindex="-1"
             class="o_tile_renderer o_renderer row py-3 cy-template_container"
             t-ref="root">
            <div class="d-flex align-items-center flex-wrap gap-3"
                 style="height: fit-content;">
                <TileCard t-foreach="state.records"
                          t-as="record"
                          t-key="record_index"
                          value="record"
                          model="props.resModel"
                          onDelete.bind="onDelete"
                          imageField="props.imageField or 'image_1920'"
                />
            </div>
        </div>
    </t>
</templates>