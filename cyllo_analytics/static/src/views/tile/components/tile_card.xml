<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="TileCard" owl="1">
        <div t-on-click="openView"
             class="col d-flex align-items-center gap-2 cy_tile_card_box cy-button-stroke"
             style="cursor:pointer; position: relative; background: none">
            <div class="tile_card_image-container mt-2">
                <img t-att-src="Image" class="tile_card_image" alt="Graphs"/>
            </div>
            <div>
                <span class="cy-template-box_txt" t-out="tileData.name"/>
            </div>
            <i class="ri-delete-bin-line tile_delete"
               title="Delete"
               t-on-click.prevent.stop="onClickDelete"
               style="top: 5px; position: absolute; right: 10px;"/>
        </div>
    </t>
</templates>