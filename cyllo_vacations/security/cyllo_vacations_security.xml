<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        
        <!-- Tour Agency Categories -->
        <record id="module_cyllo_vacations_category" model="ir.module.category">
            <field name="name">Tours &amp; Travel</field>
            <field name="description">Manage tours and travel agency</field>
            <field name="sequence">15</field>
        </record>
        
        <!-- Tour Agency User Group -->
        <record id="group_cyllo_vacations_user" model="res.groups">
            <field name="name">User</field>
            <field name="category_id" ref="module_cyllo_vacations_category"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>
        
        <!-- Tour Agency Manager Group -->
        <record id="group_cyllo_vacations_manager" model="res.groups">
            <field name="name">Manager</field>
            <field name="category_id" ref="module_cyllo_vacations_category"/>
            <field name="implied_ids" eval="[(4, ref('group_cyllo_vacations_user'))]"/>
            <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        </record>
        
        <!-- Portal User Group for Customers -->
        <record id="group_tour_portal_user" model="res.groups">
            <field name="name">Portal - Tour Customer</field>
            <field name="category_id" ref="base.module_category_hidden"/>
            <field name="implied_ids" eval="[(4, ref('base.group_portal'))]"/>
        </record>
        
        <!-- Record Rules -->
        
        <!-- Tour Package Rules -->
        <record id="tour_package_user_rule" model="ir.rule">
            <field name="name">Tour Package: User: See Own and Published</field>
            <field name="model_id" ref="model_tour_package"/>
            <field name="domain_force">['|', ('user_id', '=', user.id), ('state', '=', 'published')]</field>
            <field name="groups" eval="[(4, ref('group_cyllo_vacations_user'))]"/>
        </record>
        
        <record id="tour_package_manager_rule" model="ir.rule">
            <field name="name">Tour Package: Manager: See All</field>
            <field name="model_id" ref="model_tour_package"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_cyllo_vacations_manager'))]"/>
        </record>
        
        <record id="tour_package_portal_rule" model="ir.rule">
            <field name="name">Tour Package: Portal: See Published Only</field>
            <field name="model_id" ref="model_tour_package"/>
            <field name="domain_force">[('state', '=', 'published'), ('is_published', '=', True)]</field>
            <field name="groups" eval="[(4, ref('base.group_portal')), (4, ref('base.group_public'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>
        
        <!-- Tour Inquiry Rules -->
        <record id="tour_inquiry_user_rule" model="ir.rule">
            <field name="name">Tour Inquiry: User: See Own</field>
            <field name="model_id" ref="model_tour_inquiry"/>
            <field name="domain_force">['|', ('user_id', '=', user.id), ('user_id', '=', False)]</field>
            <field name="groups" eval="[(4, ref('group_cyllo_vacations_user'))]"/>
        </record>
        
        <record id="tour_inquiry_manager_rule" model="ir.rule">
            <field name="name">Tour Inquiry: Manager: See All</field>
            <field name="model_id" ref="model_tour_inquiry"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_cyllo_vacations_manager'))]"/>
        </record>
        
        <record id="tour_inquiry_portal_rule" model="ir.rule">
            <field name="name">Tour Inquiry: Portal: See Own</field>
            <field name="model_id" ref="model_tour_inquiry"/>
            <field name="domain_force">[('partner_id', '=', user.partner_id.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="False"/>
        </record>
        
        <!-- Tour Booking Rules -->
        <record id="tour_booking_user_rule" model="ir.rule">
            <field name="name">Tour Booking: User: See Own</field>
            <field name="model_id" ref="model_tour_booking"/>
            <field name="domain_force">['|', ('user_id', '=', user.id), ('user_id', '=', False)]</field>
            <field name="groups" eval="[(4, ref('group_cyllo_vacations_user'))]"/>
        </record>
        
        <record id="tour_booking_manager_rule" model="ir.rule">
            <field name="name">Tour Booking: Manager: See All</field>
            <field name="model_id" ref="model_tour_booking"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_cyllo_vacations_manager'))]"/>
        </record>
        
        <record id="tour_booking_portal_rule" model="ir.rule">
            <field name="name">Tour Booking: Portal: See Own</field>
            <field name="model_id" ref="model_tour_booking"/>
            <field name="domain_force">[('partner_id', '=', user.partner_id.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>
        
        <!-- Multi-company Rules -->
        <record id="tour_package_company_rule" model="ir.rule">
            <field name="name">Tour Package: Multi-company</field>
            <field name="model_id" ref="model_tour_package"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
            <field name="global" eval="True"/>
        </record>
        
        <record id="tour_booking_company_rule" model="ir.rule">
            <field name="name">Tour Booking: Multi-company</field>
            <field name="model_id" ref="model_tour_booking"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
            <field name="global" eval="True"/>
        </record>
        
        <record id="tour_inquiry_company_rule" model="ir.rule">
            <field name="name">Tour Inquiry: Multi-company</field>
            <field name="model_id" ref="model_tour_inquiry"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
            <field name="global" eval="True"/>
        </record>
        
    </data>
</odoo>

