<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Tour Booking Commission Form View -->
    <record id="view_tour_booking_commission_form" model="ir.ui.view">
        <field name="name">tour.booking.commission.form</field>
        <field name="model">tour.booking.commission</field>
        <field name="arch" type="xml">
            <form string="Tour Booking Commission">
                <header>
                    <button name="action_confirm" string="Confirm" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_create_vendor_bill" string="Create Vendor Bill" type="object" class="oe_highlight" invisible="state != 'confirmed' or vendor_bill_id"/>
                    <button name="action_mark_paid" string="Mark as Paid" type="object" invisible="state != 'confirmed'"/>
                    <button name="action_cancel" string="Cancel" type="object" invisible="state in ('cancelled', 'paid')"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,paid"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="%(account.action_move_in_invoice_type)d" type="action" class="oe_stat_button" icon="fa-file-text-o" invisible="not vendor_bill_id" context="{'form_view_initial_mode': 'readonly', 'search_default_id': vendor_bill_id}">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Vendor Bill</span>
                            </div>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label class="o_form_label" for="agent_id" string="Agent"/>
                        <h1>
                            <field name="agent_id" placeholder="Select Agent..." readonly="state != 'draft'"/>
                        </h1>
                        <div class="o_row" invisible="not booking_id">
                            <span class="text-muted me-1">Booking:</span>
                            <field name="booking_id" readonly="state != 'draft'" class="fw-bold"/>
                        </div>
                    </div>
                    <group>
                        <group>
                            <field name="rule_id"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                        <group>
                            <field name="commission_type"/>
                            <field name="commission_rate"/>
                            <field name="booking_amount" widget="monetary"/>
                            <field name="commission_amount" widget="monetary" readonly="state != 'draft'"/>
                            <field name="vendor_bill_id" readonly="1" invisible="not vendor_bill_id"/>
                            <field name="vendor_bill_state" invisible="not vendor_bill_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Notes" name="notes">
                            <field name="notes" placeholder="Additional notes..." readonly="state != 'draft'"/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Tour Booking Commission Tree View -->
    <record id="view_tour_booking_commission_tree" model="ir.ui.view">
        <field name="name">tour.booking.commission.tree</field>
        <field name="model">tour.booking.commission</field>
        <field name="arch" type="xml">
            <tree string="Tour Booking Commissions">
                <field name="agent_id"/>
                <field name="booking_id"/>
                <field name="rule_id"/>
                <field name="commission_amount" sum="Total Commission"/>
                <field name="currency_id" column_invisible="True"/>
                <field name="state" widget="badge" 
                       decoration-info="state == 'draft'" 
                       decoration-success="state == 'paid'" 
                       decoration-warning="state == 'confirmed'" 
                       decoration-danger="state == 'cancelled'"/>
            </tree>
        </field>
    </record>

    <!-- Tour Booking Commission Search View -->
    <record id="view_tour_booking_commission_search" model="ir.ui.view">
        <field name="name">tour.booking.commission.search</field>
        <field name="model">tour.booking.commission</field>
        <field name="arch" type="xml">
            <search string="Search Commissions">
                <field name="agent_id"/>
                <field name="booking_id"/>
                <field name="rule_id"/>
                <separator/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Confirmed" name="confirmed" domain="[('state', '=', 'confirmed')]"/>
                <filter string="Paid" name="paid" domain="[('state', '=', 'paid')]"/>
                <group expand="0" string="Group By">
                    <filter string="Agent" name="group_by_agent" context="{'group_by':'agent_id'}"/>
                    <filter string="Status" name="group_by_state" context="{'group_by':'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Tour Booking Commission Action -->
    <record id="action_tour_booking_commission" model="ir.actions.act_window">
        <field name="name">Commissions</field>
        <field name="res_model">tour.booking.commission</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_tour_booking_commission_search"/>
        <field name="context">{'search_default_group_by_agent': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No commissions recorded yet!
            </p>
            <p>
                Agent commissions are automatically calculated when a booking is confirmed.
            </p>
        </field>
    </record>

</odoo>
