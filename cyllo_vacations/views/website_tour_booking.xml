    <!-- Booking Confirmation Success Page -->
    <template id="tour_booking_confirmed" name="Booking Confirmed">
        <t t-call="cyllo_vacations.tour_layout">
            <div class="container my-5">
                <div class="row">
                    <div class="col-md-8 mx-auto">
                        <div class="card border-success">
                            <div class="card-header bg-success text-white text-center">
                                <i class="fa fa-check-circle fa-3x mb-2"/>
                                <h2>Booking Confirmed!</h2>
                            </div>
                            <div class="card-body text-center">
                                <p class="lead">Thank you! Your tour booking has been confirmed.</p>
                                <p>Booking Reference: <strong><t t-esc="booking.name"/></strong></p>
                                <p>Package: <strong><t t-esc="booking.package_name"/></strong></p>
                                <p>Travel Date: <strong><span t-field="booking.travel_start_date"/></strong></p>
                                <p>Total Amount: <strong><span t-field="booking.price_total" t-options='{"widget": "monetary", "display_currency": booking.currency_id}'/></strong></p>
                                
                                <hr/>
                                
                                <p class="text-muted">
                                    A confirmation email has been sent to your registered email address.
                                    You can view your booking details anytime from your account.
                                </p>
                                
                                <div class="mt-4">
                                    <a t-attf-href="/my/bookings/{{booking.id}}" class="btn btn-primary btn-lg">
                                        <i class="fa fa-eye"/> View Booking Details
                                    </a>
                                    <a href="/tours" class="btn btn-secondary btn-lg">
                                        <i class="fa fa-search"/> Browse More Tours
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>
    
</odoo>

