<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <record id="tour_hotel_view_tree" model="ir.ui.view">
        <field name="name">tour.hotel.view.tree</field>
        <field name="model">tour.hotel</field>
        <field name="arch" type="xml">
            <tree string="Hotels">
                <field name="name"/>
                <field name="code"/>
                <field name="location"/>
                <field name="star_rating"/>
                <field name="hotel_type"/>
                <field name="rating"/>
                <field name="price_per_night" widget="monetary"/>
                <field name="currency_id" column_invisible="1"/>
                <field name="active" widget="boolean_toggle"/>
            </tree>
        </field>
    </record>
    
    <record id="tour_hotel_view_form" model="ir.ui.view">
        <field name="name">tour.hotel.view.form</field>
        <field name="model">tour.hotel</field>
        <field name="arch" type="xml">
            <form string="Hotel">
                <sheet>
                    <field name="image_1920" widget="image" class="oe_avatar"/>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Hotel Name"/>
                        </h1>
                        <div class="o_row">
                            <label for="code" string="Code:"/>
                            <field name="code" readonly="1" class="me-3"/>
                            <label for="hotel_type" string="Type:"/>
                            <field name="hotel_type" class="me-3"/>
                            <label for="star_rating" string="Hotel Class (Stars):"/>
                            <field name="star_rating" class="me-3"/>
                            <label for="rating" string="Customer Rating:"/>
                            <field name="rating" widget="float" options="{'precision': 1}"/>
                        </div>
                    </div>
                    <group>
                        <group string="Location">
                            <field name="location" placeholder="e.g., Paris, France"/>
                            <field name="address" placeholder="Full street address"/>
                        </group>
                        <group string="Check-in/Check-out">
                            <field name="check_in_time" widget="float_time"/>
                            <field name="check_out_time" widget="float_time"/>
                        </group>
                    </group>
                    <group>
                        <group string="Contact Information">
                            <field name="partner_id"/>
                            <field name="phone" widget="phone"/>
                            <field name="mobile" widget="phone"/>
                            <field name="email" widget="email"/>
                            <field name="website" widget="url"/>
                        </group>
                        <group string="Address Details">
                            <field name="street"/>
                            <field name="street2"/>
                            <field name="city"/>
                            <field name="state_id"/>
                            <field name="zip"/>
                            <field name="country_id"/>
                        </group>
                    </group>
                    <group>
                        <group string="Pricing">
                            <field name="currency_id"/>
                            <field name="price_per_night" widget="monetary"/>
                            <field name="product_id"/>
                        </group>
                        <group>
                            <field name="active"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description" name="description">
                            <field name="description" widget="html" placeholder="Hotel description..."/>
                        </page>
                        <page string="Room Types" name="room_types">
                            <field name="room_type_ids" context="{'default_hotel_id': id}">
                                <tree editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="capacity"/>
                                    <field name="price_per_night" widget="monetary"/>
                                    <field name="currency_id" column_invisible="1"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Amenities" name="amenities">
                            <field name="amenity_ids" widget="many2many_tags"/>
                        </page>
                        <page string="Notes" name="notes">
                            <field name="notes" placeholder="Internal notes..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    
    <record id="tour_hotel_view_kanban" model="ir.ui.view">
        <field name="name">tour.hotel.view.kanban</field>
        <field name="model">tour.hotel</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile" sample="1">
                <field name="id"/>
                <field name="name"/>
                <field name="location"/>
                <field name="star_rating"/>
                <field name="hotel_type"/>
                <field name="rating"/>
                <field name="price_per_night"/>
                <field name="currency_id"/>
                <field name="image_512"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click o_kanban_record_has_image_fill">
                            <t t-if="record.image_512.raw_value">
                                <div class="o_kanban_image_fill_left d-none d-md-block" t-attf-style="background-image:url('#{kanban_image('tour.hotel', 'image_512', record.id.raw_value)}')"/>
                            </t>
                            <t t-else="">
                                <div class="o_kanban_image_fill_left d-none d-md-block o_kanban_image_full" t-attf-style="background-image:url('/web/static/img/placeholder.png')"/>
                            </t>
                            
                            <div class="oe_kanban_details d-flex flex-column justify-content-between">
                                <div>
                                    <div class="o_kanban_record_top mb-1">
                                        <div class="o_kanban_record_headings">
                                            <strong class="o_kanban_record_title h5 mb-0">
                                                <field name="name"/>
                                            </strong>
                                        </div>
                                        <span t-if="record.hotel_type.raw_value" class="badge rounded-pill text-bg-info ms-2">
                                            <field name="hotel_type"/>
                                        </span>
                                    </div>
                                    <div class="text-muted mb-2 mt-1">
                                        <i class="fa fa-map-marker me-1"/>
                                        <t t-if="record.location.raw_value"><field name="location"/></t>
                                        <t t-else="">Location not set</t>
                                    </div>
                                    
                                    <div class="d-flex align-items-center mb-1 mt-2">
                                        <div t-if="record.star_rating.raw_value" class="text-warning me-3">
                                            <i class="fa fa-star"/> <field name="star_rating"/>
                                        </div>
                                        <div t-if="record.rating.raw_value" class="text-success">
                                            <i class="fa fa-check-circle"/> <field name="rating"/>
                                        </div>
                                    </div>
                                </div>
                                <div class="o_kanban_record_bottom mt-3">
                                    <div class="oe_kanban_bottom_left">
                                        <!-- Placeholder for bottom left -->
                                    </div>
                                    <div class="oe_kanban_bottom_right">
                                        <span t-if="record.price_per_night.raw_value" class="fw-bold fs-5 text-primary">
                                            <field name="price_per_night" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                                        </span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>
    
    <record id="action_tour_hotel" model="ir.actions.act_window">
        <field name="name">Hotels</field>
        <field name="res_model">tour.hotel</field>
        <field name="view_mode">kanban,list,form</field>
    </record>
    
</odoo>

