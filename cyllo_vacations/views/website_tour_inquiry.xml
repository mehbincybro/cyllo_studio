<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <!-- Tour Inquiry Page -->
    <template id="tour_inquiry_page" name="Tour Inquiry Page">
        <t t-call="cyllo_vacations.tour_layout">
            <div class="container my-5">
                <div class="row">
                    <div class="col-lg-8 mx-auto">
                        <h1 class="mb-4">Send an Inquiry</h1>
                        <p class="lead mb-4">Have questions about a tour? Fill out the form below and we'll get back to you shortly.</p>
                        
                        <form action="/tour/inquiry/submit" method="post" class="js_tour_inquiry_form">
                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                            
                            <div class="card mb-4">
                                <div class="card-header">
                                    <h5 class="mb-0">Tour Package</h5>
                                </div>
                                <div class="card-body">
                                    <div class="form-group">
                                        <label for="package_id">Select Package *</label>
                                        <select class="form-control" id="package_id" name="package_id" required="required">
                                            <option value="">-- Select a Package --</option>
                                            <t t-foreach="packages" t-as="pkg">
                                                <option t-att-value="pkg.id" t-att-selected="'selected' if package_id and int(package_id) == pkg.id else None">
                                                    <t t-esc="pkg.name"/> - <t t-esc="pkg.destination"/>
                                                </option>
                                            </t>
                                        </select>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="card mb-4">
                                <div class="card-header">
                                    <h5 class="mb-0">Your Information</h5>
                                </div>
                                <div class="card-body">
                                    <div class="row">
                                        <div class="col-md-6">
                                            <div class="form-group">
                                                <label for="customer_name">Full Name *</label>
                                                <input type="text" class="form-control" id="customer_name" name="customer_name" required="required" placeholder="John Doe"/>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="form-group">
                                                <label for="customer_email">Email *</label>
                                                <input type="email" class="form-control" id="customer_email" name="customer_email" required="required" placeholder="john@example.com"/>
                                            </div>
                                        </div>
                                    </div>
                                    
                                    <div class="row">
                                        <div class="col-md-6">
                                            <div class="form-group">
                                                <label for="customer_phone">Phone</label>
                                                <input type="tel" class="form-control" id="customer_phone" name="customer_phone" placeholder="+1234567890"/>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="form-group">
                                                <label for="customer_mobile">Mobile</label>
                                                <input type="tel" class="form-control" id="customer_mobile" name="customer_mobile" placeholder="+1234567890"/>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="card mb-4">
                                <div class="card-header">
                                    <h5 class="mb-0">Travel Details</h5>
                                </div>
                                <div class="card-body">
                                    <div class="form-group">
                                        <label for="preferred_date">Preferred Travel Date</label>
                                        <input type="date" class="form-control" id="preferred_date" name="preferred_date"/>
                                    </div>
                                    
                                    <div class="row">
                                        <div class="col-md-4">
                                            <div class="form-group">
                                                <label for="num_adults">Number of Adults</label>
                                                <input type="number" class="form-control" id="num_adults" name="num_adults" min="1" value="1"/>
                                            </div>
                                        </div>
                                        <div class="col-md-4">
                                            <div class="form-group">
                                                <label for="num_children">Number of Children</label>
                                                <input type="number" class="form-control" id="num_children" name="num_children" min="0" value="0"/>
                                            </div>
                                        </div>
                                        <div class="col-md-4">
                                            <div class="form-group">
                                                <label for="num_infants">Number of Infants</label>
                                                <input type="number" class="form-control" id="num_infants" name="num_infants" min="0" value="0"/>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="card mb-4">
                                <div class="card-header">
                                    <h5 class="mb-0">Your Message</h5>
                                </div>
                                <div class="card-body">
                                    <div class="form-group">
                                        <label for="subject">Subject</label>
                                        <input type="text" class="form-control" id="subject" name="subject" placeholder="Subject of your inquiry"/>
                                    </div>
                                    
                                    <div class="form-group">
                                        <label for="message">Message *</label>
                                        <textarea class="form-control" id="message" name="message" rows="5" required="required" placeholder="Please provide details about your inquiry..."></textarea>
                                    </div>
                                    
                                    <div class="form-group">
                                        <label for="special_requirements">Special Requirements</label>
                                        <textarea class="form-control" id="special_requirements" name="special_requirements" rows="3" placeholder="Any special requirements or requests..."></textarea>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="text-center">
                                <button type="submit" class="btn btn-primary btn-lg">
                                    <i class="fa fa-paper-plane"/> Send Inquiry
                                </button>
                                <a href="/tours" class="btn btn-secondary btn-lg">
                                    <i class="fa fa-arrow-left"/> Back to Tours
                                </a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </t>
    </template>
    
    <!-- Inquiry Success Page -->
    <template id="tour_inquiry_success" name="Inquiry Success">
        <t t-call="cyllo_vacations.tour_layout">
            <div class="container my-5">
                <div class="row">
                    <div class="col-md-6 mx-auto">
                        <div class="alert alert-success text-center">
                            <i class="fa fa-check-circle fa-3x mb-3"/>
                            <h2>Inquiry Submitted Successfully!</h2>
                            <p class="lead">Thank you for your inquiry!</p>
                            <p>Reference: <strong t-esc="inquiry.name"/></p>
                            <p>We've received your inquiry about <strong t-esc="package.name"/></p>
                            <p>We'll get back to you shortly at <strong t-esc="inquiry.customer_email"/></p>
                            <div class="mt-4">
                                <a href="/tours" class="btn btn-primary">
                                    <i class="fa fa-search"/> Browse More Tours
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>
    
    <!-- Inquiry Error Page -->
    <template id="tour_inquiry_error" name="Inquiry Error">
        <t t-call="cyllo_vacations.tour_layout">
            <div class="container my-5">
                <div class="row">
                    <div class="col-md-6 mx-auto">
                        <div class="alert alert-danger text-center">
                            <i class="fa fa-exclamation-triangle fa-3x mb-3"/>
                            <h2>Inquiry Error</h2>
                            <p>Sorry, there was an error processing your inquiry.</p>
                            <p class="text-muted"><t t-esc="error"/></p>
                            <a href="/tours" class="btn btn-primary mt-3">
                                <i class="fa fa-arrow-left"/> Back to Tours
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>
    
</odoo>

