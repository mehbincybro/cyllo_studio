<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ir_actions_report_kanban" model="ir.ui.view">
        <field name="name">view.ir.actions.report.kanban</field>
        <field name="model">ir.actions.report</field>
        <field name="arch" type="xml">
            <kanban js_class="n_kanban" action="get_custom_report_page" type="object" limit="80">
                <field name="id"/>
                <field name="name"/>
                <field name="report_name"/>
                <field name="report_type"/>
                <field name="model"/>
                <field name="report_thumbnail"/>
                <templates>
                    <t t-name="kanban-box">
                        <t t-set="report_model" t-value="record.model.raw_value || ''"/>
                        <t t-set="record_name" t-value="record.name.raw_value || ''"/>

                        <!-- Clean, minimal SVG placeholder matching Cyllo Analytics aesthetic (with centered icon) -->
                        <t t-set="placeholder_data_uri" t-value="'data:image/svg+xml;utf8,&lt;svg xmlns=\'http://www.w3.org/2000/svg\' width=\'170\' height=\'135\' viewBox=\'0 0 170 135\'&gt;&lt;rect width=\'170\' height=\'135\' fill=\'%23ffffff\'/&gt;&lt;rect x=\'40\' y=\'30\' width=\'90\' height=\'6\' fill=\'%23f1f5f9\' rx=\'3\'/&gt;&lt;rect x=\'40\' y=\'45\' width=\'60\' height=\'6\' fill=\'%23f1f5f9\' rx=\'3\'/&gt;&lt;path d=\'M75 65 h20 v30 h-20 z\' fill=\'%23f8fafc\' stroke=\'%23e2e8f0\'/&gt;&lt;path d=\'M78 70 h14 M78 75 h14 M78 80 h14\' stroke=\'%23cbd5e1\' stroke-width=\'1\'/&gt;&lt;/svg&gt;'"/>

                        <!-- Cyllo Analytics Tile Card Layout -->
                        <div class="oe_kanban_global_click cyllo_report_card">
                            <div class="cyllo_report_thumbnail_wrapper">
                                <t t-if="record.report_thumbnail.raw_value">
                                    <img t-att-src="'/web/image/ir.actions.report/' + record.id.raw_value + '/report_thumbnail'" class="cyllo_report_thumbnail" alt="Report Preview"/>
                                </t>
                                <t t-else="">
                                    <img t-att-src="placeholder_data_uri" class="cyllo_report_thumbnail" alt="Report Placeholder"/>
                                </t>
                            </div>
                            <div class="cyllo_report_title" t-att-title="record_name">
                                <t t-esc="record_name"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>
</odoo>