<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ir_actions_report_kanban" model="ir.ui.view">
        <field name="name">view.ir.actions.report.kanban</field>
        <field name="model">ir.actions.report</field>
        <field name="arch" type="xml">
            <kanban js_class="n_kanban">
                <field name="name"/>
                <field name="report_name"/>
                <field name="report_type"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">

                            <div class="oe_kanban_details">
                                <strong>
                                    <field name="name"/>
                                </strong>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>
</odoo>