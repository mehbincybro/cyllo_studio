<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="cyllo_studio.CylloCalendarController" t-inherit="web.CalendarController" t-inherit-mode="primary">
       <xpath expr="//Layout" position="attributes">
          <attribute name="model">props.resModel</attribute>
       </xpath>
        <t t-set-slot="control-panel-additional-actions" position="replace"/>
        <t t-set-slot="layout-buttons" position="replace"/>
        <t t-set-slot="layout-actions" position="replace"/>
        <t t-set-slot="control-panel-navigation-additional" position="replace"/>
        <xpath expr="//div[hasclass('o_calendar_container')]" position="attributes">
          <attribute name="class" add="pe-none" separator=" "/>
       </xpath>
        <xpath expr="//div[hasclass('o_calendar_sidebar_container')]" position="attributes">
          <attribute name="class" add="pe-auto" separator=" "/>
       </xpath>
        <xpath expr="//div[hasclass('o_calendar_sidebar')]" position="attributes">
          <attribute name="class" add="pe-none" separator=" "/>
       </xpath>
    </t>
</templates>