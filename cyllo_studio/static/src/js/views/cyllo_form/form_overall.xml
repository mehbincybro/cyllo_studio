<?xml version="1.0" encoding="UTF-8" ?>
<templates>
    <t t-name="cyllo_studio.FormOverall">
        <div class="form_overall_container">
            <div>
                <t t-if="state.isStudioModel">
                    <div class="components-container  m-2">
                        <label>Display Name</label>
                    </div>
                    <div class="dropdown-checkbox-container" style="margin: 9px 12px 0 17px;">
                        <div class="cy-studio-custom-dropdown">
                            <CylloStudioDropdown
                                    t-props="{
                                        options: state.recordNameOptions,
                                        defaultValue: state.currentRecName,
                                        onChange: onRecordNameChange,
                                        searchable: true,
                                        placeholder: 'Select field'
                                    }"/>
                        </div>
                    </div>
                </t>

                <div class="components-container  m-2">
                    <label>Components</label>
                </div>
                <div style="margin-left: 18px;">
                    <label class="components-title" style="font-size: 15px;">Columns</label>
                    <div class="cy-studio-columns" id="cyComponents">
                        <div class="cy-components-column column-1"
                             t-att-style="props.sheet ? 'pointer-events: none; opacity: 0.5;' : ''">
                            <div class="cy-components-span">
                                <svg xmlns="http://www.w3.org/2000/svg" width="30px" height="38px" viewBox="0 0 512 512"
                                     fill="none">
                                    <rect x="79" y="124" width="354" height="72" rx="6" stroke="#000000"
                                          stroke-width="8"/>
                                    <rect x="79" y="220" width="354" height="72" rx="6" stroke="#000000"
                                          stroke-width="8"/>
                                    <rect x="79" y="316" width="354" height="72" rx="6" stroke="#000000"
                                          stroke-width="8"/>
                                </svg>
                            </div>
                            <div class="cy-components-text">Single</div>
                        </div>
                        <div class="cy-components-column column-2">
                            <div class="cy-components-span">
                                <svg xmlns="http://www.w3.org/2000/svg" width="30px" height="38px" viewBox="0 0 512 512"
                                     fill="none">
                                    <rect x="79" y="124" width="166" height="72" rx="6" stroke="#000000"
                                          stroke-width="8"/>
                                    <rect x="267" y="124" width="166" height="72" rx="6" stroke="#000000"
                                          stroke-width="8"/>
                                    <rect x="79" y="220" width="166" height="72" rx="6" stroke="#000000"
                                          stroke-width="8"/>
                                    <rect x="267" y="220" width="166" height="72" rx="6" stroke="#000000"
                                          stroke-width="8"/>
                                    <rect x="79" y="316" width="166" height="72" rx="6" stroke="#000000"
                                          stroke-width="8"/>
                                    <rect x="267" y="316" width="166" height="72" rx="6" stroke="#000000"
                                          stroke-width="8"/>
                                </svg>
                            </div>
                            <div class="cy-components-text">Double</div>
                        </div>
                    </div>
                    <div class="mt-2">
                        <label class="components-title" style="font-size: 15px;">Elements</label>
                        <div class="cy-studio-columns" id="cyComponents-elements-1">
                            <div class="cy-components-column tab">
                                <div class="cy-components-span">
                                    <svg xmlns="http://www.w3.org/2000/svg" version="1.1"
                                         xmlns:xlink="http://www.w3.org/1999/xlink" width="25px" height="28px"
                                         viewBox="0 0 512 512">
