                                        <circle cx="6" cy="16" r="1"/>
                                        <path d="M18 12.75H9a.75.75 0 0 1 0-1.5h9a.75.75 0 0 1 0 1.5z"/>
                                        <circle cx="6" cy="12" r="1"/>
                                        <path d="M18 8.75H9a.75.75 0 0 1 0-1.5h9a.75.75 0 0 1 0 1.5z"/>
                                        <circle cx="6" cy="8" r="1"/>
                                    </svg>
                                </div>
                                <div class="cy-components-text">Tree</div>
                            </div>
                            <!--                              <div class="cy-components-column field">-->
                            <!--                                <div class="cy-components-span">-->
                            <!--                                    <svg xmlns="http://www.w3.org/2000/svg" version="1.1"-->
                            <!--                                         xmlns:xlink="http://www.w3.org/1999/xlink" width="25px" height="38px"-->
                            <!--                                         viewBox="0 0 24 24">-->
                            <!--                                        <path d="M10 3.75a.75.75 0 1 0 0-1.5H6a.75.75 0 0 0 0 1.5h1.25v2.5H4A2.75 2.75 0 0 0 1.25 9v6A2.75 2.75 0 0 0 4 17.75h3.25v2.5H6a.75.75 0 1 0 0 1.5h4a.75.75 0 1 0 0-1.5H8.75V3.75zm-2.75 12.5H4A1.25 1.25 0 0 1 2.75 15V9A1.25 1.25 0 0 1 4 7.75h3.25zM22.75 9v6A2.75 2.75 0 0 1 20 17.75h-8a.75.75 0 1 1 0-1.5h8A1.25 1.25 0 0 0 21.25 15V9A1.25 1.25 0 0 0 20 7.75h-8a.75.75 0 1 1 0-1.5h8A2.75 2.75 0 0 1 22.75 9z"/>-->
                            <!--                                    </svg>-->
                            <!--                                </div>-->
                            <!--                                <div class="cy-components-text">Kanban</div>-->
                            <!--                            </div>-->

                            <div class="cy-components-column kanban">
                                <div class="cy-components-span">
                                    <!--                                    <svg xmlns="http://www.w3.org/2000/svg" version="1.1"-->
                                    <!--                                         xmlns:xlink="http://www.w3.org/1999/xlink" width="25px" height="38px"-->
                                    <!--                                         viewBox="0 0 24 24">-->
                                    <!--                                        <path d="M21 21.75H3A1.752 1.752 0 0 1 1.25 20V4A1.752 1.752 0 0 1 3 2.25h18A1.752 1.752 0 0 1 22.75 4v16A1.752 1.752 0 0 1 21 21.75zm-18-18a.25.25 0 0 0-.25.25v16a.25.25 0 0 0 .25.25h18a.25.25 0 0 0 .25-.25V4a.25.25 0 0 0-.25-.25z"/>-->
                                    <!--                                        <path d="M18 16.75H9a.75.75 0 0 1 0-1.5h9a.75.75 0 0 1 0 1.5z"/>-->
                                    <!--                                        <circle cx="6" cy="16" r="1"/>-->
                                    <!--                                        <path d="M18 12.75H9a.75.75 0 0 1 0-1.5h9a.75.75 0 0 1 0 1.5z"/>-->
                                    <!--                                        <circle cx="6" cy="12" r="1"/>-->
                                    <!--                                        <path d="M18 8.75H9a.75.75 0 0 1 0-1.5h9a.75.75 0 0 1 0 1.5z"/>-->
                                    <!--                                        <circle cx="6" cy="8" r="1"/>-->
                                    <!--                                    </svg>-->
                                    <i class="ri-bar-chart-2-line" style="font-size:24px;"></i>
                                </div>
                                <div class="cy-components-text">Kanban</div>
                            </div>
                            <div class="cy-components-column cy-studio-ribbon">
                                <div class="cy-components-span">
                                    <svg width="30px" height="40px" viewBox="0 0 512 512" fill="none"
                                         xmlns="http://www.w3.org/2000/svg">
                                        <path d="M95 133H417C420.866 133 424 136.134 424 140V372C424 375.866 420.866 379 417 379H95C91.134 379 88 375.866 88 372V140C88 136.134 91.134 133 95 133Z"
                                              stroke="black" stroke-width="26"/>
                                        <g clip-path="url(#clip0_7354_4862)">
                                            <rect x="268.424" y="97.9961" width="275.267" height="60"
                                                  transform="rotate(45 268.424 97.9961)" fill="black"/>
                                        </g>
                                        <defs>
                                            <clipPath id="clip0_7354_4862">
                                                <rect width="240" height="240" fill="white"
                                                      transform="translate(197 120)"/>
                                            </clipPath>
                                        </defs>
                                    </svg>
                                </div>
                                <div class="cy-components-text">Ribbon</div>
                            </div>

                        </div>
                    </div>
                </div>
            </div>
            <div>
                <div class="components-container  m-2">
                    <label>Attributes</label>
                </div>
                <div style="margin:10px;">
                    <div class="checkbox-item">
                        <input class="checkbox-input ViewCheck" id="canCreate" type="checkbox" name="create"
                               style="display: none;" t-model="props.mode.create"
                               t-on-click="(ev)=> this.props.handleView('create',!props.mode.create)"/>
                        <label class="checkbox-label" for="canCreate">
                            <span class="checkbox-indicator">
                                <svg width="12px" height="9px" viewbox="0 0 12 9">
                                    <polyline points="1 5 4 8 11 1"></polyline>
                                </svg>
                            </span>
                            <span class="label-text">Can Create</span>
                        </label>
                    </div>
                    <div class="checkbox-item">
                        <input class="checkbox-input ViewCheck" type="checkbox" id="canEdit" name="edit"
                               style="display: none;" t-model="props.mode.edit"
                               t-on-click="(ev)=> this.props.handleView('edit',!props.mode.edit)"/>
                        <label class="checkbox-label" for="canEdit">
                            <span class="checkbox-indicator">
                                <svg width="12px" height="9px" viewbox="0 0 12 9">
                                    <polyline points="1 5 4 8 11 1"></polyline>
                                </svg>
                            </span>
                            <span class="label-text">Can Edit</span>
                        </label>
                    </div>
                    <div class="checkbox-item">
                        <input class="checkbox-input ViewCheck d-none" type="checkbox" id="canDelete" name="delete"
                               style="display: none;" t-model="props.mode.delete"
                               t-on-click="(ev)=> this.props.handleView('delete',!props.mode.delete)"/>
                        <label class="checkbox-label" for="canDelete">
                            <span class="checkbox-indicator">
                                <svg width="12px" height="9px" viewbox="0 0 12 9">
                                    <polyline points="1 5 4 8 11 1"></polyline>
                                </svg>
                            </span>
                            <span class="label-text">Can Delete</span>
                        </label>
                    </div>
                    <div class="checkbox-item">
                        <input class="checkbox-input d-none ViewCheck" type="checkbox" id="showInvisibleElements"
                               name="checkbox4" t-att-checked="props.showInvisible"
                               t-on-click="(ev)=>this.props.showInvisibleFields(ev)"/>
                        <label class="checkbox-label" for="showInvisibleElements">
                            <span class="checkbox-indicator">
                                <svg width="12px" height="9px" viewbox="0 0 12 9">
                                    <polyline points="1 5 4 8 11 1"></polyline>
                                </svg>
                            </span>
                            <span class="label-text">Show Invisible Elements</span>
                        </label>
                    </div>
                    <div class="checkbox-item">
                        <input class="checkbox-input d-none ViewCheck" type="checkbox" id="buttonLimit"
                               name="checkbox4" t-att-checked="state.buttonLimitEnabled"
                               t-model="state.buttonLimitEnabled"
                               t-on-click="(ev) => this.toggleButtonLimit(ev)"/>
                        <label class="checkbox-label" for="buttonLimit">
                            <span class="checkbox-indicator">
                                <svg width="12px" height="9px" viewbox="0 0 12 9">
                                    <polyline points="1 5 4 8 11 1"></polyline>
                                </svg>
                            </span>
                            <span class="label-text">Statusbar Button Limit</span>
                        </label>
                    </div>
                    <div class="px-2" t-if="state.buttonLimitEnabled">
                        <label for="buttonLimitInput" style="font-size: 11px;
                            color: #9aa07a;
                            margin: 0 0 6px 0;
                            text-transform: uppercase;
                            letter-spacing: 0.5px;
                            font-weight: 600;
                        ">Button Limit Value
                        </label>
                        <input class="cy-input cy-input-field-align cy-studio-input-placeholder"
                               reqired="true"
                               type="number" id="buttonLimitInput" name="buttonLimitValue"
                               placeholder="Eg: 5"
                               autocomplete="off" t-model="state.buttonLimitValue"
                               t-on-change="(ev) => this.updateButtonLimitValue(ev)"
                               t-on-keyup="(ev) => this.updateButtonLimitValue(ev)"/>
                    </div>

                </div>
            </div>
            <t t-if="state.deactivatedViews.length">
                <div class="px-3 py-2">
                    <p style="
            font-size: 11px;
            color: #9aa07a;
            margin: 0 0 6px 0;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            font-weight: 600;
        ">
                        Deactivated Studio Views
                    </p>
                    <div class="cy-studio-custom-dropdown mb-2">
                        <CylloStudioDropdown
                                t-props="{
                    options: state.deactivatedViews.map(v => ({ label: v.displayName, value: v.id })),
                    defaultValue: state.selectedDeactivatedViewId,
                    onChange: onDeactivatedViewSelect,
                    searchable: false,
                    placeholder: 'Select a view'
                }"/>
                    </div>
                    <button
                            t-on-click="activateSelectedView"
                            style="
                            width: 100%;
                            background-color: #9ea700;
                            color: #fff;
                            border: 1.5px;
                            border-radius: 6px;
                            padding: 7px 0;
                            font-size: 12px;
                            font-weight: 400;
                            display: flex;
                            align-items: center;
                            justify-content: center;
                            gap: 6px;
                            cursor: pointer;
                        "
                    >
                        <i class="fa fa-check" style="font-size: 12px;"/>
                        Activate Selected View
                    </button>
                    <!-- Inside the deactivated views section, below the Activate button -->
                    <t t-if="state.isPreviewMode">
                        <button
                                t-on-click="cancelPreview"
                                style="
                                    width: 100%;
                                    margin-top: 6px;
                                    background-color: #7f8c8d;
                                    color: #fff;
                                    border: 1.5px solid #7f8c8d;
                                    border-radius: 6px;
                                    padding: 7px 0;
                                    font-size: 13px;
                                    font-weight: 500;
                                    display: flex;
                                    align-items: center;
                                    justify-content: center;
                                    gap: 6px;
                                    cursor: pointer;
                                "
                        >
                            <i class="fa fa-times" style="font-size: 12px;"/>
                            Cancel Preview
                        </button>
                    </t>
                </div>
            </t>
            <div class="px-3 py-3" t-if="state.hasStudioChanges">
                <p style="
                    font-size: 11px;
                    color: #9aa07a;
                    margin: 0 0 8px 0;
                    text-transform: uppercase;
                    letter-spacing: 0.5px;
                    font-weight: 600;
                ">
                    Restore default layout
                </p>
                <button
                        t-on-click="resetView"
                        style="
                width: 100%;
                background-color:#c0392b ;
                color: #fff;
                border: 1.5px solid #c0392b;
                border-radius: 6px;
                padding: 7px 0;
                font-size: 13px;
                font-weight: 500;
                display: flex;
                align-items: center;
                justify-content: center;
                gap: 6px;
                cursor: pointer;
                transition: background-color 0.2s, color 0.2s;
            "
                >
                    <i class="fa fa-undo" style="font-size: 12px;"/>
                    Reset to Default
                </button>
            </div>
        </div>
    </t>
</templates>