                                    </svg>
                                </div>
                                <div class="cy-components-text">Notebook</div>
                            </div>
                            <div class="cy-components-column field">
                                <div class="cy-components-span">
                                    <svg xmlns="http://www.w3.org/2000/svg" version="1.1"
                                         xmlns:xlink="http://www.w3.org/1999/xlink" width="25px" height="38px"
                                         viewBox="0 0 24 24">
                                        <path d="M10 3.75a.75.75 0 1 0 0-1.5H6a.75.75 0 0 0 0 1.5h1.25v2.5H4A2.75 2.75 0 0 0 1.25 9v6A2.75 2.75 0 0 0 4 17.75h3.25v2.5H6a.75.75 0 1 0 0 1.5h4a.75.75 0 1 0 0-1.5H8.75V3.75zm-2.75 12.5H4A1.25 1.25 0 0 1 2.75 15V9A1.25 1.25 0 0 1 4 7.75h3.25zM22.75 9v6A2.75 2.75 0 0 1 20 17.75h-8a.75.75 0 1 1 0-1.5h8A1.25 1.25 0 0 0 21.25 15V9A1.25 1.25 0 0 0 20 7.75h-8a.75.75 0 1 1 0-1.5h8A2.75 2.75 0 0 1 22.75 9z"/>
                                    </svg>
                                </div>
                                <div class="cy-components-text">Field</div>
                            </div>
                        </div>
                        <div class="cy-studio-columns" id="cyComponents-elements-2">
                            <div class="cy-components-column chatter"
                                 t-att-class="state.isChatterAvailable ? '' : 'cy-chatter-exist'"
                                 t-att-style="props.sheet ? 'opacity: 50%; pointer-events: none;' : ''">
                                <div class="cy-components-span">
                                    <svg xmlns="http://www.w3.org/2000/svg" version="1.1"
                                         xmlns:xlink="http://www.w3.org/1999/xlink" width="25px" height="38px"
                                         viewBox="0 0 512 512">
                                        <path d="M432 0H80C35.817 0 0 35.817 0 80v256c0 44.183 35.817 80 80 80h313.44l91.2 91.36A15.999 15.999 0 0 0 496 512c8.837 0 16-7.163 16-16V80c0-44.183-35.817-80-80-80zm48 457.44-68.64-68.8A15.997 15.997 0 0 0 400 384H80c-26.51 0-48-21.49-48-48V80c0-26.51 21.49-48 48-48h352c26.51 0 48 21.49 48 48v377.44z"/>
                                        <circle cx="256" cy="208" r="32"/>
                                        <circle cx="368" cy="208" r="32"/>
                                        <circle cx="144" cy="208" r="32"/>
                                    </svg>
                                </div>
                                <div class="cy-components-text">Chatter</div>
                            </div>
                            <div class="cy-components-column tree">
                                <div class="cy-components-span">
                                    <svg xmlns="http://www.w3.org/2000/svg" version="1.1"
                                         xmlns:xlink="http://www.w3.org/1999/xlink" width="25px" height="38px"
                                         viewBox="0 0 24 24">
                                        <path d="M21 21.75H3A1.752 1.752 0 0 1 1.25 20V4A1.752 1.752 0 0 1 3 2.25h18A1.752 1.752 0 0 1 22.75 4v16A1.752 1.752 0 0 1 21 21.75zm-18-18a.25.25 0 0 0-.25.25v16a.25.25 0 0 0 .25.25h18a.25.25 0 0 0 .25-.25V4a.25.25 0 0 0-.25-.25z"/>
