<?xml version="1.0" encoding="UTF-8"?>
<t t-name="cyllo_studio.Chatter" t-inherit="mail.Chatter" t-inherit-mode="extension">
    <xpath expr="//div[hasclass('o-mail-Chatter-content')]" position="inside">
        <div class="cy-studio-chatter-overlay opacity-0 opacity-100-hover">
            <div class="cy-tooltip-wrapper">
                <i t-on-click="(ev)=>this.onClick(ev,'replace')" class="bbb ri-delete-bin-6-fill cy-trash-icon"/>
                <span class="cy-tooltip-text">Delete the chatter</span>
            </div>
        </div>
    </xpath>
</t>
