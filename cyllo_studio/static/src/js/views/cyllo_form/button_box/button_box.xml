<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="cyllo_studio.ButtonBox" t-inherit="web.Form.ButtonBox">
        <div position="attributes">
            <attribute name="t-att-cy-xpath">props.cyXpath</attribute>
            <attribute name="t-ref">cy-ButtonBox</attribute>
            <attribute name="class" add="flex-wrap" separator=" "/>
            <attribute name="t-if">!state.isX2Many</attribute>
         </div>
        <div  position="inside">
                <button t-if="!state.clicked" class="btn oe_stat_button flex-grow-1 flex-lg-grow-0 cy-add-smart-button border-0 opacity-50-hover position-relative" t-on-click="addSmartButton">
                     <div class="cy-studio-blink-container position-absolute top-50 start-50 translate-middle">
                        <i class="ri-add-line position-absolute top-50 start-50 translate-middle text-primary fw-bolder"></i>
                        <div class="cy-studio-blink-anim"></div>
                    </div>
                    <i class="o_button_icon fa fa-fw fa-file-text-o me-1" style="opacity: 0.2;"></i>
                    <div class="o_field_widget o_readonly_modifier o_field_statinfo" id="SmartButtonLabel" style="opacity: 0.2;"><span class="o_stat_text">Smart Button</span><span class="o_stat_info o_stat_value">0</span></div>
                </button>
        </div>
    </t>
</templates>


