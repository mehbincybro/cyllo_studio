<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="custom_report.edit_report">
        <div class="d-flex flex-column w-100 bg-200" style="height: calc(100vh - 50px);">
            <!-- Header -->
            <div class="w-100 bg-white border-bottom px-4 py-2 d-flex align-items-center shadow-sm">
                <button class="btn btn-primary px-4 me-2"
                        t-on-click="() => save_changes(this)">Save</button>
                <button class="btn btn-light border px-4"
                        t-on-click="() => close_edit(this)">Discard</button>
                <div class="ms-4 form-check form-switch pt-1">
                    <input class="form-check-input" type="checkbox" id="previewSwitch" t-on-change="togglePreview" t-att-checked="state.previewMode"/>
                    <label class="form-check-label fw-bold" for="previewSwitch">Preview</label>
                </div>
                <div class="flex-grow-1"/>
                <button t-ref="undoBtn" t-on-click="undo" class="btn btn-light border mx-1" disabled="1" title="Undo">
                    <i class="fa fa-undo"/>
                </button>
                <button t-ref="redoBtn" t-on-click="redo" class="btn btn-light border mx-1" disabled="1" title="Redo">
                    <i class="fa fa-repeat"/>
                </button>
            </div>

            <!-- Body -->
            <div class="d-flex flex-grow-1 overflow-hidden" t-att-class="{'previewing': state.previewMode}">
                <!-- Sidebar (Editable) -->
                <div id="snippet-panel" class="snippet-panel bg-white border-end p-3 shadow-sm d-flex flex-column" t-att-class="{'d-none': state.previewMode}" style="width: 260px; overflow-y: auto; z-index: 10;">
                    <h6 class="text-uppercase text-muted mb-4 mt-2 fw-bold" style="font-size: 12px; letter-spacing: 1px;">Report Elements</h6>

                    <div class="snippet bg-light border border-secondary border-opacity-25 rounded p-3 mb-3 d-flex align-items-center shadow-sm" style="cursor: grab; transition: all 0.2s;" data-type="box" onmouseover="this.classList.add('bg-white')" onmouseout="this.classList.remove('bg-white')">
                        <i class="fa fa-square-o fa-lg text-success me-3"/>
                        <span class="fw-semibold text-dark">Box</span>
                    </div>

                    <div class="snippet field bg-light border border-secondary border-opacity-25 rounded p-3 mb-3 d-flex align-items-center shadow-sm" style="cursor: grab; transition: all 0.2s;" data-type="field" onmouseover="this.classList.add('bg-white')" onmouseout="this.classList.remove('bg-white')">
                        <i class="fa fa-database fa-lg text-success me-3"/>
                        <span class="fw-semibold text-dark">Dynamic Field</span>
                    </div>

                    <div class="snippet bg-light border border-secondary border-opacity-25 rounded p-3 mb-3 d-flex align-items-center shadow-sm" style="cursor: grab; transition: all 0.2s;" data-type="table" onmouseover="this.classList.add('bg-white')" onmouseout="this.classList.remove('bg-white')">
                        <i class="fa fa-table fa-lg text-success me-3"/>
                        <span class="fw-semibold text-dark">Table</span>
                    </div>

                    <!-- Technical Actions -->
                    <div class="border-top pt-3 mb-4">
                        <h6 class="text-uppercase text-muted mb-3 fw-bold" style="font-size: 11px; letter-spacing: 1px;">Technical Tools</h6>
                        <div class="d-flex gap-2">
                            <button class="btn btn-sm text-white text-uppercase fw-bold py-2 flex-grow-1"
                                    style="font-size: 10px; background-color: #9ea700; border: none; border-radius: 4px;"
                                    t-on-click="onEditSources">
                                <i class="fa fa-code me-1"/> Edit Sources
                            </button>
                            <button class="btn btn-sm text-white text-uppercase fw-bold py-2 flex-grow-1"
                                    style="font-size: 10px; background-color: #e85e6a; border: none; border-radius: 4px;"
                                    t-on-click="onResetReport">
                                <i class="fa fa-refresh me-1"/> Reset Report
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Properties Sidebar (Preview) -->
                <div t-if="state.previewMode and !state.showSourceEditor" class="snippet-panel bg-dark text-white border-end p-4 shadow-lg d-flex flex-column h-100" style="width: 320px; z-index: 10;">
                    <h6 class="text-uppercase small fw-bold mb-4 opacity-75" style="letter-spacing: 1px;">Report Properties</h6>

                    <div class="mb-4">
                        <label class="small opacity-50 mb-1 d-block">Report name</label>
                        <input type="text" class="form-control form-control-sm bg-black text-white border-secondary border-opacity-25"
                               t-att-value="state.reportInfo.name"
                               t-on-change="(ev) => this.onReportPropertyChange('name', ev.target.value)"/>
                    </div>

                    <div class="mb-4">
                        <label class="small opacity-50 mb-1 d-block">Paper format</label>
                        <select class="form-select form-select-sm bg-black text-white border-secondary border-opacity-25"
                                t-on-change="(ev) => this.onReportPropertyChange('paperformat_id', ev.target.value)">
                            <option t-foreach="state.paperFormats" t-as="fmt" t-key="fmt.id"
                                    t-att-value="fmt.id"
                                    t-att-selected="fmt.id === state.reportInfo.paperformat_id">
                                <t t-esc="fmt.name"/>
                            </option>
                        </select>
                    </div>

                    <div class="form-check form-switch mb-3">
                        <input class="form-check-input" type="checkbox" id="showPrintMenu"
                               t-att-checked="true" disabled="1"/>
                        <label class="form-check-label small" for="showPrintMenu">Show in print menu</label>
                    </div>

                    <div class="form-check form-switch mb-4">
                        <input class="form-check-input" type="checkbox" id="reloadAttach"
                               t-att-checked="state.reportInfo.attachment_use"
                               t-on-change="(ev) => this.onReportPropertyChange('attachment_use', ev.target.checked)"/>
                        <label class="form-check-label small" for="reloadAttach">Reload from attachment</label>
                    </div>

                    <div class="action-buttons d-flex gap-2">
                        <button class="btn btn-sm text-white text-uppercase fw-bold py-2 flex-grow-1"
                                style="font-size: 10px; background-color: #9ea700; border: none; border-radius: 4px;"
                                t-on-click="onEditSources">
                            <i class="fa fa-code me-1"/> Edit Sources
                        </button>
                        <button class="btn btn-sm text-white text-uppercase fw-bold py-2 flex-grow-1"
                                style="font-size: 10px; background-color: #e85e6a; border: none; border-radius: 4px;"
                                t-on-click="onResetReport">
                            <i class="fa fa-refresh me-1"/> Reset Report
                        </button>
                    </div>
                </div>

                <!-- Source Editor -->
                <div t-if="state.showSourceEditor" class="source-editor-container d-flex flex-column border-end bg-dark" style="width: 500px; z-index: 5;">
                    <div class="source-editor-header d-flex align-items-center justify-content-between p-2 text-white small fw-bold">
                        <span>SOURCE EDITOR</span>
                        <div class="d-flex gap-2">
                            <button class="btn btn-sm btn-success py-0 px-2" t-on-click="onSaveSource">Save</button>
                            <button class="btn btn-sm btn-light py-0 px-2" t-on-click="() => state.showSourceEditor = false">Close</button>
                        </div>
                    </div>
                    <div id="ace-editor" t-ref="aceEditor" class="flex-grow-1 w-100" style="font-size: 14px; min-height: 400px;"/>
                </div>

                <!-- Main Area -->
                <div class="flex-grow-1 overflow-auto d-flex flex-column align-items-center py-4 bg-200" style="position: relative;">
                    <!-- Preview Toolbar -->
                    <div t-if="state.previewMode" class="d-flex align-items-center justify-content-between mb-4 sticky-top px-4 py-2 bg-dark rounded-pill shadow-sm border border-secondary border-opacity-25" style="width: 90%; min-width: 600px; z-index: 100;">
                        <div class="d-flex align-items-center gap-3">
                        </div>
                        <div class="d-flex align-items-center gap-3">
                            <button class="btn btn-sm btn-outline-light text-white border-secondary border-opacity-50 px-3" t-on-click="onPrintReport">
                                <i class="fa fa-print me-1"/> Print
                            </button>
                            <div class="pagination-controls d-flex align-items-center gap-2 bg-black rounded-pill p-1">
                                <span class="small px-3 text-white opacity-75"><t t-esc="state.currentIndex + 1"/> / <t t-esc="state.records.length"/></span>
                                <div class="btn-group">
                                    <button class="btn btn-sm btn-dark py-1 rounded-circle me-1" t-on-click="onPrevRecord" style="width: 28px; height: 28px; display: flex; align-items: center; justify-content: center;"><i class="fa fa-chevron-left small"/></button>
                                    <button class="btn btn-sm btn-dark py-1 rounded-circle" t-on-click="onNextRecord" style="width: 28px; height: 28px; display: flex; align-items: center; justify-content: center;"><i class="fa fa-chevron-right small"/></button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- A4 / Custom Paper Container -->
                    <div class="cyllo-studio-report-container bg-white shadow-lg mb-5"
                         t-att-style="'width: ' + (currentPaperFormat ? currentPaperFormat.page_width : 210) + 'mm; min-height: ' + (currentPaperFormat ? currentPaperFormat.page_height : 297) + 'mm; box-sizing: border-box; position: relative; transition: all 0.3s ease;'">
                        <iframe t-if="state.previewMode and state.previewHtml"
                                class="live-report-content w-100 h-100 border-0"
                                t-att-srcdoc="state.previewHtml"/>
                        <div t-else="" id="studio_report" t-ref="report_frame" class="editable-area w-100 h-100 text-dark" style="padding: 20mm;"/>
                    </div>
                </div>
            </div>

            <!-- Branch Selector Popup -->
            <div id="branchSelector" class="bg-white shadow-lg"
                 style="position: fixed;
                        right: 40px;
                        top: 100px;
                        width: 300px;
                        border: 1px solid #dee2e6;
                        border-radius: 8px;
                        padding: 20px;
                        display: none;
                        z-index: 1050;">
                <h5 style="margin: 0 0 15px 0;
                            border-bottom: 2px solid #3b82f6;
                            padding-bottom: 10px;
                            font-size: 16px;">
                    Select Condition
                </h5>
                <i class="close-selector fa fa-times text-muted"
                   t-on-click="closeBranchSelector"
                   style="position: absolute;
                          top: 15px;
                          right: 15px;
                          cursor: pointer;
                          font-size: 16px;"/>
                <div id="branchOptions"></div>
            </div>
            <!-- Reset Report Dialog -->
            <div t-if="state.showResetDialog"
                 style="position: fixed; inset: 0; background: rgba(0,0,0,0.55); z-index: 2000; display: flex; align-items: center; justify-content: center;">
                <div class="bg-dark text-white rounded-3 shadow-lg p-4" style="width: 420px; position: relative;">
                    <!-- Close X -->
                    <button class="btn-close btn-close-white" style="position: absolute; top: 16px; right: 16px;"
                            t-on-click="() => state.showResetDialog = false"/>

                    <h5 class="fw-bold mb-3">Reset report</h5>

                    <p class="small opacity-75 mb-4">
                        All changes done to the report's structure will be discarded and
                        the report will be reset to its factory settings.
                    </p>

                    <!-- Include header and footer checkbox -->
                    <div class="d-flex align-items-start gap-3 mb-4 p-3 rounded-2" style="background: rgba(255,255,255,0.08);">
                        <div class="mt-1">
                            <input type="checkbox" id="resetHeaderFooter" class="form-check-input"
                                   t-att-checked="state.includeHeaderFooter"
                                   t-on-change="(ev) => state.includeHeaderFooter = ev.target.checked"
                                   style="width: 18px; height: 18px; accent-color: #28a745;"/>
                        </div>
                        <div>
                            <label for="resetHeaderFooter" class="fw-semibold small mb-1 d-block" style="cursor: pointer;">Include header and footer</label>
                            <span class="small opacity-50">Header and footer are shared with other reports which may be impacted by the reset.</span>
                        </div>
                    </div>

                    <!-- Buttons -->
                    <div class="d-flex gap-2">
                        <button class="btn btn-danger px-4" t-on-click="confirmResetReport">Reset report</button>
                        <button class="btn btn-secondary px-4" t-on-click="() => state.showResetDialog = false">Go back</button>
                    </div>
                </div>
            </div>
            <!-- Table Config Modal — inline overlay (controlled by state.showTableModal) -->
            <div t-if="state.showTableModal" class="tcm-overlay" t-on-click.self="onTableModalCancel">
                <div class="tcm-modal">
                    <!-- Header -->
                    <div class="tcm-header">
                        <h5>Add Table</h5>
                        <button class="tcm-close" t-on-click="onTableModalCancel">✕</button>
                    </div>

                    <!-- Section 1: Template Preset -->
                    <div class="tcm-section">
                        <div class="tcm-section-label">Template</div>
                        <div class="tcm-preset-grid">
                            <div t-att-class="'tcm-preset-card' + (state.tcm.preset === 'balance_sheet' ? ' active' : '')"
                                 t-on-click="() => this.onSelectPreset('balance_sheet')">
                                <div class="tcm-preset-icon"><i class="fa fa-balance-scale"/></div>
                                <div class="tcm-preset-info">
                                    <div class="tcm-preset-title">Balance Sheet</div>
                                    <div class="tcm-preset-desc">Assets, Liabilities &amp; Equity with computed totals</div>
                                </div>
                            </div>
                            <div t-att-class="'tcm-preset-card' + (state.tcm.preset === 'p_and_l' ? ' active' : '')"
                                 t-on-click="() => this.onSelectPreset('p_and_l')">
                                <div class="tcm-preset-icon"><i class="fa fa-line-chart"/></div>
                                <div class="tcm-preset-info">
                                    <div class="tcm-preset-title">Profit &amp; Loss</div>
                                    <div class="tcm-preset-desc">Revenue and expense sections with net total</div>
                                </div>
                            </div>
                            <div t-att-class="'tcm-preset-card' + (state.tcm.preset === 'invoice' ? ' active' : '')"
                                 t-on-click="() => this.onSelectPreset('invoice')">
                                <div class="tcm-preset-icon"><i class="fa fa-file-text-o"/></div>
                                <div class="tcm-preset-info">
                                    <div class="tcm-preset-title">Invoice Lines</div>
                                    <div class="tcm-preset-desc">Line items with qty, rate, amount and grand total</div>
                                </div>
                            </div>
                            <div t-att-class="'tcm-preset-card' + (state.tcm.preset === 'blank' ? ' active' : '')"
                                 t-on-click="() => this.onSelectPreset('blank')">
                                <div class="tcm-preset-icon"><i class="fa fa-th"/></div>
                                <div class="tcm-preset-info">
                                    <div class="tcm-preset-title">Blank Table</div>
                                    <div class="tcm-preset-desc">Fully manual, no assumptions</div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Section 2: Odoo Model -->
                    <div class="tcm-section">
                        <div class="tcm-section-label">Model</div>
                        <select class="tcm-select"
                                t-on-change="onModelChange">
                            <option value="">— Select a model —</option>
                            <t t-foreach="state.tcm.availableModels" t-as="m" t-key="m.model">
                                <option t-att-value="m.model"
                                        t-att-selected="m.model === state.tcm.model">
                                    <t t-esc="m.name"/> (<t t-esc="m.model"/>)
                                </option>
                            </t>
                        </select>
                    </div>

                    <!-- Section 3: Columns -->
                    <div class="tcm-section">
                        <div class="tcm-col-header">
                            <div class="tcm-section-label" style="margin-bottom:0">Columns</div>
                            <button class="tcm-add-btn" t-on-click="onAddColumn">+ Add</button>
                        </div>
                        <t t-if="state.tcm.columns.length === 0">
                            <div class="tcm-empty-state">No columns added yet. Click "+ Add" above.</div>
                        </t>
                        <t t-foreach="state.tcm.columns" t-as="col" t-key="col_index">
                            <div class="tcm-col-row">
                                <span class="tcm-col-drag" title="Drag to reorder">⠿</span>
                                <input type="text" class="tcm-input tcm-input-sm tcm-col-field"
                                       placeholder="Label"
                                       t-att-value="col.label"
                                       t-on-change="(ev) => this.onColumnLabelChange(col_index, ev)"/>
                                <select class="tcm-select tcm-input-sm tcm-col-field"
                                        t-on-change="(ev) => this.onColumnFieldChange(col_index, ev)">
                                    <option value="">— Field —</option>
                                    <t t-foreach="state.tcm.availableFields" t-as="f" t-key="f.name">
                                        <option t-att-value="f.name"
                                                t-att-selected="f.name === col.field">
                                            <t t-esc="f.string || f.name"/>
                                            <t t-if="f.type"> (<t t-esc="f.type"/>)</t>
                                        </option>
                                    </t>
                                </select>
                                <select class="tcm-select tcm-input-sm tcm-col-agg"
                                        t-att-value="col.aggregation"
                                        t-on-change="(ev) => this.onColumnAggChange(col_index, ev)">
                                    <option value="none">None</option>
                                    <option value="sum" t-att-selected="col.aggregation === 'sum'">SUM</option>
                                    <option value="avg" t-att-selected="col.aggregation === 'avg'">AVG</option>
                                    <option value="count" t-att-selected="col.aggregation === 'count'">COUNT</option>
                                </select>
                                <input type="text" class="tcm-input tcm-input-sm tcm-col-width"
                                       placeholder="Width"
                                       t-att-value="col.width"
                                       t-on-change="(ev) => this.onColumnWidthChange(col_index, ev)"/>
                                <button class="tcm-col-remove" t-on-click="() => this.onRemoveColumn(col_index)">✕</button>
                            </div>
                        </t>
                    </div>

                    <!-- Section 4: Row Source -->
                    <div class="tcm-section">
                        <div class="tcm-section-label">Row Source</div>
                        <div class="tcm-radio-group">
                            <label class="tcm-radio">
                                <input type="radio" name="tcm_rowsource" value="dynamic"
                                       t-att-checked="state.tcm.rowSource === 'dynamic'"
                                       t-on-change="() => this.state.tcm.rowSource = 'dynamic'"/>
                                Dynamic (repeats per record)
                            </label>
                            <label class="tcm-radio">
                                <input type="radio" name="tcm_rowsource" value="manual"
                                       t-att-checked="state.tcm.rowSource === 'manual'"
                                       t-on-change="() => this.state.tcm.rowSource = 'manual'"/>
                                Manual
                            </label>
                            <div t-if="state.tcm.rowSource === 'manual'" class="tcm-manual-count">
                                <label>Rows:</label>
                                <input type="number" class="tcm-input tcm-input-sm" style="width: 60px;"
                                       t-att-value="state.tcm.manualRows"
                                       t-on-change="(ev) => this.state.tcm.manualRows = parseInt(ev.target.value) || 5"
                                       min="1" max="100"/>
                            </div>
                        </div>
                    </div>

                    <!-- Section 5: Options -->
                    <div class="tcm-section">
                        <div class="tcm-section-label">Options</div>
                        <div class="tcm-options-grid">
                            <label class="tcm-checkbox">
                                <input type="checkbox"
                                       t-att-checked="state.tcm.headerRow"
                                       t-on-change="(ev) => this.state.tcm.headerRow = ev.target.checked"/>
                                Header row
                            </label>
                            <label class="tcm-checkbox">
                                <input type="checkbox"
                                       t-att-checked="state.tcm.totalsRow"
                                       t-on-change="(ev) => this.state.tcm.totalsRow = ev.target.checked"/>
                                Totals row
                            </label>
                            <label class="tcm-checkbox">
                                <input type="checkbox"
                                       t-att-checked="state.tcm.applyDomain"
                                       t-on-change="(ev) => this.state.tcm.applyDomain = ev.target.checked"/>
                                Apply domain filter
                            </label>
                            <label class="tcm-checkbox">
                                <input type="checkbox"
                                       t-att-checked="state.tcm.includeAllCompanies"
                                       t-on-change="(ev) => this.state.tcm.includeAllCompanies = ev.target.checked"/>
                                Include all companies
                            </label>
                        </div>

                        <!-- Inline domain editor -->
                        <div t-if="state.tcm.applyDomain" class="tcm-domain-editor">
                            <label>Domain filter (Odoo syntax)</label>
                            <input type="text" class="tcm-input tcm-input-sm"
                                   placeholder="[('account_type', '=', 'asset_receivable')]"
                                   t-att-value="state.tcm.domain"
                                   t-on-change="(ev) => this.state.tcm.domain = ev.target.value"/>
                        </div>
                    </div>

                    <!-- Footer -->
                    <div class="tcm-footer">
                        <button class="tcm-btn-cancel" t-on-click="onTableModalCancel">Cancel</button>
                        <button class="tcm-btn-insert" t-on-click="onTableModalConfirm"
                                t-att-disabled="state.tcm.preset !== 'blank' ? false : !state.tcm.model">
                            Insert Table
                        </button>
                    </div>
                </div>
            </div>

        </div>
    </t>

</templates>