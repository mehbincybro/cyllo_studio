<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!-- Template to Add New Address-->
    <template id="portal_add_address_template" name="Add Address">
        <t t-call="website.layout">
            <div id="wrap">
                <div class="container oe_website_sale py-2">
                    <div class="row"><div class="col-12"/></div>
                    <div class="row">
                        <div class="col-12 col-lg-8 order-xl-1 oe_cart">
                            <div class="portal_address_add_temp">
                                <h2 class="o_page_header mt8">Add Address</h2>
                                <form action="/address/added" method="post" class="checkout_autoformat">
                                    <div class="row">
                                        <div class="mb-3 col-lg-12 div_name">
                                            <label class="col-form-label" for="name">Name</label>
                                            <input type="text" name="name_address" class="form-control" required="1"/>
                                        </div>
                                        <div class="w-100"/>
                                        <div class="mb-3 col-lg-6" id="div_email">
                                            <label class="col-form-label" for="email">Email</label>
                                            <input type="email" name="email" class="form-control"/>
                                        </div>
                                        <div class="mb-3 col-lg-6" id="div_phone">
                                            <label class="col-form-label" for="phone">Phone</label>
                                            <input type="tel" name="phone" class="form-control"/>
                                        </div>
                                        <div class="w-100"/>
                                        <div class="mb-3 col-lg-12 div_street">
                                            <label class="col-form-label" for="street">Street
                                                <span class="d-none d-md-inline">and Number</span>
                                            </label>
                                            <input type="text" name="street_and_number" class="form-control"/>
                                        </div>
                                        <div class="mb-3 col-lg-12 div_street2">
                                            <label class="col-form-label label-optional" for="street2">Street 2</label>
                                            <input type="text" name="street2" class="form-control"/>
                                        </div>
                                        <div class="w-100"/>
                                        <div class="mb-3 col-md-4 div_zip">
                                            <label class="col-form-label label-optional" for="zip">Zip Code</label>
                                            <input type="text" name="zipcode" class="form-control"/>
                                        </div>
                                        <div class="mb-3 col-md-8 div_city">
                                            <label class="col-form-label" for="city">City</label>
                                            <input type="text" name="city" class="form-control"/>
                                        </div>
                                        <div class="w-100"/>
                                        <div class="mb-3 col-lg-6 div_country">
                                            <label class="col-form-label" for="country_id">Country</label>
                                            <select id="country" name="country_id" class="form-select country">
                                                <option value="">Country...</option>
                                                <t t-foreach="countries or []" t-as="c">
                                                    <option t-att-value="c.id"><t t-esc="c.name"/></option>
                                                </t>
                                            </select>
                                        </div>
                                        <div class="mb-3 col-lg-6 div_state">
                                            <label class="col-form-label" for="state_id">State / Province</label>
                                            <select id="state" name="state_id" class="form-select">
                                                <option value="">State / Province...</option>
                                            </select>
                                        </div>
                                        <div class="w-100"/>
                                        <div class="d-flex justify-content-between">
                                            <a role="button" href="/your_address" class="btn btn-secondary mb32">
                                                <i class="oi oi-chevron-left"/><span>Back</span>
                                            </a>
                                            <button type="submit" t-attf-class="btn btn-primary mb32 a-submit a-submit-disable a-submit-loading">
                                                <span>Add</span><i class="oi oi-chevron-right"/>
                                            </button>
                                        </div>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>
</odoo>