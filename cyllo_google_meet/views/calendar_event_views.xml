<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_calendar_event_form_google_meet" model="ir.ui.view">
        <field name="name">
            calendar.event.view.form.inherit.cyllo.google.meet.integration
        </field>
        <field name="model">calendar.event</field>
        <field name="inherit_id" ref="calendar.view_calendar_event_form"/>
        <field name="arch" type="xml">

            <!-- Hide original videocall_location when google meet is ON -->
            <xpath expr="//field[@name='videocall_location']" position="attributes">
                <attribute name="invisible">is_google_meet</attribute>
            </xpath>

            <!-- Add Google Meet section after videocall_location -->
            <xpath expr="//field[@name='videocall_location']" position="after">
                <div invisible="not is_google_meet" class="o_field_widget mt-2 mb-2">
                    <group string="Google Meet">
                        <field name="google_meet_url"
                               placeholder="https://meet.google.com/..."
                               widget="CopyClipboardChar"
                               readonly="1"/>
                        <div class="mt-2">
                            <button name="action_google_meet_url"
                                    string="Join Meeting"
                                    type="object"
                                    icon="fa-video-camera"
                                    class="btn-primary"
                                    invisible="not google_meet_url"/>
                        </div>
                    </group>
                    <field name="google_meet_event_id" invisible="1"/>
                </div>
            </xpath>

            <xpath expr="//field[@name='start']" position="after">
                <field name="is_google_meet" widget="boolean_toggle"/>
            </xpath>

        </field>
    </record>
</odoo>




