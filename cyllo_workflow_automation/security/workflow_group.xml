<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record model="ir.module.category" id="cyllo_workflow_module_management">
        <field name="name">Workflow Automation</field>
        <field name="description">Workflow Automation</field>
        <field name="sequence">10</field>
    </record>

    <record id="group_workflow_automation_admin" model="res.groups">
        <field name="name">Work Auto Admin</field>
        <field name="category_id" ref="cyllo_workflow_automation.cyllo_workflow_module_management"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record model="ir.rule" id="workflow_function_restricted_company_rule">
        <field name="name">Workflow Function: multi-company</field>
        <field name="model_id" ref="model_work_function"/>
        <field name="global" eval="True"/>
        <field name="domain_force">
            [('company_id', 'in', company_ids + [False])]
        </field>
    </record>

    <record model="ir.rule" id="workflow_automation_restricted_company_rule">
        <field name="name">Workflow Automation: multi-company</field>
        <field name="model_id" ref="model_work_auto"/>
        <field name="global" eval="True"/>
        <field name="domain_force">
            [('company_id', 'in', company_ids)]
        </field>
    </record>
</odoo>