<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!--
            Cron job: Expire pending approval requests that have passed their
            expiration datetime. Runs every hour.
        -->
        <record id="ir_cron_expire_approval_requests" model="ir.cron">
            <field name="name">Workflow Approval: Expire Pending Requests</field>
            <field name="model_id" ref="model_workflow_approval_request"/>
            <field name="state">code</field>
            <field name="code">
env['workflow.approval.request'].sudo().search([
    ('state', '=', 'pending'),
    ('expiration', '!=', False),
    ('expiration', '&lt;=', fields.Datetime.now()),
]).action_expire()
            </field>
            <field name="interval_number">1</field>
            <field name="interval_type">hours</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
            <field name="user_id" ref="base.user_root"/>
        </record>
    </data>
</odoo>
