<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!--
        Register the Approval node type as a work.function record.
        This makes the node appear in the workflow canvas palette.
        func_name = 'approval' identifies this node type throughout the backend.
    -->
    <record id="work_function_approval" model="work.function">
        <field name="name">Approval</field>
        <field name="func_name">approval</field>
        <field name="trigger_type">other</field>
        <field name="icon" type="base64"
               file="cyllo_workflow_automation/static/src/img/node-icons/approval.svg"/>
    </record>
</odoo>
