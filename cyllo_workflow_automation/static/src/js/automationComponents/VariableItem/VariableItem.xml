<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
        <!-- Template for displaying a single variable item with information and action buttons -->
    <t t-name="VariableItem">
        <div class="variable-item">
            <div class="variable-info">
                <span class="variable-name" t-esc="props.name"/>
                <span class="variable-type" t-esc="props.type"/>
            </div>
            <div class="variable-actions">
                <button t-if="props.showEdit" class="variable-action-btn edit-btn" t-on-click="onEditClick">
                    <i class="fa fa-pencil"/>
                </button>
                <button t-if="props.showDelete" class="variable-action-btn delete-btn" t-on-click="onDeleteClick">
                    <i class="fa fa-trash"/>
                </button>
                <button class="variable-action-btn details-btn" t-on-click="onDetailsClick">
                    <i class="fa fa-chevron-right"/>
                </button>
            </div>
        </div>
    </t>
</templates>
