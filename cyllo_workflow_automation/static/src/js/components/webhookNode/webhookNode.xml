<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <t t-name="WebhookNode" t-inherit="ConfigurationBase" t-inherit-mode="primary">
        <xpath expr="//div[hasclass('modal-body')]" position="inside">
            <div class="py-2">

                <!-- ══════════════════════════════════════════════════════════
                     LABEL  (unchanged field: fieldState.label)
                ══════════════════════════════════════════════════════════ -->
                <div class="mb-3">
                    <label class="form-label cy-modal-form_label">Label</label>
                    <input type="text"
                           class="form-control cy-modal-form_input"
                           t-model="fieldState.label"
                           t-on-change="(ev) => this.setLabel(ev.target.value)"
                           placeholder="e.g. Notify MultiSafepay"/>
                </div>

                <!-- ══════════════════════════════════════════════════════════
                     METHOD (tags widget) + URL
                ══════════════════════════════════════════════════════════ -->
                <div class="mb-3">
                    <label class="form-label cy-modal-form_label">Method</label>
                    <div class="d-flex flex-wrap gap-2 mb-2">
                        <t t-foreach="getMethodOptions" t-as="option" t-key="option.value">
                            <span t-att-style="fieldState.webhook_method === option.value ? 'background-color: #9ea700; color: white; border: 1px solid #9ea700; padding: 4px 12px; font-size: 12px; cursor: pointer;' : 'background-color: transparent; color: #9ea700; border: 1px solid #9ea700; padding: 4px 12px; font-size: 12px; cursor: pointer;'"
                                  class="badge rounded-pill"
                                  t-on-click="() => this.fieldState.webhook_method = option.value">
                                <t t-esc="option.label"/>
                            </span>
                        </t>
                    </div>

                    <label class="form-label cy-modal-form_label mt-1">URL</label>
                    <div class="input-group">
                        <input type="text"
                               class="form-control cy-modal-form_input"
                               t-model="fieldState.webhook_url"
                               placeholder="https://api.example.com/v1/endpoint"/>
                        <!-- Copy URL button (UI-only, no fieldState change) -->
                        <button type="button"
                                class="btn"
                                style="border: 1px solid #ced4da; color: #9ea700; background: white;"
                                title="Copy URL"
                                t-on-click="copyUrl">
                            <t t-if="uiState.urlCopied">✓</t>
                            <t t-else="">⎘</t>
                        </button>
                    </div>
                </div>

                <!-- ══════════════════════════════════════════════════════════
                     HEADERS  (unchanged field: fieldState.webhook_headers)
                     Two modes: raw JSON textarea (original) + visual
                     key/value builder that syncs back to the same field.
                ══════════════════════════════════════════════════════════ -->
                <div class="mb-3">
                    <div class="d-flex align-items-center justify-content-between mb-1">
                        <label class="form-label cy-modal-form_label mb-0">
                            Headers
                            <span class="text-muted ms-1" style="font-size:11px;font-weight:normal;">
                                (JSON)
                            </span>
                        </label>
                        <!-- Toggle between raw JSON and visual builder -->
                        <button type="button"
                                class="btn btn-link btn-sm p-0 text-decoration-none"
                                style="font-size:12px; color: #9ea700;"
                                t-on-click="toggleHeaderBuilder">
                            <t t-if="uiState.headerBuilderOpen">
                                ✎ Edit as JSON
                            </t>
                            <t t-else="">
                                ⊞ Visual Builder
                            </t>
                        </button>
                    </div>

                    <!-- Original raw JSON input (always present, always synced) -->
                    <input type="text"
                           class="form-control cy-modal-form_input font-monospace"
                           style="font-size:12px;"
                           t-model="fieldState.webhook_headers"
                           t-att-class="uiState.headerBuilderOpen ? 'd-none' : ''"
                           placeholder='{"Content-Type": "application/json", "api_key": "YOUR_KEY"}'/>

                    <!-- Visual key/value builder (UI-only panel) -->
                    <t t-if="uiState.headerBuilderOpen">
                        <div class="border rounded p-2 bg-light">
                            <t t-foreach="uiState.headerRows" t-as="row" t-key="row_index">
                                <div class="d-flex align-items-center mb-1 gap-1">
                                    <input type="text"
                                           class="form-control form-control-sm font-monospace"
                                           placeholder="Key"
                                           t-att-value="row.key"
                                           t-on-input="(ev) => this.onHeaderKeyChange(row_index, ev)"/>
                                    <span class="text-muted px-1">:</span>
                                    <input type="text"
                                           class="form-control form-control-sm"
                                           placeholder="Value"
                                           t-att-value="row.value"
                                           t-on-input="(ev) => this.onHeaderValueChange(row_index, ev)"/>
                                    <button type="button"
                                            class="btn btn-sm btn-outline-danger"
                                            style="flex-shrink:0;"
                                            t-on-click="() => this.removeHeaderRow(row_index)">
                                        ×
                                    </button>
                                </div>
                            </t>
                            <button type="button"
                                    class="btn btn-sm mt-1"
                                    style="border: 1px solid #9ea700; color: #9ea700; background: transparent;"
                                    t-on-click="addHeaderRow">
                                + Add Header
                            </button>
                        </div>
                    </t>
                </div>

                <!-- ══════════════════════════════════════════════════════════
                     PAYLOAD  (unchanged field: fieldState.webhook_payload)
                ══════════════════════════════════════════════════════════ -->
                <div class="mb-3">
                    <div class="d-flex align-items-center justify-content-between mb-1">
                        <label class="form-label cy-modal-form_label mb-0">
                            Payload (JSON)
                        </label>
                    </div>

                    <!-- M2M-like field selector to generate JSON payload -->
                    <div class="mb-2 border rounded p-1 bg-white cy-w-o-input" style="min-height: 38px; height: auto;">
                        <div class="d-flex flex-wrap align-items-center gap-1">
                            <!-- Selected Tags -->
                            <t t-foreach="selectedPayloadTags" t-as="tag" t-key="tag.key">
                                <span class="badge rounded-pill" style="background:#f5f6e6;color:#9ea700;border:1px solid #9ea700;font-size:11px;font-weight:normal;padding:4px 8px;">
                                    <t t-esc="tag.label"/>
                                    <i class="fa fa-times ms-1 cursor-pointer" t-on-click="() => this.removePayloadTag(tag.key)" title="Remove"></i>
                                </span>
                            </t>
                            <!-- Dropdown for new fields -->
                            <select class="border-0 flex-grow-1" style="outline:none; min-width: 180px; background:transparent; font-size: 12px; color: #4d5572;" t-on-change="(ev) => this.addFieldToPayload(ev)">
                                <option value="" selected="selected">Add field to payload...</option>
                                <t t-foreach="commonTokens" t-as="tok" t-key="tok.token">
                                    <t t-if="!this.selectedPayloadTags.some(t => t.token === tok.token)">
                                        <option t-att-value="tok.token"><t t-esc="tok.label"/></option>
                                    </t>
                                </t>
                                <option disabled="disabled">──────────</option>
                                <option value="CUSTOM">Add Custom Value...</option>
                            </select>
                        </div>
                    </div>
                    
                    <!-- Custom Payload Value Form -->
                    <t t-if="uiState.showCustomPayloadForm">
                        <div class="d-flex align-items-center gap-2 mb-2 p-2 border rounded bg-light" style="font-size:12px;">
                            <input type="text" class="form-control form-control-sm" placeholder="Key (e.g. custom_id)" t-model="uiState.customPayloadKey"/>
                            <input type="text" class="form-control form-control-sm" placeholder="Value (e.g. 12345 or string)" t-model="uiState.customPayloadValue"/>
                            <button type="button" class="btn btn-sm" style="background:#9ea700; color:white; white-space: nowrap;" t-on-click="addCustomPayload">Add</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary" t-on-click="() => this.uiState.showCustomPayloadForm = false">Cancel</button>
                        </div>
                    </t>

                    <!-- Original textarea — fieldState.webhook_payload, rows unchanged -->
                    <textarea class="form-control cy-modal-form_input font-monospace mt-2"
                              style="font-size:12px;"
                              t-model="fieldState.webhook_payload"
                              rows="8"
                              placeholder='{"record_name": "{{current_record.name}}"}'>
                    </textarea>
                </div>

                <!-- ══════════════════════════════════════════════════════════
                     RESPONSE ACTIONS — fieldState.webhook_actions (JSON array)
                     Zero platform-specific logic: purely data-driven dispatch.
                ══════════════════════════════════════════════════════════ -->
                <div class="mb-3">

                    <!-- Section header / toggle -->
                    <div class="d-flex align-items-center justify-content-between mb-2"
                         style="border-bottom: 2px solid #9ea700; padding-bottom: 6px;">
                        <label class="form-label cy-modal-form_label mb-0" style="font-size:13px; font-weight:600; color:#9ea700;">
                            ⚡ Response Actions
                            <span class="text-muted ms-1" style="font-size:11px; font-weight:normal;">
                                — what to do with the API response
                            </span>
                        </label>
                        <button type="button"
                                class="btn btn-link btn-sm p-0 text-decoration-none"
                                style="font-size:12px; color:#9ea700;"
                                t-on-click="toggleResponseActions">
                            <t t-if="uiState.responseActionsOpen">▲ Collapse</t>
                            <t t-else="">▼ Expand</t>
                        </button>
                    </div>

                    <t t-if="uiState.responseActionsOpen">

                        <!-- Quick-tip banner -->
                        <div class="alert alert-info py-2 px-3 mb-2" style="font-size:11px; background:#f5f6e6; border:1px solid #9ea700; color:#5a5a2a; border-radius:6px;">
                            💡 Add one action per field you want to extract from the API response.
                            Use <strong>dot notation</strong> for nested paths, e.g.
                            <code>data.payment_url</code> or <code>links.0.href</code>.
                            Actions run in order after every successful webhook call.
                        </div>

                        <!-- Saved actions list -->
                        <t t-if="responseActions.length === 0">
                            <div class="text-muted text-center py-3" style="font-size:12px; border:1px dashed #ced4da; border-radius:6px;">
                                No response actions configured yet.<br/>
                                Click <strong>+ Add Action</strong> below to start.
                            </div>
                        </t>
                        <t t-else="">
                            <div class="mb-2">
                                <t t-foreach="responseActions" t-as="act" t-key="act_index">
                                    <div class="d-flex align-items-start gap-2 mb-2 p-2 border rounded"
                                         style="background:#fafafa; font-size:12px;">
                                        <!-- Reorder buttons -->
                                        <div class="d-flex flex-column" style="gap:2px; flex-shrink:0;">
                                            <button type="button" class="btn btn-sm p-0 border-0"
                                                    style="line-height:1; color:#9ea700;"
                                                    t-on-click="() => this.moveActionUp(act_index)"
                                                    title="Move Up">▲</button>
                                            <button type="button" class="btn btn-sm p-0 border-0"
                                                    style="line-height:1; color:#9ea700;"
                                                    t-on-click="() => this.moveActionDown(act_index)"
                                                    title="Move Down">▼</button>
                                        </div>
                                        <!-- Action details -->
                                        <div class="flex-grow-1">
                                            <div style="font-weight:600; color:#333;">
                                                <t t-esc="actionTypeLabel(act.action_type)"/>
                                            </div>
                                            <div class="text-muted mt-1" style="font-size:11px;">
                                                <t t-esc="actionSummary(act)"/>
                                            </div>
                                        </div>
                                        <button type="button"
                                                class="btn btn-sm btn-outline-secondary me-1"
                                                style="flex-shrink:0;"
                                                t-on-click="() => this.editResponseAction(act_index)"
                                                title="Edit Action">✎</button>
                                        <!-- Remove -->
                                        <button type="button"
                                                class="btn btn-sm btn-outline-danger"
                                                style="flex-shrink:0;"
                                                t-on-click="() => this.removeResponseAction(act_index)"
                                                title="Remove Action">×</button>
                                    </div>
                                </t>
                            </div>
                        </t>

                        <!-- ── Add-action form ─────────────────────────────── -->
                        <t t-if="uiState.showAddActionForm">
                            <div class="border rounded p-3 mb-2" style="background:#f5f6e6; font-size:12px;">
                                <div class="fw-semibold mb-2" style="color:#5a5a2a; font-size:13px;">
                                    <t t-if="uiState.editingActionIndex !== null">Edit Response Action</t>
                                    <t t-else="">New Response Action</t>
                                </div>

                                <!-- Action Type -->
                                <div class="mb-2">
                                    <label class="form-label mb-1" style="font-size:11px; font-weight:600;">Action Type</label>
                                    <select class="form-select form-select-sm"
                                            t-model="uiState.newActionType">
                                        <t t-foreach="actionTypeOptions" t-as="opt" t-key="opt.value">
                                            <option t-att-value="opt.value"><t t-esc="opt.label"/></option>
                                        </t>
                                    </select>
                                </div>

                                <!-- Extract Path -->
                                <div class="mb-2">
                                    <label class="form-label mb-1" style="font-size:11px; font-weight:600;">
                                        Response Path
                                        <span class="text-muted fw-normal">(dot-path into the JSON response)</span>
                                    </label>
                                    <input type="text"
                                           class="form-control form-control-sm font-monospace"
                                           placeholder="e.g. data.payment_url  or  links.0.href"
                                           t-model="uiState.newActionExtractPath"/>
                                </div>

                                <!-- Label -->
                                <div class="mb-2">
                                    <label class="form-label mb-1" style="font-size:11px; font-weight:600;">
                                        Label
                                        <span class="text-muted fw-normal">(shown in chatter / email)</span>
                                    </label>
                                    <input type="text"
                                           class="form-control form-control-sm"
                                           placeholder="e.g. Payment URL"
                                           t-model="uiState.newActionLabel"/>
                                </div>

                                <!-- Conditional extra fields -->
                                <t t-if="uiState.newActionType === 'write_field'">
                                    <div class="mb-2">
                                        <label class="form-label mb-1" style="font-size:11px; font-weight:600;">
                                            Field Technical Name
                                            <span class="text-muted fw-normal">(on the trigger record)</span>
                                        </label>
                                        <input type="text"
                                               class="form-control form-control-sm font-monospace"
                                               placeholder="e.g. payment_url"
                                               t-model="uiState.newActionFieldToWrite"/>
                                    </div>
                                </t>

                                <t t-if="uiState.newActionType === 'store_variable'">
                                    <div class="mb-2">
                                        <label class="form-label mb-1" style="font-size:11px; font-weight:600;">Variable Name</label>
                                        <input type="text"
                                               class="form-control form-control-sm font-monospace"
                                               placeholder="e.g. payment_url"
                                               t-model="uiState.newActionVariableName"/>
                                    </div>
                                </t>

                                <t t-if="uiState.newActionType === 'send_email'">
                                    <div class="mb-2">
                                        <label class="form-label mb-1" style="font-size:11px; font-weight:600;">
                                            Recipients
                                            <span class="text-muted fw-normal">(leave blank to use record partner email)</span>
                                        </label>
                                        <input type="text"
                                               class="form-control form-control-sm"
                                               placeholder="email@example.com, another@example.com"
                                               t-model="uiState.newActionEmailRecipients"/>
                                    </div>
                                </t>

                                <t t-if="uiState.newActionType === 'redirect_url'">
                                    <div class="mb-2">
                                        <label class="form-label mb-1" style="font-size:11px; font-weight:600;">Open In</label>
                                        <select class="form-select form-select-sm"
                                                t-model="uiState.newActionTarget">
                                            <option value="new">New Tab</option>
                                            <option value="self">Same Tab</option>
                                        </select>
                                    </div>
                                </t>

                                <!-- Form buttons -->
                                <div class="d-flex gap-2 mt-2">
                                    <button type="button"
                                            class="btn btn-sm"
                                            style="background:#9ea700; color:white;"
                                            t-on-click="saveResponseAction">
                                        ✓ Add Action
                                    </button>
                                    <button type="button"
                                            class="btn btn-sm btn-outline-secondary"
                                            t-on-click="cancelAddAction">
                                        Cancel
                                    </button>
                                </div>
                            </div>
                        </t>

                        <!-- Show form trigger -->
                        <t t-if="!uiState.showAddActionForm">
                            <button type="button"
                                    class="btn btn-sm mt-1"
                                    style="border:1px solid #9ea700; color:#9ea700; background:transparent;"
                                    t-on-click="openAddActionForm">
                                + Add Action
                            </button>
                        </t>

                    </t><!-- /responseActionsOpen -->
                </div>

            </div>
        </xpath>
    </t>
</templates>
