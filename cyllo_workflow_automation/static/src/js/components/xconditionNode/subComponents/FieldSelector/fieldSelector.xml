<?xml version="1.0" encoding="UTF-8" ?>
<templates>
    <t t-name="FieldSelector">
        <div class="cy-w-field-selector d-flex align-items-end gap-2">
            <t t-component="component" t-props="extractProps"/>
            <FieldTypeDropdown
                    currentLabel="getDropdownLabel(state.fieldType)"
                    onSelected="(type) => this.selectFieldType(type)"
                    options="defaultOptions"
            />
        </div>
    </t>
</templates>