<?xml version="1.0" encoding="UTF-8" ?>
<templates>
    <t t-name="ActivityNode" t-inherit="ConfigurationBase" t-inherit-mode="primary">
        <!-- Template for the ActivityNode configuration, extending the base ConfigurationBase and
        adding fields for Label, Record Selection, Activity Type, Deadline, Assignee, and Summary -->
        <xpath expr="//div[hasclass('modal-body')]" position="inside">
            <div class="cy-work-auto-form d-flex cy-flex-column">
                <div class="mb-3">
                    <label for="label" class="form-label  cy-modal-form_label mb-3">
                        Label
                    </label>
                    <input
                            type="text"
                            class="o_input"
                            autocomplete="off"
                            placeholder="Label"
                            t-on-focusout="(ev) => this.setLabel(ev.target.value)"
                            t-att-value="getLabel"
                    />
                </div>
                <div class="row mb-3 align-items-end">
                    <div class="col-md-6">
                        <label for="record-select" class="form-label">Choose record</label>
                        <CustomDropdown
                                options="getRecords"
                                defaultValue="getModel"
                                onChange="(value) => this.updateObject(value)"
                                placeholder="'Select a record...'"
                                searchable="true"
                                width="''"
                        />
                    </div>
                    <div class="col-md-6">
                        <label for="type-select" class="form-label">Activity Type</label>
                        <Many2XAutocomplete
                                resModel="'mail.activity.type'"
                                getDomain="() => []"
                                fieldString="'ActivityType'"
                                update.bind="updateActivityType"
                                value="fieldState.activity_type?.display_name"
                                activeActions="{}"
                        />
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col-md-6">
                        <label for="date-select" class="form-label">Deadline</label>
                        <t t-set="dateInfo" t-value="getValueEditorInfo(fieldState.activity_deadline,'date')"/>
                        <div class="d-flex mb-3">
                            <div class="flex-grow-1 me-2">
                                <t t-component="dateInfo.component" t-props="getComponentProps(dateInfo,'date')"/>
                            </div>
                            <FieldTypeDropdown
                                    currentLabel="getDropdownLabel(fieldState.activity_deadline?.selectionType)"
                                    onSelected="(type) => this.toggleIncludeVariable(type,'date')"
                            />
                        </div>
                    </div>
                    <div class="col-md-6">
                        <label for="record-select" class="form-label">Assignee</label>
                        <t t-set="info" t-value="this.getValueEditorInfo(fieldState.activity_user,'assignee')"/>
                        <div class="d-flex mb-3">
                            <div class="flex-grow-1 me-2">
                                <t t-component="info.component"
                                   t-props="getComponentProps(info,'assignee')"/>
                            </div>
                            <FieldTypeDropdown
                                    currentLabel="getDropdownLabel(fieldState.activity_user?.selectionType)"
                                    onSelected="(type) => this.toggleIncludeVariable(type,'user')"
                            />
                        </div>
                    </div>
                </div>
                <div class="mb-3">
                    <label for="summary" class="form-label cy-modal-form_label">Summary</label>
                    <textarea class="form-control"
                              rows="4"
                              t-on-focusout="(ev) => this.setSummary(ev.target.value)"
                              t-att-value="fieldState.activity_summary || ''"
                    />
                </div>
            </div>
        </xpath>
    </t>
</templates>