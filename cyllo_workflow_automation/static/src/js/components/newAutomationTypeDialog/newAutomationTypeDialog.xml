<?xml version="1.0" encoding="UTF-8" ?>
<templates>
    <t t-name="NewAutomationTypeDialog">
        <Dialog contentClass="'cy-rename-automation-modal'">
            <t t-set-slot="header">
                <div class="d-flex align-items-center w-100">
                    <h4 class="mb-0">
                        <t t-out="props.title || 'Workflow Type'"/>
                    </h4>
                    <div t-on-click="onDiscard" type="button" class="btn-close ms-auto" aria-label="Close"/>
                </div>
            </t>
            <div class="modal-body py-3">
                <p class="mb-3">Is this workflow reusable?</p>
                <div class="d-flex gap-2">
                    <button type="button"
                            class="btn btn-outline-secondary"
                            t-on-click="() => this.onChoose(false)">
                        No
                    </button>
                    <button type="button"
                            class="btn btn-warning"
                            t-on-click="() => this.onChoose(true)">
                        Yes
                    </button>
                </div>
            </div>
            <t t-set-slot="footer">
                <button class="btn btn-secondary" t-on-click="onDiscard">
                    <t t-out="'Cancel'"/>
                </button>
            </t>
        </Dialog>
    </t>
</templates>
