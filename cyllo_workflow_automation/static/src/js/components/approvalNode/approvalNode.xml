<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="ApprovalNode" t-inherit="ConfigurationBase" t-inherit-mode="primary">
        <xpath expr="//div[hasclass('modal-body')]" position="inside">
            <div class="approval-node">

                <!-- ── Trigger Configuration ────────────────────────────── -->
                <div class="cy-config-section-header mt-1 mb-2 fw-semibold">Trigger Configuration</div>

                <div class="cy-config-section mb-3">
                    <label class="form-label mb-1 fw-semibold">Label *</label>
                    <input type="text"
                           t-att-class="'o_input ' + (approvalState.labelError ? 'border-danger' : '')"
                           style="border-radius:0px !important;"
                           t-att-value="getLabel"
                           t-on-change="(e) => this.setLabel(e.target.value)"
                           placeholder="e.g. Purchase Manager Approval"/>
                </div>

                <div class="cy-config-section mb-3">
                    <label class="form-label mb-1 fw-semibold">Trigger Rule Type *</label>
                    <select class="o_input"
                            style="border-radius:0px !important;"
                            t-on-change="(e) => this.setRuleType(e.target.value)">
                        <option value="button"
                                t-att-selected="approvalState.ruleType === 'button'">
                            Button Click
                        </option>
                        <option value="server"
                                t-att-selected="approvalState.ruleType === 'server'">
                            Server Action
                        </option>
                        <option value="state"
                                t-att-selected="approvalState.ruleType === 'state'">
                            State Change
                        </option>
                    </select>
                </div>

                <t t-if="approvalState.ruleType === 'button'">
                    <div class="cy-config-section mb-3">
                        <label class="form-label mb-1 fw-semibold">Button Method *</label>
                        <select class="o_input"
                                style="border-radius:0px !important;"
                                t-on-change="this.setButtonMethod.bind(this)">
                            <option value="">-- Select Button --</option>
                            <t t-foreach="approvalState.buttons" t-as="btn" t-key="btn.id">
                                <option t-att-value="btn.name"
                                        t-att-selected="approvalState.buttonMethod === btn.name">
                                    <t t-esc="btn.display_name"/>
                                </option>
                            </t>
                        </select>
                        <p class="form-text text-muted small">
                            The button to intercept.
                        </p>
                    </div>
                </t>

                <t t-if="approvalState.ruleType === 'server'">
                    <div class="cy-config-section mb-3">
                        <label class="form-label mb-1 fw-semibold">Server Action *</label>
                        <select class="o_input"
                                style="border-radius:0px !important;"
                                t-on-change="this.setServerActionId.bind(this)">
                            <option value="">-- Select Server Action --</option>
                            <t t-foreach="approvalState.serverActions" t-as="act" t-key="act.id">
                                <option t-att-value="act.id"
                                        t-att-selected="approvalState.serverActionId === act.id">
                                    <t t-esc="act.name"/>
                                </option>
                            </t>
                        </select>
                    </div>
                </t>

                <t t-if="approvalState.ruleType === 'state'">
                    <div class="cy-config-section mb-3">
                        <label class="form-label mb-1 fw-semibold">State Field *</label>
                        <select class="o_input"
                                style="border-radius:0px !important;"
                                t-on-change="(e) => this.onStateFieldChange(e.target.value)">
                            <option value="">-- Select State Field --</option>
                            <t t-foreach="approvalState.stateFields" t-as="fld" t-key="fld.id">
                                <option t-att-value="fld.id"
                                        t-att-selected="approvalState.stateFieldId === fld.id">
                                    <t t-esc="fld.field_description + ' (' + fld.name + ')'"/>
                                </option>
                            </t>
                        </select>
                    </div>
                    
                    <t t-if="approvalState.activeStateField and approvalState.activeStateField.ttype === 'selection'">
                        <div class="cy-config-section mb-3">
                            <label class="form-label mb-1 fw-semibold">Target State Selection *</label>
                            <select class="o_input"
                                    style="border-radius:0px !important;"
                                    t-on-change="this.setStateSelectionId.bind(this)">
                                <option value="">-- Select Target State --</option>
                                <t t-foreach="approvalState.stateSelections" t-as="sel" t-key="sel.id">
                                    <option t-att-value="sel.id"
                                            t-att-selected="approvalState.stateSelectionId === sel.id">
                                        <t t-esc="sel.name"/>
                                    </option>
                                </t>
                            </select>
                        </div>
                    </t>
                    
                    <t t-if="approvalState.activeStateField and approvalState.activeStateField.ttype === 'many2one'">
                        <div class="cy-config-section mb-3">
                            <label class="form-label mb-1 fw-semibold">Target Stage *</label>
                            <select class="o_input"
                                    style="border-radius:0px !important;"
                                    t-on-change="this.setStateM2oId.bind(this)">
                                <option value="">-- Select Target Stage --</option>
                                <t t-foreach="approvalState.stateM2os" t-as="m2o" t-key="m2o.id">
                                    <option t-att-value="m2o.id"
                                            t-att-selected="approvalState.stateM2oId === m2o.id">
                                        <t t-esc="m2o.display_name"/>
                                    </option>
                                </t>
                            </select>
                        </div>
                    </t>
                </t>

                <!-- ── Approver Configuration ────────────────────────────── -->
                <div class="cy-config-section-header mt-3 mb-2 fw-semibold">Approver Configuration</div>

                <div class="cy-config-section mb-3">
                    <label class="form-label mb-1 fw-semibold">Approver Type *</label>
                    <select class="o_input"
                            style="border-radius:0px !important;"
                            t-on-change="(e) => this.setApproverType(e.target.value)">
                        <option value="user"
                                t-att-selected="approvalState.approverType === 'user'">
                            Specific User
                        </option>
                        <option value="group"
                                t-att-selected="approvalState.approverType === 'group'">
                            User Group
                        </option>
                    </select>
                </div>

                <t t-if="approvalState.approverType === 'user'">
                    <div class="cy-config-section mb-3">
                        <label class="form-label mb-1 fw-semibold">Approver User *</label>
                        <select class="o_input"
                                style="border-radius:0px !important;"
                                t-att-class="{'cy-input-error': approvalState.approverError}"
                                t-on-change="this.setApproverUserId.bind(this)">
                            <option value="">-- Select User --</option>
                            <t t-foreach="approvalState.users" t-as="usr" t-key="usr.id">
                                <option t-att-value="usr.id"
                                        t-att-selected="approvalState.approverId === usr.id">
                                    <t t-esc="usr.name"/>
                                </option>
                            </t>
                        </select>
                        <span t-if="approvalState.approverError" class="text-danger small mt-1">
                            Select a valid user.
                        </span>
                    </div>
                </t>

                <t t-if="approvalState.approverType === 'group'">
                    <div class="cy-config-section mb-3">
                        <label class="form-label mb-1 fw-semibold">Approver Group *</label>
                        <select class="o_input"
                                style="border-radius:0px !important;"
                                t-att-class="{'cy-input-error': approvalState.approverError}"
                                t-on-change="this.setApproverGroupId.bind(this)">
                            <option value="">-- Select Group --</option>
                            <t t-foreach="approvalState.groups" t-as="grp" t-key="grp.id">
                                <option t-att-value="grp.id"
                                        t-att-selected="approvalState.approverGroupId === grp.id">
                                    <t t-esc="grp.display_name"/>
                                </option>
                            </t>
                        </select>
                        <span t-if="approvalState.approverError" class="text-danger small mt-1">
                            Select a valid group.
                        </span>
                    </div>
                </t>

                <!-- ── Notification ──────────────────────────────────────── -->
                <div class="cy-config-section-header mt-3 mb-2 fw-semibold">Notification</div>

                <div class="cy-config-section d-flex gap-4 mb-3">
                    <label class="d-flex align-items-center gap-2 cursor-pointer">
                        <input type="checkbox"
                               t-att-checked="approvalState.notifyEmail"
                               t-on-change="setNotifyEmail"/>
                        Enable Email Notifications
                    </label>
                </div>

                <!-- ── Timeout Configuration ─────────────────────────────── -->
                <div class="cy-config-section-header mt-3 mb-2 fw-semibold">Timeout</div>

                <div class="cy-config-section mb-3">
                    <label class="form-label mb-1 fw-semibold">Expire After (hours)</label>
                    <input type="number"
                           class="o_input"
                           style="border-radius:0px !important;"
                           min="0"
                           step="0.5"
                           t-att-value="approvalState.expireAfter"
                           t-on-change="setExpireAfter"
                           placeholder="0 = never expires"/>
                    <p class="form-text text-muted small">
                        Set to <strong>0</strong> to never expire. When the timer runs out the
                        <span class="badge" style="background:#b47706;">Timeout</span> output port is triggered.
                    </p>
                </div>

            </div>
        </xpath>
    </t>

</templates>
