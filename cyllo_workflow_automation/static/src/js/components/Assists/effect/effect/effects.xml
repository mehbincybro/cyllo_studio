<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="SaveConfetti">
        <div class="o_save_confetti" t-att-class="{ 'o_animating': state.isAnimating }">
            <div class="o_save_checkmark">
                <t t-if="props.isLocked">
                    <t t-if="props.isLocked">
                        <div class="locked-container">
                            <span class="locked-text" t-out="props.message"/>
                            <i t-attf-class="{{props.icon}} locked-icon"/>
                        </div>
                    </t>
                </t>
                <t t-else="">
                    <svg viewBox="0 0 52 52">
                        <circle class="checkmark__circle" cx="26" cy="26" r="25" fill="none"/>
                        <path class="checkmark__check" fill="none" d="M14.1 27.2l7.1 7.2 16.7-16.8"/>
                    </svg>
                    <div t-if="!props.isLocked" class="o_save_message">
                        <t t-esc="props.message"/>
                    </div>
                </t>
            </div>
        </div>
    </t>

    <t t-name="SaveFireworks">
        <div class="o_save_fireworks" t-att-class="{ 'o_animating': state.isAnimating }">
            <div class="o_fireworks_container">
                <t t-foreach="state.fireworks" t-as="firework" t-key="firework.id">
                    <div class="firework"
                         t-attf-style="left: {{firework.left}}; top: {{firework.top}}; --size: {{firework.size}}px; --delay: {{firework.delay}}s;">
                    </div>
                </t>
                <t t-foreach="state.stars" t-as="star" t-key="star.id">
                    <div class="star"
                         t-attf-style="left: {{star.left}}; top: {{star.top}}; --size: {{star.size}}px; --delay: {{star.delay}}s;">
                    </div>
                </t>
            </div>
            <div class="o_save_icon">
                <svg viewBox="0 0 24 24" width="100" height="100">
                    <path d="M20.285 2l-11.285 11.567-5.286-5.011-3.714 3.716 9 8.728 15-15.285z" fill="#ffffff"/>
                </svg>
            </div>
            <div class="o_save_message">
                <t t-esc="props.message"/>
            </div>
        </div>
    </t>
    <t t-name="BuildMessage">
        <div class="o_save_fireworks" t-att-class="{ 'o_animating': state.isAnimating }">
            <div class="o_fireworks_container confirmation-popup-icon">
                <t t-if="props.image">
                    <img t-att-src="props.image"
                         alt="Confirmation Image"
                         class="confirmation-popup-image"/>
                </t>
                <t t-elif="props.icon">
                    <i t-att-class="props.icon"/>
                </t>
                <t t-else="">
                    <i class="fa fa-question-circle"/>
                </t>
                <p class="confirmation-popup-message">
                    <t t-esc="props.message || 'Building Your workflow'"/>
                </p>
            </div>
        </div>
    </t>
</templates>