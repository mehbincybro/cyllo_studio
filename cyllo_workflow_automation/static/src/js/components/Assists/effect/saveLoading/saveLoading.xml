<t t-name="SaveLoading">
    <div class="o_save_fireworks" t-att-class="{ 'o_animating': state.isAnimating }">
        <div>
            <div class="saveLoading-image-container">
                <t t-if="props.image">
                    <img t-att-src="props.image"
                         alt="Confirmation Image"
                         class="confirmation-popup-image saveLoading-image"/>
                </t>
                <t t-elif="props.icon">
                    <i t-att-class="props.icon"/>
                </t>
                <t t-else="">
                    <i class="fa fa-question-circle"/>
                </t>
            </div>

            <div>
                <h4 class="saveLoading-message">
                    <t t-esc="props.message || 'Building Your workflow'"/>
                    <div class="cy-w-loader-container">
                        <div class="cy-w-loader">
                            <div></div>
                            <div></div>
                            <div></div>
                        </div>
                    </div>
                </h4>
            </div>
        </div>
    </div>
</t>