<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="TypeToggler">
        <div class="type-toggler" t-att-class="props.class">
            <t t-foreach="props.options" t-as="option" t-key="option.value">
                <button
                    class="type-toggler__button"
                    t-att-class="{ 'type-toggler__button--active': isActive(option) }"
                    t-on-click="() => this.toggleInput(option)">
                    <t t-esc="option.label"/>
                </button>
            </t>
        </div>
    </t>
</templates>