<?xml version="1.0" encoding="UTF-8"?>
<templates>
    <t t-name="WorkPager">
        <div class="cy-w-aligned-icons ">
            <a class="ri-arrow-left-s-line cy-navigation-icon px-1"
               style="height: 33px;"
               aria-label="Previous" data-tooltip="Previous" tabindex="-1"
               t-att-data-hotkey="'p'"
               t-on-click.stop="() => this.navigate(-1)"/>
            <span class="cy-w-page-count">
                <span t-if="!state.isEdit" t-on-click="currentClick">
                    <t t-out="currentRecordNumber"/>
                </span>
                <input t-if="state.isEdit" type="text" style="text-align:center" t-att-value="currentRecordNumber"
                       t-ref="currentRecordNumber" t-on-focusout="handleClickOutside"
                       class="o_pager_value o_input d-inline-block w-auto mb-n1" size="1"/>
                of
                <t class="fc-unselectable" t-out="recordLength"/>
            </span>

            <a class="ri-arrow-right-s-line cy-navigation-icon px-1"
               aria-label="Next" data-tooltip="Next" tabindex="-1"
               t-att-data-hotkey="'n'"
               t-on-click.stop="() => this.navigate(1)"/>
        </div>
    </t>
</templates>