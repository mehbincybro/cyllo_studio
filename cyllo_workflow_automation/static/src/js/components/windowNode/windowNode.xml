<?xml version="1.0" encoding="UTF-8" ?>
<templates>
    <t t-name="WindowNode" t-inherit="ConfigurationBase" t-inherit-mode="primary">
        <xpath expr="//div[hasclass('modal-body')]" position="inside">
            <Record t-props="recordProps" t-slot-scope="data">
                <div class="row py-2">
                    <div class="col-12 mb-3">
                        <label class="form-label cy-modal-form_label">
                            <span>Label</span>
                        </label>
                        <CharField
                            name="'label'"
                            record="data.record"
                            id="'label'"
                            t-on-change="ev => this.onChangeLabel(ev.target.value)"
                        />
                    </div>

                    <div class="col-12 mb-3">
                        <label class="form-label cy-modal-form_label">
                            <span>Window Action</span>
                        </label>
                        <Many2OneField
                            name="'window_action_id'"
                            record="data.record"
                            id="'window_action_id'"
                        />
                    </div>

                    <div class="col-6 mb-3">
                        <label class="form-label cy-modal-form_label">
                            <span>View Type</span>
                        </label>
                        <SelectionField
                            name="'window_view_type'"
                            record="data.record"
                            id="'window_view_type'"
                        />
                    </div>

                    <div class="col-6 mb-3">
                        <label class="form-label cy-modal-form_label">
                            <span>Target</span>
                        </label>
                        <SelectionField
                            name="'window_target'"
                            record="data.record"
                            id="'window_target'"
                        />
                    </div>

                    <div class="col-12 mb-3">
                        <label class="form-label cy-modal-form_label">
                            <span>Domain Filter <small class="text-muted">(optional)</small></span>
                        </label>
                        <CharField
                            name="'window_domain'"
                            record="data.record"
                            id="'window_domain'"
                        />
                    </div>

                    <div class="col-12 mb-3">
                        <label class="form-label cy-modal-form_label">
                            <span>Context <small class="text-muted">(optional)</small></span>
                        </label>
                        <CharField
                            name="'window_context'"
                            record="data.record"
                            id="'window_context'"
                        />
                    </div>
                </div>
            </Record>
        </xpath>
    </t>
</templates>
