<?xml version="1.0" encoding="UTF-8" ?>
<templates>
    <t t-name="RenameAutomationDialog">
        <Dialog contentClass="'cy-rename-automation-modal'">
            <t t-set-slot="header">
                <div class="d-flex align-items-center w-100">
                    <h4 class="mb-0">
                        <t t-out="props.title || 'Rename Automation'"/>
                    </h4>
                    <div t-on-click="onDiscard" type="button" class="btn-close ms-auto" aria-label="Close"/>
                </div>
            </t>
            <div class="modal-body py-3">
                <label class="form-label cy-rename-automation-label">Automation Name</label>
                <input type="text"
                       class="form-control cy-rename-automation-input"
                       t-att-value="state.name"
                       t-on-input="onInput"
                       t-on-keydown="onKeydown"
                       placeholder="Enter automation name"
                       autofocus="autofocus"/>
            </div>
            <t t-set-slot="footer">
                <button class="btn btn-primary o_save_button"
                        t-att-disabled="confirmDisabled"
                        t-on-click="onConfirm">
                    <t t-out="'Save'"/>
                </button>
                <button class="btn btn-secondary" t-on-click="onDiscard">
                    <t t-out="'Cancel'"/>
                </button>
            </t>
        </Dialog>
    </t>
</templates>
