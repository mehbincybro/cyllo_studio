<?xml version="1.0" encoding="UTF-8" ?>
<templates>
    <t t-name="cyllo_workflow_automation.autoflowModal">
        <div class="cy-onboard_modal-container">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <span class="min-w-0 text-truncate">New Record</span>
                    </div>
                    <div class="modal-body">
                        <input type="text" t-model="state.name"/>
                    </div>
                    <div class="modal-footer">
                        <t t-set-slot="footer">
                            <button class="btn btn-primary o_save_button" t-on-click="configSave">
                                Confirm
                            </button>
                            <button class="btn btn-secondary" t-on-click="onDiscard">
                                Discard
                            </button>
                        </t>
                    </div>
                </div>
            </div>
        </div>
    </t>
</templates>