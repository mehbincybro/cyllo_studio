<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="WorkflowCard" owl="1">
        <div t-on-click="openView" class="auto-card" style="cursor: pointer;">
            <div class="auto-card-inner">
               <t t-if="WorkflowCard.is_record_saved">
                    <div class="auto-card-contents">
                        <div class="kanban-flow-container-vertical">
                            <div style="position: relative;">
                                <!-- Box 1 -->
                                <div class="d-flex" style="">
                                    <div class="kanban-flow-box0">
                                        <t t-esc="WorkflowCard.model_id[1]"/> <!-- Dynamic text for Box 2 -->
                                    </div>

                                </div>

                                <!-- Box 2 -->
                                <div class="d-flex" style="">
                                    <div class="kanban-flow-box1">
                                        <t t-if="WorkflowCard &amp;&amp; WorkflowCard.triggerNames &amp;&amp; WorkflowCard.triggerNames.length">
                                            <t t-esc="WorkflowCard.triggerNames.join(', ')"/>
                                        </t>
                                        <t t-else="">
                                            <t t-esc="'Trigger Block'"/>
                                        </t>
                                    </div>
                                </div>

                                <!-- Box 3 -->
                                <div class="kanban-flow-box2" style="">
                                    <t t-esc="'Builtin Blocks'"/> <!-- Dynamic text for Box 3 -->
                                </div>
                                <div class="work-auto-left-card"> <!-- Line connecting Box 1 and Box 2 -->
                                    <img src="cyllo_workflow_automation/static/src/img/cardArrow/Arrow 10-10 sahid3.svg"
                                         style="height: 63px;width:70px"/>
                                </div>
                                <div class="work-auto-right-card"> <!-- Line connecting Box 2 and Box 3 -->

                                    <img src="cyllo_workflow_automation/static/src/img/cardArrow/Arrow 10-10 sahid3.svg"
                                         style="height: 63px;width:70px"/>
                                </div>
                            </div>
                        </div>
                    </div>
               </t>
                <t t-else="">
                    <div class="d-flex align-items-center justify-content-center">
                        <div class="auto-card-image">
                            <img t-att-src="Image" alt="Card image"/>
                        </div>
                    </div>
                </t>
                <div class="auto-card-content">
                    <h3 class="auto-card-title" t-out="WorkflowCard.name"/>
                </div>
                <button class="auto-card-delete" t-on-click.prevent.stop="onClickDelete" title="Delete">
                    <i class="ri-delete-bin-line"/>
                </button>
            </div>
        </div>
    </t>
</templates>
