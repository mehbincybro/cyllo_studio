<odoo>
    <record model="ir.module.category" id="module_category_insurance_management">
        <field name="name">Insurance Management</field>
        <field name="description">Helps to manage various assets operations</field>
        <field name="sequence">25</field>
    </record>
    <!-- Insurance User -->
    <record id="group_insurance_user" model="res.groups">
        <field name="name">Insurance User</field>
        <field name="category_id" ref="cyllo_insurance.module_category_insurance_management"/>
    </record>

    <!-- Insurance Admin -->
    <record id="group_insurance_admin" model="res.groups">
        <field name="name">Insurance Admin</field>
        <field name="implied_ids" eval="[Command.link(ref('cyllo_insurance.group_insurance_user'))]"/>
        <field name="category_id" ref="cyllo_insurance.module_category_insurance_management"/>
        <field name="users" eval="[Command.link(ref('base.user_root')), Command.link(ref('base.user_admin'))]"/>
    </record>

</odoo>
