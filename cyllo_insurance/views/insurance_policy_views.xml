<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_policy_tree" model="ir.ui.view">
        <field name="name">insurance.policy.tree</field>
        <field name="model">insurance.policy</field>
        <field name="arch" type="xml">
            <tree>
                <field name="policy_no"/>
                <field name="user_id"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="state"/>
                <field name="premium_amount" sum="Total"/>
                <field name="remaining_coverage" sum="Total"/>
                <field name="currency_id" column_invisible="1"/>
            </tree>
        </field>
    </record>

    <record id="view_policy_form" model="ir.ui.view">
        <field name="name">insurance.policy.form</field>
        <field name="model">insurance.policy</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_active" string="Confirm" type="object" class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_expired" string="Expire" type="object" class="btn-secondary"
                            invisible="state != 'active'"/>
                    <button name="action_reset_to_draft" string="Reset to draft" type="object" class="btn-secondary"
                            invisible="state != 'expired'"/>
                    <button name="action_cancel" string="Cancel" type="object" class="btn-secondary"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="currency_id" invisible="True"/>
                            <field name="policy_no" readonly="1"/>
                            <field name="plan_id"/>
                            <field name="user_id"/>
                        </group>

                        <group>
                            <field name="issue_date"/>
                            <field name="start_date"/>
                            <field name="end_date"/>
                        </group>

                        <group>
                            <field name="premium_amount"/>
                            <field name="coverage_limit"/>
                            <field name="deductible"/>
                            <field name="used_coverage" readonly="1"/>
                            <field name="remaining_coverage" readonly="1"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Claims">
                            <field name="claim_ids" readonly="1"/>
                        </page>
                        <page string="Coverage">
                            <field name="coverage_line_ids">
                                <tree editable="bottom">
                                    <field name="currency_id" column_invisible="1"/>
                                    <field name="policy_id" column_invisible="1"/>
                                    <field name="addon_added" column_invisible="1"/>
                                    <field name="coverage_id"/>
                                    <field name="coverage_type"/>
                                    <field name="coverage_amount"/>
                                    <!--                                    <field name="deductible"/>-->
                                    <button name="action_add_addons" string="Add" type="object" class="btn-primary"
                                            invisible="coverage_type != 'addons' or addon_added"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Description">
                            <field name="description"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
