<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_policy_tree" model="ir.ui.view">
        <field name="name">insurance.policy.tree</field>
        <field name="model">insurance.policy</field>
        <field name="arch" type="xml">
            <tree>
                <field name="policy_no"/>
                <field name="plan_id"/>
                <field name="user_id"/>
                <field name="parent_policy_id"/>
                <field name="state" widget="badge"/>
            </tree>
        </field>
    </record>

    <record id="view_policy_form" model="ir.ui.view">
        <field name="name">insurance.policy.form</field>
        <field name="model">insurance.policy</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_confirm" string="Confirm" type="object" class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_assess_risk" string="Assess Risk" type="object" class="btn-primary"
                            invisible="state != 'confirmed'"
                            groups="cyllo_insurance.group_insurance_user"/>
                    <button name="action_approve_policy" string="Approve" type="object" class="btn-success"
                            invisible="state != 'under_review'"
                            groups="cyllo_insurance.group_insurance_admin"/>
                    <button name="action_reject_underwriting" string="Reject" type="object" class="btn-danger"
                            invisible="state != 'under_review'"
                            groups="cyllo_insurance.group_insurance_admin"/>
                    <button name="action_renew_policy" string="Renew Policy" type="object" class="btn-primary"
                            invisible="state not in ('active', 'expired') or child_policy_ids"/>
                    <button name="action_create_invoice" string="Create Invoice" type="object" class="btn-primary"
                            invisible="state not in ('confirmed', 'approved')"/>
                    <button name="action_expired" string="Expire" type="object" class="btn-secondary"
                            invisible="state != 'active'"/>
                    <button name="action_reset_to_draft" string="Reset to draft" type="object" class="btn-secondary"
                            invisible="state not in ('expired', 'cancel')"/>
                    <button name="action_cancel" string="Cancel" type="object" class="btn-secondary"
                            invisible="state in ('expired', 'cancel')"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,confirmed,under_review,approved,invoiced,active,expired,cancel"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_invoice"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-pencil-square-o"
                                invisible="invoice_count == 0">
                            <field name="invoice_count" widget="statinfo" string="Invoice"/>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="currency_id" invisible="True"/>
                            <field name="policy_no"/>
                            <field name="plan_id"/>
                            <field name="user_id"/>
                        </group>

                        <group>
                            <field name="issue_date"/>
                            <field name="start_date"/>
                            <field name="end_date"/>
                            <field name="is_recurring" invisible="1"/>
                            <field name="parent_policy_id" readonly="1"
                                   options="{'no_create': True, 'no_open': True}"/>
                            <field name="excluded_incident_ids" widget="many2many_tags"/>
                            <field name="child_policy_ids" invisible="1"/>
                        </group>

                        <group>
                            <field name="premium_amount"/>
                            <field name="coverage_limit"/>
                            <field name="deductible"/>
                            <field name="used_coverage" readonly="1"/>
                            <field name="remaining_coverage" readonly="1"/>

                            <field name="ncb_percentage" readonly="state != 'draft'"/>

                            <field name="ncb_discount_amount" readonly="1" invisible="ncb_discount_amount == 0"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Claims">
                            <field name="claim_ids" readonly="1"/>
                        </page>
                        <page string="Coverage">
                            <field name="coverage_line_ids">
                                <tree editable="bottom">
                                    <field name="currency_id" column_invisible="1"/>
                                    <field name="policy_id" column_invisible="1"/>
                                    <field name="addon_added" column_invisible="1"/>
                                    <field name="coverage_id"/>
                                    <field name="coverage_type"/>
                                    <field name="coverage_amount"/>
                                    <button name="action_add_addons" string="Add" type="object" class="btn-primary"
                                            invisible="coverage_type != 'addons' or addon_added"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Renewal History">
                            <field name="renewal_history_ids" readonly="1">
                                <tree>
                                    <field name="policy_no"/>
                                    <field name="start_date"/>
                                    <field name="end_date"/>
                                    <field name="state"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Risk Assessment"
                              invisible="not risk_assessment_notes">
                            <group>
                                <field name="risk_triggered" readonly="1"/>
                                <field name="risk_assessment_notes" readonly="1" nolabel="1" colspan="2"/>
                            </group>
                        </page>
                        <page string="Description">
                            <field name="description"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
