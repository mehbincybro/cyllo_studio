<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_coverage_tree" model="ir.ui.view">
        <field name="name">insurance.coverage.tree</field>
        <field name="model">insurance.coverage</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="code"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <record id="view_coverage_form" model="ir.ui.view">
        <field name="name">insurance.coverage.form</field>
        <field name="model">insurance.coverage</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                        </group>
                        <group>
                            <field name="active"/>
                            <field name="description"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
