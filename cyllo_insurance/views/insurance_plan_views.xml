<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_plan_tree" model="ir.ui.view">
        <field name="name">insurance.plan.tree</field>
        <field name="model">insurance.plan</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="currency_id" column_invisible="1"/>
                <field name="policy_type_id"/>
                <field name="default_premium" sum="Total"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <record id="view_plan_form" model="ir.ui.view">
        <field name="name">insurance.plan.form</field>
        <field name="model">insurance.plan</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_active" string="Confirm" type="object" class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_expired" string="Expire" type="object" class="btn-secondary"
                            invisible="state != 'active'"/>
                    <button name="action_reset_to_draft" string="Reset to draft" type="object" class="btn-secondary"
                            invisible="state != 'expired'"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="currency_id" invisible="True"/>
                            <field name="name" readonly="state != 'draft'"/>
                            <field name="code" readonly="state != 'draft'"/>
                            <field name="policy_type_id" readonly="state != 'draft'"/>
                        </group>
                        <group>
                            <field name="valid_from" readonly="state != 'draft'"/>
                            <field name="valid_to" readonly="state != 'draft'"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Financial">
                            <group>
                                <field name="default_premium" readonly="state != 'draft'"/>
                                <field name="default_coverage_limit" readonly="state != 'draft'"/>
                                <field name="default_deductible" readonly="state != 'draft'"/>
                            </group>
                        </page>

                        <page string="Coverage">
                            <field name="coverage_line_ids">
                                <tree editable="bottom">
                                    <field name="currency_id" column_invisible="1"/>
                                    <field name="plan_id" column_invisible="1"/>
                                    <field name="coverage_id"/>
                                    <field name="coverage_type"/>
                                    <field name="coverage_amount"/>
<!--                                    <field name="deductible"/>-->
                                </tree>
                            </field>
<!--                            <group class="oe_subtotal_footer fs-1">-->
<!--                                <field name="total_coverage_amount"/>-->
<!--                            </group>-->
                        </page>
                        <page string="Description">
                            <field name="description"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
