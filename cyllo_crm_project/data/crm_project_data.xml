<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="1">

        <!-- CRM Leads Default Project -->
        <record id="project_crm_leads" model="project.project">
            <field name="name">CRM Leads</field>
            <field name="user_id" ref="base.user_admin"/>
        </record>

        <!-- CRM Leads Task Stages -->

        <record id="crm_leads_stage_new" model="project.task.type">
            <field name="name">New</field>
            <field name="sequence">1</field>
            <field name="project_ids" eval="[(4, ref('project_crm_leads'))]"/>
        </record>

        <record id="crm_leads_stage_in_progress" model="project.task.type">
            <field name="name">In Progress</field>
            <field name="sequence">2</field>
            <field name="project_ids" eval="[(4, ref('project_crm_leads'))]"/>
        </record>

        <record id="crm_leads_stage_done" model="project.task.type">
            <field name="name">Done</field>
            <field name="sequence">3</field>
            <field name="fold" eval="True"/>
            <field name="project_ids" eval="[(4, ref('project_crm_leads'))]"/>
        </record>

    </data>
</odoo>
