<?xml version="1.0" encoding="UTF-8" ?>
<template xml:space="preserve">
    <!-- Create sticky note template from systray-->
    <t t-name="StickyNotesAdd" owl="1">
        <t t-if="!props.mode">
            <div class="add_note">
                <i class="ri-add-circle-line"/>
                <h6>Add New Note...</h6>
            </div>
        </t>
        <t t-else="">
             <div class="o_button_close" >
                 <i class="fa fa-undo fa-lg"/>
             </div>
         </t>
    </t>
</template>