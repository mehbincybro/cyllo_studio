<?xml version="1.0" encoding="UTF-8" ?>
<template xml:space="preserve">
    <!-- Create sticky note template from systray-->
    <t t-name="StickyNotes" owl="1">
         <body class="menu" t-ref="menuRef">
             <div class="header cy-note-header d-flex m-2 justify-content-between">
                 <h1 class="m-0">Notes</h1>
                 <button type="button" id="close_to_do_sidebar" class="bg-transparent border-0" t-on-click="_close_note">
                     <i class="ri-close-line"/>
                 </button>
             </div>
             <hr class="o_sticky_line"/>
             <div class="content cyllo-notes-content" style="height: 90vh; padding: 10px; overflow: auto;">
                 <StickyNoteAdd mode="this.state.isEdit" t-on-click="() => this.state.isEdit = !this.state.isEdit"/>
                 <br/>
                 <StickyNoteCreate t-if="this.state.isEdit" t-props="this.state.edit_note"/>
                 <StickyNoteUpdate t-if="this.state.isEdit"/>
                 <t t-foreach="this.state.notes" t-as="notes" t-key="notes.id">
                     <StickyNoteItem id="notes.id" title="notes.title" description="notes.description"
                                     create_date="notes.create_date" colour="notes.colour"/>
                 </t>
             </div>
         </body>
    </t>
</template>