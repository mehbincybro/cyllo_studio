<?xml version="1.0" encoding="UTF-8" ?>
<template xml:space="preserve">
    <!-- Create sticky note template from systray-->
    <t t-name="StickyNotesCreate" owl="1">
         <div class="o_create_note" id="note_create">
             <div class="note-title">
                 <input type="text" id="note_title" class="form-control note-title-input border-0"
                        t-ref="noteTitle" placeholder="Title" t-on-keydown="onKeydown"
                        aria-describedby="to-do-button"/>
             </div>
             <div class="note-description mt-3">
                 <input type="textarea" id="note_description" class="form-control note-title-input border-0"
                        rows="4" t-ref="noteDescription" placeholder="Type in your note here..."
                        t-on-keydown="onKeydown" aria-describedby="to-do-button"/>
             </div>
             <div class="d-flex p-3 text-white color_pallets" t-ref="colorRef">
                 <div class="p-2 o_pallet_block" role="button" style="background-color: #ffe66e;"
                      t-on-click="(ev) => this.click_pallet(ev)"/>
                 <div class="p-2 o_pallet_block" role="button" style="background-color: #a1ef9b;"
                      t-on-click="(ev) => this.click_pallet(ev)"/>
                 <div class="p-2 o_pallet_block" role="button" style="background-color: #ffafdf;"
                      t-on-click="(ev) => this.click_pallet(ev)"/>
                 <div class="p-2 o_pallet_block" role="button" style="background-color: #d7afff;"
                      t-on-click="(ev) => this.click_pallet(ev)"/>
                 <div class="p-2 o_pallet_block" role="button" style="background-color: #9edfff;"
                      t-on-click="(ev) => this.click_pallet(ev)"/>
                 <div class="p-2 o_pallet_block" role="button" style="background-color: #e0e0e0;"
                      t-on-click="(ev) => this.click_pallet(ev)"/>
                 <div class="p-2 o_pallet_block" role="button" style="background-color: #767676;"
                      t-on-click="(ev) => this.click_pallet(ev)"/>
             </div>
             <div class="note-save-update mt-3 d-flex">
                 <t t-if="!props.id">
                     <button class="btn btn-secondary btn-save" t-on-click="_note_cancel" type="button">
                         Cancel</button>
                 </t>
                 <button class="btn btn-primary btn-save" type="button" data-update="0" t-on-click="_note_save">
                     Save</button>
             </div>
         </div>
     </t>
</template>