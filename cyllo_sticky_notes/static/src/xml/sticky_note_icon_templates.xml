<?xml version="1.0" encoding="UTF-8" ?>
<template xml:space="preserve">
    <!-- Create sticky note template from systray -->
    <t t-name="StickyNotesSystray" owl="1">
        <div class="o_sticky_icon">
             <div class="toggle-icon o_icon" t-on-click="sticky_note">
                 <i id="create_sticky" class="ri-edit-line cy-icons" aria-label="Sticky Notes"/>
             </div>
        </div>
        <StickyNotes t-if="this.state.isOpen"/>
    </t>
</template>