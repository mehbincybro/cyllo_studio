<?xml version="1.0" encoding="UTF-8" ?>
<templates id="tab_templates" xml:space="preserve">
    <!-- Marketing Tabs Template -->
    <t t-name="MarketingTabs" owl="1">
        <!-- Marketing Tabs Component -->
        <div class="row mx-0 my-4">
            <div class="main-contents col o_notebook cy-marketing-auto_tab-view p-0"
                 t-ref="tabContent">
                <ul class="nav nav-tabs px-2 mt-2" role="tablist">
                    <t t-foreach="props.activities" t-as="activity"
                       t-key="activity.id">
                        <li class="nav-item cy-nav-item-style-width" role="presentation"
                            t-on-click="() => this.onClickTab(activity)" t-att-title="activity.name">
                             <a class="nav-link nav-link cy-marketing-auto-tab"
                                t-attf-class="{{activity_index === 0 and 'active'}}"
                                data-bs-toggle="tab"
                                t-attf-href="#tab-{{activity.id}}" role="tab"
                                t-out="activity.name"/>
                        </li>
                    </t>
                </ul>
                <div class="tab-content cy-marketing-tab_container px-3">
                    <div class="tree">
                        <ul class="cy-marketing-auto_list">
                            <li class="cy-marketing-auto_list-item">
                            <t t-foreach="sortedValues" t-as="activity"
                               t-key="activity.id">
                                <div class="cy-mainChild_div">
                                    <!-- Include MarketingChild component -->
                                    <MarketingChild activity="activity" edit="props.edit"
                                                    activity_index="activity_index"
                                                    handleActivity.bind="handleActivity"
                                                    onDelete.bind="handleDelete"/>
                                </div>
                            </t>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </t>
</templates>