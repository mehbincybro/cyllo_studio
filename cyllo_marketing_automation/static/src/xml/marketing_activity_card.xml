<?xml version="1.0" encoding="UTF-8" ?>
<templates id="cards_template" xml:space="preserve">
    <!-- Marketing Cards Template -->
    <t t-name="MarketingCards" owl="1">
        <!-- Marketing Card Component -->
        <div class="cy-card_box col-md-4">
                <div class="cy-card_top-section cyllo_statics_automation_card">
                    <div class="cy-cardbox-icon cy-cardbox-space"
                         t-att-class="props.type === 'Total' ? 'cy-marketing-tile_total':(props.type === 'Running' ? 'cy-marketing-tile_running' : 'cy-marketing-tile_completed')">
                        <img t-if="props.type == 'Total'" class="total"
                             src="/cyllo_marketing_automation/static/src/icons/total.svg"/>
                        <img t-if="props.type == 'Running'" class="running"
                             src="/cyllo_marketing_automation/static/src/icons/running.svg"/>
                        <img t-if="props.type == 'Completed'" class="completed"
                             src="/cyllo_marketing_automation/static/src/icons/completed.svg"/>
                    </div>
                    <div class="cy-card_detail">
                        <span class="cy-cardbox--state"><t t-out="props.type"/></span>
                        <span class="cy-cardbox-state_count"><t t-out="props.value"/></span>
                    </div>
                </div>
            <div class="cy-card_desc">
                    <span class="cy-card_desc-icon">
                        <t t-out="props.type"/>
                        Participants</span>
                </div>
            </div>
    </t>
</templates>