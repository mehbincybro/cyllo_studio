<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Record for Tree View of Marketing Campaign Model -->
    <record id="view_ir_model_tree" model="ir.ui.view">
        <field name="name">view.ir.model.tree</field>
        <field name="model">ir.model</field>
        <field name="priority">0</field>
        <field name="arch" type="xml">
            <tree string="Model Description">
                <field name="name"/>
            </tree>
        </field>
    </record>
</odoo>