<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Record for defining a tree view named 'marketing.filter.tree' for the model 'marketing.filter' -->
    <record id="view_marketing_filter_tree" model="ir.ui.view">
        <field name="name">view.marketing.filter.tree</field>
        <field name="model">marketing.filter</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="model_id"/>
                <field name="user_id"/>
            </tree>
        </field>
    </record>
    <!-- Record for defining a form view named 'marketing.filter.form' for the model 'marketing.filter' -->
    <record id="view_marketing_filter_form" model="ir.ui.view">
        <field name="name">view.marketing.filter.form</field>
        <field name="model">marketing.filter</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="model_id" required="True" options="{'no_quick_create':True,'no_create_edit':True,'no_open': True}"/>
                            <field name="model_name" />
                        </group>
                        <group>
                            <field name="user_id" options="{'no_quick_create':True,'no_create_edit':True,'no_open': True}"/>
                        </group>
                        <div class="domain-filter cy-marketing-auto-domain-filter d-flex gap-3" invisible="not model_id">
                            <div>
                                <label for="domain" string="Domain" style="color:black ;"/>
                            </div>
                            <field name="domain" string="Domain" widget="domain" options="{'model': 'model_name'}"/>
                        </div>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>
    <!-- Record for defining an action window named 'action_view_favourites' for the model 'marketing.filter' -->
    <record id="action_view_favourites" model="ir.actions.act_window">
        <field name="name">Filter</field>
        <field name="res_model">marketing.filter</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>