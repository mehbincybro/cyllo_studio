<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <!-- Record for Form View Inheriting from mass_mailing.mailing_trace_view_form -->
    <record id="view_mailing_trace_view_form" model="ir.ui.view">
        <field name="name">view.mailing.trace.form.cyllo.marketing.automation</field>
        <field name="model">mailing.trace</field>
        <field name="inherit_id" ref="mass_mailing.mailing_trace_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='source_id']" position="after">
                <field name="marketing_activity_line_id"/>
            </xpath>
        </field>
    </record>
</odoo>
