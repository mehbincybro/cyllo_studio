<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Record for defining a tree view named 'marketing.activity.line.tree' for the model 'marketing.activity.line' -->
    <record id="view_marketing_activity_line_tree" model="ir.ui.view">
        <field name="name">view.marketing.activity.line.tree</field>
        <field name="model">marketing.activity.line</field>
        <field name="arch" type="xml">
            <tree>
                <field name="activity_id"/>
                <field name="participant_id"/>
                <field name="state"/>
                <field name="record_id" invisible="1"/>
                <field name="mail_failure_message"/>
                <field name="mail_opened" invisible="1"/>
                <field name="mail_clicked" invisible="1"/>
                <field name="mail_replied" invisible="1"/>
                <field name="mail_bounced" invisible="1"/>
            </tree>
        </field>
    </record>
</odoo>