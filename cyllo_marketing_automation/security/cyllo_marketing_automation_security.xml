<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="rule_marketing_campaign" model="ir.rule">
        <field name="name">Marketing Campaign multi company</field>
        <field name="model_id" ref="model_marketing_campaign"/>
        <field name="domain_force">[('company_id', 'in', company_ids +
            [False])]
        </field>
    </record>
    <record id="rule_marketing_filter" model="ir.rule">
        <field name="name">Marketing Filter multi company</field>
        <field name="model_id" ref="model_marketing_filter"/>
        <field name="domain_force">[('company_id', 'in', company_ids +
            [False])]
        </field>
    </record>
</odoo>