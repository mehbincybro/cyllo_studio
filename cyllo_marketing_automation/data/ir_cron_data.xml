<?xml version="1.0" encoding="utf-8"?>
<odoo>
<!--    This cron job is responsible for run each activity.-->
    <record id="ir_cron_marketing_automation_run_activity" model="ir.cron">
        <field name="name">Marketing Automation: Run Activity</field>
        <field name="interval_number">1</field>
        <field name="interval_type">hours</field>
        <field name="numbercall">-1</field>
        <field name="user_id" ref="base.user_root"/>
        <field name="doall" eval="False"/>
        <field name="model_id" ref="model_marketing_campaign"/>
        <field name="code">model.run_marketing_activities()</field>
        <field name="state">code</field>
    </record>
</odoo>
