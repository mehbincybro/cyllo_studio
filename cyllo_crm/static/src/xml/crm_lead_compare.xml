<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="cyllo_crm.dropdown_Widget" owl="1">
        <select class="form-select" t-on-change="(ev) => selectValue(ev.target.value)">
            <option value="values[0]"><t t-esc="values[0]"/></option>
            <t t-foreach="values" t-as="value" t-key="value">
                <option
                    t-att-value="value"
                    t-att-selected="state.selectedValue === value">
                    <t t-esc="value"/>
                </option>
            </t>
        </select>
    </t>
</templates>