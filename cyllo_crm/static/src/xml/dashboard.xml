                    <!--                            <span class="legend-color meetings-color"/>-->
                    <!--                            <span class="legend-text">Meetings</span>-->
                    <!--                        </div>-->
                    <!--                    </div>-->
                </div>

                <!-- Top Performers -->
                <div class="performers-card">
                    <div class="chart-header">
                        <h3 class="chart-title">Top Performers</h3>
                        <div class="chart-subtitle"
                             t-if="state.filters.salesTeam">
                            <span t-esc="'Team: ' + getSalesTeamName()"/>
                        </div>
                    </div>
                    <div class="performers-list">
                        <t t-foreach="state.topPerformers" t-as="performer"
                           t-key="performer_index">
                            <div class="performer-item">
                                <div class="performer-info">
                                    <div class="performer-avatar"
                                         t-esc="performer.initials"/>
                                    <div class="performer-details">
                                        <p class="performer-name"
                                           t-esc="performer.name"/>
                                        <p class="performer-deals"
                                           t-esc="performer.deals + ' deals'"/>
                                    </div>
                                </div>
                                <div class="performer-amount"
                                     t-esc="performer.formatted_amount"/>
                            </div>
                        </t>
                    </div>
                </div>
            </div>

            <!-- Lead Notifications and Activities Status Section - Side by Side -->
            <div class="notifications-activities-grid">
                <!-- Lead Notifications Section -->
                <div class="notifications-section">
                    <div class="notifications-header">
                        <div class="notifications-title-group">
                            <span class="notifications-title">
                                <i class="fa fa-bell"/>
                                Updates
                            </span>
                            <span class="notifications-count"
                                  t-if="state.unreadVisibleCount and state.leadNotifications.length">
                                <t t-esc="state.unreadVisibleCount"/>
                            </span>
                        </div>
                        <!--                        <div class="notifications-actions">-->
                        <!--                            &lt;!&ndash; Refresh Button &ndash;&gt;-->
                        <!--                            <button class="btn btn-refresh" t-on-click="onRefreshNotifications">-->
                        <!--                                <i class="fa fa-sync-alt me-1"/>-->
                        <!--                                <span>Refresh</span>-->
                        <!--                            </button>-->
                        <!--                        </div>-->
                    </div>

                    <div class="notifications-content">
                        <!-- No notifications message -->
                        <div class="no-notifications"
                             t-if="!state.leadNotifications or !state.leadNotifications.length">
                            <div class="no-notifications-content">
                                <i class="fa fa-bell-slash no-notifications-icon"/>
                                <h4 class="no-notifications-title">No New
                                    Notifications
                                </h4>
                                <p class="no-notifications-text">You're all
                                    caught up! Check back later for new lead
                                    updates.
                                </p>
                            </div>
                        </div>
                        <!-- Notifications List -->
                        <div class="notifications-list"
                             t-if="state.leadNotifications and state.leadNotifications.length">
                            <t t-set="displayNotifications"
                               t-value="state.showAllNotifications ? state.leadNotifications : state.leadNotifications.slice(0, 6)"/>
                            <t t-foreach="displayNotifications"
                               t-as="notification" t-key="notification.id">
                                <div class="notification-item"
                                     t-att-class="getNotificationClass(notification)"
                                     t-on-click="onNotificationClick"
                                     t-att-data-id="notification.id">

                                    <!-- Notification Content -->
                                    <div class="notification-content">
                                         <div class="notification-header">
                                            <div class="notification-meta">
                                            </div>
                                        </div>

                                        <div class="notification-body">
                                            <p class="notification-message"
                                               t-esc="notification.message"/>
                                        </div>
                                    </div>

                                    <!-- Notification Actions -->
                                    <div class="notification-actions">
                                        <!-- View Lead Button -->
                                        <button class="btn btn-view-lead"
                                                t-on-click.stop="onViewLead"
                                                t-att-data-lead-id="notification.lead_id"
                                                t-if="notification.lead_id">
                                            View Lead
                                        </button>

                                        <!-- Dismiss Button -->
                                        <button class="btn btn-dismiss"
                                                t-on-click.stop="onDismissNotification"
                                                t-att-data-id="notification.id">
                                            Dismiss
                                        </button>
                                    </div>
                                </div>
                            </t>

                            <!-- Show More/Less Button -->
                            <div class="notifications-toggle-section"
                                 t-if="state.leadNotifications.length > 6">
                                <button class="btn btn-primary btn-sm"
                                        t-on-click="onToggleNotifications">
                                    <i t-att-class="state.showAllNotifications ? 'fa fa-chevron-up' : 'fa fa-chevron-down'"/>
                                    <span t-if="state.showAllNotifications">Show
                                        Less
                                    </span>
                                    <span t-else="">
                                        Show
                                        <t t-esc="state.leadNotifications.length - 6"/>
                                        More Notifications
                                    </span>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

