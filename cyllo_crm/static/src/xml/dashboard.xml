<?xml version="1.0" encoding="UTF-8" ?>
<templates>
    <t t-name="crm_dashboard.crm_dashboard_template">
        <div class="o_crm_dashboard">
            <!-- Header Section -->
            <div class="dashboard-header">
                <div class="header-content">
                    <h1 class="dashboard-title">Start Selling</h1>
                    <p class="dashboard-subtitle">Welcome back! Here's what's
                        happening with your sales today.
                    </p>
                </div>
                <div class="dashboard-filters-section">

                <div class="filters-header" t-att-style="state.showFilters ? 'border-radius: 12px 12px 0 0'  : 'border-radius: 12px'">
                    <h3 class="filters-title">
                        <i class="ri-filter-line"/>
                        Filters
                    </h3>
                    <div class="filters-actions">
                        <button class="btn btn-primary btn-sm d-flex justify-content-center align-items-center cy-filter-toggle-btn"
                                t-on-click="onToggleFilters">
                            <i t-att-class="state.showFilters ? 'ri-arrow-up-s-line' : 'ri-arrow-down-s-line'"/>
                            <span t-if="state.showFilters">Hide Filters</span>
                            <span t-else="">Show Filters</span>
                        </button>
                        <button class="btn btn-secondary btn-sm"
                                t-on-click="onResetFilters">
                            <i class="ri-refresh-line"/>
                            Reset
                        </button>
                    </div>
                </div>

                <div class="filters-content" t-if="state.showFilters">
                    <!-- Main filter row - all filters in one row -->
                    <div class="filter-row">
                        <!-- Date Range Filter -->
                        <div class="filter-item">
                            <label class="filter-label">
                                <i class="fa fa-calendar"/>
                                Date Range
                            </label>
                            <div class="filter-control">
                                <select class="form-select"
                                        t-model="state.filters.dateRange"
                                        t-on-change="onDateRangeChange">
                                    <option value="today">Today</option>
                                    <option value="this_week">This Week</option>
                                    <option value="this_month"
                                            selected="selected">This Month
                                    </option>
                                    <option value="this_quarter">This Quarter
                                    </option>
                                    <option value="this_year">This Year</option>
                                    <!--                                    <option value="last_month">Last Month</option>-->
                                    <!--                                    <option value="last_quarter">Last Quarter</option>-->
                                    <!--                                    <option value="last_year">Last Year</option>-->
                                    <option value="custom">Custom Range</option>
                                </select>
                            </div>
                        </div>

                        <!-- Sales Team Filter -->
                        <div class="filter-item">
                            <label class="filter-label">
                                <i class="fa fa-users"/>
                                Sales Team
                            </label>
                            <div class="filter-control">
                                <select class="form-select"
                                        t-model="state.filters.salesTeam"
                                        t-on-change="onSalesTeamChange">
                                    <option value="">All Teams</option>
                                    <t t-if="state.salesTeams">
                                        <t t-foreach="state.salesTeams"
                                           t-as="team" t-key="team.id">
                                            <option t-att-value="team.id"
                                                    t-esc="team.name"/>
                                        </t>
                                    </t>
                                </select>
                            </div>
                        </div>

                        <!-- Salesperson Filter -->
                        <div class="filter-item">
                            <label class="filter-label">
                                <i class="fa fa-user"/>
                                Salesperson
                            </label>
                            <div class="filter-control">
                                <select class="form-select"
                                        t-model="state.filters.salesperson"
                                        t-on-change="onSalespersonChange">
                                    <option value="">All Salespersons</option>
                                    <t t-if="state.salespersons">
                                        <t t-foreach="state.salespersons"
                                           t-as="person" t-key="person.id">
                                            <option t-att-value="person.id"
                                                    t-esc="person.name"/>
                                        </t>
                                    </t>
                                </select>
                            </div>
                        </div>
                    </div>

                    <!-- Custom Date Range (appears when custom is selected) -->
                    <div class="custom-date-section"
                         t-if="state.filters.dateRange === 'custom'">
                        <div class="date-inputs">
                            <div class="date-input-group">
                                <label class="date-label">From Date</label>
                                <input type="date" class=" date-input"
                                       t-model="state.filters.dateFrom"
                                       t-att-max="state.filters.dateTo"
                                       t-on-change="onCustomDateChange"/>
                            </div>
                            <div class="date-separator">
                                <i class="fa fa-arrow-right"/>
                            </div>
                            <div class="date-input-group">
                                <label class="date-label">To Date</label>
                                <input type="date" class="date-input"
                                       t-model="state.filters.dateTo"
                                       t-att-min="state.filters.dateFrom"
                                       t-on-change="onCustomDateChange"/>
                            </div>
                        </div>
                    </div>

                    <!-- Active Filters Display -->
                    <div class="active-filters-section"
                         t-if="hasActiveFilters()">
                        <div class="active-filters-header">
                            <span class="active-filters-label">
                                <i class="fa fa-tag"/>
                                Active Filters
                            </span>
                        </div>
                        <div class="filter-tags">
                            <span class="filter-tag"
                                  t-if="state.filters.dateRange !== 'this_month'">
                                <span class="tag-content"
                                      t-esc="getDateRangeLabel()"/>
                                <i class="fa fa-times tag-remove"
                                   t-on-click="clearDateFilter"/>
                            </span>
                            <span class="filter-tag"
                                  t-if="state.filters.salesTeam">
                                <span class="tag-content"
                                      t-esc="'Team: ' + getSalesTeamName()"/>
                                <i class="fa fa-times tag-remove"
                                   t-on-click="clearSalesTeamFilter"/>
                            </span>
                            <span class="filter-tag"
                                  t-if="state.filters.salesperson">
                                <span class="tag-content"
                                      t-esc="'Person: ' + getSalespersonName()"/>
                                <i class="fa fa-times tag-remove"
                                   t-on-click="clearSalespersonFilter"/>
                            </span>
                            <span class="filter-tag" t-if="state.filters.stage">
                                <span class="tag-content"
                                      t-esc="'Stage: ' + getStageName()"/>
                                <i class="fa fa-times tag-remove"
                                   t-on-click="clearStageFilter"/>
                            </span>
                        </div>
                    </div>
                </div>
            </div>
            </div>


            <!-- Key Metrics Cards -->
            <div class="metrics-grid">
                <t t-foreach="state.metrics" t-as="metric" t-key="metric_index">
                    <div class="metric-card"
                         t-att-class="'metric-card-' + metric.type">
                        <div class="metric-content">
                            <div class="metric-info">
                                <p class="metric-label" t-esc="metric.label"/>
                                <p class="metric-value"
                                   t-esc="metric.formatted_value"/>
                                <p class="metric-change"
                                   t-att-class="metric.change >= 0 ? 'positive-change' : 'negative-change'">
                                    <t t-if="metric.change >= 0">+</t>
                                    <t t-esc="metric.change"/>% from last period
                                </p>
                            </div>
                            <div class="metric-icon"
                                 t-att-class="metric.type + '-icon'">
                                <i t-att-class="metric.icon"/>
                            </div>
                        </div>
                    </div>
                </t>
            </div>

            <!-- Charts Section -->
            <div class="charts-grid" t-ref="crmDashboardChartGrids">
                <!-- Revenue Chart -->
                <div class="chart-card">
                    <div class="chart-header">
                        <h3 class="chart-title">Revenue &amp; Leads Trend</h3>
                        <div class="chart-actions">
                            <button class="btn btn-sm btn-secondary"
                                    t-on-click="()=>this.exportData('lead')"
                                    data-chart="revenue">
                                <i class="fa fa-download"/>
                            </button>
                        </div>
                    </div>
                    <div class="chart-container">
                        <canvas t-ref="revenueChart"/>
                    </div>
                </div>

                <!-- Pipeline Chart -->
                <div class="chart-card">
                    <div class="chart-header">
                        <h3 class="chart-title">Sales Pipeline</h3>
                        <div class="chart-actions">
                            <button class="btn btn-sm btn-secondary"
                                    t-on-click="()=>this.exportData('sale')"
                                    data-chart="pipeline">
                                <i class="fa fa-download"/>
                            </button>
                        </div>
                    </div>
                    <div id="salesChartWrapper">
                        <div class="chart-container">
                            <canvas t-ref="pipelineChart"/>
                        </div>
                        <div class="chart-legend">
                            <t t-foreach="state.pipeline" t-as="stage"
                               t-key="stage_index">
                                <div class="legend-item">
                                    <span class="legend-color"
                                          t-att-style="'background-color: ' + stage.color"/>
                                    <span class="legend-text"
                                          t-esc="stage.stage + ': ' + stage.value + '%'"/>
                                </div>
                            </t>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Activities and Performance Section -->
            <div class="performance-grid">
                <!-- Weekly Activities -->
                <div class="activities-card">
                    <div class="chart-header">
                        <h3 class="chart-title">Activities Overview</h3>
                    </div>
                    <div class="chart-container">
                        <canvas t-ref="activitiesChart"/>
                    </div>
                    <!--                    <div class="activities-legend">-->
