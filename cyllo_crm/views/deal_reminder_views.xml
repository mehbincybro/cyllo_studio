<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_crm_config_settings_inherit" model="ir.ui.view">
        <field name="name">crm.config.settings.inherit</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="crm.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//setting[@id='website_crm_iap_reveal_settings']" position="after">
                <setting id="review_id" help="Enable Review process to avoid Junk Leads">
                    <field name="module_cyllo_crm_review"/>
                </setting>
                <setting id="deal_reminder_settings" help='Select the number of days for deal reminder'>
                    <field name="is_deal_remainder" />
                    <div class="content-group" invisible="not  is_deal_remainder ">
                        <div class="mt8" >
                            <label for="deal_remainder_days" class="o_light_label"/>
                            <field name="deal_remainder_days"/>
                        </div>
                    </div>
                </setting>
            </xpath>
        </field>
    </record>
</odoo>
