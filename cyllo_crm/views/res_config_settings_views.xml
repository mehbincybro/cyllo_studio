<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_res_config_settings_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form</field>
        <field name="model">res.config.settings</field>
        <field name="priority" eval="5"/>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@name='generate_lead_setting_container']"
                   position="after">
                <block title="Advanced CRM" id="advanced_crm_features">
                    <setting id="advance_lead_crm_view"
                             help="Advance lead creation from Website">
                        <field name="module_cyllo_crm_advance_lead"/>
                    </setting>
                    <setting id="advance_followup_crm_view"
                             help="Mandatory Followups for activities in leads/Opportunity ">
                        <div class="content-group">
                            <span>Add exit criteria's
                                for each stage, which should
                                happen, to move to the next stage.
                            </span>
                            <br/>
                            <br/>
                            <button string="Configure Exit Criteria"
                                    name="action_configure_exit_criteria"
                                    type="object"
                                    class="btn-primary"/>
                        </div>
                    </setting>
                    <setting id="deal_reminder"
                             help="Enable automatic reminders for stale deals. When enabled, the system will check for leads that haven't been updated within the selected number of days and notify the assigned user via email.">
                        <field name="deal_reminder"/>
                        <div class="content-group"
                             invisible="not deal_reminder">
                            <div class="mt16">
                                <label for="deal_reminder"/>
                                <field name="deal_reminder_days"/>
                            </div>
                        </div>
                    </setting>
                    <setting id="module_cyllo_crm_project_setting"
                             help="Enable creating a project from a won CRM lead.">
                        <field name="module_cyllo_crm_project"/>
                        <div class="content-group"
                             invisible="not module_cyllo_crm_project">
                            <span>
                                When enabled, users can create a project
                                directly
                                from a won CRM lead.
                            </span>
                        </div>
                    </setting>
                    <setting
                            id="module_cyllo_visiting_card_digitization_setting"
                            help="Enable digitization of visiting cards to automatically extract contact details and create CRM leads.">
                        <field name="module_cyllo_visiting_card_digitization"/>
                        <div class="content-group"
                             invisible="not module_cyllo_visiting_card_digitization">
                            <span>
                                When enabled, users can upload visiting cards
                                directly from the Kanban view
                                and automatically create a CRM lead.
                            </span>
                        </div>
                    </setting>
                    <setting
                            id="module_crm_survey_setting"
                            help="Enable CRM Survey to create, manage, and analyze customer surveys directly within the CRM.">
                        <field name="module_crm_survey"/>
                        <div class="content-group"
                             invisible="not module_crm_survey">
                            <span>
                                When enabled, users can create and manage
                                customer surveys,
                                link survey responses to CRM leads and
                                opportunities,
                                and gain insights to improve customer
                                engagement.
                            </span>
                        </div>
                    </setting>
                    <setting
                            id="module_crm_google_form_setting"
                            help="Enable CRM Google Forms to create, manage, and link Google Forms directly from CRM leads.">
                        <field name="module_cyllo_crm_google_form"/>
                        <div class="content-group"
                             invisible="not module_cyllo_crm_google_form">
                            <span>
                                When enabled, users can create Google Forms
                                directly from CRM leads,
                                store form IDs and URLs in the lead, and
                                optionally automate lead creation
                                from form responses.
                            </span>
                        </div>
                    </setting>
                </block>

            </xpath>
        </field>
    </record>

</odoo>
