<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_crm_stage_exit_criteria_form" model="ir.ui.view">
        <field name="name">crm.stage.exit.criteria.form</field>
        <field name="model">crm.stage.exit.criteria</field>
        <field name="arch" type="xml">
            <form string="Configure Stage Exit Criteria">
                <sheet>
                    <div class="alert alert-info" role="alert">
                        Note: Each stage can only have one exit criteria.
                    </div>
                    <group>
                        <field name="stage_ids" widget="many2many_tags" invisible="1"/>
                    </group>
                    <field name="exit_criteria_ids">
                        <tree editable="bottom">
                            <field name="stage_id" domain="[('id', 'in', parent.stage_ids),('is_won','=',False)]"/>
                            <field name="activity_id"/>
                            <field name="user_id"/>
                        </tree>
                    </field>
                    <footer>
                        <button string="Save" name="action_save" type="object" class="btn-primary"/>
                        <button string="Cancel" special="cancel" class="btn-secondary"/>
                    </footer>
                </sheet>
            </form>
        </field>
    </record>
</odoo>