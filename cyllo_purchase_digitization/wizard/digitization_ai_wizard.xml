<?xml version="1.0" encoding="utf-8"?>
<odoo>
<record id="view_digitization_ai_wizard_form" model="ir.ui.view">
    <field name="name">digitization.ai.wizard.form</field>
    <field name="model">digitization.ai.wizard</field>
    <field name="arch" type="xml">
        <form string="AI Digitization">
            <div class="o_form_label">Manual OCR digitization failed.Do you want to switch to AI Digitization?</div>
            <footer>
                <button string="Switch to AI" type="object" name="action_switch_to_ai" class="btn-primary"/>
                <button string="Cancel" class="btn-secondary" special="cancel"/>
            </footer>
        </form>
    </field>
</record>
</odoo>