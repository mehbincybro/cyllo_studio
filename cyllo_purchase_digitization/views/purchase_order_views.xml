<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_purchase_order_form" model="ir.ui.view">
        <field name="name">view.purchase.order.form</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position='after'>
                <field name="ocr_digitize_completed" invisible="1"/>
                <div role="status"
                     class="alert alert-success mb8 text-center"
                     invisible="ocr_digitize_completed != True or state not in ['draft', 'cancel']">
                    Digitization Successfully completed
                    <button type="object"
                            name="action_retry_digitization"
                            class="btn btn-link">
                        Retry
                    </button>
                </div>
                <field name="ocr_digitize_failed" invisible="1"/>
                <div role="status"
                     class="alert alert-danger mb8 text-center"
                     invisible="ocr_digitize_failed != True or state not in ['draft', 'sent']">
                    <field name="ocr_digitize_message"/>
                    <button type="object"
                            name="action_retry_digitization"
                            class="btn btn-link">
                        Retry
                    </button>
                </div>
            </xpath>
            <xpath expr="//button[@name='button_cancel']"
                   position="after">
                <field name="ocr_digitize_enabled" invisible="1"/>
                <button name="action_send_digitization"
                        type="object"
                        string="Send To Digitization"
                        title="Digitization"
                        invisible="ocr_digitize_enabled != True or state not in ['draft','sent'] or ocr_digitize_completed != False"/>
            </xpath>
            <xpath expr="//div[hasclass('oe_chatter')]" position="before">
                <div class="o_attachment_preview"/>
            </xpath>
        </field>
    </record>
    <record id="view_purchase_order_tree" model="ir.ui.view">
        <field name="name">view.purchase.order.tree</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_kpis_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//tree" position="attributes">
                <attribute name="js_class">button_in_tree</attribute>
            </xpath>
        </field>
    </record>
</odoo>