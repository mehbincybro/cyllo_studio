<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_account_pdc_bounce_reason_form" model="ir.ui.view">
        <field name="name">view.account.pdc.bounce.reason.form</field>
        <field name="model">account.pdc.bounce.reason</field>
        <field name="arch" type="xml">
            <form string="Register PDC Payment">
                <group>
                    <field name="reason"/>
                    <field name="bank_name" invisible="1"/>
                    <field name="cheque_reference" invisible="1"/>
                </group>
                <footer>
                    <button string="Confirm" name="action_bounce" type="object" class="oe_highlight" data-hotkey="q"/>
                    <button string="Discard" class="btn btn-secondary" special="cancel" data-hotkey="x"/>
                </footer>
            </form>
        </field>
    </record>
    <record id="action_view_pdc_bounce_reason" model="ir.actions.act_window">
        <field name="name">PDC Bounce Reason</field>
        <field name="res_model">account.pdc.bounce.reason</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>