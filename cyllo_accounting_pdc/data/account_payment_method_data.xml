<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <!--default PDC inbound and outbound methods -->
    <record id="account_payment_method_pdc_outbound" model="account.payment.method">
        <field name="name">PDC</field>
        <field name="code">pdc_payment</field>
        <field name="payment_type">outbound</field>
    </record>
    <record id="account_payment_method_pdc_inbound" model="account.payment.method">
        <field name="name">PDC</field>
        <field name="code">pdc_payment</field>
        <field name="payment_type">inbound</field>
    </record>
</odoo>