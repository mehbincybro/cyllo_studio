<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Views -->
    <record id="view_account_pdc_payment_tree" model="ir.ui.view">
        <field name="name">view.account.pdc.payment.tree</field>
        <field name="model">account.pdc.payment</field>
        <field name="arch" type="xml">
            <tree edit="false">
                <field name="suitable_journal_ids" column_invisible="1"/>
                <field name="date"/>
                <field name="bank_name"/>
                <field name="cheque_reference"/>
                <field name="amount"/>
                <field name="company_id" optional="hide" groups="base.group_multi_company"/>
                <field name="partner_id" string="Customer"/>
                <field name="due_date" widget="remaining_days"/>
                <field name="currency_id" string="Payment Currency" optional="hide"/>
                <field name="payment_status" widget="badge" decoration-info="payment_status == 'draft'" decoration-primary="payment_status == 'registered'" decoration-success="payment_status == 'posted'" decoration-muted="payment_status == 'cancelled'" decoration-warning="payment_status == 'bounced'"/>
                <field name="state" column_invisible="1"/>
            </tree>
        </field>
    </record>
    <record id="view_account_pdc_payment_vender_tree" model="ir.ui.view">
        <field name="name">view.account.pdc.payment.vendor.tree</field>
        <field name="model">account.pdc.payment</field>
        <field name="inherit_id" ref="view_account_pdc_payment_tree"/>
        <field name="mode">primary</field>
        <field name="arch" type="xml">
            <field name="partner_id" position="attributes">
                <attribute name="string">Vendor</attribute>
            </field>
        </field>
    </record>
    <record id="view_account_pdc_payment_supplier_tree" model="ir.ui.view">
        <field name="name">view.account.pdc.payment.supplier.tree</field>
        <field name="model">account.pdc.payment</field>
        <field name="inherit_id" ref="view_account_pdc_payment_tree"/>
        <field name="mode">primary</field>
        <field name="arch" type="xml">
            <field name="partner_id" position="attributes">
                <attribute name="string">Partner</attribute>
            </field>
        </field>
    </record>
    <record id="view_account_pdc_payment_kanban" model="ir.ui.view">
        <field name="name">view.account.pdc.payment.kanban</field>
        <field name="model">account.pdc.payment</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile" create="0" group_create="0" sample="1">
                <field name="partner_id"/>
                <field name="date"/>
                <field name="state"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_global_click">
                            <div class="row mb4">
                                <div class="col-6">
                                    <strong><span><field name="name"/></span></strong>
                                </div>
                                <div class="col-6 text-end">
                                    <strong><i class="fa fa-clock-o" role="img" aria-label="Date" title="Date"/> <t t-out="record.date.value"/></strong>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-12">
                                    <span><field name="partner_id"/></span>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-6">
                                    <field name="amount" widget='monetary'/>
                                    <field name="currency_id" invisible="1"/>
                                </div>
                                <div class="col-6">
                                    <span class="float-end">
                                        <field name="state" widget="label_selection" options="{'classes': {'draft': 'secondary', 'sent': 'success'}}"/>
                                    </span>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>
    <record id="view_account_pdc_payment_form" model="ir.ui.view">
        <field name="name">view.account.pdc.payment.form</field>
        <field name="model">account.pdc.payment</field>
        <field name="arch" type="xml">
            <form string="Register PDC Payment">
                <header>
                    <button name="action_draft" string="Set to Draft" type="object" class="oe_highlight"
                            invisible="payment_status != 'cancelled'"/>
                    <button name="action_deposit" string="Deposit" type="object" class="oe_highlight"
                            invisible="payment_status != 'bounced'"/>
                    <button name="action_post" string="Confirm" type="object" class="oe_highlight"
                            invisible="payment_status != 'draft'"/>
                    <button name="%(cyllo_accounting_pdc.action_view_pdc_bounce_reason)d" string="Bounce" type="action" class="oe_highlight"
                            invisible="payment_status != 'registered'"/>
                    <button name="action_done" string="Done" type="object" class="oe_highlight"
                            invisible="payment_status not in ['registered','']"/>
                    <button name="action_cancel" string="Cancel" type="object"
                            invisible="payment_status in ['registered','posted', 'cancelled']"/>
                    <field name="payment_status" widget="statusbar" statusbar_visible="draft,registered,posted"/>
                </header>
                <sheet>
                    <field name="suitable_journal_ids" invisible="1"/>
                    <field name="partner_type" invisible="1"/>
                    <field name="state" invisible="1"/>
                    <field name="company_id" invisible="1"/>
                    <div class="oe_button_box" name="button_box">
                        <!-- Journal Entry  button -->
                        <button name="action_open_journal_entry" type="object" class="oe_stat_button"
                                icon="fa-bars" invisible="pdc_move_count == 0"
                                groups="account.group_account_user,account.group_account_readonly">
                            <field name="pdc_move_count" string="Journal Entries" widget="statinfo"/>
                        </button>
                    </div>
                    <group name="main_group">
                        <group name="group1">
                            <field name="payment_type" widget="radio" options="{'horizontal': True}"
                                   readonly="state != 'draft'"/>
                            <field name="partner_id" context="{'default_is_company': True}" string="Customer"
                                   options="{'no_quick_create': True}"
                                   readonly="state != 'draft'"
                                   invisible="partner_type != 'customer'"/>
                            <field name="partner_id" context="{'default_is_company': True}" string="Vendor"
                                   options="{'no_quick_create': True}"
                                   readonly="state != 'draft'"
                                   invisible="partner_type != 'supplier'"/>
                            <label for="amount"/>
                            <div name="amount_div" class="o_row">
                                <field name="amount" readonly="state != 'draft'"/>
                                <field name="currency_id"
                                       options="{'no_create': True, 'no_open': True}"
                                       required="1"
                                       readonly="state != 'draft'"
                                       groups="base.group_multi_currency"/>
                            </div>
                            <field name="date" readonly="state != 'draft'"/>
                            <field name="ref" string="Memo" readonly="payment_status == 'posted'"/>
                        </group>
                        <group name="group2">
                            <field name="payment_method_line_id"/>
                            <field name="journal_id" readonly="payment_status == 'posted'"/>
                            <field name="due_date" readonly="payment_status == 'posted'"/>
                            <field name="bank_name" readonly="payment_status == 'posted'"/>
                            <field name="cheque_reference" readonly="payment_status == 'posted'"/>
                        </group>
                        <group/>
                    </group>
                </sheet>
                <div class="o_attachment_preview"/>
                <div class="oe_chatter">
                    <field name="message_follower_ids" groups="base.group_user"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>
    <record id="view_account_pdc_payment_search" model="ir.ui.view">
        <field name="name">view.account.pdc.payment.search</field>
        <field name="model">account.pdc.payment</field>
        <field name="arch" type="xml">
            <search string="Payments">
                <field name="partner_id" string="Customer/Vendor"/>
                <field name="journal_id"/>
                <separator/>
                <filter string="Customer PDC Payments" name="inbound_filter"
                        domain="[('partner_type', '=', 'customer')]"/>
                <filter string="Vendor PDC Payments" name="outbound_filter"
                        domain="[('partner_type', '=', 'supplier')]"/>
                <separator/>
                <filter string="Draft" name="state_draft" domain="[('payment_status', '=', 'draft')]"/>
                <filter string="Accepted" name="state_posted" domain="[('payment_status', '=', 'posted')]"/>
                <filter string="Bounced" name="state_posted" domain="[('payment_status', '=', 'bounced')]"/>
                <filter string="Status" name="state" domain="[]" context="{'group_by': 'state'}"/>
            </search>
        </field>
    </record>


    <!-- Actions -->
    <record id="action_view_pdc_payments" model="ir.actions.act_window">
        <field name="name">PDC Payments</field>
        <field name="res_model">account.pdc.payment</field>
        <field name="view_mode">tree,kanban,form,activity</field>
        <field name="view_id" ref="view_account_pdc_payment_tree"/>
    </record>
    <record id="action_view_pdc_payments_receivable" model="ir.actions.act_window">
        <field name="name">Customer PDC Payments</field>
        <field name="res_model">account.pdc.payment</field>
        <field name="view_mode">tree,kanban,form,activity</field>
        <field name="context">{
            'default_payment_type': 'inbound',
            'default_partner_type': 'customer',
            'search_default_inbound_filter': 1,
            'default_move_journal_types': ('bank'),
            }
        </field>
        <field name="view_id" ref="view_account_pdc_payment_tree"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Register a PDC payment</p>
            <p>
                PDC Payments are used to register liquidity movements.
                You can process those payments by your own means or by using installed facilities.
            </p>
        </field>
    </record>
    <record id="action_view_pdc_payments_payable" model="ir.actions.act_window">
        <field name="name">Vendor PDC Payments</field>
        <field name="res_model">account.pdc.payment</field>
        <field name="view_mode">tree,kanban,form,activity</field>
        <field name="context">{
            'default_payment_type': 'outbound',
            'default_partner_type': 'supplier',
            'search_default_outbound_filter': 1,
            'default_move_journal_types': ('bank', 'cash'),
            'display_account_trust': True,
            }</field>
        <field name="view_id" ref="view_account_pdc_payment_vender_tree"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Register a PDC payment</p>
            <p>
                PDC Payments are used to register liquidity movements.
                You can process those payments by your own means or by using installed facilities.
            </p>
        </field>
    </record>

    <!-- Menus -->
    <menuitem id="menu_pdc_payments_payable" name="PDC Payments" sequence="21"
              action="action_view_pdc_payments_payable" parent="account.menu_finance_payables"/>
    <menuitem id="menu_pdc_payments_receivable" name="PDC Payments" sequence="16"
              action="action_view_pdc_payments_receivable" parent="account.menu_finance_receivables"/>
</odoo>
