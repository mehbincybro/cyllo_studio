<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Template for the Open Street Map Snippet -->
    <template id="open_street_map_snippet" name="Open Street Map Snippet">
        <section class="container open_street_map_snippet">
            <div class="d-flex">
                <div>
                    <div class="form-group row mt-3">
                        <label for="place_name">
                            Place Name:
                        </label>
                        <div class="col-sm-2">
                            <input type="text" id="place_name" name="place_name" class="place_name_input" placeholder="Place name"/>
                        </div>
                    </div>
                    <div class="form-group row">
                        <label for="pincode" >
                            Pincode:
                        </label>
                        <div class="col-sm-2">
                            <input type="text" id="pincode" name="pincode" class="pincode_input" placeholder="Pincode"/>
                        </div>
                    </div>
                    <div class="form-group row">
                        <label for="city" >City:</label>
                        <div class="col-sm-2">
                            <input type="text" id="city" name="city" class="city_input" placeholder="City"/>
                        </div>
                    </div>
                    <div class="form-group row">
                        <label for="state" >
                            State:
                        </label>
                        <div class="col-sm-2">
                            <input type="text" id="state" name="state" class="state_input" placeholder="State"/>
                        </div>
                    </div>
                    <div class="form-group row">
                        <label for="country" >
                            Country:
                        </label>
                        <div class="col-sm-2">
                            <input type="text" id="country" name="country" class="country_input" placeholder="Country"/>
                        </div>
                    </div>
                    <div class="form-group row">
                        <label for="latitude" >
                            Latitude:
                        </label>
                        <div class="col-sm-2">
                            <input type="text" id="latitude" name="latitude" class="latitude_input" placeholder="Longitude"/>
                        </div>
                    </div>
                    <div class="form-group row">
                        <label for="longitude" >
                            Longitude:
                        </label>
                        <div class="col-sm-2">
                            <input type="text" id="longitude" name="longitude" class="longitude_input" placeholder="Longitude"/>
                        </div>
                    </div>
                    <div class="form-group row mt-3">
                        <div class="offset-sm-1">
                            <button type="button" class="search_button_s btn btn-primary">
                                Search
                            </button>
                            <button type="button" class="refresh_button_s btn btn-primary" style="margin-left: 3px;">
                                Refresh
                            </button>
                        </div>
                    </div>
                </div>
                <div id="map" class="map" style="height:500px; width:65%; margin-left:2em;"/>
            </div>
        </section>
    </template>
    <!-- Template to add the Open Street Map snippet to external snippets -->
    <template id="external_snippets" inherit_id="website.snippets" priority="8">
        <xpath expr="//div[@id='snippet_effect']//t[@t-snippet][last()]" position="after">
            <t t-snippet="cyllo_map.open_street_map_snippet"/>
        </xpath>
    </template>
</odoo>