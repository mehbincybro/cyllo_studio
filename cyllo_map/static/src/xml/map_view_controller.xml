<?xml version="1.0" encoding="UTF-8"?>
<!--Template of the Controller displays the control panel with Layout-->
<templates xml:space="preserve">
    <t t-name="cyllo_map.MapView">
        <div t-att-class="className" t-ref="root">
            <Layout className="model.useSampleModel ? 'o_view_sample_data' : ''" display="display">
                <t t-set-slot="layout-actions">
                    <SearchBar autofocus="firstLoad"/>
                </t>
                <t t-set-slot="control-panel-navigation-additional">
                    <t t-component="searchBarToggler.component" t-props="searchBarToggler.props"/>
                </t>
                <t t-set-slot="control-panel-additional-actions">
                    <CogMenu/>
                </t>
                <t t-component="props.Renderer" list="model.root" archInfo="props.archInfo"
                   Compiler="props.Compiler" readonly="true" openRecord.bind="openRecord"
                   layoutChanged.bind="layoutChanged" noContentHelp="props.info.noContentHelp"/>
            </Layout>
        </div>
    </t>
</templates>