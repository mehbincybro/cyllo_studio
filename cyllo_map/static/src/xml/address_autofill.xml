<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <!-- Template for the AddressAutofill component -->
    <t t-name="cyllo_map.AddressAutofill" t-inherit="web.CharField" owl="1">
        <xpath expr="//input" position="replace">
            <div style="display: flex;">
                <input class="o_input" t-att-class="{'o_field_translate': isTranslatable}"
                       t-att-id="props.id" t-att-type="props.isPassword ? 'password' : 'text'"
                       t-att-autocomplete="props.autocomplete or (props.isPassword ? 'new-password' : 'off')"
                       t-att-maxlength="maxLength > 0 and maxLength" t-att-placeholder="props.placeholder"
                       t-ref="input"/>
                <a class="ms-3 d-inline-flex align-items-center" t-on-click="() => this.AutoFill()">
                    <i class="fa fa-search fa-fw" data-tooltip="Autofill Address" aria-label="Autofill Address"/>
                </a>
            </div>
        </xpath>
    </t>
</templates>