<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_res_config_settings_inherit_cyllo_advance_lead_form"
            model="ir.ui.view">
        <field name="name">res.config.settings.inherit.cyllo.wishlist</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//setting[@id='website_crm_iap_reveal_settings']"
                   position="after">
                <setting id="wishlist_lead"
                         help="Automatically create leads for products that customers have wishlisted on the website but haven't purchased within a set period.">
                    <field name='create_lead_wishlist'/>
                    <div class="content-group"
                         invisible="not create_lead_wishlist">
                        <div>
                            <label for="wishlist_days" class="me-2"/>
                            <field name="wishlist_days"/>
                        </div>
                    </div>
                </setting>
                <setting id="abandoned_cart_lead"
                         help="Automatically create leads for products that customers have abandoned in the cart but haven't purchased within a set period.">
                    <field name='create_lead_abandoned_cart'/>
                    <div class="content-group"
                         invisible="not create_lead_abandoned_cart">
                        <div>
                            <label for="abandoned_cart_days" class="me-2"/>
                            <field name="abandoned_cart_days"/>
                        </div>
                    </div>
                </setting>
                <setting id="referral_lead"
                         help="Creates a referral lead when a customer refers products after purchase on the website.">
                    <field name='create_lead_referral'/>
                </setting>
            </xpath>
        </field>
    </record>
</odoo>