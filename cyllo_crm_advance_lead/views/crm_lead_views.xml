<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_crm_lead_inherit_cyllo_advance_lead_form"
            model="ir.ui.view">
        <field name="name">crm.lead.form.inherit.advance.lead</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='action_schedule_meeting']"
                   position="after">
                <button name="action_get_automation" type="object"
                        class="oe_stat_button"
                        invisible="not is_installed or count == 0"
                        icon="fa-cogs"
                        string="Automation">
                    <field name="count" string="Automation" widget="statinfo"/>
                </button>
            </xpath>
            <button name="action_schedule_meeting" position="after">
                <button name="action_view_wishlist_products" type="object"
                        class="oe_stat_button"
                        invisible="not wishlist_product_ids"
                        icon="fa-regular fa-heart">
                    <field name="wishlist_product_ids" invisible="1"/>
                    <field name="wishlist_product_count" widget="statinfo"
                           string="Wishlist Products"/>
                </button>
                <button name="action_view_abandoned_sale_quotation"
                        type="object"
                        class="oe_stat_button"
                        invisible="type == 'opportunity' or not order_ids"
                        icon="fa-pencil-square-o">
                    <field name="order_ids" invisible="1"/>
                    <field name="quotation_count" widget="statinfo"
                           string="Quotations"/>
                </button>
                <button name="action_view_referral_products" type="object"
                        class="oe_stat_button"
                        invisible="not referral_product_ids"
                        icon="fa-solid fa-rotate-right">
                    <field name="referral_product_ids" invisible="1"/>
                    <field name="referral_product_count" widget="statinfo"
                           string="Referred Products"/>
                </button>
            </button>
        </field>
    </record>
</odoo>