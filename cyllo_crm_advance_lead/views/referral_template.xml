<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <template id="product_referral_template" name="Product Referral Form">
        <t t-call="website.layout">
            <div class="referral">
                <div class="referral-container">
                    <div class="referral-header">
                        <h2>Refer a Friend</h2>
                    </div>
                    <div class="info-banner">Refer products from your recent
                        order!
                    </div>
                    <form t-attf-action="/referral/submit" method="post">
                        <input type="hidden" name="csrf_token"
                               t-att-value="request.csrf_token()"/>
                        <input type="hidden" name="sale_order"
                               t-att-value="order_id"/>
                        <div class="form-group">
                            <label>Full Name</label>
                            <input
                                    name="friend_name"
                                    type="text"
                                    required="required"
                                    class="form-input"
                                    placeholder="Enter your friend's full name"
                            />
                            <i class="fa fa-user input-icon"/>
                        </div>
                        <div class="form-group">
                            <label>Email Address</label>
                            <input
                                    name="friend_email"
                                    type="email"
                                    required="required"
                                    class="form-input"
                                    placeholder="Enter your friend's email"
                            />
                            <i class="fa fa-envelope input-icon"/>
                        </div>
                        <div class="form-group">
                            <label>Phone Number</label>
                            <input
                                    name="friend_phone"
                                    type="tel"
                                    class="form-input"
                                    placeholder="Enter your friend's phone number (optional)"
                            />
                            <i class="fa fa-phone input-icon"/>
                        </div>
                        <button type="submit" class="referral-btn">
                            <i class="fa fa-paper-plane"/>
                            Send Referral
                        </button>
                    </form>
                </div>
            </div>
        </t>
    </template>
</odoo>