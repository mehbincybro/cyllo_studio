<?xml version="1.0" encoding="UTF-8" ?>
<odoo noupdate="1">
    <record id="ir_cron_process_wishlist_leads" model="ir.cron">
        <field name="name">Process Wishlist Leads</field>
        <field name="model_id" ref="crm.model_crm_lead"/>
        <field name="state">code</field>
        <field name="code">model._create_lead_for_wishlist_products()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="active" eval="True"/>
    </record>
    <record id="ir_cron_process_abandoned_cart_leads" model="ir.cron">
        <field name="name">Process Abandoned Cart Leads</field>
        <field name="model_id" ref="crm.model_crm_lead"/>
        <field name="state">code</field>
        <field name="code">model._create_lead_for_abandoned_cart()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="active" eval="True"/>
    </record>
</odoo>