<?xml version="1.0" encoding="UTF-8" ?>
<template id="template" xml:space="preserve">
<!--Changing branding in pos-->
   <t t-name="cy_pos_logo" t-inherit="point_of_sale.Navbar" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('pos-branding')]" position="replace">
            <div t-if="!ui.isSmall" class="pos-branding d-flex justify-content-start flex-grow-1 h-100 p-0 my-0 text-start">
                    <img class="pos-logo h-75 ms-3 me-auto align-self-center" t-on-click="() => debug.toggleWidget()" src="/cyllo_branding/static/src/img/cyllo-logo.svg" alt="Logo" />
                </div>
        </xpath>
    </t>
</template>
