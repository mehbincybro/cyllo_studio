<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="brand_promotion_message" inherit_id="web.brand_promotion_message" name="Brand Promotion Message">
        <xpath expr="//a[hasclass('badge')]" position="replace">
            <a target="_blank" t-attf-href="https://www.cyllo.com/" class="badge text-bg-light">
                <img alt="Cyllo" src="/cyllo_website/static/img/cyllo-logo.svg"
                     width="62" height="20"
                     style="width: auto; height: 1em; vertical-align: baseline;"/>
            </a>
        </xpath>
    </template>

    <template id="brand_promotion" inherit_id="website.brand_promotion" name="Brand Promotion">
        <xpath expr="//t[@t-call='web.brand_promotion_message']" position="replace">
            <t t-call="web.brand_promotion_message">
                <t t-set="_message">Create a
                    <a target="_blank" href="https://www.cyllo.com/">free website</a>
                </t>
                <t t-set="_utm_medium" t-valuef="website"/>
            </t>
        </xpath>
    </template>
</odoo>