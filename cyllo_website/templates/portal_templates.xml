<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="cyllo_website.portal_record_sidebar" inherit_id="portal.portal_record_sidebar">
        <xpath expr="//div[hasclass('o_portal_sidebar_content')]" position="replace">
            <div class="o_portal_sidebar_content d-lg-inline-block mb-4 mb-lg-0 p-3 p-lg-0" id="sidebar_content">
                <div t-if="title" class="position-relative d-flex align-items-center justify-content-md-center justify-content-lg-between flex-wrap gap-2">
                    <t t-out="title"/>
                </div>
                <t t-if="entries" t-out="entries"/>
                <div class="d-none d-lg-block mt-5 small text-center text-muted">
                    Powered by
                    <a target="_blank" href="https://www.cyllo.com/" title="cyllo">
                        <img src="/cyllo_website/static/img/cyllo-logo.svg" alt="Cyllo Logo" height="15"/>
                    </a>
                </div>
            </div>
        </xpath>
    </template>
</odoo>