<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Rule 1: Partner Tracking -->
        <record id="audit_rule_partner" model="audit.rule">
            <field name="name">Track Partner Changes</field>
            <field name="model_id" ref="base.model_res_partner"/>
            <field name="log_level">info</field>
            <field name="track_create">True</field>
            <field name="track_write">True</field>
            <field name="track_unlink">True</field>
            <field name="tracking_scope">all</field>
            <field name="user_selection_type">all</field>
            <field name="sequence">10</field>
        </record>

        <!-- Rule 2: User Security Audit -->
        <record id="audit_rule_users" model="audit.rule">
            <field name="name">Monitor User Security</field>
            <field name="model_id" ref="base.model_res_users"/>
            <field name="log_level">warning</field>
            <field name="track_create">False</field>
            <field name="track_write">True</field>
            <field name="track_unlink">True</field>
            <field name="tracking_scope">tracked</field>
            <field name="tracked_field_ids" eval="[
                Command.link(ref('base.field_res_users__login')),
                Command.link(ref('base.field_res_users__password')),
                Command.link(ref('base.field_res_users__active'))
            ]"/>
            <field name="user_selection_type">all</field>
            <field name="sequence">20</field>
        </record>

        <!-- Rule 3: Permission Group Audit -->
        <record id="audit_rule_groups" model="audit.rule">
            <field name="name">Permission Group Audit</field>
            <field name="model_id" ref="base.model_res_groups"/>
            <field name="log_level">critical</field>
            <field name="track_create">True</field>
            <field name="track_write">True</field>
            <field name="track_unlink">True</field>
            <field name="tracking_scope">all</field>
            <field name="user_selection_type">all</field>
            <field name="sequence">30</field>
        </record>
    </data>
</odoo>
