<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record model="ir.module.category" id="module_category_audit_log">
        <field name="name">Audit Log</field>
        <field name="description">Helps to manage various Audit log operations</field>
        <field name="sequence">25</field>
    </record>
    <!--    Audit Log User Group-->
    <record id="group_cyllo_audit_log_users" model="res.groups">
        <field name="name">Audit Log  Users</field>
        <field name="category_id" ref="cyllo_auditlog.module_category_audit_log"/>
    </record>
    <!--    Audit Log Manager Group-->
    <record id="group_cyllo_audit_log_admin" model="res.groups">
        <field name="name">Audit Log Manager</field>
        <field name="category_id" ref="cyllo_auditlog.module_category_audit_log"/>
        <field name="implied_ids"
               eval="[Command.link(ref('cyllo_auditlog.group_cyllo_audit_log_users')),
               Command.link(ref('base.group_multi_currency')),
               Command.link(ref('base.group_multi_company'))]"/>
        <field name="users" eval="[Command.link(ref('base.user_root')), Command.link(ref('base.user_admin'))]"/>
    </record>

    <record id="audit_rule_company_rule" model="ir.rule">
        <field name="name">Audit Rule by Company</field>
        <field name="model_id" ref="model_audit_rule"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <field name="groups"
               eval="[Command.link(ref('cyllo_auditlog.group_cyllo_audit_log_users')),
               Command.link(ref('cyllo_auditlog.group_cyllo_audit_log_admin'))]"/>
    </record>

    <record id="audit_log_company_rule" model="ir.rule">
        <field name="name">Audit Log by Company</field>
        <field name="model_id" ref="model_audit_log"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <field name="groups"
               eval="[Command.link(ref('cyllo_auditlog.group_cyllo_audit_log_users')),
               Command.link(ref('cyllo_auditlog.group_cyllo_audit_log_admin'))]"/>
    </record>

    <record id="audit_log_line_company_rule" model="ir.rule">
        <field name="name">Audit Log Line by Company</field>
        <field name="model_id" ref="model_audit_log_line"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <field name="groups"
               eval="[Command.link(ref('cyllo_auditlog.group_cyllo_audit_log_users')),
               Command.link(ref('cyllo_auditlog.group_cyllo_audit_log_admin'))]"/>
    </record>

    <record id="audit_session_company_rule" model="ir.rule">
        <field name="name">Audit Session by Company</field>
        <field name="model_id" ref="model_audit_session"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <field name="groups"
               eval="[Command.link(ref('cyllo_auditlog.group_cyllo_audit_log_users')),
               Command.link(ref('cyllo_auditlog.group_cyllo_audit_log_admin'))]"/>
    </record>

    <record id="audit_http_request_company_rule" model="ir.rule">
        <field name="name">Audit HTTP Request by Company</field>
        <field name="model_id" ref="model_audit_http_request"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <field name="groups"
               eval="[Command.link(ref('cyllo_auditlog.group_cyllo_audit_log_users')),
               Command.link(ref('cyllo_auditlog.group_cyllo_audit_log_admin'))]"/>
    </record>
</odoo>
