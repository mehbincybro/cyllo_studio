<?xml version="1.0" encoding="UTF-8" ?>

<templates xml:space="preserve">
    <t t-name="repair_floor.Dashboard" owl="1">

        <div class="o_repair_floor_app d-flex flex-column bg-100" style="height: 100%; width: 100%; overflow: hidden;">

            <div class="o_rf_header px-3 py-2 bg-white shadow-sm d-flex justify-content-between align-items-center border-bottom"
                 style="z-index: 1060; position: relative;">
                <div class="d-flex align-items-center gap-3">
                    <i class="fa fa-wrench fa-lg text-primary"/>
                    <h2 class="m-0 fw-bold text-dark fs-4">Repair Floor</h2>
                </div>

                <div class="d-flex align-items-center gap-4">
                    <div class="d-flex align-items-center">
                        <div class="dropdown me-3 shadow-sm rounded"
                             t-att-class="state.isManager ? '' : 'opacity-75'">
                            <button class="btn btn-outline-secondary dropdown-toggle fw-bold d-flex align-items-center bg-white py-1"
                                    type="button" data-bs-toggle="dropdown" aria-expanded="false"
                                    t-att-disabled="!state.isManager"
                                    t-att-aria-disabled="state.isManager ? 'false' : 'true'"
                                    style="font-size: 0.85rem; border-color: #dee2e6;">
                                <i class="fa fa-user-circle me-2 fs-5 text-primary"/>
                                <t t-if="state.selectedEmployee">
                                    <span class="text-dark"><t t-esc="state.selectedEmployee.name"/></span>
                                </t>
                                <t t-else="">
                                    <span class="text-muted">Select Operator</span>
                                </t>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end shadow border-0"
                                style="max-height: 300px; overflow-y: auto; z-index: 1050;">
                                <li>
                                    <button class="dropdown-item py-2 fw-bold text-danger"
                                            t-on-click="() => this.selectEmployee(null)">
                                        <i class="fa fa-user-times me-2"/>
                                        Clear Operator
                                    </button>
                                </li>
                                <li><hr class="dropdown-divider"/></li>
                                <t t-foreach="state.employees" t-as="employee" t-key="employee.id">
                                    <li>
                                        <button class="dropdown-item py-2 fw-bold"
                                                t-on-click="() => this.selectEmployee(employee)">
                                            <i class="fa fa-user text-muted me-2"/>
                                            <t t-esc="employee.name"/>
                                        </button>
                                    </li>
                                </t>
                            </ul>
                        </div>
                    </div>

                    <button class="btn btn-light border shadow-sm fw-bold hover-primary" t-on-click="fetchRepairOrders">
                        <i class="fa fa-refresh me-2"/>
                        Refresh
                    </button>
                </div>
            </div>
            <div class="bg-white border-bottom shadow-sm user-select-none"
                 style="display: table; width: 100%; table-layout: fixed; box-sizing: border-box; position: relative; z-index: 1;">

    <div style="display: table-row;">

        <div class="cursor-pointer transition-base border-end"
             style="display: table-cell; height: 56px; vertical-align: middle; text-align: center; overflow: hidden;"
             t-att-class="state.currentFilter === 'draft' ? 'bg-secondary text-dark' : 'text-muted'"
             t-on-click="() => this.setView('draft')">
            <span class="fw-bold text-uppercase d-inline-flex align-items-center gap-1"
                  style="font-size: 0.9rem; white-space: nowrap;">
                <i class="fa fa-file-text-o"/>
                New
                <span class="badge rounded-pill ms-1"
                      t-att-class="state.currentFilter === 'draft' ? 'bg-white text-dark' : 'bg-secondary text-white'">
                    <t t-esc="state.repairs.draft.length"/>
                </span>
            </span>
        </div>

        <div class="cursor-pointer transition-base border-end"
             style="display: table-cell; height: 56px; vertical-align: middle; text-align: center; overflow: hidden;"
             t-att-class="state.currentFilter === 'confirmed' ? 'bg-warning text-white' : 'text-muted'"
             t-on-click="() => this.setView('confirmed')">
            <span class="fw-bold text-uppercase d-inline-flex align-items-center gap-1"
                  style="font-size: 0.9rem; white-space: nowrap;">
                <i class="fa fa-check-square-o"/>
                Confirmed
                <span class="badge rounded-pill ms-1"
                      t-att-class="state.currentFilter === 'confirmed' ? 'bg-white text-dark' : 'bg-secondary text-white'">
                    <t t-esc="state.repairs.confirmed.length"/>
                </span>
            </span>
        </div>

        <div class="cursor-pointer transition-base border-end"
             style="display: table-cell; height: 56px; vertical-align: middle; text-align: center; overflow: hidden;"
             t-att-class="state.currentFilter === 'under_repair' ? 'bg-info text-white' : 'text-muted'"
             t-on-click="() => this.setView('under_repair')">
            <span class="fw-bold text-uppercase d-inline-flex align-items-center gap-1"
                  style="font-size: 0.9rem; white-space: nowrap;">
                <i class="fa fa-cogs"/>
                Under Repair
                <span class="badge rounded-pill ms-1"
                      t-att-class="state.currentFilter === 'under_repair' ? 'bg-white text-info' : 'bg-secondary text-white'">
                    <t t-esc="state.repairs.under_repair.length"/>
                </span>
            </span>
        </div>

        <div class="cursor-pointer transition-base border-end"
             style="display: table-cell; height: 56px; vertical-align: middle; text-align: center; overflow: hidden;"
             t-att-class="state.currentFilter === 'done' ? 'bg-success text-white' : 'text-muted'"
             t-on-click="() => this.setView('done')">
            <span class="fw-bold text-uppercase d-inline-flex align-items-center gap-1"
                  style="font-size: 0.9rem; white-space: nowrap;">
                <i class="fa fa-check-circle"/>
                Done
                <span class="badge rounded-pill ms-1"
                      t-att-class="state.currentFilter === 'done' ? 'bg-white text-success' : 'bg-secondary text-white'">
                    <t t-esc="state.repairs.done.length"/>
                </span>
            </span>
        </div>

        <div class="cursor-pointer transition-base"
             style="display: table-cell; height: 56px; vertical-align: middle; text-align: center; overflow: hidden;"
             t-att-class="state.currentFilter === 'cancel' ? 'bg-danger text-white' : 'text-muted'"
             t-on-click="() => this.setView('cancel')">
            <span class="fw-bold text-uppercase d-inline-flex align-items-center gap-1"
                  style="font-size: 0.9rem; white-space: nowrap;">
                <i class="fa fa-times-circle"/>
                Cancelled
                <span class="badge rounded-pill ms-1"
                      t-att-class="state.currentFilter === 'cancel' ? 'bg-white text-danger' : 'bg-secondary text-white'">
                    <t t-esc="state.repairs.cancel.length"/>
                </span>
            </span>
        </div>

    </div>
</div>

            <div class="o_rf_content flex-grow-1 p-3 overflow-auto bg-100">
                <div class="o_rf_column w-100 bg-200 p-3 rounded-3 shadow-sm border">

                    <h4 class="mb-3 pb-2 border-bottom border-secondary border-opacity-25 d-flex align-items-center fw-bold text-dark">
                        <t t-if="state.currentFilter === 'draft'">
                            <i class="fa fa-file-text-o text-secondary me-2"/>
                            New Repairs
                        </t>
                        <t t-elif="state.currentFilter === 'confirmed'">
                            <i class="fa fa-check-square-o text-warning me-2"/>
                            Confirmed Repairs
                        </t>
                        <t t-elif="state.currentFilter === 'under_repair'">
                            <i class="fa fa-cogs text-info me-2"/>
                            Under Repair
                        </t>
                        <t t-elif="state.currentFilter === 'done'">
                            <i class="fa fa-check-circle text-success me-2"/>
                            Completed Repairs
                        </t>
                        <t t-elif="state.currentFilter === 'cancel'">
                            <i class="fa fa-times-circle text-danger me-2"/>
                            Cancelled Repairs
                        </t>

                    </h4>

                    <div class="row g-2">
                        <t t-if="state.repairs[state.currentFilter].length > 0">
                            <t t-foreach="state.repairs[state.currentFilter]" t-as="repair" t-key="repair.id">
                                <div class="col-xl-4 col-lg-6 col-12">
                                    <RepairCard record="repair" onUpdate.bind="fetchRepairOrders"
                                                activeEmployeeId="state.selectedEmployee ? state.selectedEmployee.id : null"
                                                isManager="state.isManager"/>
                                </div>
                            </t>
                        </t>
                        <t t-else="">
                            <div class="col-12 py-5 text-center text-muted opacity-25">
                                <i class="fa fa-inbox fa-3x mb-2"/>
                                <h5>No records found for this status.</h5>
                            </div>
                        </t>
                    </div>

                </div>
            </div>

        </div>
    </t>
</templates>
