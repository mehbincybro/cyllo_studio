<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <t t-name="repair_floor.Dashboard" owl="1">
        <div class="o_repair_floor_app d-flex flex-column h-100 bg-100">

            <div class="o_rf_header px-3 py-2 bg-white shadow-sm d-flex justify-content-between align-items-center border-bottom">
                <div class="d-flex align-items-center gap-3">
                    <i class="fa fa-wrench fa-lg text-primary"/>
                    <h2 class="m-0 fw-bold text-dark fs-4">Repair Floor</h2>
                </div>

                <div class="d-flex align-items-center gap-4">
                    <div class="form-check form-switch d-flex align-items-center gap-2 m-0 p-0">
                        <label class="form-check-label mb-0 cursor-pointer fw-bold" for="viewToggle">
                            <t t-if="state.currentFilter === 'active'">Active Repairs</t>
                            <t t-else="">Completed</t>
                        </label>
                        <input class="form-check-input fs-4 m-0 cursor-pointer shadow-sm" type="checkbox" role="switch" id="viewToggle" t-att-checked="state.currentFilter === 'completed'" t-on-change="toggleFilter"/>
                    </div>

                    <div class="d-flex align-items-center">
                        <div class="dropdown me-3 shadow-sm rounded">
                            <button class="btn btn-outline-secondary dropdown-toggle fw-bold d-flex align-items-center bg-white py-1" type="button" data-bs-toggle="dropdown" aria-expanded="false" style="font-size: 0.85rem; border-color: #dee2e6;">
                                <i class="fa fa-user-circle me-2 fs-5 text-primary"/>
                                <t t-if="state.selectedEmployee">
                                    <span class="text-dark"><t t-esc="state.selectedEmployee.name"/></span>
                                </t>
                                <t t-else="">
                                    <span class="text-muted">Select Operator</span>
                                </t>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end shadow border-0" style="max-height: 300px; overflow-y: auto; z-index: 1050;">
                                <li>
                                    <button class="dropdown-item py-2 fw-bold text-danger" t-on-click="() => this.selectEmployee(null)">
                                        <i class="fa fa-user-times me-2"/> Clear Operator
                                    </button>
                                </li>
                                <li><hr class="dropdown-divider"/></li>
                                <t t-foreach="state.employees" t-as="employee" t-key="employee.id">
                                    <li>
                                        <button class="dropdown-item py-2 fw-bold" t-on-click="() => this.selectEmployee(employee)">
                                            <i class="fa fa-user text-muted me-2"/> <t t-esc="employee.name"/>
                                        </button>
                                    </li>
                                </t>
                            </ul>
                        </div>
                    </div>

                    <button class="btn btn-light border shadow-sm fw-bold hover-primary" t-on-click="fetchRepairOrders">
                        <i class="fa fa-refresh me-2"/> Refresh
                    </button>
                </div>
            </div>

            <div class="o_rf_content d-flex flex-row p-3 overflow-auto h-100 gap-2">
                <t t-if="state.currentFilter === 'active'">
                    <div class="o_rf_column w-50 bg-200 p-3 rounded-3 shadow-sm border">
                        <h4 class="mb-3 pb-2 border-bottom border-secondary border-opacity-25 d-flex align-items-center fw-bold">
                            <i class="fa fa-list-ul me-2"/> To Do
                            <span class="badge bg-warning rounded-pill ms-auto shadow-sm text-white">
                                <t t-esc="state.repairs.confirmed.length"/>
                            </span>
                        </h4>
                        <div class="row g-2">
                            <t t-if="state.repairs.confirmed.length > 0">
                                <t t-foreach="state.repairs.confirmed" t-as="repair" t-key="repair.id">
                                    <div class="col-6">
                                        <RepairCard record="repair" onUpdate.bind="fetchRepairOrders" activeEmployeeId="state.selectedEmployee ? state.selectedEmployee.id : null"/>
                                    </div>
                                </t>
                            </t>
                            <t t-else="">
                                <div class="col-12 py-5 text-center text-muted opacity-25">
                                    <i class="fa fa-inbox fa-3x mb-2"/>
                                    <h5>No pending repairs</h5>
                                </div>
                            </t>
                        </div>
                    </div>

                    <div class="o_rf_column w-50 bg-200 p-3 rounded-3 shadow-sm border">
                        <h4 class="mb-3 pb-2 border-bottom border-secondary border-opacity-25 d-flex align-items-center fw-bold">
                            <i class="fa fa-cogs me-2"/> Under Repair
                            <span class="badge bg-warning rounded-pill ms-auto shadow-sm text-white">
                                <t t-esc="state.repairs.under_repair.length"/>
                            </span>
                        </h4>
                        <div class="row g-2">
                            <t t-if="state.repairs.under_repair.length > 0">
                                <t t-foreach="state.repairs.under_repair" t-as="repair" t-key="repair.id">
                                    <div class="col-6">
                                        <RepairCard record="repair" onUpdate.bind="fetchRepairOrders" activeEmployeeId="state.selectedEmployee ? state.selectedEmployee.id : null"/>
                                    </div>
                                </t>
                            </t>
                            <t t-else="">
                                <div class="col-12 py-5 text-center text-muted opacity-25">
                                    <i class="fa fa-check-circle fa-3x mb-2"/>
                                    <h5>Floor is clear!</h5>
                                </div>
                            </t>
                        </div>
                    </div>
                </t>

                <t t-else="">
                    <div class="o_rf_column w-100 bg-200 p-3 rounded-3 shadow-sm border">
                        <h4 class="mb-3 pb-2 border-bottom border-secondary border-opacity-25 d-flex align-items-center fw-bold">
                            <i class="fa fa-history me-2"/> Completed Repairs
                            <span class="badge bg-warning rounded-pill ms-auto shadow-sm text-white">
                                <t t-esc="state.repairs.done.length"/>
                            </span>
                        </h4>
                        <div class="row g-2">
                            <t t-if="state.repairs.done.length > 0">
                                <t t-foreach="state.repairs.done" t-as="repair" t-key="repair.id">
                                    <div class="col-4">
                                        <RepairCard record="repair" onUpdate.bind="fetchRepairOrders" activeEmployeeId="state.selectedEmployee ? state.selectedEmployee.id : null"/>
                                    </div>
                                </t>
                            </t>
                            <t t-else="">
                                <div class="col-12 py-5 text-center text-muted opacity-25">
                                    <i class="fa fa-folder-open fa-3x mb-2"/>
                                    <h5>No completed repairs yet.</h5>
                                </div>
                            </t>
                        </div>
                    </div>
                </t>
            </div>
        </div>
    </t>
</templates>