<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <t t-name="repair_floor.RepairCard" owl="1">
        <div class="card shadow-sm border-0 rounded-3 bg-white cursor-pointer h-100 hover-shadow transition-base">
            <div class="card-body p-3 d-flex flex-column">

                <div class="d-flex justify-content-between align-items-center border-bottom pb-2 mb-2">
                    <h5 class="card-title fw-bolder m-0 text-dark text-truncate d-flex align-items-center">
                        <i class="fa fa-ticket me-2 fs-6"/>
                        <span class="text-truncate"><t t-esc="props.record.name"/></span>
                    </h5>

                    <div class="d-flex align-items-center">

                        <i t-if="props.record.under_warranty" class="fa fa-shield text-success fs-5 me-2"
                           title="Under Warranty"/>

                        <t t-if="props.record.state === 'under_repair'">
                            <i t-if="props.record.is_timer_running" class="fa fa-clock-o fa-spin text-success fs-5 me-2"
                               title="In Progress..."/>
                            <i t-else="" class="fa fa-pause-circle text-warning fs-5 me-2" title="Paused"/>
                        </t>

                        <div class="dropdown" t-if="props.isManager || props.record.state !== 'draft'">
                            <button class="btn btn-sm text-muted p-0 border-0" type="button" data-bs-toggle="dropdown"
                                    t-on-click.stop="">
                                <i class="fa fa-ellipsis-v fs-5 px-2"/>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0">
                                <t t-if="props.isManager">
                                    <li>
                                        <button class="dropdown-item py-2 fw-bold text-primary"
                                                t-on-click.stop="openRepairOrder">
                                            <i class="fa fa-external-link-square me-2"/>
                                            Open Repair Order
                                        </button>
                                    </li>
                                </t>

                                <t t-if="props.record.state !== 'done' and props.record.state !== 'cancel'">
                                    <li>
                                        <button class="dropdown-item py-2 fw-bold text-success"
                                                t-on-click.stop="editRepairLine">
                                            <i class="fa fa-plus me-2"/>
                                            Edit Repair Line
                                        </button>
                                    </li>
                                </t>

                                <li>
                                    <button class="dropdown-item py-2 fw-bold text-info"
                                            t-on-click.stop="editNotes">
                                        <i class="fa fa-sticky-note me-2"/>
                                        Notes
                                    </button>
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>

                <div class="small mb-2 text-truncate fw-bold">
                    <i class="fa fa-box text-muted me-2"/>
                    <t t-esc="props.record.product_id[1]"/>
                </div>

                <div class="small mb-3 text-truncate text-muted">
                    <i class="fa fa-user-circle me-2"/>
                    <t t-esc="props.record.partner_id ? props.record.partner_id[1] : 'Internal'"/>
                </div>

                <div class="d-flex align-items-center flex-wrap gap-1 mb-1"
                     t-if="props.record.tags_data and props.record.tags_data.length > 0">
                    <i class="fa fa-tags text-muted me-1" style="font-size: 0.85rem;" title="Tags"/>
                    <t t-foreach="props.record.tags_data" t-as="tag" t-key="tag.id">
                        <span class="badge rounded-pill"
                              style="background-color: #e1f0ff; color: #3b5998; font-size: 0.7rem; font-weight: 500; padding: 0.3em 0.6em; border: 1px solid #cce5ff;">
                            <t t-esc="tag.name"/>
                        </span>
                    </t>
                </div>

                <t t-if="props.record.state !== 'done' and props.record.state !== 'cancel'">
                    <div class="d-flex justify-content-center mt-auto pt-2 gap-2">

                        <button t-if="props.record.state === 'confirmed'"
                                class="btn btn-success w-100 btn-sm rounded-pill fw-bold shadow-sm"
                                t-on-click.stop="startRepair">
                            <i class="fa fa-play me-1"/>
                            Start Repair
                        </button>

                        <button t-if="props.record.state === 'under_repair' and !props.record.is_timer_running"
                                class="btn btn-info w-100 btn-sm rounded-pill fw-bold shadow-sm text-white"
                                t-on-click.stop="startRepair">
                            <i class="fa fa-play-circle me-1"/>
                            Resume
                        </button>

                        <button t-if="props.record.state === 'under_repair' and props.record.is_timer_running"
                                class="btn btn-warning w-50 btn-sm rounded-pill fw-bold shadow-sm text-dark"
                                t-on-click.stop="pauseRepair">
                            <i class="fa fa-pause me-1"/>
                            Pause
                        </button>

                        <button t-if="props.record.state === 'under_repair'"
                                class="btn btn-danger w-50 btn-sm rounded-pill fw-bold shadow-sm"
                                t-on-click.stop="stopRepair">
                            <i class="fa fa-stop me-1"/>
                            End
                        </button>

                    </div>
                </t>

                <t t-if="props.record.state === 'done' and !props.record.sale_order_id">
                    <div class="d-flex justify-content-center mt-auto pt-2 gap-2">
                        <button class="btn btn-primary w-100 btn-sm rounded-pill fw-bold shadow-sm"
                                t-on-click.stop="createQuotation">
                            <i class="fa fa-file-text-o me-1"/>
                            Create Quotation
                        </button>
                    </div>
                </t>

            </div>
        </div>
    </t>
</templates>