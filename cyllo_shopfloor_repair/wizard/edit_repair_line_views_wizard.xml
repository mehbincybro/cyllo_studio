<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_edit_repair_line_wizard_form" model="ir.ui.view">
        <field name="name">edit.repair.line.wizard.form</field>
        <field name="model">edit.repair.line.wizard</field>
        <field name="arch" type="xml">
            <form string="Edit Repair Line">
                <group>
                    <field name="repair_id"/>
                    <field name="repair_line_type"/>
                    <field name="product_id"/>
                    <label for="quantity"/>
                    <div class="o_row">
                        <field name="quantity" class="oe_inline"/>
                        <field name="uom_id" class="oe_inline text-muted" readonly="1" invisible="not product_id"/>
                    </div>
                </group>
                <footer>
                    <button name="action_edit_repair_line" type="object" string="Confirm" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_edit_repair_line_wizard" model="ir.actions.act_window">
        <field name="name">Edit Repair Line</field>
        <field name="res_model">edit.repair.line.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
