<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="res_config_settings_view_form_inherit_repair_limit" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.repair.limit</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">

            <xpath expr="//app[@name='repair']" position="inside">

                <block title="Repair Floor Operations" name="repair_orders">
                    <setting id="repair_max_active_orders_setting" string="Max Active Repairs"
                             help="Maximum number of concurrent repairs an operator can start. Set to 0 for unlimited.">
                        <field name="repair_max_active_orders"/>
                    </setting>
                </block>

            </xpath>

        </field>
    </record>

</odoo>