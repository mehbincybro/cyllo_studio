<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_repair_floor_notes_popup" model="ir.ui.view">
        <field name="name">repair.floor.notes.popup</field>
        <field name="model">repair.order</field>
        <field name="priority">9999</field>
        <field name="arch" type="xml">
            <form string="Repair Notes">
                <sheet>
                    <div class="fw-bold mb-2">Internal Notes:</div>
                    <field name="internal_notes" placeholder="Type internal repair notes here..." widget="html"/>
                </sheet>
                <footer>
                    <button string="Save Notes" class="btn-primary" special="save"/>
                    <button string="Discard" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>