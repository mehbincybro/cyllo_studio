<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_repair_order_form_inherit_shopfloor_button" model="ir.ui.view">
        <field name="name">repair.order.form.inherit.shopfloor.button</field>
        <field name="model">repair.order</field>
        <field name="inherit_id" ref="repair.view_repair_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_open_repair_floor" type="object" class="oe_stat_button" icon="fa-wrench">
                    <div class="o_stat_info">
                        <span class="o_stat_text">Repair Floor</span>
                    </div>
                </button>
            </xpath>
        </field>
    </record>
</odoo>
