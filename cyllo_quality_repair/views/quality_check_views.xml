<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_quality_check_form_inherit_repair" model="ir.ui.view">
        <field name="name">quality.check.form.inherit.repair</field>
        <field name="model">quality.check</field>
        <field name="inherit_id" ref="cyllo_quality.view_quality_check_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='picking_id']" position="after">
                <field name="repair_id"/>
            </xpath>
        </field>
    </record>
</odoo>
