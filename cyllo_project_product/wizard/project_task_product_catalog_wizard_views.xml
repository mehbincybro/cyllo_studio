<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="project_task_product_catalog_wizard_view_form" model="ir.ui.view">
        <field name="name">project.task.product.catalog.wizard.form</field>
        <field name="model">project.task.product.catalog.wizard</field>
        <field name="arch" type="xml">
            <form string="Add Products">
                <field name="available_sale_order_ids" invisible="1"/>
                <field name="can_create_sale_order" invisible="1"/>
                <group>
<!--                    <p class="text-muted">-->
<!--                        Choose where the products selected from the catalog should be added.-->
<!--                    </p>-->
                    <field name="task_id" invisible="1"/>
                    <field name="partner_id" invisible="1"/>
                    <field name="action_type"
                           widget="radio"
                           invisible="not can_create_sale_order"/>
                    <field name="limited_action_type"
                           widget="radio"
                           invisible="can_create_sale_order"/>
                    <field name="sale_order_id"
                           invisible="action_type in ('new_quotation', 'new_sale_order')"
                           required="action_type not in ('new_quotation', 'new_sale_order')"
                           options="{'no_create': True, 'no_open': False}"/>
                </group>
                <footer>
                    <button name="action_open_product_catalog"
                            string="Continue to Product Catalog"
                            type="object"
                            class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
