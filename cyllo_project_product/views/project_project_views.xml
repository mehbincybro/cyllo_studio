<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="edit_project_project_inherit_product" model="ir.ui.view">
        <field name="name">project.project.form.inherit.product</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.edit_project"/>
        <field name="arch" type="xml">
            <xpath expr="//setting[field[@name='allow_billable']]" position="after">
                <setting id="task_products_setting" help="Track the material used to complete tasks">
                    <field name="allow_task_products"/>
                </setting>
                <setting id="extra_quotations_setting" help="Create new quotations directly from tasks">
                    <field name="allow_extra_quotations"/>
                </setting>
            </xpath>
        </field>
    </record>
</odoo>
