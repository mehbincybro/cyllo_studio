<?xml version="1.0" encoding="utf-8" ?>
<template>
    <!--Template for Kitchen order stages  -->
    <t t-name="KitchenCustomDashBoard">
        <header>
            <div id="kitchen_screen" class="kitchen">
                <div class="body_wrapper">
                    <div class="kitchen_header_bar">
                        <div class="kitchen_header_left">
                            <div class="kitchen_header_title">Kitchen Screen</div>
                            <div class="kitchen_header_meta">
                                <span class="kitchen_header_meta_item">
                                    POS: <t t-esc="state.shop_id"/>
                                </span>
                            </div>
                        </div>
                        <div class="kitchen_header_right">
                            <span class="kitchen_header_badge">
                                <t t-esc="(state.order_details || []).length"/> orders
                            </span>
                            <button class="btn btn-light kitchen_close_btn kitchen_header_close_btn"
                                    type="button"
                                    t-on-click="close_kitchen_screen">Close</button>
                        </div>
                    </div>
                    <div class="container o_pj_dashboard">
                        <t t-call="KitchenOrder"/>
                    </div>
                </div>
            </div>
        </header>
    </t>
    <!--Template for Kitchen Orders in the kitchen screen -->
    <t t-name="KitchenOrder">
        <section class="screen_info custom_padding_top">
            <div class="wrapper">
                <div class="container-fluid">
                    <div class="kitchen_board">
                        <t t-set="columns" t-value="this.getStageColumns()"/>
                        <t t-foreach="columns" t-as="col" t-key="col.stage.id">
                            <div class="kitchen_column"
                                 t-attf-data-stage-id="{{col.stage.id}}"
                                 t-on-dragover="on_stage_drag_over"
                                 t-on-dragleave="on_stage_drag_leave"
                                 t-on-drop="on_stage_drop">
                                <div class="kitchen_column_header">
                                    <div class="kitchen_column_title">
                                        <t t-if="col.stage.image and col.stage.image != 'false'">
                                            <img class="kitchen_stage_icon"
                                                 t-attf-src="data:image/png;base64,{{col.stage.image}}"
                                                 alt=""
                                                 loading="lazy"/>
                                        </t>
                                        <span class="kitchen_column_name">
                                            <t t-esc="col.stage.name"/>
                                        </span>
                                    </div>
                                    <span class="kitchen_column_badge">
                                        <t t-esc="col.count"/>
                                    </span>
                                </div>

                                <div class="kitchen_column_body">
                                    <t t-if="col.orders.length == 0">
                                        <div class="kitchen_column_empty">No orders</div>
                                    </t>
                                    <t t-foreach="col.orders" t-as="order" t-key="order.id">
                                        <div class="card kitchen_card"
                                             t-attf-data-order-id="{{order.id}}"
                                             draggable="true"
                                             t-on-dragstart="on_order_drag_start"
                                             t-on-dragend="on_order_drag_end"
                                             t-on-click="advance_order">
                                            <t t-if="(col.isReadyStage and order.order_status == 'ready') or (col.isCancelStage and order.order_status == 'cancel')">
                                                <button class="kitchen_card_remove"
                                                        type="button"
                                                        title="Remove"
                                                        aria-label="Remove"
                                                        t-attf-data-order-id="{{order.id}}"
                                                        draggable="false"
                                                        t-on-click="remove_completed_order">
                                                    ×
                                                </button>
                                            </t>
                                            <div t-attf-class="card-header {{order.order_status == 'ready' ? 'bg_green' : (order.order_status == 'waiting' ? 'bg_blue' : (order.order_status == 'cancel' ? 'bg_red' : 'bg_grey'))}}">
                                                <div class="left" style="padding-bottom: 8px">
                                                    <div class="status">
                                                        <h4 class="c_white">
<!--                                                            <t t-if="order.order_status == 'ready'">Completed</t>-->
<!--                                                            <t t-elif="order.order_status == 'waiting'">Ready</t>-->
<!--                                                            <t t-elif="order.order_status == 'draft'">Cooking</t>-->
<!--                                                            <t t-elif="order.order_status == 'cancel'">Cancelled</t>-->
                                                        </h4>
                                                        <div style="padding: 3px 7px;" class="container-fluid">
                                                            <ul style="display:contents" class="c_white">
                                                                <li><b><span style="font-size: 13px;"><t t-esc="order.name"/></span></b></li>
                                                                <li><b><span style="font-size: 12px;">Time</span></b> <span style="font-size: 12px;"><t t-esc="order.hour"/>:<t t-esc="order.minutes"/></span></li>
                                                                <li><b><span style="font-size: 12px;">Table:</span></b> <span style="font-size: 12px;"><t t-esc="order.table_id[1]"/></span></li>
                                                                <li><b><span style="font-size: 12px;">Floor:</span></b> <span style="font-size: 12px;"><t t-esc="order.floor"/></span></li>
                                                            </ul>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="right">
                                                    <span class="c_white"><t t-esc="order.user_id[1]"/></span>
                                                </div>
                                            </div>

                                            <ul class="list-group list-group-flush">
                                                <t t-foreach="order.lines" t-as="line_id" t-key="line_id">
                                                    <t t-set="line" t-value="state.lines.find(l => l.id == line_id)"/>
                                                    <t t-if="line">
                                                        <button t-attf-class="list-group-item {{order.order_status == 'waiting' ? 'accept_order_line' : ''}}"
                                                                t-on-click="(e) => this.on_line_click(e, order.order_status)"
                                                                t-attf-id="lines_id_{{line.id}}"
                                                                t-att-value="line.id"
                                                                t-attf-style="{{order.order_status=='waiting' and line.order_status=='ready' ? 'text-decoration: line-through !important;color: #bfbfbf !important;' : ''}}">
                                                            <span><t t-esc="line.qty"/> x </span>
                                                            <t t-esc="line.full_product_name"/>
                                                            <t t-if="line.note">
                                                                <br/>
                                                                <i class="fa fa-tag fa-lg" role="img" aria-label="Note" title="Note"/>
                                                                <span style="font-size:14px"><t t-esc="line.note"/></span>
                                                            </t>
                                                        </button>
                                                    </t>
                                                </t>
                                            </ul>
                                        </div>
                                    </t>
                                </div>
                            </div>
                        </t>
                    </div>
                </div>
            </div>
        </section>
    </t>
</template>
