<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <data>
        <record id="dashboard_sheet_cash_bank_journal" model="dashboard.sheet">
            <field name="name">Cash and Bank journal</field>
            <field name="type">bar</field>
            <field name="dimension_axis">x</field>
            <field name="limit">30</field>
            <field name="is_enabled">True</field>
            <field name="sheet_type_id" ref="cyllo_analytics.dashboard_sheet_type_bar"/>
        </record>
        <record id="dashboard_sheet_journals" model="dashboard.sheet">
            <field name="name">journals</field>
            <field name="type">pie</field>
            <field name="dimension_axis">x</field>
            <field name="limit">30</field>
            <field name="is_enabled">True</field>
            <field name="sheet_type_id" ref="cyllo_analytics.dashboard_sheet_type_pie"/>
        </record>
        <record id="dashboard_sheet_chart_of_accounts" model="dashboard.sheet">
            <field name="name">Chart of Accounts</field>
            <field name="type">line</field>
            <field name="dimension_axis">x</field>
            <field name="limit">30</field>
            <field name="is_enabled">True</field>
            <field name="sheet_type_id" ref="cyllo_analytics.dashboard_sheet_type_line"/>
        </record>
        <record id="dashboard_sheet_payable_receivable" model="dashboard.sheet">
            <field name="name">Payment</field>
            <field name="type">doughnut</field>
            <field name="dimension_axis">x</field>
            <field name="limit">30</field>
            <field name="is_enabled">True</field>
            <field name="sheet_type_id" ref="cyllo_analytics.dashboard_sheet_type_doughnut"/>
        </record>
        <record id="dashboard_sheet_income_statement" model="dashboard.sheet">
            <field name="name">Profit and loss</field>
            <field name="type">pictorialBar</field>
            <field name="dimension_axis">x</field>
            <field name="limit">30</field>
            <field name="is_enabled">True</field>
            <field name="sheet_type_id" ref="cyllo_analytics.dashboard_sheet_type_pictorialbar"/>
        </record>
        <record id="dashboard_sheet_balance_sheet" model="dashboard.sheet">
            <field name="name">Posted Entries</field>
            <field name="type">kpi</field>
            <field name="dimension_axis">y</field>
            <field name="limit">0</field>
            <field name="is_enabled">True</field>
            <field name="sheet_type_id" ref="cyllo_analytics.dashboard_sheet_type_kpi"/>
            <field name="kpi_view" eval="'View 1'"/>
            <field name="kpi_target" eval="500000"/>
        </record>
        <record id="dashboard_sheet_cash_flow" model="dashboard.sheet">
            <field name="name">Invoice</field>
            <field name="type">kpi</field>
            <field name="dimension_axis">y</field>
            <field name="limit">0</field>
            <field name="is_enabled">True</field>
            <field name="sheet_type_id" ref="cyllo_analytics.dashboard_sheet_type_kpi"/>
            <field name="kpi_view" eval="'View 2'"/>
            <field name="kpi_target" eval="1000000"/>
        </record>
        <record id="dashboard_sheet_equity" model="dashboard.sheet">
            <field name="name">Draft entries</field>
            <field name="type">table</field>
            <field name="dimension_axis">x</field>
            <field name="limit">0</field>
            <field name="is_enabled">True</field>
            <field name="sheet_type_id" ref="cyllo_analytics.dashboard_sheet_type_table"/>
        </record>
    </data>
</odoo>
