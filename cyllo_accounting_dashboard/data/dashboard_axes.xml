        <record id="dashboard_sheet_cash_bank_journal_axis_0" model="dashboard.sheet.axis">
            <field name="value">Journal &gt; Journal Name</field>
            <field name="alias">account_journal_name</field>
            <field name="query">account_journal.name -&gt;&gt; 'en_US' AS account_journal_name</field>
            <field name="column">account_journal.name</field>
            <field name="type">dimension</field>
            <field name="sheet_id" ref="dashboard_sheet_cash_bank_journal"/>
        </record>
        <record id="dashboard_sheet_cash_bank_journal_axis_1" model="dashboard.sheet.axis">
            <field name="value">SUM(account_move_amount_untaxed_signed)</field>
            <field name="alias">account_move_amount_untaxed_signed_sum</field>
            <field name="query">SUM(ROUND(account_move.amount_untaxed_signed / COALESCE((
                            SELECT rate FROM res_currency_rate
                            WHERE currency_id = account_move.currency_id
                            AND company_id = 1
                            ORDER BY name DESC
                            LIMIT 1
                        ), 1) * COALESCE((
                            SELECT rate
                            FROM res_currency_rate
                            WHERE currency_id = 1
                            AND company_id = 1
                            ORDER BY name DESC
                            LIMIT 1
                        ), 1), 2)) AS account_move_amount_untaxed_signed_sum</field>
            <field name="column">account_move.amount_untaxed_signed</field>
            <field name="type">measure</field>
            <field name="sheet_id" ref="dashboard_sheet_cash_bank_journal"/>
        </record>
