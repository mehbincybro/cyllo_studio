<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <data>
        <record id="dashboard_sheet_income_statement_filter_0" model="dashboard.sheet.filter">
            <field name="name">Profit and loss</field>
            <field name="domain">account_account.account_type IN ('income', 'income_other', 'expense', 'expense_depreciation', 'expense_direct_cost')</field>
            <field name="is_active">True</field>
            <field name="sheet_id" ref="dashboard_sheet_income_statement" />
        </record>
        <record id="dashboard_sheet_balance_sheet_filter_0" model="dashboard.sheet.filter">
            <field name="name">Posted Entries</field>
            <field name="domain">account_move_line.parent_state = 'posted'</field>
            <field name="is_active">True</field>
            <field name="sheet_id" ref="dashboard_sheet_balance_sheet" />
        </record>
        <record id="dashboard_sheet_cash_flow_filter_0" model="dashboard.sheet.filter">
            <field name="name">Invoice filter</field>
            <field name="domain">account_move.move_type = 'out_invoice'</field>
            <field name="is_active">True</field>
            <field name="sheet_id" ref="dashboard_sheet_cash_flow" />
        </record>
        <record id="dashboard_sheet_equity_filter_0" model="dashboard.sheet.filter">
            <field name="name">Draft entries</field>
            <field name="domain">account_move.state = 'draft'</field>
            <field name="is_active">True</field>
            <field name="sheet_id" ref="dashboard_sheet_equity" />
        </record>
        <record id="dashboard_sheet_journals_0" model="dashboard.sheet.filter">
            <field name="name">Posted</field>
            <field name="domain">account_move_line.parent_state = 'posted'</field>
            <field name="is_active">True</field>
            <field name="sheet_id" ref="dashboard_sheet_journals" />
        </record>
        <record id="dashboard_sheet_cash_bank_journal_0" model="dashboard.sheet.filter">
            <field name="name">cash and bank</field>
            <field name="domain">account_journal.type IN ('cash', 'bank')</field>
            <field name="is_active">True</field>
            <field name="sheet_id" ref="dashboard_sheet_cash_bank_journal" />
        </record>
    </data>
</odoo>