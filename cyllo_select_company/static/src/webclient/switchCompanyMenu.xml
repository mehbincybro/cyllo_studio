<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <t t-name="cyllo_select_company.SelectAllCompaniesMenu" t-inherit="web.SwitchCompanyMenu"
       t-inherit-mode="extension" owl="1">
        <xpath expr="//t[@t-key='company.id']" position="after">
            <DropdownItem class="'p-0'" t-on-click.stop="() => this.onSelectAllCompanies()">
                <div class="d-flex">
                    <div role="menuitemcheckbox"
                         tabindex="0"
                         t-attf-class="{ 'border-primary': isCurrent ? }"
                         class="border-end toggle_company">
                        <span class="btn border-0 p-2">
                            <i class="fa fa-fw py-2" t-att-class="isSelectedAllCompanies ? 'fa-check-square text-primary' : 'fa-square-o'"/>
                        </span>
                    </div>
                    <div role="button"
                        tabindex="0"
                        class="d-flex flex-grow-1 align-items-center py-0 ps-2"
                        t-attf-title="{{ isSelectedAllCompanies ? 'Switch to main Company' : 'Select All Companies' }}"
                        name="select_all_companies">
                        <t t-if="!isSelectedAllCompanies">
                            <span>Select all</span>
                        </t>
                        <t t-else="">
                            <span>Switch to main company</span>
                        </t>
                    </div>
                </div>
            </DropdownItem>
        </xpath>
    </t>
</templates>
