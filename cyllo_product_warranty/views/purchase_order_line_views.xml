<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="purchase_order_form_view_warranty" model="ir.ui.view">
        <field name="name">purchase.order.form.warranty</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <field name="display_extend_warranty" invisible="1"/>
                <button name="action_extend_warranty"
                        string="Extend Warranty"
                        type="object"
                        class="btn-primary"
                        invisible="not display_extend_warranty or state not in ['purchase', 'done']"/>
            </xpath>
            <xpath expr="//field[@name='order_line']/tree/field[@name='qty_received']" position="after">
                <field name="warranty_expiration_date"
                       optional="show"/>
            </xpath>
            <xpath expr="//field[@name='order_line']/form//field[@name='qty_invoiced']" position="after">
                <field name="warranty_expiration_date"
                       invisible="parent.state not in ('purchase', 'done')"/>
            </xpath>
        </field>
    </record>

    <record id="purchase_order_line_tree_view_warranty" model="ir.ui.view">
        <field name="name">purchase.order.line.tree.warranty</field>
        <field name="model">purchase.order.line</field>
        <field name="inherit_id" ref="purchase.purchase_order_line_tree"/>
        <field name="arch" type="xml">
            <field name="date_planned" position="after">
                <field name="warranty_expiration_date"
                       optional="show"/>
            </field>
        </field>
    </record>

    <record id="purchase_order_line_form_view_warranty" model="ir.ui.view">
        <field name="name">purchase.order.line.form.warranty</field>
        <field name="model">purchase.order.line</field>
        <field name="inherit_id" ref="purchase.purchase_order_line_form2"/>
        <field name="arch" type="xml">
            <field name="date_planned" position="after">
                <field name="warranty_expiration_date"/>
            </field>
        </field>
    </record>
</odoo>
