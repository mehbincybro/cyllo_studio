<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="warranty_extension_wizard_view_form" model="ir.ui.view">
        <field name="name">warranty.extension.wizard.view.form</field>
        <field name="model">warranty.extension.wizard</field>
        <field name="arch" type="xml">
            <form string="Extend Warranty">
                <sheet>
                    <group>
                        <field name="order_id" invisible="not order_id" readonly="1"/>
                        <field name="purchase_order_id" invisible="not purchase_order_id" readonly="1"/>
                    </group>
                    <group string="Order Lines">
                        <field name="line_ids"
                               invisible="not order_id"
                               domain="[('order_id', '=', order_id), ('is_under_warranty', '=', True)]"
                               widget="many2many_checkboxes" nolabel="1">
                            <tree>
                                <field name="product_id"/>
                                <field name="name"/>
                                <field name="warranty_expiration_date"/>
                            </tree>
                        </field>
                        <field name="purchase_line_ids"
                               invisible="not purchase_order_id"
                               domain="[('order_id', '=', purchase_order_id), ('is_under_warranty', '=', True)]"
                               widget="many2many_checkboxes" nolabel="1">
                            <tree>
                                <field name="product_id"/>
                                <field name="name"/>
                                <field name="warranty_expiration_date"/>
                            </tree>
                        </field>
                    </group>
                    <group>
                        <group>
                            <field name="extension_period"/>
                            <field name="extension_unit"/>
                        </group>
                    </group>
                </sheet>
                <footer>
                    <button name="action_confirm" string="Confirm" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_warranty_extension_wizard" model="ir.actions.act_window">
        <field name="name">Extend Warranty</field>
        <field name="res_model">warranty.extension.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
