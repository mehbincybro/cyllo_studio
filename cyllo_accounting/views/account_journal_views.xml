<?xml version="1.0" encoding="utf-8"?>

<odoo>
    <record id="view_account_journal_dashboard" model="ir.ui.view">
        <field name="name">view.account.journal.dashboard</field>
        <field name="model">account.journal</field>
        <field name="inherit_id" ref="account.account_journal_dashboard_kanban_view"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='action_configure_bank_journal']" position="after">
                <button name="%(cyllo_accounting.action_view_reconciliation)s" id="reconcile_items" type="action"
                        string="Reconcile" class="btn-primary ms-1"/>
            </xpath>
            <xpath expr="//button[@id='reconcile_items']" position="after">
                <button name="%(cyllo_accounting.action_view_import_bank_statement)s" type="action"
                        string="Upload Statements" class="btn-primary"/>
            </xpath>
        </field>
    </record>
    <record id="view_account_journal_form" model="ir.ui.view">
        <field name="name">view.account.journal.form</field>
        <field name="model">account.journal</field>
        <field name="inherit_id" ref="account.view_account_journal_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook//field[@name='bank_statements_source']/.." position="after">
                <group name="online_bank" string="Online Bank" groups="account.group_account_user">
                    <label for="saltedge_account_id"/>
                    <field name="saltedge_account_id" nolabel="1" readonly="1"/>
                    <label for="online_bank_provider_id" string="Provider"
                           invisible="online_bank_provider_id == False"/>
                    <field name="online_bank_provider_id" nolabel="1" invisible="online_bank_provider_id == False"
                            readonly="1"/>
                </group>
            </xpath>
        </field>
    </record>

</odoo>

