                    <notebook>
                        <page string="Expense Board" name="expense_board" invisible="not depreciation_move_ids" autofocus="autofocus">
                            <field name="depreciation_move_ids">
                                <tree decoration-info="state == 'draft'" create="0"  default_order="asset_date asc, id asc" editable="top">
                                    <field name="asset_date" string="Expense Date"/>
                                    <field name="state" column_invisible="1"/>
                                    <field name="company_id" column_invisible="1"/>
                                    <field name="asset_amount" string="Expense"/>
                                    <field name="asset_residual_amount" string="Recognized expense"/>
                                    <field name="total_residual" string="Residual"/>
                                    <field name="asset_days" column_invisible="1"/>
                                    <field name="name" string="Journal Entry"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Related Expenses" name="related_expenses">
                            <field name="invoice_line_ids" readonly="state in ('posted', 'close')"
                                   domain="[('parent_state', '=', 'posted'), ('credit', '=', '0'),
                                   ('company_id', '=', company_id),
                                   ('account_type', 'in', ('asset_current', 'asset_prepayments'))]"
                                   context="{'disable_preview': 1, 'tree_view_ref': 'account_asset.view_move_line_tree_asset'}">
                                <tree create="0">
                                    <field name="date"/>
                                    <field name="account_id"/>
                                    <field name="name"/>
                                    <field name="debit" widget="monetary"/>
