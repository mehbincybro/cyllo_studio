<?xml version="1.0" encoding="utf-8"?>

<odoo>
    <record id="view_account_move_line_tree" model="ir.ui.view">
        <field name="name">view.account.move.line.tree</field>
        <field name="model">account.move.line</field>
        <field name="inherit_id" ref="account.view_move_line_tree" />
        <field name="mode">primary</field>
        <field name="arch" type="xml">
            <xpath expr="//tree" position="attributes">
                <attribute name="js_class">reconcile_one2many_click</attribute>
            </xpath>
        </field>
    </record>

    <record id="view_account_move_line_tree" model="ir.ui.view">
        <field name="name">view.account.move.line.tree</field>
        <field name="model">account.move.line</field>
        <field name="arch" type="xml">
            <tree>
                <field name="account_id"/>
                <field name="partner_id"/>
                <field name="date"/>
                <field name="invoice_date"/>
                <field name="move_id"/>
                <field name="name"/>
                <field name="date_maturity"/>
                <field name="amount_residual"/>
            </tree>
        </field>
    </record>
    <record id="view_account_move_line_search" model="ir.ui.view">
        <field name="name">view.account.move.line.search</field>
        <field name="model">account.move.line</field>
        <field name="inherit_id" ref="account.view_account_move_line_filter"/>
        <field name="mode">primary</field>
        <field name="arch" type="xml">
            <xpath expr="//separator" position="before">
                <separator/>
                <filter string="Journals" name="journal_ids_in"
                        domain="[('journal_id', 'in', context.get('journal_ids'))]" invisible="1"/>
                 <separator/>
                <filter string="Account" name="account_ids_in"
                        domain="[('account_id', 'in', context.get('account_ids'))]" invisible="1"/>
                <separator/>
                <filter string="Taxes" name="tax_ids_in"
                        domain="[('tax_ids', 'in', context.get('tax_ids'))]" invisible="1"/>
            </xpath>
            <xpath expr="//searchpanel" position="replace">
                <searchpanel class="account_root">
                    <field name="account_root_id" icon="fa-filter" groupby="account_id" limit="0"/>
                </searchpanel>
            </xpath>
        </field>
    </record>
</odoo>