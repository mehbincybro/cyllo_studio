<odoo>
    <record id="view_tax_return_wizard_form" model="ir.ui.view">
        <field name="name">tax.return.wizard.form</field>
        <field name="model">tax.return.wizard</field>
        <field name="arch" type="xml">
            <form string="Tax Return">
                <group>
                    <group>
                        <field name="periodicity"/>
                        <field name="journal_id"/>
                    </group>
                    <group col="2">
                        <field name="date_from"/>
                        <field name="date_to"/>
                    </group>
                </group>
                <footer>
                    <button name="action_apply"
                            string="Apply"
                            type="object"
                            class="btn-primary"/>
                    <button string="Cancel"
                            special="cancel"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_tax_return_wizard" model="ir.actions.act_window">
        <field name="name">Tax Returns</field>
        <field name="res_model">tax.return.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_tax_return_wizard_form"/>
        <field name="target">new</field>
    </record>
</odoo>