<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!-- Wizard Form View -->
    <record id="view_account_move_lock_form" model="ir.ui.view">
        <field name="name">account.move.lock.form</field>
        <field name="model">account.move.lock</field>
        <field name="arch" type="xml">
            <form string="Configuration">
                <sheet>
                    <div class="alert alert-warning" role="alert" invisible="not has_draft_entries">
                        <strong>You have draft entries in the given period, Please post or delete them</strong>
                        <button name="action_open_draft_entries" type="object" class="btn btn-link">
                            <b><i>-> drafts</i></b>
                        </button>
                    </div>
                    <div class="text-muted">
                        <i>Lock transactions up to specific dates, inclusive</i>
                    </div>
                    <hr/>
                    <group>
                        <field name="company_id" invisible="1"/>
                        <field name="fiscal_year_id" invisible="1"/>
                        <group>
                            <field name="sale_lock_date"/>
                            <field name="purchase_lock_date"/>
                        </group>
                        <group>
                            <field name="all_lock_date"/>
                            <field name="has_draft_entries" invisible="1"/>
                        </group>
                    </group>
                </sheet>
                <footer>
                    <button string="Close Fiscal Year"
                            name="action_close"
                            type="object"
                            invisible="not fiscal_year_id"
                            class="btn btn-primary"/>
                    <button string="Save"
                            name="action_save"
                            type="object"
                            class="btn btn-primary"/>
                    <button string="Cancel"
                            class="btn btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Wizard Action -->
    <record id="action_view_account_move_lock_wizard" model="ir.actions.act_window">
        <field name="name">Close Entries</field>
        <field name="res_model">account.move.lock</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
