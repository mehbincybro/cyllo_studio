<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_account_asset_modify_form" model="ir.ui.view">
        <field name="name">view.account.asset.modify.form</field>
        <field name="model">account.asset.modify</field>
        <field name="arch" type="xml">
            <form string="Re-evaluate">
                <group  col="4">
                    <group colspan="2" col="2">
                        <field name="asset_id" invisible="1"/>
                        <field name="residual_value" required="1"/>
                    </group>
                    <group colspan="2" col="2">
                        <field name="company_id" invisible="1"/>
                        <field name="currency_id" invisible="1"/>
                        <field name="name"/>
                    </group>
                </group>

                <footer>
                    <button name="action_modify" string="Modify" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-default" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
    <record id="action_view_account_asset_modify" model="ir.actions.act_window">
         <field name="name">Re-evaluate</field>
         <field name="res_model">account.asset.modify</field>
         <field name="type">ir.actions.act_window</field>
         <field name="view_mode">form</field>
         <field name="view_id" ref="view_account_asset_modify_form"/>
         <field name="target">new</field>
   </record>
</odoo>
