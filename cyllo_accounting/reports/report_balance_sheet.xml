                                       t-as="periodData"
                                       t-key="periodData_index">
                                        <th class="text-end">
                                            <t t-esc="periodData"/>
                                        </th>
                                    </t>
                                </t>
                            </tr>
                            <tr class="o_heading">
                                <th colspan="9"/>
                                <t t-if="data['periods']">
