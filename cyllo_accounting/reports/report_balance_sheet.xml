                                        t-key="amountIncome_index" class="text-end">
                                        <span>
                                            <t t-out="currency_symbol[0]"/>
                                            <span class="mx-1" t-esc="amountIncome['format_amount']"/>
                                        </span>
                                    </td>
                                </tr>
                            </t>
                            <tr class="border-bottom border-gainsboro">
                                <th colspan="9" style="font-weight: normal;">
                                    <span class="ms-4">Total Unallocated Earnings</span>
                                </th>
                                <td t-foreach="pdf_data[0]" t-as="data" t-key="data_index" class="text-end">
                                    <span>
                                        <t t-if="data['total_unallocated_earning']">
                                            <t t-out="data['currency_symbol']"/>
                                            <span class="mx-1" t-esc="data['total_unallocated_earning']"/>
                                        </t>
                                    </span>
                                </td>
                            </tr>
                            <tr class="border-bottom border-gainsboro">
                                <th colspan="9" style="font-weight: normal;">
                                    <span class="ms-4">Retained
                                        Earnings
                                    </span>
                                </th>
                                <td t-foreach="pdf_data[0]" t-as="data" t-key="data_index" class="text-end">
                                    <span>
                                        <t t-if="data['equity'] and data['equity'][2] != 0">
                                            <t t-out="data['currency_symbol']"/>
                                            <span class="mx-1" t-esc="data['equity'][1]"/>
                                        </t>
                                    </span>
                                </td>
                            </tr>
                            <t t-set="account_lines"
                               t-value="self.get_account_lines('equity', pdf_data)"/>
                            <t t-if="len(account_lines) != 0">
                                <tr t-if="len(account_lines) != 0" t-foreach="account_lines[0][0]" t-as="account"
                                    t-key="account_index" class="border-bottom border-gainsboro cy-report-line-acc">
                                    <t t-set="accAmountIncome"
                                       t-value="self.get_account_line(account['id'], account_lines)"/>
                                    <th t-if="len(accAmountIncome)" colspan="9" style="font-weight: normal;">
                                        <span class="ms-5" t-esc="account['name']"/>
                                    </th>
                                    <td t-if="len(accAmountIncome)" t-foreach="accAmountIncome" t-as="amountIncome"
                                        t-key="amountIncome_index" class="text-end">
                                        <span>
                                            <t t-out="currency_symbol[0]"/>
                                            <span class="mx-1" t-esc="amountIncome['format_amount']"/>
                                        </span>
                                    </td>
                                </tr>
                            </t>
                            <tr class="border-bottom border-gainsboro">
                                <th colspan="9" style="font-weight: normal;">
                                    <span class="ms-4">Total EQUITY</span>
                                </th>
                                <td t-foreach="pdf_data[0]" t-as="data" t-key="data_index" class="text-end">
                                    <span>
                                        <t t-if="data['total_equity']">
                                            <t t-out="data['currency_symbol']"/>
                                            <span class="mx-1" t-esc="data['total_equity']"/>
                                        </t>
                                    </span>
                                </td>
                            </tr>
                            <tr class="border-bottom border-gainsboro">
                                <th colspan="9" style="font-weight: normal;">
                                    <span class="ms-4">LIABILITIES + EQUITY</span>
                                </th>
                                <td t-foreach="pdf_data[0]" t-as="data" t-key="data_index" class="text-end">
                                    <span>
                                        <t t-if="data['total_balance']">
                                            <t t-out="data['currency_symbol']"/>
                                            <span class="mx-1" t-esc="data['total_balance']"/>
                                        </t>
                                    </span>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </t>
        </t>
    </template>
</odoo>