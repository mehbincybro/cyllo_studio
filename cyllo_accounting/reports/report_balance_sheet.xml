<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_balance_sheet">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <t t-set="data_report_margin_top" t-value="12"/>
                <t t-set="data_report_header_spacing" t-value="9"/>
                <t t-set="data_report_dpi" t-value="110"/>
                <div class="page">
                    <h3>
                        <center>
                            <b>
                                <span t-esc="report_name"/>
                            </b>
                        </center>
                    </h3>
                    <br/>
                    <br/>
                    <div class="filters">
                        <table class="table table-sm table-reports">
                            <thead class="filter_table"
                                   style="background:#FFFFFF;">
                                <tr>
                                    <th>Date Range</th>
                                    <th>Comparison</th>
                                    <th>Account</th>
                                    <th>Journal</th>
                                    <th>Analytic Account</th>
                                    <th>Target move</th>
                                </tr>
                            </thead>
                            <tbody style="font-size:11px;font-weight:100;">
                                <tr>
                                    <th>
                                        <t t-if="filter_by">
                                            <t t-esc="filter_by"/>
                                        </t>
                                    </th>
                                    <th>
                                        <t t-if="comparison_type">
                                            <t t-if="comparison">
                                                <t t-esc="comparison_type"/>
                                                :
                                                <t t-esc="comparison"/>
                                            </t>
                                        </t>
                                    </th>
                                    <th>
                                        <t t-if="accounts">
                                            <t t-esc="','.join(accounts)"/>
                                        </t>
                                    </th>
                                    <th>
                                        <t t-if="journals">
                                            <t t-esc="','.join(journals)"/>
                                        </t>
                                    </th>
                                    <th>
                                        <t t-if="journals">
                                            <t t-esc="','.join(account_analytic)"/>
                                        </t>
                                    </th>
                                    <th>
                                        <t t-if="data['filterData']['target_move']">
                                            <t t-esc="','.join(data['filterData']['target_move'])"/>
                                        </t>
                                    </th>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                    <br/>
                    <br/>
                    <br/>
                    <table cellspacing="0" width="100%"
                           style="border: 1px solid white; text-align: left;">
