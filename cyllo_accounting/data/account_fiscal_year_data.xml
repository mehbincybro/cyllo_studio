<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data noupdate="1">
        <record id="account_fiscal_year_current" model="account.fiscal.year">
            <field name="name" eval="DateTime.today().year"/>
            <field name="start_date" eval="(DateTime(DateTime.today().year, 1, 1))"/>
            <field name="end_date" eval="(DateTime(DateTime.today().year, 12, 31))"/>
            <field name="state">open</field>
        </record>
    </data>
</odoo>