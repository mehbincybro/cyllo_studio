<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="account_asset_asset_multi_company_rule" model="ir.rule">
        <field name="name">Deferred revenue/expense multi-company</field>
        <field ref="model_account_asset_asset" name="model_id"/>
        <field eval="True" name="global"/>
        <field name="domain_force">['|',('company_id','=',False),('company_id', 'in',
            company_ids)]
        </field>
    </record>

