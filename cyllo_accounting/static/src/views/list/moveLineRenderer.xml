<?xml version="1.0" encoding="UTF-8" ?>
<templates>
    <t t-name="MoveLineRenderer" t-inherit="web.ListRenderer" t-inherit-mode="primary">
        <xpath expr="//th[hasclass('o_list_record_selector')]" position="after">
            <th/>
        </xpath>
    </t>
    <t t-name="MoveLineRenderer.RecordRaw" t-inherit="web.ListRenderer.RecordRow" t-inherit-mode="primary">
        <xpath expr="//td[hasclass('o_list_record_selector')]" position="after">
            <td >
                <button t-on-click="() => this.handleViewClick(record)" type="button" class="btn btn-secondary">View</button>
            </td>
        </xpath>
    </t>
</templates>