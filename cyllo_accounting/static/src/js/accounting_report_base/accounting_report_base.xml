<?xml version="1.0" encoding="UTF-8" ?>
<templates id="template" xml:space="preserve">
    <t t-name="AccountingReportBase">
        <div t-ref="root" class="w-100 cy_accounting_report_main">
            <div class="cy_accounting_sub">
                <div class="filter_view_dfr p-2">
                    <div class="cy-accounting_title-div">
                        <h1 class="p-1">
                            <div class="d-flex flex-column gap-3 gap-lg-1 px-3 pt-2 pb-3">
                                <div class="o_control_panel_breadcrumbs d-flex align-items-center gap-1 order-0 h-lg-100">
                                    <div class="o_cp_top">
                                        <div class="o_cp_top_left d-flex flex-grow-1 align-items-center cy_accounting_report_title">
                                            <t t-if="breadCrumbs">
                                                <span t-out="breadCrumbs" class="on-h-blue cursor-pointer" t-on-click="onClickBreadCrumbs"/>
                                                <span class="mx-1"/>/
                                                <span class="mx-1" t-out="reportName"/>
                                            </t>
                                            <t t-else="" t-out="reportName"/>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </h1>
                    </div>
                    <div class="cy_accounting_filters-main d-flex mx-2 cy_accounting_filters-main-side-bar" t-attf-class="{{ uiState.isSideBarActive ? sidebarClass.on : sidebarClass.off}}">
                        <div class="cy_accounting_report_print">
                            <button t-if="pdfReport" type="button"
                                    class="btn btn-primary btn-report-print"
                                    t-on-click="printPDF">
                                    Print (PDF)
                            </button>
                            <button type="button"
                                    class="btn btn-primary btn-report-print"
                                    t-on-click="printXLSX">
                                    Export (XLSX)
                            </button>
                        </div>
                        <div class="cy_accounting_filters_sub d-flex">
<!--                            Filters are to be added here-->
                        </div>
                    </div>
                </div>
            </div>
            <br/>
            <div class="cy_filtered_data-body" t-attf-class="{{ uiState.isSideBarActive ? sidebarClass.bodyOn : sidebarClass.bodyOff}}">
                <div class="cy_div-body_sheet cy_div-table-body_sheet">
                    <div>
                        <div class="cy_table_main-view" >
<!--                Datas are to be added here-->
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </t>
</templates>