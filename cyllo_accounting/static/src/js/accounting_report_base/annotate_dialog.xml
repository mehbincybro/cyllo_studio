<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <!-- AnnotateDialog: A template for displaying a dialog for adding annotations -->
    <t t-name="AnnotateDialog">
    <Dialog size="'md'" title="props.title">
      <textarea type="text" t-model="state.message" class="p-2"
                placeholder="Note an annotation here"/>
        <t t-set-slot="footer">
        <button class="btn btn-primary"
                t-on-click="onConfirm">Save</button>
      </t>
    </Dialog>
  </t>
</templates>
