<?xml version="1.0" encoding="UTF-8" ?>
<templates id="template" xml:space="preserve">
    <t t-name="TaxReport" t-inherit="cyllo_accounting.AccountingReportBase" t-inherit-mode="primary">
        <xpath expr="//div[hasclass('cy_accounting_filters_sub')]" position="inside">
            <t t-call="TaxHeaderButtons"/>
        </xpath>
        <xpath expr="//div[hasclass('cy_table_main-view')]" position="inside">
            <div>
                <div class="table_view_dfr table_view_dfr_tax">
                    <div>
                        <div class="table_main_view">
                            <t t-call="TableData"/>
                        </div>
                    </div>
                </div>
            </div>
        </xpath>
    </t>

    <t t-name="TaxTableData">
        <t t-foreach="getTableData" t-as="key" t-key="key_index">
            <tr class="border-bottom cy-report-line-acc" style="border-spacing: 0 10px;background:#dfdfdf;"><th scope="row" colspan="100%"><span style="font-size: 16px;" t-out="key.key === 'sale'? 'Sales' : 'Purchase'"/></th></tr>
            <t t-foreach="key.data" t-as="line" t-key="line_index">
                <tr class="h-2-rem cy-report-line-acc">
                    <th colspan="100%" scope="row">
                        <div class="d-flex">
                            <t t-out="line.display_name"/>
                            <t t-set="annot"
                                            t-value="line.annotations and line.annotations.hasOwnProperty(ledgerId) ? line.annotations[ledgerId] : ''"/>
                            <t t-call="TaxMenu">
                                <t t-set="tax" t-value="line"/>
                                <t t-set="annotation" t-value="annot"/>
                            </t>
                            <t t-call="AnnotationsTemplate">
                                <t t-set="tax" t-value="line"/>
                                <t t-set="annotation" t-value="annot"/>
                            </t>
                        </div>
                    </th>
                </tr>
                <t t-foreach="line.values" t-as="value" t-key="value_index">
                    <tr class="h-2-rem">
                        <th t-out="value.account.name"/>
                        <th colspan="5" />
                        <t t-foreach="value.values" t-as="val" t-key="val_index">
                            <th class="text-center">
                                <div class="row">
                                    <div  class="col-6" t-out="val.net"/>
                                    <div  class="col-6" t-out="val.tax"/>
                                </div>
                            </th>
                        </t>
                    </tr>
                </t>
            </t>
            <tr class="h-2-rem border-bottom cy-report-line-acc" style="border-spacing: 0 10px;">
                <th><t t-out="key.key === 'sale' ? 'Sales ' : 'Purchase '"/> Total</th>
                <th colspan="5"/>
                <t t-foreach="key.totals" t-as="total" t-key="total_index">
                    <th class="text-center">
                        <div class="row">
                            <div class="col-6" t-out="total.net"/>
                            <div class="col-6" t-out="total.tax"/>
                        </div>
                    </th>
                </t>
            </tr>
        </t>
    </t>

    <t t-name="AccountTableData">
        <t t-foreach="getTableData" t-as="key" t-key="key_index">
            <tr class="h-2-rem border-bottom cy-report-line-acc" style="border-spacing: 0 10px;background:#dfdfdf;"><th scope="row" colspan="100%"><span style="font-size: 16px;" t-out="key.key === 'sale'? 'Sales' : 'Purchase'"/></th></tr>
            <t t-foreach="key.data" t-as="line" t-key="line_index">
                <tr class="h-2-rem">
                    <th colspan="100%" scope="row"><t t-out="line.account.name"/></th>
                </tr>
                <t t-foreach="line.values" t-as="value" t-key="value_index">
                    <tr class="h-2-rem cy-report-line-acc">
                        <th>
                            <div class="d-flex">
                                <t t-out="value.display_name"/>
                                <t t-set="annot"
                                            t-value="value.annotations and value.annotations.hasOwnProperty(ledgerId) ? value.annotations[ledgerId] : ''"/>
                                <t t-call="TaxMenu">
                                    <t t-set="tax" t-value="value"/>
                                    <t t-set="annotation" t-value="annot"/>
                                </t>
                                <t t-call="AnnotationsTemplate">
                                    <t t-set="tax" t-value="value"/>
                                    <t t-set="annotation" t-value="annot"/>
                                </t>
                            </div>
                        </th>
                        <th colspan="5" />
                        <t t-foreach="value.values" t-as="val" t-key="val_index">
                            <th class="text-center">
                                <div class="row">
                                    <div class="col-6" t-out="val.net"/>
                                    <div class="col-6" t-out="val.tax"/>
                                </div>
                            </th>

                        </t>
                    </tr>

                </t>
            </t>
            <tr class=" h-2-rem border-bottom cy-report-line-acc" style="border-spacing: 0 10px;">
                <th><t t-out="key.key === 'sale' ? 'Sales ' : 'Purchase '"/> Total</th>
                <th colspan="5"/>
                <t t-foreach="key.totals" t-as="total" t-key="total_index">
                    <th class="text-center">
                        <div class="row">
                            <div class="col-6" t-out="total.net"/>
                            <div class="col-6" t-out="total.tax"/>
                        </div>
                    </th>
                </t>
            </tr>
            <tr/>
        </t>
    </t>

    <t t-name="GenericTableData">
        <t t-foreach="getTableData" t-as="data" t-key="data_index">
            <tr class="h-2-rem border-bottom cy-report-line-acc" style="border-spacing: 0 10px;background:#dfdfdf;">
                <th colspan="100%">
                    <span style="font-size: 16px;" t-out="data.key === 'sale' ? 'Sales ' : 'Purchase '"/>
                </th>
            </tr>
            <t t-foreach="data.values" t-as="value" t-key="value_index">
                <tr class="h-2-rem cy-report-line-acc">
                    <th>
                        <div class="d-flex">
                            <t t-esc="value.display_name"/>
                            <t t-set="annot"
                                            t-value="value.annotations and value.annotations.hasOwnProperty(ledgerId) ? value.annotations[ledgerId] : ''"/>
                            <t t-call="TaxMenu">
                                <t t-set="annotation" t-value="annot"/>
                                <t t-set="tax" t-value="value"/>
                            </t>
                            <t t-call="AnnotationsTemplate">
                                <t t-set="tax" t-value="value"/>
                                <t t-set="annotation" t-value="annot"/>
                            </t>

                        </div>
                    </th>
                    <th colspan="5"/>
                    <t t-foreach="value.values" t-as="val" t-key="val_index">
                        <th class="text-center">
                            <div class="row">
                                <div class="col-6"><t t-esc="val.net"/></div>
                                <div class="col-6"><t t-out="val.tax"/></div>
                            </div>
                        </th>
                    </t>

                </tr>
            </t>
            <tr class="h-2-rem border-bottom cy-report-line-acc" style="border-spacing: 0 10px;">
                <th><span t-out="data.key === 'sale' ? 'Sales ' : 'Purchase '"/>Total</th>
                <th colspan="5"/>
                <t t-foreach="data.totals" t-as="total" t-key="total_index">
                    <th class="text-center">
                        <div class="row">
                            <div class="col-6"><t t-esc="total.net"/></div>
                            <div class="col-6"><t t-out="total.tax"/></div>
                        </div>
                    </th>
                </t>
            </tr>
        </t>
    </t>

    <t t-name="TableData">
        <table cellspacing="0" class="table table-striped table-hover" width="100%">
            <thead>
                <tr class="o_heading">
                    <th colspan="6" />
                    <th t-foreach="periodData" t-as="period" t-key="period_index" class="text-center" t-out="period" />
                </tr>
                <tr class="o_heading">
                    <th colspan="6" />
                    <th t-foreach="periodData" t-as="period" t-key="period_index" class="text-center">
                        <div class="row">
                            <div class="col-6">NET</div>
                            <div class="col-6">TAX</div>
                        </div>
                    </th>
                </tr>
            </thead>
            <tbody>
                <t t-if="filters.report_type === 'generic'">
                    <t t-call="GenericTableData"/>
                </t>
                <t t-elif="filters.report_type === 'account'">
                    <t t-call="AccountTableData"/>
                </t>
                <t t-elif="filters.report_type === 'tax'">
                    <t t-call="TaxTableData"/>
                </t>
            </tbody>
        </table>
    </t>

    <t t-name="TaxHeaderButtons">
        <t t-call="dateRange">
            <t t-set="dateFilterTemplate" t-value="'toAndFromDateFilter'"/>
            <t t-set="separateAt" t-value="3"/>
        </t>
        <t t-call="reportComparison"/>
        <div class="drop search_Target_move" style="">
            <Dropdown togglerClass="'btn dropdown-toggle'">
                <t t-set-slot="toggler">
                    <span class="fa fa-filter"/>
                    Options:
                    <span t-if="!state.draft">Posted Entries</span>
                    <span t-elif="state.draft">Include Draft &amp; Posted Entries</span>
                    <span class="target"/>
                </t>
                <DropdownItem class="'btn d-flex align-items-center px-2 py-2 m-0'" onSelected="() => this.toggleDraftEntries(!state.draft)">
                        <i t-if="state.draft" class="ri-check-line"/>
                        <span class="mx-2">
                            Include Draft Entries
                        </span>
                </DropdownItem>
            </Dropdown>
        </div>
        <div class="drop search_Target_move" style="">
            <Dropdown togglerClass="'btn dropdown-toggle'">
                <t t-set-slot="toggler">
                    <span class="fa fa-book"/>
                    Reports:<span class="mx-2" t-out="reportTypes[filters.report_type]"/>
                    <span class="target"/>
                </t>
                <t t-foreach="reportTypes" t-as="type" t-key="type_index">
                    <DropdownItem
                          class="'btn d-flex align-items-center px-2 py-2 m-0'"
                          onSelected="() => this.onChangeReportType(type)">
                        <i t-if="type === filters.report_type" class="ri-check-line"/>
                        <span class="mx-2" t-out="reportTypes[type]"/>
                    </DropdownItem>
                </t>
            </Dropdown>
        </div>
    </t>

    <t t-name="TaxMenu">
        <Dropdown class="'border_unset_button'">
             <t t-set-slot="toggler">
                <span class="mx-2 fa fa-caret-down"/>
             </t>
             <DropdownItem
                     onSelected="() => this.viewJournalItems(tax.tax_id)">
                    Journal Items
             </DropdownItem>
             <DropdownItem
                     onSelected="() => this.openAnnotation(tax.tax_id, annotation, tax.display_name)">
                    Annotation
             </DropdownItem>
         </Dropdown>
    </t>

    <t t-name="AnnotationsTemplate">
        <div t-on-click="() => this.openAnnotation(tax.tax_id, annotation, tax.display_name)"
              t-if="annotation" class="mx-2 cursor-pointer position-relative">
             <div class="cy-annotation-tooltip">
                <span class="ri-ball-pen-line"/>
             </div>
             <div class="cy-annotation-tooltip-content justify-content-around modal_background position-absolute"
                  t-out="annotation"/>
        </div>
        <div class="mx-1 delete-on-h-show ri-delete-bin-6-line on-h-red cursor-pointer"
             t-if="annotation"
             t-on-click="() => this.removeAnnotation(tax.tax_id, tax.display_name)"/>
    </t>

</templates>
