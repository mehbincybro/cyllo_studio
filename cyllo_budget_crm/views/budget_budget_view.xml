<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!--    Defines the Inherited View of budget lines-->
    <record id="view_budget_budget_form" model="ir.ui.view">
        <field name="name">view.budget.budget.</field>
        <field name="model">budget.budget</field>
        <field name="inherit_id" ref="cyllo_budget_management.view_budget_budget_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='analytic_account_id']" position="after">
                <field name="crm_team_member_id" />
                <field name="crm_achievement" column_invisible="1" />
            </xpath>
        </field>
    </record>
</odoo>