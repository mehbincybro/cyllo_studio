<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="ir_model_tabs_view_tree" model="ir.ui.view">
        <field name="name">ir.model.tabs.view.tree</field>
        <field name="model">ir.model.tabs</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="string"/>
                <field name="model_id" context="{'model': True}"/>
            </tree>
        </field>
    </record>

    <record id="action_ir_model_tabs" model="ir.actions.act_window">
        <field name="name">Tabs</field>
        <field name="res_model">ir.model.tabs</field>
        <field name="view_mode">tree</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face"></p>
        </field>
    </record>
</odoo>
