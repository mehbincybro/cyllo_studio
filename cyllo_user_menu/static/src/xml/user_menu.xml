<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-inherit="web.UserMenu" t-inherit-mode="extension" owl="1">
        <xpath expr="//Dropdown" position="replace">
            <ul class="navbar-menu cy-user-menu cy-navbar-menu">
                <li class="dropdown">
                    <a class="nav-link cy-nav-links d-flex align-items-center"
                       href="#" data-bs-toggle="dropdown">
                        <span t-esc="user.name"/>
                        <img class="profile-pic me-2" t-att-src="source" alt="User" style="width: 35px; border-radius:3px;"/>
                    </a>
                    <div class="dropdown-content cy_user_menu_dropdown dropdown collapse dropdown-menu" t-ref="dropdown" id="user_menu"
                         style="max-width:88%;">
                        <p class="dropdown-item" href="#" t-on-click="handleClick" >
                            <i class="fa fa-database oi-small me-1"/><t t-esc="user.db.name"/>
                        </p>
                        <hr/>
                        <a  class="dropdown-item" t-on-click="profile">
                            View Account
                        </a>
                        <a class="dropdown-item" href="#" t-on-click="shortCut">
                            Shortcut
                            <button class="btn btn-secondary" disabled="True"><t t-esc="command"/></button>
                        </a>
                        <div class="content_footer">
                            <hr/>
                            <DropdownItem>
                                <a class="ri-logout-box-r-line" href="/web/session/logout" t-on-click="logOut">
                                    Sign Out
                                </a>
                            </DropdownItem>
                        </div>
                    </div>
              </li>
            </ul>
        </xpath>
    </t>
</templates>