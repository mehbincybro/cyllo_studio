<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="helpdesk_ticket_view_form_inherit_sale" model="ir.ui.view">
        <field name="name">helpdesk.ticket.view.form.inherit.sale</field>
        <field name="model">helpdesk.ticket</field>
        <field name="inherit_id" ref="cyllo_help_desk.helpdesk_ticket_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header/field[@name='stage_id']" position="before">
                <button name="action_create_sale_order" type="object" string="Create Sales Order" invisible="not customer_id or not use_sale_order"/>
            </xpath>
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_sale_orders" type="object" class="oe_stat_button" icon="fa-usd" invisible="not use_sale_order or sale_order_count == 0">
                    <field name="sale_order_count" widget="statinfo" string="Sales Orders"/>
                </button>
                <button name="action_view_customer_sale_orders" type="object" class="oe_stat_button" icon="fa-usd" invisible="not use_sale_order or customer_sale_order_count == 0">
                    <field name="customer_sale_order_count" widget="statinfo" string="Customer Sales"/>
                </button>
            </xpath>
            <xpath expr="//field[@name='company_id']" position="after">
                 <field name="sale_order_id" domain="[('partner_id', 'child_of', customer_id), ('state', 'in', ['sale', 'done'])]" invisible="not use_sale_order"/>
                 <field name="sale_order_line_id" domain="[('order_id', '=', sale_order_id)]" invisible="not sale_order_id"/>
            </xpath>
            <xpath expr="//group[@invisible='1']" position="inside">
                <field name="sale_order_ids" invisible="1"/>
            </xpath>
        </field>
    </record>
</odoo>
