<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Company rule for cyllo office connector-->
    <record id="rule_cyllo_office_connector_company" model="ir.rule">
        <field name="name">Office Connector Multi Company</field>
        <field name="model_id" ref="model_cyllo_office_connector"/>
        <field name="global" eval="True"/>
        <field name="domain_force">[('company_id', 'in', company_ids +
            [False])]
        </field>
    </record>
</odoo>
