<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!-- Inherited form view of res.partner and an action -->
    <record id="view_res_partner_form" model="ir.ui.view">
        <field name="name">view.res.partner.form</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='sales_purchases']" position="after">
                <page string="Office 365" name="office_365">
                    <field name="office_connectors_ids" nolabel="1"
                           readonly="1">
                        <tree>
                            <field name="partner_id"/>
                            <field name="connector_id"/>
                            <field name="office_365_identifier"/>
                        </tree>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
    <record id="action_view_customers" model="ir.actions.act_window">
        <field name="name">Customers</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">kanban,tree,form</field>
    </record>
</odoo>