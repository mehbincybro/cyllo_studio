<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_advance_payment_form" model="ir.ui.view">
        <field name="name">view.advance.payment.form</field>
        <field name="model">advance.payment</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="communication"/>
                            <label string="Advance PayAmount" for="pay_amount"/>
                            <div class="oe_inline">
                                <field name="pay_amount" class="oe_inline"/>
                                <field name="currency_id" options="{'no_create': True, 'no_create_edit':True, 'no_open':True}" class="oe_inline"/>
                            </div>
                            <field name="total_amount" readonly="1"/>
                            <field name="amount_difference" readonly="1"/>
                        </group>
                        <group>
                            <field name="payment_method_line_id" options="{'no_create': True, 'no_create_edit':True}"/>
                            <field name="journal_id" options="{'no_create': True, 'no_create_edit':True}" domain="[('type','in',['bank', 'cash'])]"/>
                            <field name="date"/>
                            <field name="company_id" readonly="1"/>
                        </group>
                    </group>
                    <footer>
                        <button name="action_validate_payment" type="object" string="Advance Payment" class="oe_highlight"/>
                        <button string="Cancel" class="btn-default" special="cancel"/>
                    </footer>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_view_advance_payment_action" model="ir.actions.act_window">
        <field name="name">Advance Payment</field>
        <field name="res_model">advance.payment</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>