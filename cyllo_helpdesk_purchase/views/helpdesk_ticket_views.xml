<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="helpdesk_ticket_view_form_inherit_purchase" model="ir.ui.view">
        <field name="name">helpdesk.ticket.view.form.inherit.purchase</field>
        <field name="model">helpdesk.ticket</field>
        <field name="inherit_id" ref="cyllo_help_desk.helpdesk_ticket_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_customer_purchase_orders" type="object" class="oe_stat_button" icon="fa-shopping-cart" invisible="customer_purchase_order_count == 0">
                    <field name="customer_purchase_order_count" widget="statinfo" string="Customer Purchases"/>
                </button>
            </xpath>
        </field>
    </record>
</odoo>
