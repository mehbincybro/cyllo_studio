<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_shortcut_menu_form" model="ir.ui.view">
        <field name="name">view.shortcut.menu.form</field>
        <field name="model">shortcut.menu</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="window_action_id"/>
                        <field name="client_action_id"/>
                        <field name="menu_id"/>
                        <field name="res_model"/>
                        <field name="xml_id"/>
                        <field name="model"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_shortcut_menu_tree" model="ir.ui.view">
        <field name="name">view.shortcut.menu.tree</field>
        <field name="model">shortcut.menu</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="window_action_id"/>
                <field name="client_action_id"/>
                <field name="menu_id"/>
                <field name="res_model"/>
                <field name="xml_id"/>
                <field name="model"/>
            </tree>
        </field>
    </record>

    <record id="action_view_shortcut_menus" model="ir.actions.act_window">
        <field name="name">Shortcut Menus</field>
        <field name="res_model">shortcut.menu</field>
        <field name="context">{'create': False,'edit':False}</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>