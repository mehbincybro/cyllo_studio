<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_login_user_detail_form" model="ir.ui.view">
        <field name="name">view.login.user.detail.form</field>
        <field name="model">login.user.detail</field>
        <field name="arch" type="xml">
        <form>
            <sheet>
                <group>
                    <field name="name"/>
                    <field name="date_time"/>
                    <field name="ip_address"/>
                </group>
            </sheet>
        </form>
        </field>
    </record>

    <record id="view_login_user_detail_tree" model="ir.ui.view">
        <field name="name">view.login.user.detail.tree</field>
        <field name="model">login.user.detail</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="date_time"/>
                <field name="ip_address"/>
            </tree>
        </field>
    </record>

    <record id="action_view_login_details" model="ir.actions.act_window">
        <field name="name">Login User Details</field>
        <field name="res_model">login.user.detail</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>