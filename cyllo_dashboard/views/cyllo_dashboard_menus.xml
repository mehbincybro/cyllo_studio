<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!-- Define an action for the "Dashboard" -->
    <record id="action_cy_user_dashboard" model="ir.actions.client">
        <field name="name">User Dashboard</field>
        <field name="tag">cyllo_user_dashboard</field>
        <field name="target">current</field>
    </record>
    <menuitem id="menu_cyllo_dashboard_root"
              name="User Dashboard"
              sequence="0"/>
    <menuitem id="menu_dashboard"
              name="Dashboard"
              parent="menu_cyllo_dashboard_root"
              action="action_cy_user_dashboard"
              sequence="0"/>
    <menuitem id="menu_login_details" name="Login Details"
              parent="base.menu_users"
              action="action_view_login_details"/>
    <menuitem id="menu_shortcut_menus" name="Shortcut Menus"
              parent="base.menu_users"
              action="action_view_shortcut_menus"/>
</odoo>