<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_change_password_own_form" model="ir.ui.view">
        <field name="name">view.change.password.own.form</field>
        <field name="model">change.password.own</field>
        <field name="arch" type="xml">
            <form string="Change Password">
                <group>
                    <field name="old_password" password="True" required="1"/>
                    <field name="new_password" password="True" required="1"/>
                    <field name="confirm_password" password="True"
                           required="1"/>
                </group>
                <footer>
                    <button string="Change Password"
                            name="action_change_password_dashboard"
                            type="object" class="change-pwd-btn btn-primary"
                            data-hotkey="q"/>
                    <button string="Cancel" class="btn-secondary"
                            special="cancel" data-hotkey="x"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>