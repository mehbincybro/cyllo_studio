<?xml version="1.0" encoding="UTF-8" ?>
<templates id="template" xml:space="preserve">
    <t t-name="UserDashboard" owl="1">
        <div t-if="session.is_admin" class="cyllo_user_dashboard w-100" t-ref="root">
            <div class="cyllo_user_dashboard-row row m-0">
                <div class="col-lg-2 p-0">
                        <div class="cy-box_container p-3  h-100">
                            <div class="cy-userdashboard_user-container mb-3">
                                <img t-if="this.state.userProfile.image" class="cy-img"
                                 t-att-src="'data:image/png;base64,'+this.state.userProfile.image"
                                 alt=""/>
                                <img t-else="" class="cy-img"
                                     src="/cyllo_dashboard/static/src/img/dummy.jpg"
                                     alt=""/>
                            </div>
                            <div class="cy-userdashboard_user-detail w-100">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div>
                                        <h2 class="cy-userdashboard-name mb-1"><t t-esc="this.state.userProfile.name"/></h2>
                                        <p class="cy-userdashboard_md-txt d-flex align-items-center gap-1">
                                            <i class="ri-mail-fill"/>
                                            <t t-esc="this.state.userProfile.work_email"/></p>
                                    </div>
                                    <div class="d-flex align-items-center mb-2" t-if="this.state.weatherDetails.temp">
                                        <img t-attf-src="https://openweathermap.org/img/w/{{this.state.weatherDetails.icon}}.png"
                                             style="width:40px; height:40px;"
                                             onerror="this.src='/cyllo_dashboard/static/src/img/cloud-fill.svg';"
                                        />
                                        <span class="cy-userdashboard_md-txt"> <t
                                                t-esc="this.state.weatherDetails.temp"/>
                                            <span>&#176;</span>C</span>
                                    </div>
                                </div>
                                <form action="" class="d-flex gap-2 flex-wrap w-100">
                                    <div class="cy-user_form-content">
                                        <div t-if="session.is_admin"
                                             class="d-flex align-items-normal justify-content-between mb-2">
                                            <label for="" class="cy-userdashboard_label">Auto Edit</label>
                                            <div>
                                                <label class="switch switch-auto-edit">
                                                    <input type="checkbox" class="auto-edit-checkbox"
                                                           t-att-checked="state.autoEdit"
                                                           t-on-click="(ev) => this.onToggleAutoEdit(ev)"
                                                           t-model="state.autoEdit"/>
                                                    <span class="slider round slider-auto-edit"/>
                                                </label>
                                            </div>
                                        </div>
                                        <label for="" class="cy-userdashboard_label">Language</label>
                                        <div class="dropdown cy-userdashboard_dropdwn">
                                            <select id="lang" name="lang" t-attf-class="form-control" required="1"
                                                    t-on-change="onChangeLang">
                                                <t t-foreach="this.state.userProfile.active_lang or []" t-as="lang"
                                                   t-key="lang_index">
                                                    <option t-att-value="lang.code"
                                                            t-att-selected="lang.id == this.state.userProfile.language ? 'selected': ''">
                                                        <t t-esc="lang.name"/>
                                                    </option>
                                                </t>
                                            </select>
                                        </div>
                                    </div>
                                    <div class="cy-user_form-content">
                                        <label for="" class="cy-userdashboard_label">Timezone</label>
                                        <div class="dropdown cy-userdashboard_dropdwn">
                                            <select id="tz" name="tz" t-attf-class="form-control" required="1"
                                                    t-on-change="onChangeTimezone">
                                                <t t-foreach="this.state.userProfile.timezone or []" t-as="tz"
                                                   t-key="tz_index">
                                                    <option t-att-selected="this.tz == tz[0] ? 'selected': ''"
                                                            t-att-value="tz[0]">
                                                    <t t-esc="tz[1]"/>
                                                </option>
                                            </t>
                                        </select>
                                        </div>
                                    </div>
                                </form>
                                <div class="d-flex gap-2 mt-4 cy-userdashboard_btn-container">
                                    <button class="btn cy-button-stroke w-100 text-nowrap" type="button"
                                            t-on-click="onClickPermissions">
                                        Permissions
                                    </button>
                                    <button class="btn cy-button-primary-stroke w-100 cy-active-btn"
                                            type="button" t-on-click="onClickChangePassword"
                                            style="white-space: nowrap;">
                                        Change password
                                    </button>
                                </div>
                                <br/>
                                <div id="div-timer">
                                    <div>
                                        <h5 id="idle_timer"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                <div class="col-lg-10 p-0">
                        <div class="row cy-box_container m-0 h-100">
                            <div class="col-lg-9 px-4 my-4 cy-border-right">
                                <div>
                                    <div class="cy-border-btm pb-3 mb-2">
                                        <h2 class="cy_tile-text">Your Shortcuts</h2>
                                    </div>
                                    <div class="d-flex flex-wrap py-3" t-if="state.shortcuts.length">
                                    <t t-foreach="state.shortcuts" t-as="shortcut" t-key="shortcut_index">
                                        <div class="d-flex align-items-center gap-2">
                                            <i
                                                    t-on-click="() => this.onClickShortCutAdd(shortcut.model)"
                                                    class="ri-add-circle-line" style="cursor:pointer"/>
                                            <button class="cy-userdashboard_shortcut-btn m-0"
                                                    t-on-click="() => this.onClickShortCutMenu(shortcut)">
                                                <t t-set="is_unique" t-value="isCompleteNameUnique(shortcut.name)"/>
                                                <t t-if="is_unique">
                                                    <t t-esc="shortcut.name"/>
                                                </t>
                                                <t t-else="">
                                                    <t t-esc="shortcut.menu_id[1]"/>
                                                </t>
                                            </button>
                                        </div>
                                    </t>
                                    </div>
                                    <div class="d-flex flex-wrap py-3 justify-content-center" t-else="">
                                        <h4 class="no_shortcut">No shortcuts added</h4>
                                    </div>
                                </div>
                                <div t-if="session.is_admin">
                                    <div class="cy-border-btm pb-3 mb-2" t-if="state.loginUserDetails!=0">
                                        <h2 class="cy_tile-text">Login Details</h2>
                                    </div>
                                    <table class="w-100 mb-3" t-if="state.loginUserDetails!=0">
                                        <thead class="cy-userdashboard_sm-head">
                                            <th>User Name</th>
                                            <th>Login Date and Time</th>
                                            <th>IP Address</th>
                                        </thead>
                                        <tbody>
                                            <t t-foreach="state.loginUserDetails" t-as="user" t-key="user_index">
                                                <tr>
                                                    <td class="">
                                                        <p class="cy-userdashboard--detail"><t t-esc="user.name"/></p>
                                                    </td>
                                                    <td class="">
                                                        <p class="cy-userdashboard--detail"><t t-esc="user.date_time"/></p>
                                                    </td>
                                                    <td class="">
                                                        <p class="cy-userdashboard--detail"><t t-esc="user.ip_address"/></p>
                                                    </td>
                                                </tr>
                                            </t>
                                        </tbody>
                                    </table>
                                </div>
                                <div>
                                    <div class="cy-border-btm pb-3 mb-2"
                                         t-if="state.performanceInsights.is_admin == true">
                                        <h2 class="cy_tile-text">System Monitor</h2>
                                    </div>
                                    <div class="cy-border-btm pb-3 mb-2" t-elif="session.is_admin">
                                        <h2 class="cy_tile-text">System Monitor</h2>
                                    </div>
                                    <div class="cy-userdasboard_system-monitor cy-border-btm"
                                         t-if="state.performanceInsights.is_admin == true">
                                        <div class="cy-userdashboard_system-container">
                                            <h3 class="cy-userdashboard_system-size"><t t-esc="state.performanceInsights.total_memory"/>
                                                GB</h3>
                                            <span class="cy-userdashboard_system-name">Total Memory</span>
                                        </div>
                                        <div class="cy-userdashboard_system-container">
                                            <h3 class="cy-userdashboard_system-size"><t t-esc="state.performanceInsights.used_memory"/>
                                                GB</h3>
                                            <span class="cy-userdashboard_system-name">Used Memory</span>
                                        </div>
                                        <div class="cy-userdashboard_system-container">
                                            <h3 class="cy-userdashboard_system-size"><t t-esc="state.performanceInsights.total_ram"/>
                                                GB</h3>
                                            <span class="cy-userdashboard_system-name">Total Ram</span>
                                        </div>
                                        <div class="cy-userdashboard_system-container">
                                            <h3 class="cy-userdashboard_system-size"><t t-esc="state.performanceInsights.total_cpu_usage"/>
                                                %</h3>
                                            <span class="cy-userdashboard_system-name">CPU Usage</span>
                                        </div>
                                        <div class="cy-userdashboard_system-container">
                                            <h3 class="cy-userdashboard_system-size"><t t-esc="state.performanceInsights.ram_percent"/>
                                                %</h3>
                                            <span class="cy-userdashboard_system-name">Ram Usage in %</span>
                                        </div>
                                        <div class="cy-userdashboard_system-container">
                                            <h3 class="cy-userdashboard_system-size">
                                                <t t-if="state.performanceInsights.os_dict"
                                                   t-esc="state.performanceInsights.os_dict.operating_system"/></h3>
                                            <span class="cy-userdashboard_system-name">Operating System</span>
                                        </div>
                                    </div>
                                    <div class="cy-userdasboard_system-monitor cy-userdasboard_system-monitor-no-content cy-border-btm "
                                         t-elif="session.is_admin">
                                        <div class="cy-userdashboard_system-container">

                                        </div>
                                        <div class="cy-userdashboard_system-container">

                                        </div>
                                        <div class="cy-userdashboard_system-container">

                                        </div>
                                        <div class="cy-userdashboard_system-container">

                                        </div>
                                        <div class="cy-userdashboard_system-container">

                                        </div>
                                        <div class="cy-userdashboard_system-container">

                                        </div>
                                    </div>
                                </div>
                                <div class="d-flex align-items-center  justify-content-between  mt-4 cyllo-admindashboard-detail-mainbox"
                                     t-if="state.performanceInsights.conf_dict and state.performanceInsights.is_admin == true">
                                    <div class="w-100 pe-2 pe-md-4 ">
                                        <div class="cy-db-border-btm mb-2 cyllo-userdashboard__list">
                                            <div class="d-flex align-items-center gap-2">
                                                <span class="cyllo_main-dashboard-icon"><i class="ri-user-fill"/></span>
                                                <span class="cy-userdashboard-system_label d-block">db_user</span>
                                            </div>
                                            <span class="cy-userdashboard-system_content"><t t-esc="state.performanceInsights.conf_dict.db_user"/></span>
                                        </div>
                                        <div class="cy-db-border-btm mb-2 cyllo-userdashboard__list">
                                            <div class="d-flex align-items-center gap-2">
                                                <span class="cyllo_main-dashboard-icon"><i
                                                        class="ri-database-2-fill"/></span>
                                                <span class="cy-userdashboard-system_label d-block">limit_memory_soft</span>
                                            </div>
                                            <span class="cy-userdashboard-system_content"><t t-esc="state.performanceInsights.conf_dict.limit_memory_soft"/></span>
                                        </div>
                                        <div class="cy-db-border-btm mb-2 cyllo-userdashboard__list">
                                            <div class="d-flex align-items-center gap-2">
                                                <span class="cyllo_main-dashboard-icon"><i
                                                        class="ri-database-2-fill"/></span>

                                                <span class="cy-userdashboard-system_label d-block">limit_memory_hard</span>
                                            </div>
                                            <span class="cy-userdashboard-system_content"><t t-esc="state.performanceInsights.conf_dict.limit_memory_hard"/></span>
                                        </div>
                                        <div class="cy-db-border-btm mb-2 cyllo-userdashboard__list">
                                            <div class="d-flex align-items-center gap-2">
                                                <span class="cyllo_main-dashboard-icon"><i
                                                        class="ri-database-2-fill"/></span>
                                                <span class="cy-userdashboard-system_label d-block">transient_age_limit</span>
                                            </div>
                                            <span class="cy-userdashboard-system_content"><t t-esc="state.performanceInsights.conf_dict.transient_age_limit"/></span>
                                        </div>
                                        <div class="cy-db-border-btm mb-2 cyllo-userdashboard__list">
                                            <div class="d-flex align-items-center gap-2">
                                                <span class="cyllo_main-dashboard-icon"><i class="ri-team-line"/></span>
                                                <span class="cy-userdashboard-system_label d-block">workers</span>
                                            </div>
                                            <span class="cy-userdashboard-system_content"><t t-esc="state.performanceInsights.conf_dict.workers"/></span>
                                        </div>
                                    </div>
                                    <div class="w-100 px-2 px-md-4">
                                        <div class="cy-db-border-btm mb-2 cyllo-userdashboard__list">
                                            <div class="d-flex align-items-center gap-2">
                                                <span class="cyllo_main-dashboard-icon"><i class="ri-time-line"/></span>
                                                <span class="cy-userdashboard-system_label">limit_time_cpu</span>
                                            </div>
                                            <span class="cy-userdashboard-system_content"><t t-esc="state.performanceInsights.conf_dict.limit_time_cpu"/>
                                                s</span>
                                        </div>
                                        <div class="cy-db-border-btm mb-2 cyllo-userdashboard__list">
                                            <div class="d-flex align-items-center gap-2">
                                                <span class="cyllo_main-dashboard-icon"><i
                                                        class="ri-database-2-fill"/></span>
                                                <span class="cy-userdashboard-system_label">limit_request</span>
                                            </div>
                                            <span class="cy-userdashboard-system_content"><t t-esc="state.performanceInsights.conf_dict.limit_request"/></span>
                                        </div>
                                        <div class="cy-db-border-btm mb-2 cyllo-userdashboard__list">
                                            <div class="d-flex align-items-center gap-2">
                                                <span class="cyllo_main-dashboard-icon"><i class="ri-time-line"/></span>
                                                <span class="cy-userdashboard-system_label">limit_time_real</span>
                                            </div>
                                            <span class="cy-userdashboard-system_content"><t t-esc="state.performanceInsights.conf_dict.limit_time_real"/></span>
                                        </div>
                                        <div class="cy-db-border-btm mb-2 cyllo-userdashboard__list">
                                            <div class="d-flex align-items-center gap-2">
                                                <span class="cyllo_main-dashboard-icon"><i class="ri-task-line"/></span>
                                                <span class="cy-userdashboard-system_label">max_cron_threads</span>
                                            </div>
                                            <span class="cy-userdashboard-system_content"><t t-esc="state.performanceInsights.conf_dict.max_cron_threads"/></span>
                                        </div>
                                        <div class="cy-db-border-btm mb-2 cyllo-userdashboard__list">
                                            <div class="d-flex align-items-center gap-2">
                                            <span class="cyllo_main-dashboard-icon"><i
                                                    class="ri-database-2-fill"/></span>
                                                <span class="cy-userdashboard-system_label">http_port</span>
                                        </div>
                                            <span
                                                    class="cy-userdashboard-system_content"><t t-esc="state.performanceInsights.conf_dict.http_port"/></span>
                                        </div>
                                    </div>
                                </div>
                                <div class="d-flex align-items-center justify-content-between cy-performanceInsight-no_content mt-4"
                                     t-elif="session.is_admin">
                                    <div class="w-100 pe-2 pe-md-4 cy-border-right">
                                        <div class="d-flex justify-content-between cy-performanceInsight flex-wrap mb-2">

                                        </div>
                                        <div class="d-flex justify-content-between cy-performanceInsight flex-wrap mb-2">

                                        </div>
                                        <div class="d-flex justify-content-between cy-performanceInsight flex-wrap mb-2">

                                        </div>
                                        <div class="d-flex justify-content-between cy-performanceInsight flex-wrap mb-2">

                                        </div>
                                        <div class="d-flex justify-content-between cy-performanceInsight flex-wrap mb-2">

                                        </div>
                                    </div>
                                    <div class="w-100 px-2 px-md-4">
                                        <div class="d-flex justify-content-between cy-performanceInsight flex-wrap mb-2">

                                        </div>
                                        <div class="d-flex justify-content-between cy-performanceInsight flex-wrap mb-2">

                                        </div>
                                        <div class="d-flex justify-content-between cy-performanceInsight flex-wrap mb-2">

                                        </div>
                                        <div class="d-flex justify-content-between cy-performanceInsight flex-wrap mb-2">

                                        </div>
                                        <div class="d-flex justify-content-between cy-performanceInsight flex-wrap mb-2">

                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-lg-3 p-4" style="height: 53rem;
                            overflow: auto;">
                                <div class="cy-border-btm pb-3 mb-2">
                                    <h2 class="cy_tile-text">Upcoming Activities</h2>
                                </div>
                                <t t-foreach="this.state.activities" t-as="group" t-key="group_index">
                                    <div class="d-flex align-items-center justify-content-between mt-3 cy-userdashboard__upcoming-container"
                                         t-att-data-model_name="group.model"
                                         t-on-click="() => this.openActivityGroup(group)" style="cursor:pointer">
                                        <div class="d-flex align-items-center gap-2" t-if="group.type === 'activity'">
                                            <div>
                                                <p class="cy-userdashboard__upcoming-txt"><t t-esc="group.name"/></p>
                                                <span class="cy-userdashboard_upcoming-vsm-txt"
                                                      t-if="group.overdue_count"
                                                      t-on-click.stop="() => this.openActivityGroup(group, 'overdue')"
                                                      style="cursor:pointer">
                                                    <t t-esc="group.overdue_count"/>
                                                    late</span>
                                                <span class="cy-userdashboard_upcoming-vsm-txt" t-else=""><t t-esc="group.overdue_count"/>
                                                    late</span>
                                                <span t-if="group.today_count"
                                                      t-on-click.stop="() => this.openActivityGroup(group, 'today')"
                                                      style="cursor:pointer"><t t-esc="group.today_count"/>
                                                    Today</span>
                                                <span t-else="">0 Today</span>
                                            </div>
                                        </div>
                                        <span class="cy-userdashboard__upcoming-box-count"
                                              t-if="group.planned_count"
                                              t-on-click.stop="() => this.openActivityGroup(group, 'upcoming_all')"
                                              style="cursor:pointer">
                                            <t t-esc="group.planned_count"/>
                                            Future</span>
                                        <span class="cy-userdashboard__upcoming-box-count" t-else="">0 Future</span>
                                </div>
                                </t>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        <div t-else="" class="row py-3 cyllo-non-admin-main" t-ref="root-non-admin">
            <div class="col p-0 cy-db-border-right">
                <div class="p-3  h-100">
                    <div class="cyllo-useradmin-profile mb-3">
                        <img t-if="this.state.userProfile.image" class="cy-db-user-img"
                             t-att-src="'data:image/png;base64,'+this.state.userProfile.image"
                             alt=""/>
                        <img t-else="" class="cy-db-user-img"
                             src="/cyllo_dashboard/static/src/img/dummy.jpg"
                             alt=""/>
                    </div>
                    <div class="cy-userdashboard_user-detail w-100">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <h2 class="cy-non-admin-userdashboard-name mb-1"><t t-esc="this.state.userProfile.name"/></h2>
                                <p t-if="this.state.userProfile.work_email" class="cy-non-admin-userdashboard_md-txt d-flex align-items-center gap-1"><i class="ri-mail-fill"/>
                                    <t t-esc="this.state.userProfile.work_email"/></p>
                            </div>
                            <div class="d-flex align-items-center mb-2" t-if="this.state.weatherDetails.temp">
                                <img t-attf-src="https://openweathermap.org/img/w/{{this.state.weatherDetails.icon}}.png"
                                     style="width:40px; height:40px;"
                                     onerror="this.src='/cyllo_dashboard/static/src/img/cloud-fill.svg';"
                                />
                                <span>
                                    <t t-esc="this.state.weatherDetails.temp"/>
                                    <span>&#176;</span>C
                                </span>
                            </div>
                        </div>
                        <form action="" class="d-flex gap-2 flex-wrap w-100">
                            <div class="cy-non-admin-user_form-content">
                                <label for="" class="cy-non-admin-userdashboard_label">Language</label>
                                <div class="dropdown cy-non-admin-userdashboard_dropdwn">
                                    <select id="lang" name="lang" t-attf-class="form-control" required="1"
                                            t-on-change="onChangeLang" style="height:44px;">
                                        <t t-foreach="this.state.userProfile.active_lang or []" t-as="lang"
                                           t-key="lang_index">
                                            <option t-att-value="lang.code"
                                                    t-att-selected="lang.id == this.state.userProfile.language ? 'selected': ''">
                                                <t t-esc="lang.name"/>
                                            </option>
                                        </t>
                                    </select>
                                </div>
                            </div>
                            <div class="cy-non-admin-user_form-content">
                                <label for="" class="cy-non-admin-userdashboard_label">Timezone</label>
                                <div class="dropdown cy-non-admin-userdashboard_dropdwn">
                                    <select id="tz" name="tz" t-attf-class="form-control" required="1"
                                            t-on-change="onChangeTimezone" style="height:44px;">
                                        <t t-foreach="this.state.userProfile.timezone or []" t-as="tz"
                                           t-key="tz_index">
                                            <option t-att-selected="this.tz == tz[0] ? 'selected': ''"
                                                    t-att-value="tz[0]">
                                            <t t-esc="tz[1]"/>
                                        </option>
                                    </t>
                                </select>
                                </div>
                            </div>
                            <div class="cy-non-admin-user_form-content">
                                <label for="" class="cy-non-admin-userdashboard_label">Notification Type</label>
                                <div class="form-check ">
                                    <input class="form-check-input" type="radio" name="handle_option" id="email"
                                           value="email" t-on-input="(ev) => this.onInputNotifType(ev)"
                                           t-att-checked="this.state.userProfile.notif_type === 'email' ? 'checked' : ''"/>
                                    <label class="" for="option1">Handle by Email</label>
                                </div>
                                <div class="form-check form-check-inline">
                                    <input class="form-check-input" type="radio" name="handle_option" id="inbox"
                                           value="inbox" t-on-input="(ev) => this.onInputNotifType(ev)"
                                           t-att-checked="this.state.userProfile.notif_type === 'inbox' ? 'checked' : ''"/>
                                    <label class="" for="option1">Handle in Odoo</label>
                                </div>
                            </div>
                        </form>
                        <div class="d-flex  gap-2 mt-2 cy-userdashboard_btn-container">
                            <button class="btn cy-admin-dashboard-button-stroke w-100 text-nowrap" type="button"
                                    t-on-click="onClickPermissions">
                                Permissions
                            </button>
                            <button
                                    class="btn cy-admin-dashboard-button-primary-stroke w-100 cy-change-pw-btn text-nowrap"
                                    type="button" t-on-click="onClickChangePassword">
                                Change password
                            </button>
                        </div>

                    </div>
                </div>
            </div>
            <div class="col-lg-9 p-0" style="width:80%;">
                <div class="row m-0">
                    <div class="col-lg-8 px-4 cy-db-border-right">
                        <div class="cy-db-border-btm pb-3 mb-3">
                            <h2 class="cy-db-subhead-text">Personal Details</h2>
                        </div>
                        <div class="row">
                            <div t-if="this.state.nonAdmin.phone" class="col-6 p-0">
                                <div class="cyllo-user-dashboard_ps-container">
                                    <label for="" class="cyllo-useradmin--md-text">Phone</label>
                                    <span><t t-esc="this.state.nonAdmin.phone"/></span>
                                </div>
                            </div>
                            <div t-if="state.nonAdmin.action_id" class="col-6 p-0">
                                <div class="cyllo-user-dashboard_ps-container">
                                    <label class="cyllo-useradmin--md-text" for="">Home Action</label>
                                    <span><t t-esc="this.state.nonAdmin.action_id"/></span>
                                </div>
                            </div>
                            <div t-if="this.state.nonAdmin.job_position" class="col-6 p-0">
                                <div class="cyllo-user-dashboard_ps-container">
                                    <label class="cyllo-useradmin--md-text" for="">Job Position</label>
                                    <span><t t-esc="this.state.nonAdmin.job_position"/></span>
                                </div>
                            </div>
                            <div class="col-6 p-0">
                                <div class="cyllo-user-dashboard_ps-container">
                                    <label class="cyllo-useradmin--md-text" for="">Default Company</label>
                                    <span><t t-esc="state.nonAdmin.default_company.name"/></span>
                                </div>
                            </div>
                            <div class="col-12 p-0">
                                <div class="cyllo-user-dashboard_ps-container">
                                    <label class="cyllo-useradmin--md-text" for="">Allowed Company</label>
                                    <div class="d-flex flex-wrap mt-4">
                                        <t t-foreach="state.nonAdmin.allowed_companies[0]" t-as="company"
                                           t-key="company.id">
                                            <span class="cyllo_useradmin--badge cursor-pointer"
                                                  t-on-click="() => this.onClickCompany(company)"><t t-esc="company.name"/></span>
                                        </t>
                                    </div>
                                </div>
                            </div>
                            <div class="col-12 p-0">
                                <div class="cyllo-user-dashboard_ps-container">
                                    <div class="d-flex justify-content-between">
                                        <label for="" class="cyllo-useradmin--md-text">Email
                                            Signature</label>
                                        <div class="d-flex gap-1">
                                            <button class="btn cyllo-userdashboard-feature-btn d-none"
                                                    id="signatureSaveBtn"
                                                    t-on-click="saveSignature"><i class="ri-save-fill"/>
                                            </button>
                                            <button class="btn cyllo-userdashboard-feature-btn" id="signatureEditBtn"
                                                    t-on-click="editSignature"><i class="ri-pencil-fill"/>
                                            </button>
                                        </div>
                                    </div>
                                    <span id="signatureContent"><t t-out="markupSignature"/></span>
                                    <textarea name="" class="d-none w-100 cyllo-user_dashboard-textarea"
                                              id="email-sign-textarea" cols=""
                                              t-att-value="signature" rows="2"/>

                                </div>
                            </div>
                        </div>
                        <div class="mt-3">
                            <div class="cy-db-border-btm pb-3 ">
                                <h2 class="cy-db-subhead-text">Your Shortcuts</h2>
                            </div>
                            <div class="d-flex flex-wrap gap-2 py-3" t-if="state.shortcuts.length">
                                <t t-foreach="state.shortcuts" t-as="shortcut" t-key="shortcut_index">
                                    <button class="cy-na-userdashboard_shortcut-btn cyllo-userdashboard-shortcut text-truncate"
                                            t-on-click.prevent.stop="() => this.onClickShortCutMenu(shortcut)">
                                        <i class="ri-add-line"
                                           t-on-click.prevent.stop="() => this.onClickShortCutAdd(shortcut.model)">
                                        </i>
                                        <t t-set="is_unique" t-value="isCompleteNameUnique(shortcut.name)"/>
                                        <span class="text-truncate"
                                              t-attf-title='#{is_unique ? shortcut.name : shortcut.menu_id[1]}'>
                                        <t t-if="is_unique">
                                            <t t-esc="shortcut.name"/>
                                        </t>
                                            <t t-else="">
                                            <t t-esc="shortcut.menu_id[1]"/>
                                        </t>
                                        </span>
                                    </button>
                                </t>
                            </div>
                            <div class="d-flex flex-wrap py-3 justify-content-center" t-else="">
                                <h4 class="no_shortcut">No shortcuts added</h4>
                            </div>

                        </div>
                        <div class="cyllo_state_btns mb-4">
                            <div class="cy-non-admin-box_container cyllo_useradmin-state--btn"
                                 t-on-click="onClickGroups">
                                <i class="ri-group-fill cyllo_useradmin--icon"/>
                                <span class="cy-non-admin-userdashboard_label">Groups</span>
                            </div>
                            <div class="cy-non-admin-box_container cyllo_useradmin-state--btn"
                                 t-on-click="onClickAccessRights">
                                <i class="ri-folders-fill cyllo_useradmin--icon"/>
                                <span class="cy-non-admin-userdashboard_label">Access Right</span>
                            </div>
                            <div class="cy-non-admin-box_container cyllo_useradmin-state--btn"
                                 t-on-click="onClickRecordRules">
                                <i class="ri-stack-fill cyllo_useradmin--icon"/>
                                <span class="cy-non-admin-userdashboard_label">Record Rules</span>
                            </div>
                        </div>

                    </div>
                    <div class="col-lg-4 p-4">
                        <div class="cy-db-border-btm pb-3 mb-2">
                            <h2 class="cy-db-subhead-text">Upcoming Activities</h2>
                        </div>
                        <t t-foreach="this.state.activities" t-as="group" t-key="group_index">
                            <div class="d-flex align-items-center justify-content-between mt-3 cy-userdashboard__upcoming-container"
                                 t-att-data-model_name="group.model"
                                 t-on-click="() => this.openActivityGroup(group)" style="cursor:pointer">
                                <div class="d-flex align-items-center gap-2" t-if="group.type === 'activity'">
                                    <div>
                                        <p class="cy-userdashboard__upcoming-txt"><t t-esc="group.name"/></p>
                                        <span class="cy-userdashboard_upcoming-vsm-txt"
                                              t-if="group.overdue_count"
                                              t-on-click.stop="() => this.openActivityGroup(group, 'overdue')"
                                              style="cursor:pointer">
                                            <t t-esc="group.overdue_count"/>
                                            late</span>
                                        <span class="cy-userdashboard_upcoming-vsm-txt" t-else=""><t t-esc="group.overdue_count"/>
                                            late</span>
                                        <span t-if="group.today_count"
                                              t-on-click.stop="() => this.openActivityGroup(group, 'today')"
                                              style="cursor:pointer"><t t-esc="group.today_count"/>
                                            Today</span>
                                        <span t-else="">0 Today</span>
                                    </div>
                                </div>
                                <span class="cy-userdashboard__upcoming-box-count"
                                      t-if="group.planned_count"
                                      t-on-click.stop="() => this.openActivityGroup(group, 'upcoming_all')"
                                      style="cursor:pointer">
                                    <t t-esc="group.planned_count"/>
                                    Future</span>
                                <span class="cy-userdashboard__upcoming-box-count" t-else="">0 Future</span>
                        </div>
                        </t>
                    </div>
                </div>
            </div>
        </div>
    </t>
    <t t-name="cyllo_dashboard.CompanyDetailsDialog">
        <Dialog size="'md'" title="props.title">
            <div class="row">
                <div class="col-12 d-flex">
                    <div class="col-6">
                        <div t-if="props.company.email">
                            <label for="" class="cy-non-admin-userdashboard_label">Email</label>
                            <span class="cyllo-useradmin--md-text cy-company-text"><t t-esc="props.company.email"/></span>
                        </div>
                        <div class="mt-2" t-if="props.company.phone">
                        <label for="" class="cy-non-admin-userdashboard_label">Phone</label>
                            <span class="cyllo-useradmin--md-text cy-company-text"><t t-esc="props.company.phone"/></span>
                    </div>
                        <div class="mt-2" t-if="props.company.currency_id">
                        <label for="" class="cy-non-admin-userdashboard_label">Currency</label>
                            <span class="cyllo-useradmin--md-text cy-company-text"><t t-esc="props.company.currency_id[1]"/></span>
                    </div>
                        <div class="mt-2" t-if="props.company.vat">
                        <label for="" class="cy-non-admin-userdashboard_label">TAX ID</label>
                            <span class="cyllo-useradmin--md-text cy-company-text"><t t-esc="props.company.vat"/></span>
                    </div>
                    </div>
                    <div class="col-6">
                        <div t-if="props.company.street or props.company.state_id or props.company.country_id">
                            <label for="" class="cy-non-admin-userdashboard_label">Address</label>
                            <span t-if="props.company.street" class="cyllo-useradmin--md-text cy-company-text"><t t-esc="props.company.street"/></span>
                            <span t-if="props.company.street2" class="cyllo-useradmin--md-text cy-company-text"><t t-esc="props.company.street2"/></span>
                            <span t-if="props.company.state_id" class="cyllo-useradmin--md-text cy-company-text"><t t-esc="props.company.state_id[1]"/></span>
                            <span t-if="props.company.country_id" class="cyllo-useradmin--md-text cy-company-text"><t t-esc="props.company.country_id[1]"/></span>
                            <span t-if="props.company.zip" class="cyllo-useradmin--md-text cy-company-text"><t t-esc="props.company.zip"/></span>
                        </div>
                    </div>
                </div>
            </div>
            <t t-set-slot="footer">
                <t t-set-slot="footer">
                    <button class="btn btn-primary" t-on-click="() => this.props.close()">
                    Close
                    </button>
                </t>
            </t>
        </Dialog>
    </t>
</templates>