    <!-- Scheduled action for reminders -->
    <record id="ir_cron_appointment_reminders" model="ir.cron">
        <field name="name">Appointment Pro: Send Reminders</field>
        <field name="model_id" ref="model_appointment_appointment"/>
        <field name="state">code</field>
        <field name="code">model._send_reminder_emails()</field>
        <field name="interval_number">30</field>
        <field name="interval_type">minutes</field>
        <field name="numbercall">-1</field>
        <field name="active" eval="True"/>
    </record>
</odoo>
