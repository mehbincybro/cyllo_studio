<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Manage Appointment Page (token-based public link) -->
    <template id="appointment_manage" name="Manage My Appointment">
        <t t-call="website.layout">
            <div id="wrap" class="oe_structure oe_empty bg-100">
                <div class="container py-5">
                    <div class="row justify-content-center">
                        <div class="col-lg-7">
                            <div class="card shadow border-0" style="border-radius: 16px; overflow: hidden;">
                                <div class="card-header bg-white border-bottom pt-4 pb-3 px-4">
                                    <h3 class="mb-1">Manage Your Appointment</h3>
                                    <p class="text-muted mb-0">Reference: <strong><t t-esc="appointment.name"/></strong></p>
                                </div>
                                <div class="card-body p-4">
                                    <t t-if="error_message">
                                        <div class="alert alert-danger mb-4" role="alert" style="border-radius: 10px;">
                                            <i class="fa fa-exclamation-circle me-2"/>
                                            <t t-esc="error_message"/>
                                        </div>
                                    </t>
                                    <t t-if="success_message">
                                        <div class="alert alert-success mb-4" role="alert" style="border-radius: 10px;">
                                            <i class="fa fa-check-circle me-2"/>
                                            <t t-esc="success_message"/>
                                        </div>
                                    </t>
                                    <!-- Appointment Summary -->
                                    <div class="rounded-3 bg-light p-4 mb-4">
                                        <div class="row">
                                            <div class="col-md-6 mb-3">
                                                <p class="text-muted small fw-bold mb-1 text-uppercase">Service</p>
                                                <p class="mb-0 fw-semibold"><t t-esc="appointment.appointment_type_id.name"/></p>
                                            </div>
                                            <div class="col-md-6 mb-3">
                                                <p class="text-muted small fw-bold mb-1 text-uppercase">Status</p>
                                                <span class="badge rounded-pill bg-success">
                                                    <t t-esc="dict(appointment.fields_get(allfields=['state'])['state']['selection'])[appointment.state]"/>
                                                </span>
                                            </div>
                                            <div class="col-md-6 mb-3">
                                                <p class="text-muted small fw-bold mb-1 text-uppercase">Date &amp; Time</p>
                                                <p class="mb-0 fw-semibold">
                                                    <span t-field="appointment.start_datetime" t-options="{'widget': 'datetime', 'format': 'medium'}"/>
                                                </p>
                                            </div>
                                            <div class="col-md-6 mb-3" t-if="appointment.staff_id">
                                                <p class="text-muted small fw-bold mb-1 text-uppercase">Staff</p>
                                                <p class="mb-0 fw-semibold"><t t-esc="appointment.staff_id.name"/></p>
                                            </div>
                                        </div>
                                    </div>
                                    <!-- Action Buttons -->
                                    <div class="d-flex gap-3 flex-wrap">
                                        <t t-if="can_reschedule">
                                            <a t-attf-href="/appointment/manage/{{token}}/reschedule"
                                               class="btn btn-primary btn-lg flex-grow-1"
                                               style="border-radius: 8px; font-weight: 600;">
                                                <i class="fa fa-calendar me-2"/>Reschedule
                                            </a>
                                        </t>
                                        <t t-if="not can_reschedule and appointment.state == 'confirmed'">
                                            <button class="btn btn-outline-secondary btn-lg flex-grow-1" disabled="disabled" style="border-radius: 8px;">
                                                <i class="fa fa-calendar me-2"/>Reschedule (Deadline Passed)
                                            </button>
                                        </t>
                                        <t t-if="can_cancel">
                                            <button type="button" class="btn btn-outline-danger btn-lg flex-grow-1"
                                                    data-bs-toggle="collapse" data-bs-target="#cancel_section"
                                                    style="border-radius: 8px; font-weight: 600;">
                                                <i class="fa fa-times me-2"/>Cancel Appointment
                                            </button>
                                        </t>
                                    </div>
                                    <!-- Cancel Confirmation Panel -->
                                    <t t-if="can_cancel">
                                        <div class="collapse mt-4" id="cancel_section">
                                            <div class="card border-danger" style="border-radius: 10px;">
                                                <div class="card-body">
                                                    <h5 class="text-danger mb-3">
                                                        <i class="fa fa-exclamation-triangle me-2"/>Confirm Cancellation
                                                    </h5>
                                                    <p class="text-muted small mb-3">This action cannot be undone. You may optionally provide a reason.</p>
                                                    <form t-attf-action="/appointment/manage/{{token}}/cancel" method="post">
                                                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                                        <div class="mb-3">
                                                            <textarea name="reason" class="form-control" rows="2"
                                                                      placeholder="Reason for cancellation..."
                                                                      style="border-radius: 8px;"/>
                                                        </div>
                                                        <button type="submit" class="btn btn-danger w-100" style="border-radius: 8px;">
                                                            Yes, Cancel My Appointment
                                                        </button>
                                                    </form>
                                                </div>
                                            </div>
                                        </div>
                                    </t>
                                    <div class="mt-4 text-center">
                                        <a href="/appointment" class="text-muted small">
                                            <i class="fa fa-arrow-left me-1"/>Book a new appointment
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <!-- Reschedule Appointment Page -->
    <template id="appointment_reschedule" name="Reschedule Appointment">
        <t t-call="website.layout">
            <div id="wrap" class="oe_structure oe_empty bg-100">
                <div class="container py-5">
                    <div class="row justify-content-center">
                        <div class="col-lg-8">
                            <div class="card shadow border-0" style="border-radius: 16px; overflow: hidden;">
                                <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4">
                                    <h3>Reschedule: <t t-esc="appointment_type.name"/></h3>
                                    <p class="text-muted">Select a new date and time for your appointment.</p>
                                </div>
                                <div class="card-body p-4">
                                    <t t-if="error_message">
                                        <div class="alert alert-danger mb-4" style="border-radius: 10px;">
                                            <i class="fa fa-exclamation-circle me-2"/>
                                            <t t-esc="error_message"/>
                                        </div>
                                    </t>
                                    <form t-attf-action="/appointment/manage/{{token}}/reschedule/submit"
                                          method="post" id="reschedule_form">
                                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                        <input type="hidden" name="is_dynamic" id="is_dynamic_input" value="false"/>
                                        <input type="hidden" name="dynamic_slot_datetime" id="dynamic_slot_datetime"/>
                                        <input type="hidden" name="slot_id" id="predefined_slot_id"/>
                                        <div class="row">
                                            <t t-if="staffs">
                                                <div class="col-md-6 mb-4">
                                                    <label class="form-label fw-bold">Select Staff</label>
                                                    <select name="staff_id" id="staff_select" class="form-select form-select-lg" style="border-radius: 8px;">
                                                        <option value="">-- Any Staff --</option>
                                                        <t t-foreach="staffs" t-as="staff">
                                                            <option t-att-value="staff.id"
                                                                    t-att-selected="appointment.staff_id.id == staff.id">
                                                                <t t-esc="staff.name"/>
                                                            </option>
                                                        </t>
                                                    </select>
                                                </div>
                                            </t>
                                            <t t-if="resources">
                                                <div class="col-md-6 mb-4">
                                                    <label class="form-label fw-bold">Select Resource</label>
                                                    <select name="resource_id" id="resource_select" class="form-select form-select-lg" style="border-radius: 8px;">
                                                        <option value="">-- Any Resource --</option>
                                                        <t t-foreach="resources" t-as="res">
                                                            <option t-att-value="res.id"><t t-esc="res.name"/></option>
                                                        </t>
                                                    </select>
                                                </div>
                                            </t>
                                            <div t-attf-class="{{'col-md-6' if staffs or resources else 'col-md-12'}} mb-4">
                                                <label class="form-label fw-bold">Select New Date</label>
                                                <input type="date" id="date_select" class="form-control form-control-lg"
                                                       required="1" style="border-radius: 8px;"/>
                                            </div>
                                        </div>
                                        <div class="mb-4" id="slots_container" style="display:none;">
                                            <label class="form-label fw-bold">Available Times</label>
                                            <div class="row g-2" id="slots_grid"/>
                                            <div id="no_slots_msg" class="alert alert-warning mt-2"
                                                 style="display:none; border-radius: 8px;">
                                                No available slots on this date. Please try another day.
                                            </div>
                                        </div>
                                        <button type="submit" id="submit_btn" class="btn btn-primary btn-lg w-100 mt-2"
                                                disabled="disabled" style="border-radius: 8px; font-weight: 600;">
                                            Confirm New Time
                                        </button>
                                        <a t-attf-href="/appointment/manage/{{token}}"
                                           class="btn btn-link w-100 mt-2 text-muted">
                                            <i class="fa fa-arrow-left me-1"/>Back
                                        </a>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <!-- Data provider for external reschedule JS -->
            <input type="hidden" id="reschedule_appointment_type_id" t-att-value="appointment_type.id"/>
        </t>
    </template>

    <!-- Appointment Cancelled Confirmation -->
    <template id="appointment_cancelled" name="Appointment Cancelled">
        <t t-call="website.layout">
            <div id="wrap" class="oe_structure oe_empty bg-100">
                <div class="container py-5">
                    <div class="row justify-content-center">
                        <div class="col-md-7 text-center">
                            <div class="card shadow-lg border-0" style="border-radius: 20px; overflow: hidden;">
                                <div class="bg-danger text-white py-5 text-center">
                                    <i class="fa fa-times-circle fa-5x mb-3"/>
                                    <h1 class="display-5 fw-bold">Appointment Cancelled</h1>
                                    <p class="lead mb-0">Your appointment has been successfully cancelled.</p>
                                </div>
                                <div class="card-body p-5">
                                    <p class="text-muted mb-1">Cancelled appointment:</p>
                                    <h5 class="fw-bold"><t t-esc="appointment.appointment_type_id.name"/></h5>
                                    <p class="text-muted mt-3">You are welcome to book again anytime.</p>
                                    <div class="mt-4">
                                        <a href="/appointment" class="btn btn-primary btn-lg" style="border-radius: 10px;">
                                            Book a New Appointment
                                        </a>
                                        <a href="/" class="btn btn-outline-secondary btn-lg ms-2" style="border-radius: 10px;">
                                            Return Home
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

</odoo>
