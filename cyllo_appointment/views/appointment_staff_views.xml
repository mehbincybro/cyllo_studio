<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Staff Form View -->
    <record id="view_appointment_staff_form" model="ir.ui.view">
        <field name="name">appointment.staff.form</field>
        <field name="model">appointment.staff</field>
        <field name="arch" type="xml">
            <form string="Staff Member">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_upcoming_appointments" type="object"
                            class="oe_stat_button" icon="fa-calendar">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_value"><field name="upcoming_appointment_count"/></span>
                                <span class="o_stat_text">Upcoming</span>
                            </div>
                        </button>
                        <button name="action_view_appointments" type="object"
                            class="oe_stat_button" icon="fa-history">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_value"><field name="appointment_count"/></span>
                                <span class="o_stat_text">Total</span>
                            </div>
                        </button>
                    </div>
                    <field name="image" widget="image" class="oe_avatar"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Staff Member Name"/></h1>
                        <field name="job_title" placeholder="Job Title / Specialization"/>
                    </div>
                    <group>
                        <group string="Contact">
                            <field name="email"/>
                            <field name="phone"/>
                            <field name="mobile"/>
                            <field name="user_id"/>
                            <field name="color" widget="color_picker"/>
                            <field name="active" widget="boolean_toggle"/>
                        </group>
                        <group string="Availability">
                            <field name="working_hours_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Appointment Types" name="types">
                            <field name="appointment_type_ids" widget="many2many_tags"/>
                        </page>
                        <page string="Notifications" name="notifications">
                            <group>
                                <field name="notify_on_new_appointment"/>
                                <field name="notify_on_cancellation"/>
                                <field name="notify_on_reschedule"/>
                            </group>
                        </page>
                        <page string="Bio" name="bio">
                            <field name="bio" placeholder="Staff member bio..."/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Staff List View -->
    <record id="view_appointment_staff_list" model="ir.ui.view">
        <field name="name">appointment.staff.list</field>
        <field name="model">appointment.staff</field>
        <field name="arch" type="xml">
            <tree string="Staff Members">
                <field name="name"/>
                <field name="job_title"/>
                <field name="email"/>
                <field name="phone"/>
                <field name="working_hours_id"/>
                <field name="upcoming_appointment_count" string="Upcoming"/>
                <field name="appointment_count" string="Total"/>
                <field name="active" column_invisible="1"/>
            </tree>
        </field>
    </record>

    <!-- Staff Kanban View -->
    <record id="view_appointment_staff_kanban" model="ir.ui.view">
        <field name="name">appointment.staff.kanban</field>
        <field name="model">appointment.staff</field>
        <field name="arch" type="xml">
            <kanban>
                <field name="id"/>
                <field name="name"/>
                <field name="job_title"/>
                <field name="email"/>
                <field name="color"/>
                <field name="upcoming_appointment_count"/>
                <field name="appointment_count"/>
                <field name="image"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="apt-staff-card oe_kanban_global_click">
                            <div class="apt-staff-avatar">
                                <img t-if="record.image.raw_value"
                                    t-attf-src="/web/image/appointment.staff/{{record.id.raw_value}}/image"
                                    class="o_image_64_max rounded-circle"/>
                                <div t-else="" class="apt-staff-avatar-placeholder">
                                    <i class="fa fa-user fa-2x"/>
                                </div>
                            </div>
                            <strong class="d-block mt-2"><t t-esc="record.name.value"/></strong>
                            <div class="text-muted small"><t t-esc="record.job_title.value"/></div>
                            <div class="apt-staff-stats mt-2">
                                <span class="badge badge-primary mr-1">
                                    <i class="fa fa-calendar"/> <t t-esc="record.upcoming_appointment_count.value"/> upcoming
                                </span>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Action -->
    <record id="action_appointment_staff" model="ir.actions.act_window">
        <field name="name">Staff Members</field>
        <field name="res_model">appointment.staff</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Add your first staff member!</p>
            <p>Manage staff members who handle appointments.</p>
        </field>
    </record>
</odoo>
