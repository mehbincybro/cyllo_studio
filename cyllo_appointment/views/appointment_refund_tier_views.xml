<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- List View -->
    <record id="view_appointment_refund_tier_tree" model="ir.ui.view">
        <field name="name">appointment.refund.tier.tree</field>
        <field name="model">appointment.refund.tier</field>
        <field name="arch" type="xml">
            <tree editable="bottom" string="Refund Tiers">
                <field name="appointment_type_id"/>
                <field name="name"/>
                <field name="hours_before" string="Cancelled More Than (hrs before)"/>
                <field name="refund_percentage" string="Refund %"
                       widget="percentage"/>
            </tree>
        </field>
    </record>
    <!-- Form View (standalone, rarely needed but good to have) -->
    <record id="view_appointment_refund_tier_form" model="ir.ui.view">
        <field name="name">appointment.refund.tier.form</field>
        <field name="model">appointment.refund.tier</field>
        <field name="arch" type="xml">
            <form string="Refund Tier">
                <sheet>
                    <group>
                        <group>
                            <field name="appointment_type_id"/>
                            <field name="name"/>
                        </group>
                        <group>
                            <field name="hours_before"
                                   string="Cancelled More Than (hours before)"/>
                            <field name="refund_percentage" string="Refund %"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>