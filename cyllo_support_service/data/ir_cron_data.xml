<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!--Cron run daily basis to check inactive tickets-->
    <record id="ir_cron_check_inactivity" model="ir.cron">
        <field name="name">Check Inactivity</field>
        <field name="model_id" ref="model_support_service_ticket"/>
        <field name="state">code</field>
        <field name="code">model.check_support_service_inactivity()</field>
        <field name="user_id" ref="base.user_root"/>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="doall" eval="False"/>
    </record>
</odoo>