<?xml version="1.0" encoding="UTF-8" ?>
<odoo noupdate="1">
    <!-- Record for stage 'New' -->
    <record id="support_service_stage_new" model="support.service.stage">
        <field name="name">New</field>
        <field name="sequence">1</field>
    </record>
    <!-- Record for stage 'In Progress' -->
    <record id="support_service_stage_in_progress" model="support.service.stage">
        <field name="name">In Progress</field>
        <field name="sequence">2</field>
    </record>
    <!-- Record for stage 'On Hold' -->
    <record id="support_service_stage_on_hold" model="support.service.stage">
        <field name="name">On Hold</field>
        <field name="sequence">3</field>
    </record>
    <!-- Record for stage 'To Invoice' -->
    <record id="support_service_stage_to_invoice" model="support.service.stage">
        <field name="name">To Invoice</field>
        <field name="sequence">4</field>
    </record>
    <!-- Record for stage 'Solved' -->
    <record id="support_service_stage_solved" model="support.service.stage">
        <field name="name">Solved</field>
        <field name="sequence">5</field>
    </record>
    <record id="support_service_stage_canceled" model="support.service.stage">
        <field name="name">Canceled</field>
        <field name="is_fold" eval="False"/>
        <field name="sequence">6</field>
    </record>
    <!-- Record for stage 'Closed' -->
    <record id="support_service_stage_closed" model="support.service.stage">
        <field name="name">Closed</field>
        <field name="is_fold" eval="False"/>
        <field name="is_closed" eval="True"/>
        <field name="sequence">7</field>
    </record>
</odoo>
