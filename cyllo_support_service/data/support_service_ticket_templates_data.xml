<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!-- Template for email send to the customer when ticket is in progress stage -->
    <record id="mail_template_support_service" model="mail.template">
        <field name="name">Support Service</field>
        <field name="model_id"
               ref="cyllo_support_service.model_support_service_ticket"/>
        <field name="subject">Ticket Generated</field>
        <field name="body_html" type="html">
            <table border="0" cellpadding="0" cellspacing="0"
                   style="padding-top: 16px; background-color: #F1F1F1; font-family:Verdana, Arial,sans-serif; color: #454748; width: 100%; border-collapse:separate;">
                <tr>
                    <td align="center">
                        <table border="0" cellpadding="0" cellspacing="0"
                               width="590"
                               style="padding: 16px; background-color: white; color: #454748; border-collapse:separate;  margin-bottom: 20px;">
                            <tbody>
                                <!-- CONTENT -->
                                <tr>
                                    <td align="center"
                                        style="min-width: 590px;">
                                        <table border="0" cellpadding="0"
                                               cellspacing="0" width="590"
                                               style="min-width: 590px; background-color: white; padding: 0px 8px 0px 8px; border-collapse:separate;">
                                            <tr>
                                                <td valign="top"
                                                    style="font-size: 13px;">
                                                    <div>
                                                        Dear
                                                        <t t-out="object.customer_id.name"/>
                                                        ,
                                                        <br/>
                                                        <br/>
                                                        Your support service
                                                        ticket
                                                        <span>
                                                            <a t-attf-href='/support-service-ticket/{{object.id}}'
                                                               style="text-decoration:none;"
                                                               class="text-decoration-none">
                                                                <t t-out="object.name"/>
                                                            </a>
                                                        </span>
                                                        has been submitted.
                                                        <br/>
                                                        <br/>
                                                        Ticket No :
                                                        <span>
                                                            <t t-out="object.ticket"/>
                                                        </span>
                                                        <br/>
                                                        <br/>
                                                        Team :
                                                        <span>
                                                            <t t-out="object.team_id.name"/>
                                                        </span>
                                                        <br/>
                                                        <br/>
                                                        Responsible Person
                                                        :
                                                        <span>
                                                            <t t-out="object.user_id.name"/>
                                                        </span>
                                                        <br/>
                                                        <br/>
                                                        State :
                                                        <span>
                                                            <t t-out="object.stage_id.name"/>
                                                        </span>
                                                        <br/>
                                                        <br/>
                                                        <div style="margin: 16px 0px 16px 0px; text-align: center;">
                                                            <a t-attf-href='/support-service-ticket/{{object.id}}'
                                                               style="display: inline-block; padding: 10px; text-decoration: none; font-size: 12px; background-color: #875A7B; color: #fff; border-radius: 5px;">
                                                                <strong>
                                                                    View
                                                                    Ticket
                                                                </strong>
                                                            </a>
                                                        </div>
                                                    </div>
                                                </td>
                                            </tr>
                                            <tr>
                                                <td style="text-align:center;">
                                                    <hr width="100%"
                                                        style="background-color:rgb(204,204,204);border:medium none;clear:both;display:block;font-size:0px;min-height:1px;line-height:0; margin: 16px 0px 16px 0px;"/>
                                                </td>
                                            </tr>
                                        </table>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </td>
                </tr>
            </table>
        </field>
    </record>
    <!-- Email template that send to the customer to inform about the completion of work -->
    <record id="mail_template_support_services" model="mail.template">
        <field name="name">Support Services</field>
        <field name="model_id"
               ref="cyllo_support_service.model_support_service_ticket"/>
        <field name="subject">Issue Solved</field>
        <field name="body_html" type="html">
            <table border="0" cellpadding="0" cellspacing="0"
                   style="padding-top: 16px; background-color: #F1F1F1; font-family:Verdana, Arial,sans-serif; color: #454748; width: 100%; border-collapse:separate;">
                <tr>
                    <td align="center">
                        <table border="0" cellpadding="0" cellspacing="0"
                               width="590"
                               style="padding: 16px; background-color: white; color: #454748; border-collapse:separate;  margin-bottom: 20px;">
                            <tbody>
                                <tr>
                                    <td align="center"
                                        style="min-width: 590px;">
                                        <table border="0" cellpadding="0"
                                               cellspacing="0" width="590"
                                               style="min-width: 590px; background-color: white; padding: 0px 8px; border-collapse:separate;">
                                            <tr>
                                                <td valign="top"
                                                    style="font-size: 13px;">
                                                    <div>
                                                        Dear
                                                        <t
                                                                t-out="object.customer_id.name"/>
                                                        ,
                                                        <br/>
                                                        <br/>
                                                        This is to inform you
                                                        that the issue you
                                                        reported has been
                                                        successfully resolved.
                                                        <br/>
                                                        <br/>
                                                        Details:
                                                        <br/>
                                                        <span>
                                                            <a t-attf-href='/support-service-ticket/{{object.id}}'
                                                               style="text-decoration:none;"
                                                               class="text-decoration-none">
                                                                <t t-out="object.name"/>
                                                            </a>
                                                        </span>
                                                        <br/>
                                                        <br/>
                                                        Ticket No:
                                                        <span>
                                                            <t t-out="object.ticket"/>
                                                        </span>
                                                        <br/>
                                                        <br/>
                                                        Team:
                                                        <span>
                                                            <t t-out="object.team_id.name"/>
                                                        </span>
                                                        <br/>
                                                        <br/>
                                                        Responsible Person:
                                                        <span>
                                                            <t t-out="object.user_id.name"/>
                                                        </span>
                                                        <br/>
                                                        <br/>
                                                        State:
                                                        <span>
                                                            <t t-out="object.stage_id.name"/>
                                                        </span>
                                                        <br/>
                                                        <br/>
                                                        <!-- Total Expected Amount -->
                                                        Total Expected Amount:
                                                        <strong>
                                                            <t t-out="object.ticket_order_id.amount_total"/>
                                                        </strong>
                                                        <br/>
                                                        <br/>
                                                        <!-- Calculate Remaining Amount -->
                                                        <t t-set="remaining_amount"
                                                           t-value="0"/>
                                                        <t t-set="unpaid_invoices"
                                                           t-value="[]"/>
                                                        <t t-foreach="object.ticket_invoice_ids"
                                                           t-as="inv">
                                                            <t t-if="inv.payment_state != 'paid'">
                                                                <t t-set="remaining_amount"
                                                                   t-value="remaining_amount + inv.amount_residual"/>
                                                                <t t-set="unpaid_invoices"
                                                                   t-value="unpaid_invoices + [inv]"/>
                                                            </t>
                                                        </t>
                                                        <!-- Show Remaining Amount if exists -->
                                                        <t t-if="remaining_amount &gt; 0">
                                                            Remaining Amount to
                                                            Pay:
                                                            <strong>
                                                                <t t-out="remaining_amount"/>
                                                            </strong>
                                                            <br/>
                                                            <br/>
                                                            <!-- If only one unpaid invoice -->
                                                            <t t-if="len(unpaid_invoices) == 1">
                                                                <div style="margin: 16px 0px; text-align: center;">
                                                                    <a t-attf-href='/my/invoices/{{ unpaid_invoices[0].id }}'
                                                                       style="display: inline-block; padding: 10px; text-decoration: none; font-size: 12px; background-color: #875A7B; color: #fff; border-radius: 5px;">
                                                                        <strong>
                                                                            Pay
                                                                            Bill
                                                                            (Amount:
                                                                            <t t-out="remaining_amount"/>
                                                                            )
                                                                        </strong>
                                                                    </a>
                                                                </div>
                                                            </t>
                                                            <t t-if="len(unpaid_invoices) &gt; 1">
                                                                <strong>Invoice
                                                                    Details:
                                                                </strong>
                                                                <br/>
                                                                <br/>
                                                                <table style="width: 100%; border-collapse: collapse; font-size: 13px;">
                                                                    <thead>
                                                                        <tr style="background-color: #f9f9f9;">
                                                                            <th style="padding: 8px; text-align: left;">
                                                                                Invoice
                                                                            </th>
                                                                            <th style="padding: 8px; text-align: left;">
                                                                                Amount
                                                                                Due
                                                                            </th>
                                                                            <th style="padding: 8px; text-align: center;">
                                                                                Action
                                                                            </th>
                                                                        </tr>
                                                                    </thead>
                                                                    <tbody>
                                                                        <t t-foreach="unpaid_invoices"
                                                                           t-as="invoice">
                                                                            <tr>
                                                                                <td style="padding: 8px;">
                                                                                    <t t-out="invoice.name"/>
                                                                                </td>
                                                                                <td style="padding: 8px;">
                                                                                    <t t-out="invoice.amount_residual"/>
                                                                                </td>
                                                                                <td style="padding: 8px; text-align: center;">
                                                                                    <a t-attf-href='/my/invoices/{{ invoice.id }}'
                                                                                       style="display: inline-block; padding: 6px 10px; text-decoration: none; font-size: 12px; background-color: #9EA709; color: #fff; border-radius: 4px;">
                                                                                        <strong>
                                                                                            Pay
                                                                                            Now
                                                                                        </strong>
                                                                                    </a>
                                                                                </td>
                                                                            </tr>
                                                                        </t>
                                                                    </tbody>
                                                                </table>
                                                            </t>
                                                        </t>
                                                        <p>Please rate our
                                                            services and share
                                                            your feedback.
                                                        </p>
                                                        <div style="margin: 16px 0px; text-align: center;">
                                                            <a t-attf-href='/rate/{{object._rating_get_access_token()}}/5'
                                                               style="display: inline-block; padding: 10px; text-decoration: none; font-size: 12px; background-color: #9EA709; color: #fff; border-radius: 5px;">
                                                                <strong>Rate
                                                                    Us
                                                                </strong>
                                                            </a>
                                                        </div>
                                                    </div>
                                                </td>
                                            </tr>
                                            <tr>
                                                <td style="text-align:center;">
                                                    <hr width="100%"
                                                        style="background-color:rgb(204,204,204);border:none;clear:both;display:block;font-size:0px;min-height:1px;line-height:0; margin: 16px 0;"/>
                                                </td>
                                            </tr>
                                        </table>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </td>
                </tr>
            </table>
        </field>
    </record>
</odoo>
