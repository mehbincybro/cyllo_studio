"            </table>\n"
"        "
msgstr ""
"<table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" style=\"padding-top: 16px; background-color: #F1F1F1; font-family:Verdana, Arial,sans-serif; color: #454748; width: 100%; border-collapse:separate;\">\n"
"                <tr>\n"
"                    <td align=\"center\">\n"
"                        <table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"590\" style=\"padding: 16px; background-color: white; color: #454748; border-collapse:separate;  margin-bottom: 20px;\">\n"
"                            <tbody>\n"
"                                <tr>\n"
"                                    <td align=\"center\" style=\"min-width: 590px;\">\n"
"                                        <table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"590\" style=\"min-width: 590px; background-color: white; padding: 0px 8px; border-collapse:separate;\">\n"
"                                            <tr>\n"
"                                                <td valign=\"top\" style=\"font-size: 13px;\">\n"
"                                                    <div>\n"
"                                                        عزيزي\n"
"                                                        <t t-out=\"object.customer_id.name\"></t>\n"
"                                                        ,\n"
"                                                        <br>\n"
"                                                        <br>\n"
"                                                        نود إعلامك بأن المشكلة\n"
"                                                        التي أبلغت عنها قد تم\n"
"                                                        حلها بنجاح.\n"
"                                                        <br>\n"
"                                                        <br>\n"
"                                                        التفاصيل:\n"
"                                                        <br>\n"
"                                                        <span>\n"
"                                                            <a t-attf-href=\"/support-service-ticket/{{object.id}}\" style=\"text-decoration:none;\" class=\"text-decoration-none\">\n"
"                                                                <t t-out=\"object.name\"></t>\n"
"                                                            </a>\n"
"                                                        </span>\n"
"                                                        <br>\n"
"                                                        <br>\n"
"                                                        رقم التذكرة:\n"
"                                                        <span>\n"
"                                                            <t t-out=\"object.ticket\"></t>\n"
"                                                        </span>\n"
"                                                        <br>\n"
"                                                        <br>\n"
"                                                        الفريق:\n"
"                                                        <span>\n"
"                                                            <t t-out=\"object.team_id.name\"></t>\n"
"                                                        </span>\n"
"                                                        <br>\n"
"                                                        <br>\n"
"                                                        الشخص المسؤول:\n"
"                                                        <span>\n"
"                                                            <t t-out=\"object.user_id.name\"></t>\n"
"                                                        </span>\n"
"                                                        <br>\n"
"                                                        <br>\n"
"                                                        الحالة:\n"
"                                                        <span>\n"
"                                                            <t t-out=\"object.stage_id.name\"></t>\n"
"                                                        </span>\n"
"                                                        <br>\n"
"                                                        <br>\n"
"                                                        <!-- Total Expected Amount -->\n"
"                                                        المبلغ الإجمالي المتوقع:\n"
"                                                        <strong>\n"
"                                                            <t t-out=\"object.ticket_order_id.amount_total\"></t>\n"
"                                                        </strong>\n"
"                                                        <br>\n"
"                                                        <br>\n"
"                                                        <!-- Calculate Remaining Amount -->\n"
"                                                        <t t-set=\"remaining_amount\" t-value=\"0\"></t>\n"
"                                                        <t t-set=\"unpaid_invoices\" t-value=\"[]\"></t>\n"
"                                                        <t t-foreach=\"object.ticket_invoice_ids\" t-as=\"inv\">\n"
"                                                            <t t-if=\"inv.payment_state != 'paid'\">\n"
"                                                                <t t-set=\"remaining_amount\" t-value=\"remaining_amount + inv.amount_residual\"></t>\n"
"                                                                <t t-set=\"unpaid_invoices\" t-value=\"unpaid_invoices + [inv]\"></t>\n"
"                                                            </t>\n"
"                                                        </t>\n"
"                                                        <!-- Show Remaining Amount if exists -->\n"
"                                                        <t t-if=\"remaining_amount &gt; 0\">\n"
"                                                            المبلغ المتبقي للدفع:\n"
"                                                            <strong>\n"
"                                                                <t t-out=\"remaining_amount\"></t>\n"
"                                                            </strong>\n"
"                                                            <br>\n"
"                                                            <br>\n"
"                                                            <!-- If only one unpaid invoice -->\n"
"                                                            <t t-if=\"len(unpaid_invoices) == 1\">\n"
"                                                                <div style=\"margin: 16px 0px; text-align: center;\">\n"
"                                                                    <a t-attf-href=\"/my/invoices/{{ unpaid_invoices[0].id }}\" style=\"display: inline-block; padding: 10px; text-decoration: none; font-size: 12px; background-color: #875A7B; color: #fff; border-radius: 5px;\">\n"
"                                                                        <strong>\n"
"                                                                            دفع\n"
"                                                                            الفاتورة\n"
"                                                                            (المبلغ:\n"
"                                                                            <t t-out=\"remaining_amount\"></t>\n"
"                                                                            )\n"
"                                                                        </strong>\n"
"                                                                    </a>\n"
"                                                                </div>\n"
"                                                            </t>\n"
"                                                            <t t-if=\"len(unpaid_invoices) &gt; 1\">\n"
"                                                                <strong>تفاصيل\n"
"                                                                    الفاتورة:\n"
"                                                                </strong>\n"
"                                                                <br>\n"
"                                                                <br>\n"
"                                                                <table style=\"width: 100%; border-collapse: collapse; font-size: 13px;\">\n"
"                                                                    <thead>\n"
"                                                                        <tr style=\"background-color: #f9f9f9;\">\n"
"                                                                            <th style=\"padding: 8px; text-align: left;\">\n"
"                                                                                الفاتورة\n"
"                                                                            </th>\n"
"                                                                            <th style=\"padding: 8px; text-align: left;\">\n"
"                                                                                المبلغ\n"
"                                                                                المستحق\n"
"                                                                            </th>\n"
"                                                                            <th style=\"padding: 8px; text-align: center;\">\n"
"                                                                                الإجراء\n"
"                                                                            </th>\n"
"                                                                        </tr>\n"
"                                                                    </thead>\n"
"                                                                    <tbody>\n"
"                                                                        <t t-foreach=\"unpaid_invoices\" t-as=\"invoice\">\n"
"                                                                            <tr>\n"
"                                                                                <td style=\"padding: 8px;\">\n"
"                                                                                    <t t-out=\"invoice.name\"></t>\n"
"                                                                                </td>\n"
"                                                                                <td style=\"padding: 8px;\">\n"
"                                                                                    <t t-out=\"invoice.amount_residual\"></t>\n"
"                                                                                </td>\n"
"                                                                                <td style=\"padding: 8px; text-align: center;\">\n"
"                                                                                    <a t-attf-href=\"/my/invoices/{{ invoice.id }}\" style=\"display: inline-block; padding: 6px 10px; text-decoration: none; font-size: 12px; background-color: #9EA709; color: #fff; border-radius: 4px;\">\n"
"                                                                                        <strong>\n"
"                                                                                            ادفع\n"
"                                                                                            الآن\n"
"                                                                                        </strong>\n"
"                                                                                    </a>\n"
"                                                                                </td>\n"
"                                                                            </tr>\n"
"                                                                        </t>\n"
"                                                                    </tbody>\n"
"                                                                </table>\n"
"                                                            </t>\n"
"                                                        </t>\n"
"                                                        <p>يرجى تقييم\n"
"                                                            خدماتنا ومشاركة\n"
"                                                            ملاحظاتك.\n"
"                                                        </p>\n"
"                                                        <div style=\"margin: 16px 0px; text-align: center;\">\n"
"                                                            <a t-attf-href=\"/rate/{{object._rating_get_access_token()}}/5\" style=\"display: inline-block; padding: 10px; text-decoration: none; font-size: 12px; background-color: #9EA709; color: #fff; border-radius: 5px;\">\n"
"                                                                <strong>قيمنا\n"
"                                                                </strong>\n"
"                                                            </a>\n"
"                                                        </div>\n"
"                                                    </div>\n"
"                                                </td>\n"
"                                            </tr>\n"
"                                            <tr>\n"
"                                                <td style=\"text-align:center;\">\n"
"                                                    <hr width=\"100%\" style=\"background-color:rgb(204,204,204);border:none;clear:both;display:block;font-size:0px;min-height:1px;line-height:0; margin: 16px 0;\">\n"
"                                                </td>\n"
"                                            </tr>\n"
"                                        </table>\n"
"                                    </td>\n"
"                                </tr>\n"
"                            </tbody>\n"
"                        </table>\n"
"                    </td>\n"
"                </tr>\n"
"            </table>"

