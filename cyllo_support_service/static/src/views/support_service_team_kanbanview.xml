<?xml version="1.0" encoding="UTF-8"?>
<!-- Template for support service overview-->
<templates xml:space="preserve">
    <t t-name="cyllo_support_service.SupportServiceTeamKanbanView"
       t-inherit="web.KanbanRenderer" t-inherit-mode="primary" owl="1">
        <xpath expr="//div[@t-ref='root']" position="before">
            <t t-if="overView">
                <SupportServiceOverview/>
            </t>
        </xpath>
    </t>
</templates>
