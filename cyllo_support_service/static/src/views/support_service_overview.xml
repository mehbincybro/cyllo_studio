<?xml version="1.0" encoding="UTF-8"?>
<!-- Template for support service overview -->
<templates>
    <t t-name="cyllo_support_service.SupportServiceOverview" owl="1">
        <main class="col-lg-12 ms-sm-auto col-lg-12" style="overflow-x:hidden">
            <section id="cy-main-section">
                <div class="cy-form-settings-main-content flex-grow-1">
                    <div class="row cy-helpdesk_section">
                        <div>
                            <div class="row cy-support_service_container flex-wrap cy-border-btm gap-4">
                                <div class="col">
                                    <h2 class="cy-support_service_title cy-border-btm">
                                        My Tickets
                                    </h2>
                                    <!-- Table structure that shows the open tickets details in priority basis -->
                                    <table class=" cy-support_service-table">
                                        <tbody>
                                            <tr>
                                                <td>Open Tickets</td>
                                                <td t-on-click="() => this.getTicketDetails()">
                                                    <div class="cy-support_service_btn" style="cursor:pointer">
                                                        <p><t t-out="ticketData['all_tickets']"/></p>
                                                        Ticket
                                                    </div>
                                                </td>
                                                <td t-on-click="() => this.getTicketDetails('high_priority')">
                                                    <div class="cy-support_service_btn cy-support_service_high_priority" style="cursor:pointer">
                                                        <p><t t-out="ticketData['high_priority']"/></p>
                                                        High Priority
                                                    </div>
                                                </td>
                                                <td t-on-click="() => this.getTicketDetails('urgent_tickets')">
                                                    <div class="cy-support_service_btn cy-support_service_urgent" style="cursor:pointer">
                                                        <p><t t-out="ticketData['urgent']"/></p>
                                                        Urgent
                                                    </div>
                                                </td>
                                            </tr>
                                            <!-- Table row to show the failed ticket details -->
                                            <tr>
                                                <td>Failed Tickets</td>
                                                <td t-on-click="() => this.getTicketDetails('',true)" style="cursor:pointer"><t t-out="ticketData['failed_ticket_count']"/></td>
                                                <td t-on-click="() => this.getTicketDetails('high_priority',true)" style="cursor:pointer"><t t-out="ticketData['failed_high_priority_ticket_count']"/></td>
                                                <td t-on-click="() => this.getTicketDetails('urgent_tickets',true)" style="cursor:pointer"><t t-out="ticketData['failed_urgent_ticket_count']"/></td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                                <!-- Division that shows the performance of the user -->
                                <div class="col">
                                    <h2 class="cy-support_service_title cy-border-btm">
                                        My Performance
                                    </h2>
                                    <!-- Table that showing the closed tickets and success rate of the user -->
                                    <table class="cy-support_service-table">
                                        <tbody>
                                            <tr>
                                                <td>Closed Tickets</td>
                                                <td t-on-click="() => this.getTodayClosedTicket()">
                                                    <div class="cy-support_service_btn" style="cursor:pointer">
                                                        <p><t t-out="ticketData['my_today_closed_ticket_count']"/></p>
                                                        Today
                                                    </div>
                                                </td>
                                                <td t-on-click="() => this.getLastWeekClosedTicket()">
                                                    <div class="cy-support_service_btn" style="cursor:pointer">
                                                        <p><t t-out="ticketData['my_last_seven_days_closed_ticket_count']"/></p>
                                                        Last Week
                                                    </div>
                                                </td>
                                            </tr>
                                            <tr>
                                                <td>Success Rate</td>
                                                <td t-on-click="() => this.getTodaySuccessRate()" style="cursor:pointer"><t t-out="ticketData['my_today_success_rate']"/></td>
                                                <td t-on-click="() => this.getLastWeekSuccessRate()" style="cursor:pointer"><t t-out="ticketData['my_last_seven_days_success_rate']"/></td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </section>
        </main>
    </t>
</templates>
