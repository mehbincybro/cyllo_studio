<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!-- Report Template For Support Service Ticket-->
    <template id="support_service_report_document">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <div class="page">
                    <div class="align-items-center"
                         style="min-height:110px; background-color: #9EA700;">
                        <div style="padding: 30px">
                            <span t-esc="datetime.date.today().strftime('%d/%m/%Y')"
                                  style="color:#fff;"/>
                            <h3 style="margin-top:20px;color:#fff;font-weight:bold;">
                                Support Service Ticket Record
                            </h3>
                        </div>
                    </div>
                    <h3 t-esc="docs['name']" t-if="docs" class="mt-5"
                        style="margin-left: 10px;"/>
                    <div style="border-radius: 19px;margin-top: 20px;height: 10px;width: 50%;background: #9EA700;"/>
                    <div class="mt-3 ml-1">
                        <table class="table table-borderless">
                            <tbody>
                                <tr t-if="docs.customer_id">
                                    <th scope="row">Name :</th>
                                    <td>
                                        <span t-field="docs.customer_id"/>
                                    </td>
                                </tr>
                                <tr t-if="docs.email">
                                    <th scope="row">Email :</th>
                                    <td>
                                        <span t-esc="docs.email"/>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                    <div style="border-radius: 19px;margin-top: 20px;height: 10px;width: 75%;background: #9EA700;"/>
                    <div id="informations" class="row mt-4 mb-4">
                        <div class="col-auto col-3 mw-100 mb-2"
                             t-if="docs.category_id" name="category_id">
                            <strong>Category :</strong>
                            <p class="m-0" t-field="docs.category_id"/>
                        </div>
                        <div class="col-auto col-3 mw-100 mb-2"
                             t-if="docs.priority" name="priority">
                            <strong>Priority:</strong>
                            <p class="m-0" t-field="docs.priority"/>
                        </div>
                        <div class="col-auto col-3 mw-100 mb-2"
                             t-if="docs.ticket_type" name="ticket_type">
                            <strong>Ticket Type:</strong>
                            <p class="m-0" t-field="docs.ticket_type"/>
                        </div>
                        <div class="col-auto col-3 mw-100 mb-2"
                             t-if="docs.team_id" name="team_id">
                            <strong>Support Team:</strong>
                            <p class="m-0" t-field="docs.team_id"/>
                        </div>
                    </div>
                    <div id="informations2" class="row mt-4 mb-4">
                        <div class="col-3 mw-100 mb-2" t-if="docs.stage_id"
                             name="stage_id">
                            <strong>Status :</strong>
                            <p class="m-0" t-field="docs.stage_id"/>
                        </div>
                        <div class="col-3 mw-100 mb-2" t-if="docs.date"
                             name="date">
                            <strong>Submitted Date:</strong>
                            <p class="m-0" t-field="docs.date"/>
                        </div>
                        <div class="col-3 mw-100 mb-2" t-if="docs.deadline"
                             name="deadline">
                            <strong>Deadline:</strong>
                            <p class="m-0" t-field="docs.deadline"/>
                        </div>
                    </div>
                    <div style="border-radius: 19px;margin-top: 20px;height: 10px;width: 100%;background: #9EA700;"/>
                    <div class="col-auto mt-3" t-if="docs.description"
                         name="description">
                        <strong>Description:</strong>
                        <p class="m-0" t-field="docs.description"/>
                    </div>
                </div>
            </t>
        </t>
    </template>
</odoo>