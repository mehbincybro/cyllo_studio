<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Action for support service stage -->
    <record id="action_view_stage" model="ir.actions.act_window">
        <field name="name">Stage</field>
        <field name="res_model">support.service.stage</field>
        <field name="view_mode">tree,form</field>
    </record>
    <!-- Tree view for support service stage -->
    <record id="view_support_service_stage_tree" model="ir.ui.view">
        <field name="name">view.support.service.stage.tree</field>
        <field name="model">support.service.stage</field>
        <field name="arch" type="xml">
            <tree default_order="sequence">
                <field name="name"/>
                <field name="fold"/>
                <field name="is_closed"/>
                <field name="is_canceled"/>
            </tree>
        </field>
    </record>
    <!-- Form view for support service stage -->
    <record id="view_support_service_stage_form" model="ir.ui.view">
        <field name="name">view.support.service.stage.form</field>
        <field name="model">support.service.stage</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="sequence"/>
                        <field name="fold"/>
                        <field name="is_closed"/>
                        <field name="is_canceled"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
