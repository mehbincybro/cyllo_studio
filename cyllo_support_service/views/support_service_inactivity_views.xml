<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Action for support service inactivity -->
    <record id="action_view_inactivity" model="ir.actions.act_window">
        <field name="name">Inactivity</field>
        <field name="res_model">support.service.inactivity</field>
        <field name="view_mode">tree</field>
    </record>
        <!-- Tree view for support service inactivity -->
    <record id="view_support_service_inactivity_tree" model="ir.ui.view">
        <field name="name">view.support.service.inactivity.tree</field>
        <field name="model">support.service.inactivity</field>
        <field name="arch" type="xml">
            <tree>
                <field name="team_id" invisible="1"/>
                <field name="stage_id"/>
                <field name="no_of_inactive_days"/>
                <field name="state_id"/>
            </tree>
        </field>
    </record>
</odoo>