<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Template for breadcrumbs-->
    <template id="support_service_ticket_portal_layout" name="Portal layout : Support Service Ticket"
              inherit_id="portal.portal_breadcrumbs" priority="66">
        <xpath expr="//ol[hasclass('o_portal_submenu')]" position="inside">
            <li t-if="page_name == 'support_service_tickets'" class="breadcrumb-item active">
                <span>Support Service Tickets</span>
            </li>
            <li t-if="page_name == 'support_service_ticket_details'" class="breadcrumb-item active">
                <a t-attf-href="/support_service_ticket" aria-label="Home">
                    <span>Support Service Ticket</span>
                </a>
                <span>/
                    <t t-out="support_service_ticket.name"/>
                </span>
            </li>
            <li t-if="page_name == 'create_ticket'" class="breadcrumb-item active">
                <a t-attf-href="/support_service_ticket" aria-label="Home">
                    <span>Support Service Ticket</span>
                </a>
                <span>/ Create</span>
            </li>
        </xpath>
    </template>

    <!--    Table content of support service tickets -->
    <template id="portal_support_service_table" name="Table Support Service Portal">
        <t t-if="table_content">
            <table class="table mt16">
                <tbody>
                    <t t-foreach="table_content" t-as="support_service_ticket">
                        <tr>
                            <td>
                                <div class="disciplinary_track_row">
                                    <div class="row">
                                        <div class="request_top col-md-8">
                                            <span class="request-title">
                                                <h5>
                                                    <a t-att-href="support_service_ticket.get_portal_url()"
                                                       class="disciplinary_tracking_name"
                                                       t-esc="support_service_ticket.name"/>
                                                </h5>
                                            </span>
                                            <span class="service_req_employee mr4">
                                                Employee:
                                                <t t-esc="support_service_ticket.user_id.name"/>
                                            </span>
                                            <br/>
                                            <span class="service_req_category">
                                                Category:
                                                <t t-esc="support_service_ticket.category_id.name"/>
                                            </span>
                                            <br/>
                                        </div>
                                        <div class="request_content col-md-4">
                                            <span t-if="support_service_ticket.stage_id.id == %(cyllo_support_service.support_service_stage_new)d"
                                                  class="badge text-bg-info state_badge">
                                                <t t-esc="support_service_ticket.stage_id.name"/>
                                            </span>
                                            <span t-elif="support_service_ticket.stage_id.id == %(cyllo_support_service.support_service_stage_in_progress)d"
                                                  class="badge text-bg-info state_badge">
                                                <t t-esc="support_service_ticket.stage_id.name"/>
                                            </span>
                                            <span t-elif="support_service_ticket.stage_id.id == %(cyllo_support_service.support_service_stage_on_hold)d"
                                                  class="badge text-bg-info state_badge">
                                                <t t-esc="support_service_ticket.stage_id.name"/>
                                            </span>
                                            <span t-elif="support_service_ticket.stage_id.id == %(cyllo_support_service.support_service_stage_to_invoice)d"
                                                  class="badge text-bg-info state_badge">
                                                <t t-esc="support_service_ticket.stage_id.name"/>
                                            </span>
                                            <span t-elif="support_service_ticket.stage_id.id == %(cyllo_support_service.support_service_stage_solved)d"
                                                  class="badge text-bg-success state_badge">
                                                <t t-esc="support_service_ticket.stage_id.name"/>
                                            </span>
                                            <span t-elif="support_service_ticket.stage_id.id == %(cyllo_support_service.support_service_stage_canceled)d"
                                                  class="badge text-bg-warning state_badge">
                                                <t t-esc="support_service_ticket.stage_id.name"/>
                                            </span>
                                            <span t-elif="support_service_ticket.stage_id.id == %(cyllo_support_service.support_service_stage_closed)d"
                                                  class="badge text-bg-info state_badge">
                                                <t t-esc="support_service_ticket.stage_id.name"/>
                                            </span>
                                            <div class="o_cyllo_support_date">
                                                <t t-if="support_service_ticket.date">
                                                    <span t-field="support_service_ticket.date" class="date"/>
                                                </t>
                                                <span class="img-rounded user_img" t-field="support_service_ticket.create_user_avatar"
                                                      t-att-title="support_service_ticket.create_uid.name"
                                                      t-options="{'widget': 'image', 'class': 'img-rounded create_user_image'}"/>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </td>
                        </tr>
                    </t>
                </tbody>
            </table>
        </t>
    </template>

    <!--  Template that shows all my Support Service Tickets -->
    <template id="support_service_ticket_template" name="Support Service Tickets">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True"/>
            <t t-call="portal.portal_searchbar">
                <t t-set="title">Support Service Ticket</t>
            </t>
            <div class="row">
                <div class="col-md-6 col-6">
                    <ul class="nav nav-tabs" id="myTab" role="tablist"
                        style="border-color: white;">
                        <li class="nav-item" role="presentation">
                            <button class="nav-link cy-support_service-ticket-state-btn active" id="profile-tab" data-bs-toggle="tab" style="border-color: white;"
                                    data-bs-target="#all" type="button" role="tab" aria-controls="profile" aria-selected="false">
                                All
                            </button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link cy-support_service-ticket-state-btn" id="profile-tab" data-bs-toggle="tab" style="border-color: white;"
                                    data-bs-target="#draft" type="button" role="tab" aria-controls="profile" aria-selected="false">
                                Draft
                            </button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link cy-support_service-ticket-state-btn" id="profile-tab" data-bs-toggle="tab" style="border-color: white;"
                                    data-bs-target="#in_progress" type="button" role="tab" aria-controls="profile" aria-selected="false">
                                In Progress
                            </button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link cy-support_service-ticket-state-btn" id="profile-tab" data-bs-toggle="tab" style="border-color: white;"
                                    data-bs-target="#on_hold" type="button" role="tab" aria-controls="profile" aria-selected="false">
                                On Hold
                            </button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link cy-support_service-ticket-state-btn" id="profile-tab" data-bs-toggle="tab" style="border-color: white;"
                                    data-bs-target="#solved" type="button" role="tab" aria-controls="profile" aria-selected="false">
                                Solved
                            </button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link cy-support_service-ticket-state-btn" id="profile-tab" data-bs-toggle="tab" style="border-color: white;"
                                    data-bs-target="#closed" type="button" role="tab" aria-controls="profile" aria-selected="false">
                                Closed
                            </button>
                        </li>
                    </ul>
                </div>
                <div class="col-md-6 col-6  d-flex justify-content-end">
                    <a href="/support_service_ticket/create" class="btn btn-primary create_ticket_btn mt24 mb8">
                        Create Ticket
                    </a>
                </div>
            </div>
            <div class="tab-content">
                <t t-set="url" t-value="'/support_service_ticket/create'"/>
                <t t-set="description" t-value="'Currently No Tickets !'"/>
                <div class="tab-pane fade show active w-100" id="all" role="tabpanel" aria-labelledby="home-tab">
                    <t t-if="support_service_ticket_count == 0">
                        <t t-call="cyllo_portal.no_record_portal"/>
                    </t>
                    <t t-else="">
                        <t t-set="table_content" t-value="support_service_tickets"/>
                        <t t-call="cyllo_support_service.portal_support_service_table"/>
                    </t>
                </div>
                <div class="tab-pane fade w-100" id="draft" role="tabpanel" aria-labelledby="profile-tab">
                    <t t-if="draft_support_service_ticket_count == 0">
                        <t t-call="cyllo_portal.no_record_portal"/>
                    </t>
                    <t t-else="">
                        <t t-set="table_content" t-value="draft_support_service_tickets"/>
                        <t t-call="cyllo_support_service.portal_support_service_table"/>
                    </t>
                </div>
                <div class="tab-pane fade w-100" id="in_progress" role="tabpanel" aria-labelledby="profile-tab">
                    <t t-if="in_progress_support_service_ticket_count == 0">
                        <t t-call="cyllo_portal.no_record_portal"/>
                    </t>
                    <t t-else="">
                        <t t-set="table_content" t-value="in_progress_support_service_tickets"/>
                        <t t-call="cyllo_support_service.portal_support_service_table"/>
                    </t>
                </div>
                <div class="tab-pane w-100 fade" id="on_hold" role="tabpanel" aria-labelledby="profile-tab">
                    <t t-if="on_hold_support_service_ticket_count == 0">
                        <t t-call="cyllo_portal.no_record_portal"/>
                    </t>
                    <t t-else="">
                        <t t-set="table_content" t-value="on_hold_support_service_tickets"/>
                        <t t-call="cyllo_support_service.portal_support_service_table"/>
                    </t>
                </div>
                <div class="tab-pane fade w-100" id="solved" role="tabpanel" aria-labelledby="profile-tab">
                    <t t-if="solved_support_service_ticket_count == 0">
                        <t t-call="cyllo_portal.no_record_portal"/>
                    </t>
                    <t t-else="">
                        <t t-set="table_content" t-value="solved_support_service_tickets"/>
                        <t t-call="cyllo_support_service.portal_support_service_table"/>
                    </t>
                </div>
                <div class="tab-pane fade w-100" id="closed" role="tabpanel" aria-labelledby="profile-tab">
                    <t t-if="closed_support_service_ticket_count == 0">
                        <t t-call="cyllo_portal.no_record_portal"/>
                    </t>
                    <t t-else="">
                        <t t-set="table_content" t-value="closed_support_service_tickets"/>
                        <t t-call="cyllo_support_service.portal_support_service_table"/>
                    </t>
                </div>
            </div>
        </t>
    </template>
    <!--  Template that shows details of Support Service Ticket -->
    <template id="support_service_ticket_details" name="Support Service Ticket Content" inherit_id="portal.portal_sidebar" primary="True">
        <xpath expr="//div[hasclass('o_portal_sidebar')]" position="inside">
            <t t-set="o_portal_fullwidth_alert" groups="base.group_user">
                <t t-call="portal.portal_back_in_edit_mode">
                    <t t-set="backend_url" t-value="'/web#return_label=Website&amp;model=support.service.ticket&amp;id=%s&amp;' % object.id"/>
                </t>
            </t>
            <div class="row mt16 o_cy_portal_sidebar o_portal_support_service_sidebar">
                <t t-call="cyllo_portal.cy_portal_record_sidebar" id="support_service_portal_sidebar">
                    <t t-set="classes" t-value="'col-lg-auto d-print-none'"/>
                    <t t-set="title">
                        <h2 t-esc="object.ticket"/>
                    </t>
                    <t t-set="entries">
                        <div class="d-flex flex-column gap-1 order-md-last order-lg-first" id="support_service_sidebar_button">
                            <div class="d-flex flex-column gap-4">
                                <div class="o_download_pdf">
                                    <a class="btn btn-primary o_print_btn d-block" t-att-href="object.get_portal_url(report_type='pdf')"
                                       id="print_disciplinary_report" title="View Details" target="_blank">
                                        <i class="fa fa-print"/>
                                        View Details
                                    </a>
                                </div>
                            </div>
                            <div class="d-flex flex-column gap-4"
                                 t-if="support_service_ticket.stage_id.id != %(cyllo_support_service.support_service_stage_closed)d">
                                <div class="o_btn_start_service">
                                    <a t-attf-href="/support_service_ticket/close/{{support_service_ticket.id}}" class="btn btn-secondary mt24 w-100 mb8">
                                        Close Ticket
                                    </a>
                                </div>
                            </div>
                        </div>
                        <div class="navspy flex-grow-1 ps-0" t-ignore="true" role="complementary">
                            <ul class="nav flex-column bs-sidenav"/>
                        </div>
                        <div t-if="object.date">
                            <small>
                                <b>Requested Date</b>
                            </small>
                            <div t-field="object.date"/>
                        </div>
                        <br/>
                        <div t-if="object.user_id">
                            <h6>
                                <small class="text-muted">Your contact</small>
                            </h6>
                            <div class="o_portal_contact_details d-flex flex-column gap-2">
                                <div class="d-flex justify-content-start align-items-center gap-2">
                                    <img class="o_avatar o_portal_contact_img rounded" t-if="object.user_id"
                                         t-att-src="image_data_uri(object.user_id.avatar_1024)" alt="Contact"/>
                                    <img class="o_avatar o_portal_contact_img rounded" t-else=""
                                         t-att-alt="'%s' % object.company_id.name" alt="Contact"/>
                                    <div>
                                        <h6 class="mb-0" t-out="object.user_id.name"/>
                                        <a href="#discussion" class="d-flex align-items-center gap-2 small fw-bold">
                                            Send message
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </t>
                <div id="quote_content" class="col-12 col-lg justify-content-end">
                    <div class="p-3 o_cy_portal_border border">
                        <h2 class="my-0 col-12 col-lg flex-grow-1 mb-1 mb-lg-0">
                            <t t-esc="object.ticket"/>
                            <span class="badge text-bg-warning  state_badge mt-2" style="font-size:15px;" t-field="object.stage_id">
                            </span>
                        </h2>
                        <br/>
                        <div id="informations" class="row mt-4">
                            <div id="customer_info" class="col-12 col-lg-6 offset-lg-1 ms-auto">
                                <hr class="my-0"/>
                                <strong t-field="object.customer_id"/>
                                <div t-field="object.customer_id" t-options="{ 'widget': 'contact', 'fields': [ 'name', 'address', 'phone', 'email']}"/>
                            </div>
                        </div>
                        <hr/>
                        <section id="details" style="page-break-inside: auto;" class="mt32 row">
                            <h3 id="service_details" style="font-size: 20px;">
                                Service Information
                            </h3>
                            <br/>
                            <div class="row mt-2 mb-2" id="service_request_information">
                                <div class="col-md-3 mb-2" t-if="object.name">
                                    <strong>Name :</strong>
                                    <br/>
                                    <span t-field="object.name"/>
                                </div>
                                <div class="col-md-3 mb-2" t-if="object.customer_id">
                                    <strong>Customer Name</strong>
                                    <br/>
                                    <span t-field="object.customer_id"/>
                                </div>
                                <div class="col-md-3 mt-2 mb-2"
                                     t-if="object.user_id">
                                    <strong>Assigned to</strong>
                                    <br/>
                                    <span t-field="object.user_id"/>
                                </div>
                                <div class="col-md-3 mt-2 mb-2" t-if="object.company_id">
                                    <strong>Company</strong>
                                    <br/>
                                    <span t-field="object.company_id"/>
                                </div>
                                <div class="col-md-3 mt-2 mb-2" t-if="object.date">
                                    <strong>Requested Date</strong>
                                    <br/>
                                    <span t-field="object.date"/>
                                </div>
                                <div class="col-md-3 mt-2 mb-2" t-if="object.deadline">
                                    <strong>Date Deadline</strong>
                                    <br/>
                                    <span t-field="object.deadline"/>
                                </div>
                                <div class="col-md-3 mt-2 mb-2" t-if="object.team_id">
                                    <strong>Team</strong>
                                    <br/>
                                    <span t-field="object.team_id"/>
                                </div>
                                <div class="col-md-3 mt-2 mb-2" t-if="object.category_id">
                                    <strong>Category</strong>
                                    <br/>
                                    <span t-field="object.category_id"/>
                                </div>
                            </div>
                        </section>
                        <section id="details" style="page-break-inside: auto;" class="mt32 row" t-if="object.description">
                            <h3 id="service_details" style="font-size: 20px;">
                                Service Description
                            </h3>
                            <br/>
                            <div class="row mt-2 mb-3" style="margin-left:2px;" id="service_request_description" t-esc="object.description"/>
                        </section>
                        <!--====== Adding Chatter==========-->
                        <div id="_communication">
                            <h3>Communication history</h3>
                            <t t-call="portal.message_thread"/>
                        </div>
                    </div>
                </div>
            </div>
        </xpath>
    </template>
    <!--  Template of supportservice Ticket Form  -->
    <template id="support_service_ticket_form">
        <t t-call="website.layout">
            <div id="wrap" class="oe_structure oe_empty cyllo_register_support_ticket_form">
                <div class="s_col_no_bgcolor container s_allow_columns w-50">
                    <div class="justify-content-center d-flex mt-5">
                        <br/>
                        <h3>
                            Support Service Ticket
                        </h3>
                        <br/>
                    </div>
                    <div class="container mt-4 mb-5 justify-content-center d-flex">
                        <form action="/ticket/submit" method="post" enctype="multipart/form-data"
                              class="o_mark_required cy-support_service-ticket_form" data-mark="*">
                            <div class="row">
                                <div class="col-12">
                                    <label for="name" class="cy-support_service_ticket-label">
                                        Name
                                    </label>
                                    <input id="customer" type="hidden" name="csrf_token"
                                           t-att-value="request.csrf_token()" class="form-control"/>
                                    <input type="text" class="form-control cy-support_service-ticket_input" name="customer_name"
                                           id="customer_name" t-att-value="request.env.user.name" required="1" readonly="1"/>
                                </div>
                                <div class="col-12 col-sm-6">
                                    <label for="email" class="cy-support_service_ticket-label">
                                        Email
                                    </label>
                                    <input type="text" class="form-control cy-support_service-ticket_input" id="email"
                                           name="email" t-att-value="request.env.user.email or ''" required="1"/>
                                </div>
                                <div class="col-12 col-sm-6">
                                    <label for="phone" class="cy-support_service_ticket-label">
                                        Phone
                                    </label>
                                    <input type="text" class="form-control cy-support_service-ticket_input" id="phone"
                                           placeholder="+1 55 555 555" t-att-value="request.env.user.phone" required="1"/>
                                </div>
                                <div class="col-12">
                                    <label for="ticket_name" class="cy-support_service_ticket-label">
                                        Ticket Subject
                                    </label>
                                    <input type="text" class="form-control cy-support_service-ticket_input"
                                           id="ticket_name" name="ticket_name" required="1"/>
                                </div>
                                <div class="col-12">
                                    <label for="description" class="cy-support_service_ticket-label">
                                        Description
                                    </label>
                                    <textarea class="form-control cy-support_service-ticket_input"
                                              id="description" name="description" placeholder=""/>
                                </div>
                                <div class="col-12 col-sm-6">
                                    <label for="category_id" class="cy-support_service_ticket-label">
                                        Ticket Category
                                    </label>
                                    <select name="category_name" t-attf-class="form-control s_website_form_input">
                                        <t t-foreach="categories or []" t-as="category">
                                            <option t-att-value="category.id">
                                                <t t-esc="category.name"/>
                                            </option>
                                        </t>
                                    </select>
                                </div>
                                <div class="col-12 col-sm-6">
                                    <label for="sale-order" class="cy-support_service_ticket-label ">
                                        Sale Order
                                    </label>
                                    <select name="sale_order" t-attf-class="form-control s_website_form_input">
                                        <t t-foreach="sale_order_items or []" t-as="sale_order">
                                            <option t-att-value="sale_order.id">
                                                <t t-esc="sale_order.name"/>
                                            </option>
                                        </t>
                                    </select>
                                </div>
                                <div class="col-12 col-sm-6">
                                    <label for="sale-order" class="cy-support_service_ticket-label ">
                                        Ticket Type
                                    </label>
                                    <select name="ticket_type" t-attf-class="form-control s_website_form_input">
                                        <option value="enquiries">Enquiries</option>
                                        <option value="issues">Issues</option>
                                    </select>
                                </div>
                                <div class="col-12 col-sm-6 cy_support_priority_div">
                                    <label for="priority" class="cy-support_service_ticket-label ">
                                        Priority :
                                    </label>
                                    <div class="stars-box">
                                        <i class="star fa fa-star" title="Priority: Low" data-message="Priority: Low" value="1"/>
                                        <i class="star fa fa-star" title="Priority: High" data-message="Priority: High" value="2"/>
                                        <i class="star fa fa-star" title="Priority: Very High" data-message="Priority: Very High" value="3"/>
                                    </div>
                                    <input type="hidden" name="priority" value="0" class="rate_value"/>
                                </div>
                                <div class="col-12">
                                    <label for="ticket_name" class="cy-support_service_ticket-label">
                                        Attachments
                                    </label>
                                    <input type="file" class="form-control cy-support_service-ticket_input"
                                           id="attachments" multiple="multiple" accept="*" name="attachments"/>
                                </div>
                                <div class="d-flex justify-content-center mt-5">
                                    <button class="btn btn-primary w-100 cy-button-primary-stroke" type="submit">
                                        Submit
                                    </button>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </t>
    </template>
    <!--  Template shown when closing a Support service Ticket by user  -->
    <template id="support_service_ticket_closing_template">
        <t t-call="website.layout">
            <div style="margin-top: 100px;" class="jumbotron text-center">
                <h1 class="display-3">Thank You!</h1>
                <p class="lead">Your ticket has been successfully closed.</p>
                <a href="/support_service_ticket">Back to Tickets</a>
            </div>
        </t>
    </template>
</odoo>