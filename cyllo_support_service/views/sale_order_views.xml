<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Record to add a field inside sale order -->
    <record id="view_sale_order_form_inherit_ticket" model="ir.ui.view">
        <field name="name">view.sale.order.form.inherit.ticket</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='payment_term_id']" position="after">
                <field name="ticket_reference" invisible="1"/>
            </xpath>
        </field>
    </record>
</odoo>
