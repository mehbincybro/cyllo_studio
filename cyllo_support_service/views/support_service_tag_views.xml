<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Action for support service tag -->
    <record id="action_view_tag" model="ir.actions.act_window">
        <field name="name">Tag</field>
        <field name="res_model">support.service.tag</field>
        <field name="view_mode">tree</field>
    </record>
    <!-- Tree view for support service tag -->
    <record id="view_support_service_tag_tree" model="ir.ui.view">
        <field name="name">view.support.service.tag.tree</field>
        <field name="model">support.service.tag</field>
        <field name="arch" type="xml">
            <tree editable="bottom">
                <field name="name"/>
                <field name="color" widget="color_picker"/>
            </tree>
        </field>
    </record>
</odoo>
