<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Action for support service team -->
    <record id="action_view_team" model="ir.actions.act_window">
        <field name="name">Team</field>
        <field name="res_model">support.service.team</field>
        <field name="view_mode">tree,form,kanban</field>
        <field name="context">{'overview':false}</field>
    </record>
    <!-- Tree view for support service team -->
    <record id="view_support_service_team_tree" model="ir.ui.view">
        <field name="name">view.support.service.team.tree</field>
        <field name="model">support.service.team</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="company_id"/>
            </tree>
        </field>
    </record>
    <!-- Form view for support service team -->
    <record id="view_support_service_team_form" model="ir.ui.view">
        <field name="name">view.support.service.team.form</field>
        <field name="model">support.service.team</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <section id="cy-main-section">
                        <div class="cy-form-settings-main-content flex-grow-1 ">
                            <div class="row cy-form-settings_content">
                                <div>
                                    <form class="py-2">
                                        <div class="mb-4">
                                            <label for="name"
                                                   class="form-label cy-form_label cy-form_label-sm">
                                                Name
                                            </label>
                                            <div class="input-group cy-inputbox-container"
                                                    style="flex-wrap:nowrap;">
                                                <field name="name"
                                                       class="cy-form-inputbox"
                                                       style="padding:1rem; margin-bottom:0px"/>
                                                <select class="cy-selection_box"
                                                        style="padding:12px; width:1%"
                                                        id="language">
                                                    <option value="english">
                                                        EN
                                                    </option>
                                                    <option value="spanish">
                                                        SN
                                                    </option>
                                                    <option value="french">FH
                                                    </option>
                                                </select>
                                            </div>
                                        </div>
                                        <p class="cy-form-settings-txt cy-checkbox-undertxt">
                                            Team Manager
                                        </p>
                                        <field name="manager_id"/>
                                        <field name="description"
                                               placeholder="Describe the team"/>
                                        <field name="company_id"/>
                                        <div>
                                            <div class="mb-3 cy-border-btm">
                                                <h4 class="cy-form_label">
                                                    Track and Bill Time
                                                </h4>
                                            </div>
                                            <div class="mb-4">
                                                <div class="form-check">
                                                    <field name="is_timesheet"/>
                                                    <label class="form-check-label cy-form_label cy-form_label-sm"
                                                           for="is_timesheet">
                                                        Timesheet
                                                    </label>
                                                </div>
                                                <p class="cy-form-settings-txt cy-checkbox-undertxt">
                                                    Set timesheet needed or not
                                                </p>
                                            </div>
                                            <div class="mb-4">
                                                <div class="form-check">
                                                    <field name="is_paid"/>
                                                    <label class="form-check-label cy-form_label cy-form_label-sm"
                                                           for="is_paid">
                                                        Is Paid
                                                    </label>
                                                </div>
                                                <p class="cy-form-settings-txt cy-checkbox-undertxt">
                                                    Choose: group works for
                                                    free ticket or pays.
                                                </p>
                                            </div>
                                            <div class="mb-4">
                                                    <field name="project_id" invisible="1"/>
                                            </div>
                                        </div>
                                        <div>
                                            <div class="mb-3 cy-border-btm">
                                                <p class="cy-form_label">
                                                    Performance
                                                </p>
                                            </div>
                                            <div class="mb-4">
                                                <div class="form-check">
                                                    <label class="form-check-label cy-form_label cy-form_label-sm"
                                                           for="working_hour_id">
                                                        Working Hours
                                                    </label>
                                                    <field name="working_hour_id"/>
                                                </div>
                                                <p class="cy-form-settings-txt cy-checkbox-undertxt">
                                                    Set the working hours of
                                                    the team
                                                </p>
                                            </div>
                                        </div>
                                        <div>
                                            <div class="mb-3 cy-border-btm">
                                                <h4 class="cy-form_label">
                                                    Ticket Closing
                                                </h4>
                                            </div>
                                            <div class="mb-4">
                                                <div class="form-check">
                                                    <field name="closing_inactive_tickets"/>
                                                    <label class="form-check-label cy-form_label cy-form_label-sm"
                                                           for="closing_inactive_tickets">
                                                        Ticket Closing Due to
                                                        inactivity
                                                    </label>
                                                </div>
                                            </div>
                                            <div class="mb-4" invisible="closing_inactive_tickets != True">
                                                <div class="form-check">
                                                    <div>
                                                        <field name="inactivity_ids">
                                                            <tree editable="bottom">
                                                                <field name="stage_id"/>
                                                                <field name="no_of_inactive_days"/>
                                                                <field name="state_id"/>
                                                            </tree>
                                                        </field>
                                                    </div>
                                                </div>
                                                <p class="cy-form-settings-txt cy-checkbox-undertxt">
                                                   Select the initial and final stages for moving the ticket and specify the number of inactive days.
                                                </p>
                                            </div>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </section>
                </sheet>
            </form>
        </field>
    </record>
    <!-- Kanban view for support_service team -->
    <record id="view_support_service_team_kanban" model="ir.ui.view">
        <field name="name">view.support.service.team.kanban</field>
        <field name="model">support.service.team</field>
        <field name="arch" type="xml">
            <kanban class="o_slide_kanban o_kanban_dashboard"
                    js_class="support_service_dashboard_kanban" sample="1">
                <templates>
                    <t t-name="kanban-box">
                        <div class=" card  cy-support_service_card">
                            <div class="card-body">
                                <div
                                        class="d-flex justify-content-between align-items-center gap-2 mb-3">
                                    <div class="cy-support_service_title cy-support_service-card">
                                        <field name="display_name"/>
                                        <br/>
                                        <div style="font-size:small; font-weight: initial;">
                                            <field name="company_id"/>
                                        </div>
                                    </div>
                                    <div class="d-flex gap-2">
                                        <button class="btn cy-button-primary-stroke cy-support_service-btn"
                                                name="action_get_team_tickets"
                                                type="object">View Tickets
                                        </button>
                                    </div>
                                </div>
                                <a class="d-flex justify-content-between align-items-center mb-2"
                                   type="object"
                                   name="get_team_closed_tickets">
                                    <span class="cy-support_service_subtitle">
                                        Tickets Closed
                                    </span>
                                    <span class="ms-3">
                                        <field name="closed_ticket_count"/>
                                    </span>
                                </a>
                                <a class="d-flex justify-content-between align-items-center mb-2"
                                   name="get_team_solved_tickets"
                                   type="object">
                                    <span class="cy-support_service_subtitle">
                                        Success Rate
                                    </span>
                                    <span class="cy-support_service_card-count">
                                        <field name="success_rate"/>
                                        %
                                    </span>
                                </a>
                                <div class="d-flex justify-content-between align-items-center">
                                    <div class="mt-3 text-center cy-support_service_card-state">
                                        <a name="get_team_open_tickets"
                                           type="object">
                                            <span>
                                                <field name="open_count"/>
                                            </span>
                                            <p class="m-0">Open</p>
                                        </a>
                                    </div>
                                    <div class="mt-3 text-center cy-support_service_card-state">
                                        <a name="get_team_unassigned_tickets"
                                           type="object">
                                            <span>
                                                <field name="unassigned_count"/>
                                            </span>
                                            <p class="m-0">Unassigned
                                            </p>
                                        </a>
                                    </div>
                                    <div class="mt-3 text-center cy-support_service_card-state">
                                        <a name="get_team_urgent_tickets"
                                           type="object">
                                            <span>
                                                <field name="urgent_count"/>
                                            </span>
                                            <p class="m-0">Urgent</p>
                                        </a>
                                    </div>
                                    <div class="mt-3 text-center cy-support_service_card-state">
                                        <a name="get_team_failed_tickets"
                                           type="object">
                                            <span>
                                                <field name="failed_ticket_count"/>
                                            </span>
                                            <p class="m-0">Failed</p>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>
</odoo>
