<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Action for support service category -->
    <record id="action_view_category" model="ir.actions.act_window">
        <field name="name">Category</field>
        <field name="res_model">support.service.category</field>
        <field name="view_mode">tree,form</field>
    </record>
    <!-- Tree view for support service category -->
    <record id="view_support_service_category_tree" model="ir.ui.view">
        <field name="name">view.support.service.category.tree</field>
        <field name="model">support.service.category</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="parent_id"/>
            </tree>
        </field>
    </record>
    <!-- Form view for support service category -->
    <record id="view_support_service_category_form" model="ir.ui.view">
        <field name="name">view.support.service.category.form</field>
        <field name="model">support.service.category</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="parent_id"/>
                            <field name="description" placeholder="Description about the category"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
