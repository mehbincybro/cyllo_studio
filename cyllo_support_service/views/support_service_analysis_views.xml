<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!-- Action for support service analysis -->
    <record id="action_view_support_service_analysis" model="ir.actions.act_window">
        <field name="name">Support Service Analysis</field>
        <field name="res_model">support.service.ticket</field>
        <field name="view_mode">graph,pivot</field>
    </record>
    <!-- Graph view for support service analysis -->
    <record id="view_support_service_ticket_graph" model="ir.ui.view">
        <field name="name">view.support.service.ticket.graph</field>
        <field name="model">support.service.ticket</field>
        <field name="arch" type="xml">
            <graph>
                <field name="stage_id" type="measure"/>
            </graph>
        </field>
    </record>
    <!-- Pivot view for support service analysis -->
    <record id="view_support_service_ticket_pivot" model="ir.ui.view">
        <field name="name">view.support.service.ticket.pivot</field>
        <field name="model">support.service.ticket</field>
        <field name="arch" type="xml">
            <pivot sample="1">
            </pivot>
        </field>
    </record>
</odoo>
