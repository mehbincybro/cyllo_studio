<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Allows users to log time or resume timer on a support ticket -->
    <record id="view_ticket_timesheet_confirm_form" model="ir.ui.view">
        <field name="name">view.ticket.timesheet.confirm.form</field>
        <field name="model">ticket.timesheet.confirm</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="unit_amount"/>
                        <field name="note" required="True"/>
                    </group>
                </sheet>
                <footer>
                    <button string="Log Time" type="object"
                            name="ticket_log_time"/>
                    <button string="Resume Timer" type="object"
                            name="ticket_resume_timer"/>
                    <button string="Cancel" type="object" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
