<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Record to add fields inside repair order -->
    <record id="view_repair_order_wizard_form" model="ir.ui.view">
        <field name="name">view.repair.order.wizard.form</field>
        <field name="model">repair.order.wizard</field>
        <field name="arch" type="xml">
            <form>
                <field name="ticket_id" invisible="1"/>
                <field name="partner_id" invisible="1"/>
                <field name="internal_notes" invisible="1"/>
                <sheet>
                    <group>
                        <field name="sale_order_id" string="Sale Order"/>
                        <field name="product_id" string="Product to Repair"/>
                        <field name="product_ids" string="Product in Sale Order"
                               invisible="1"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_confirm" string="Create Repair"
                            type="object"
                            class="oe_highlight"/>
                    <button string="Cancel" type="object" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
