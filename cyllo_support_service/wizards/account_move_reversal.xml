<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Record to add fields inside account move reversal -->
    <record id="view_account_move_reversal_form" model="ir.ui.view">
        <field name="name">view.account.move.reversal.form</field>
        <field name="model">account.move.reversal</field>
        <field name="inherit_id" ref="account.view_account_move_reversal"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='journal_id']" position="after">
                <field name="sale_order_id" invisible="not ticket_id"/>
                <field name="move_ids" widget="many2many_tags"
                       options="{'no_create_edit': True, 'no_create': True}"
                       invisible="not ticket_id" required="ticket_id"/>
                <field name="ticket_id" invisible="1"/>
                <field name="account_move_ids" invisible="1"/>
            </xpath>
        </field>
    </record>
</odoo>
