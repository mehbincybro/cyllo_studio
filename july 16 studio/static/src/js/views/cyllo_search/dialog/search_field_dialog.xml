<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <t t-name="cyllo_studio.SearchFieldDialog">
        <div class="cy-search-modal-body">
        <Dialog title="props.properties ? 'Update Autocomplete Field' : 'Add Autocomplete Field'">
            <div class="search-autocomplete_dialog">
                <p class="cy-studio-modal_subtitle">
                    <t t-if="props.properties">
                        Update the Autocomplete Field
                    </t>
                    <t t-else="">
                        Fill the form to add the Autocomplete Field
                    </t>
                </p>
                    <div class="row">
                    <div class="col">
                        <div class="form-group mb-3 col-10">
                            <label>Label</label>
                            <input type="text" class="form-control" t-model="state.string"
                                   t-attf-placeholder="{{props.allFields[state.field]?.string || 'Enter a label'}}"/>
                        </div>
                        <div class="form-group mb-3 col-10 filter_domain">
                            <label>Field</label>
                            <div class="cy-studio-custom-dropdown-dialog-search-field-view">
                                <CylloStudioDropdown
                                        options="AllFields"
                                        onChange="(value) => this.handleAllFieldSelect(value)"
                                        defaultValue="defaultAllFields"
                                        searchable="true"
                                />
                            </div>

                            <div class="invalid-feedback">Enter label
                                Please select a field.
                            </div>
                        </div>
                    </div>
                        <div class="col">
                        <div class="form-group mb-3 col-10">
                            <label>Visible To</label>
                            <div class="form-control" style="max-height:80px; overflow:auto;">
                                <MultiRecordSelector resIds="state.groupIds" resModel="'res.groups'"
                                                     update="(groupIds)=> state.groupIds = groupIds"/>
                            </div>
                        </div>
                            <div class="d-flex col-10">
                            <input class="customCheckbox ViewCheck" type="checkbox" name="invisible" id="invisible"
                                   t-on-click="onDomainRadioClick"
                                   t-att-checked="!['False','false', '0'].includes(state.invisible)"/>
                                <label class="cy-navbar_label customCheckbox-label" for="invisible">Invisible</label>
                        </div>
                    </div>
                </div>
                    <t t-set-slot="footer">
                    <button class="btn btn-primary" t-on-click="onConfirm">Confirm</button>
                        <button class="btn btn-secondary" t-on-click="onDiscard">Discard</button>
                </t>
            </div>
        </Dialog>
    </div>
    </t>
</templates>