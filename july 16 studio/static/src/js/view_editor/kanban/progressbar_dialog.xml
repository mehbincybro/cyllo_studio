<?xml version="1.0" encoding="UTF-8"?>
<templates>
    <t t-name="cyllo_studio.ProgressBarDialog" owl="1">
        <Dialog title="'Progress Bar'" size="'lg'" bodyClass="'overflow-visible'">
            <div class="progressbar_dialog">
                <p class="cy-studio-modal_subtitle">
                    <t t-if="props.progressAttributes">
                        Edit the Progress Bar
                    </t>
                    <t t-else="">
                        Add the Progress Bar
                    </t>
                </p>
                <div class="row">
                    <div class="col">
                        <div class="form-group mb-3 col-10 field_dropdown">
                            <label>Field</label>
                            <CylloStudioDropdown
                                    options="getField('selection')"
                                    onChange="(value) => this.handleFieldSelect(value)"
                                    defaultValue="properties.field"
                                    searchable="true"
                            />
                        </div>
                        <div class="form-group mb-3 col-10 sum_dropdown" t-if="getField('monetary').length > 0">
                            <label>Sum Field</label>
                            <CylloStudioDropdown
                                    options="getField('monetary')"
                                    onChange="(value) => this.handleFieldSelect(value, true)"
                                    defaultValue="properties.sum_field"
                                    searchable="true"
                            />
                        </div>
                        <div class="form-group mb-3 col-10">
                            <label>Help</label>
                            <div class="border-bottom">
                                <input type="text" class="o_input" t-model="properties.help"/>
                            </div>
                        </div>
                    </div>
                    <div class="col">
                        <div class="form-group mb-3 col-10">
                            <label t-if="hasValue=='show' or hasValue=='hide'" class="me-2">Colors</label>
                            <div t-if="hasValue != 'show' and hasValue != 'hide'"
                                 class="d-flex justify-content-center align-items-center" style="min-height: 200px;">
                                <svg width="320" height="240" xmlns="http://www.w3.org/2000/svg">
                                    <defs>
                                        <linearGradient id="profileGradient" x1="0%" y1="0%" x2="100%" y2="100%">
                                            <stop offset="0%" style="stop-color:#667eea;stop-opacity:1"/>
                                            <stop offset="100%" style="stop-color:#764ba2;stop-opacity:1"/>
                                        </linearGradient>
                                        <linearGradient id="progressGradient" x1="0%" y1="0%" x2="100%" y2="0%">
                                            <stop offset="0%" style="stop-color:#28a745;stop-opacity:1"/>
                                            <stop offset="100%" style="stop-color:#20c997;stop-opacity:1"/>
                                        </linearGradient>
                                        <filter id="cardShadow" x="-20%" y="-20%" width="140%" height="140%">
                                            <feDropShadow dx="0" dy="4" stdDeviation="8" flood-color="#000000"
                                                          flood-opacity="0.1"/>
                                        </filter>
                                    </defs>

                                    <!-- Background card -->
                                    <rect x="15" y="15" width="290" height="210" rx="12" ry="12" fill="white"
                                          stroke="#e1e5e9" stroke-width="1" filter="url(#cardShadow)"/>

                                    <!-- Profile section -->
                                    <!-- Profile image circle -->
                                    <circle cx="50" cy="55" r="22" fill="url(#profileGradient)"/>
                                    <!-- Profile initials -->
                                    <text x="50" y="62" text-anchor="middle" font-family="Segoe UI, sans-serif"
                                          font-size="14" font-weight="bold" fill="white">AM
                                    </text>

                                    <!-- Profile info -->
                                    <text x="80" y="50" font-family="Segoe UI, sans-serif" font-size="13"
                                          font-weight="600" fill="#2c3e50">Anna Martin
                                    </text>
                                    <text x="80" y="65" font-family="Segoe UI, sans-serif" font-size="11"
                                          fill="#7f8c8d">Project Manager
                                    </text>

                                    <!-- Activity Status label -->
                                    <text x="30" y="100" font-family="Segoe UI, sans-serif" font-size="11"
                                          font-weight="500" fill="#5a6c7d">Activity Status
                                    </text>

                                    <!-- Progress bar container -->
                                    <rect x="30" y="110" width="260" height="85" rx="8" ry="8" fill="#f8f9fa"
                                          stroke="#e9ecef" stroke-width="1"/>

                                    <!-- Completed item -->
                                    <rect x="38" y="118" width="244" height="22" rx="6" ry="6" fill="#d4edda"/>
                                    <rect x="38" y="118" width="3" height="22" rx="1" ry="1" fill="#28a745"/>
                                    <text x="48" y="132" font-family="Segoe UI, sans-serif" font-size="10"
                                          font-weight="500" fill="#155724">Planning
                                    </text>
                                    <circle cx="270" cy="129" r="4" fill="#28a745"/>

                                    <!-- In Progress item -->
                                    <rect x="38" y="145" width="244" height="22" rx="6" ry="6" fill="#fff3cd"/>
                                    <rect x="38" y="145" width="3" height="22" rx="1" ry="1" fill="#ffc107"/>
                                    <text x="48" y="159" font-family="Segoe UI, sans-serif" font-size="10"
                                          font-weight="500" fill="#856404">Development
                                    </text>
                                    <circle cx="270" cy="156" r="4" fill="#ffc107"/>

                                    <!-- Pending item -->
                                    <rect x="38" y="172" width="244" height="22" rx="6" ry="6" fill="#f8d7da"/>
                                    <rect x="38" y="172" width="3" height="22" rx="1" ry="1" fill="#dc3545"/>
                                    <text x="48" y="186" font-family="Segoe UI, sans-serif" font-size="10"
                                          font-weight="500" fill="#721c24">Testing
                                    </text>
                                    <circle cx="270" cy="183" r="4" fill="#dc3545"/>

                                    <!-- Separator line -->
                                    <line x1="30" y1="208" x2="290" y2="208" stroke="#e9ecef" stroke-width="1"/>

                                    <!-- Overall Progress label -->
                                    <text x="30" y="225" font-family="Segoe UI, sans-serif" font-size="11"
                                          font-weight="500" fill="#5a6c7d">Overall Progress
                                    </text>

                                    <!-- Progress bar background -->
                                    <rect x="160" y="215" width="120" height="8" rx="4" ry="4" fill="#e9ecef"/>
                                    <!-- Progress bar fill -->
                                    <rect x="160" y="215" width="78" height="8" rx="4" ry="4"
                                          fill="url(#progressGradient)"/>

                                    <!-- Progress text -->
                                    <text x="290" y="230" text-anchor="end" font-family="Segoe UI, sans-serif"
                                          font-size="10" fill="#6c757d">65% Complete
                                    </text>
                                </svg>
                            </div>
                            <t t-foreach="properties.colors" t-as="data" t-key="data_index">
                                <div class="cy-drag-input_container mb-2 color_dropdown">
                                    <div class="w-100 cy-studio-progress cy-draginput--box ms-0 py-1">
                                        <CylloStudioDropdown
                                                options="getSelectionValues(data[0])"
                                                onChange="(value) => this.handleSelectionValue(value, data_index)"
                                                defaultValue="data[0]"
                                        />
                                    </div>
                                    <div class="w-100 cy-draginput--box">
                                        <div class="d-flex justify-content-between gap-2 px-2 py-1 cursor-pointer cy-studio-click"
                                             t-on-click="()=> state.dropdown = data_index ">
                                            <span class="cy-content-text text-capitalize cy-studio-click"
                                                  t-esc="data[1]"/>
                                            <div style="width:20px; height:20px;" class="cy-studio-click"
                                                 t-att-class="state.colors[data[1]]"/>
                                        </div>
                                        <div t-if="state.dropdown === data_index"
                                             class="position-absolute bg-white z-index-1 border" style="width:16.5%;">
                                            <div t-foreach="getColors(data[1])" t-as="color" t-key="color"
                                                 class="d-flex justify-content-between gap-2 px-2 py-2 cursor-pointer opacity-50-hover"
                                                 t-att-class="data[1] === color ? 'bg-secondary' : ''"
                                                 t-on-click="()=> properties.colors[data_index][1] = color">
                                                <span class="cy-content-text text-capitalize"
                                                      t-att-class="data[1] === color ? 'text-primary' : ''"
                                                      t-esc="color"/>
                                                <div style="width:20px; height:20px;"
                                                     t-attf-class="{{state.colors[color]}}"/>
                                            </div>
                                        </div>
                                    </div>
                                    <button class="cy-drag_edit-btn cy-drag_delete"
                                            t-on-click="()=> this.handleDeleteValue(data_index)">
                                        <i class="ri-delete-bin-6-fill"/>
                                    </button>
                                </div>
                            </t>
                            <button t-if="hasValue =='show'" class="btn btn-primary" t-on-click="handleAddValue">Add
                                Value
                            </button>
                        </div>
                    </div>
                </div>
                <t t-set-slot="footer">
                    <button class="btn btn-primary" t-on-click="handelSave">Save</button>
                    <button class="btn btn-secondary" t-on-click="handelDiscard">Discard</button>
                </t>
            </div>
        </Dialog>
    </t>

    <t t-name="cy_studio.progressbar_sample_colors">
        <div class="opacity-50">
            <div class="cy-drag-input_container mb-2">
                <div class="w-100 cy-studio-progress cy-draginput--box ms-0 py-1">
                    <div class="custom-dropdown o-autocomplete" style="width: undefined">
                        <div class="d-flex">
                            <span class="selected-text">Overdue</span>
                            <i class="fa fa-chevron-down"/>
                        </div>
                    </div>
                </div>
                <div class="w-100 cy-draginput--box">
                    <div class="d-flex justify-content-between gap-2 px-2 py-1 cursor-pointer cy-studio-click">
                        <span class="cy-content-text text-capitalize cy-studio-click">warning</span>
                        <div style="width:20px; height:20px;" class="cy-studio-click bg-warning"/>
                    </div>
                </div>
                <button class="cy-drag_edit-btn cy-drag_delete">
                    <i class="ri-delete-bin-6-fill"/>
                </button>
            </div>
        </div>
    </t>
</templates>