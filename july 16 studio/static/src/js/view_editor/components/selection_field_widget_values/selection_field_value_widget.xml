<?xml version="1.0" encoding="UTF-8" ?>
<templates>
    <t t-name="cyllo_studio.SelectionFieldValue" owl="1">
         <div class="cy-drag-input_container mb-2" t-att-data-index="props.index">
            <button class="btn btn-secondary handle-drag cy-drag_edit-btn" type="button"><i class="ri-drag-move-line handle-drag"/></button>
            <input type="text" t-model="state.value" class="w-100 cy-draginput--box p-1" style="background-color: white !important"/>
            <button class="cy-drag_edit-btn cy-drag_delete" type="button" t-on-click="()=> props.deleteValue(props.index)"><i class="ri-delete-bin-6-fill"/></button>
         </div>
    </t>
</templates>