<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ir_model_access_tree" model="ir.ui.view">
        <field name="name">view.ir.model.access.tree</field>
        <field name="model">ir.model.access</field>
        <field name="arch"  type="xml">
            <tree string="Access Rights" editable="top" js_class="n_list"
                  decoration-warning="not group_id and
                                         (perm_read or perm_write or
                                          perm_create or perm_unlink)">
                <field name="name"/>
                <field name="model_id"/>
                <field name="group_id"/>
                <field name="perm_read"/>
                <field name="perm_write"/>
                <field name="perm_create"/>
                <field name="perm_unlink"/>
            </tree>
        </field>
    </record>
</odoo>
