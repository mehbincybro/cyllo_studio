<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_cyllo_report_template_tree" model="ir.ui.view">
        <field name="name">cyllo.report.template.tree</field>
        <field name="model">cyllo.report.template</field>
        <field name="arch" type="xml">
            <tree string="Report Templates">
                <field name="name"/>
                <field name="category"/>
                <field name="source_model"/>
                <field name="source_template"/>
                <field name="write_date"/>
            </tree>
        </field>
    </record>

    <record id="view_cyllo_report_template_form" model="ir.ui.view">
        <field name="name">cyllo.report.template.form</field>
        <field name="model">cyllo.report.template</field>
        <field name="arch" type="xml">
            <form string="Report Template">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="category"/>
                        <field name="description"/>
                    </group>
                    <group>
                        <field name="source_report_id" readonly="1"/>
                        <field name="source_model" readonly="1"/>
                        <field name="source_template" readonly="1"/>
                        <field name="doc_template" readonly="1"/>
                    </group>
                    <notebook>
                        <page string="Template Payload">
                            <field name="payload_json" readonly="1" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_cyllo_report_template_library" model="ir.actions.act_window">
        <field name="name">Report Template Library</field>
        <field name="res_model">cyllo.report.template</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
