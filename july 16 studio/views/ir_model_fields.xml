<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="ir_model_fields_form_view_inherit" model="ir.ui.view">
        <field name="name">ir.model.fields.form.view.inherit</field>
        <field name="model">ir.model.fields</field>
        <field name="inherit_id" ref="base.view_model_fields_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='compute']" position="after">
                 <field name="constraint_fields"/>
                <field name="constraint_code" widget="code"/>
            </xpath>
        </field>
    </record>

</odoo>
