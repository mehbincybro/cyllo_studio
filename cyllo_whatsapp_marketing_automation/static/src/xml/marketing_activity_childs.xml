<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <!-- Template to extend MarketingChild view -->
    <t t-inherit="cyllo_marketing_automation.MarketingChild"
       t-inherit-mode="extension">
        <xpath expr="//div[hasclass('child-activities-head-main')]"
               position="after">
            <div class="child-activities-content align-items-center justify-content-between p-2"
                 t-if="props.activity.type == 'whatsapp'">
                <center>
                    <button class="child-branch-add-child active-div cy-marketing-auto_icon-btn cy-marketing-auto_icon-active"
                            t-attf-data-trigger="activity_another"
                            t-on-click="onClickAddActivityDiv"
                            title="Another Activity">
                        <i class="ri-git-merge-line"/>
                    </button>
                </center>
            </div>
        </xpath>
        <xpath expr="//button[hasclass('cy-marketing-auto_icon-btn')]"
               position="inside">
            <i t-if="props.activity.type == 'whatsapp'"
               class="ri-whatsapp-line"/>
        </xpath>
    </t>
</templates>