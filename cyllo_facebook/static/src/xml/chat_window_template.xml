<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
   <t t-name="cyllo_facebook.ChatWindow.headerContent"
      t-inherit="mail.ChatWindow.headerContent" t-inherit-mode="extension">
       <xpath expr="//div[@t-if='!state.editingName']"
              position="before">
           <img t-if="this.store.facebook"
                src="cyllo_facebook/static/src/img/fb.png"
                alt="" style="width: 25px;margin-left: 3%;"/>
       </xpath>
   </t>
</templates>