<?xml version="1.0" encoding="UTF-8"?>
<!--Overwrite the templates "mail.Chatter" to rearrange the view and added features-->
<templates id="template" xml:space="preserve">
    <t name="mail.ChatterAdvanced" t-inherit="mail.Message" t-inherit-mode="extension" owl="1">
        <xpath expr="//t[@t-if='showSubtypeDescription']" position="after">
            <t t-if="message.subtype_id">
                <div t-if="message.subtype_id[1] =='Facebook Message'">
                    <a class="o_fb_comment_reply btn btn-sm btn-link px-0" href="#" t-on-click="onClickReply">
                        Reply</a>
                    <div id="reply_to_comments" style="display:none;" t-ref="reply_section">
                        <textarea rows="4" name="comment_reply" class="form-control" id="fb_comment_reply_area"
                                t-ref="message_reply" placeholder="Write a reply..." width="30px"/>
                        <button class="btn btn-primary" t-on-click="postReply" t-att-value="message.email_from"
                                title="Click to Reply" width="3px">Reply</button>
                    </div>
                </div>
            </t>
        </xpath>
    </t>
</templates>