<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <t t-inherit="mail.Composer" t-inherit-mode="extension" owl="1">
        <xpath expr="//t[@t-set='compact']" position="before">
            <t t-if="state.model=='res.partner'">
                <div class="flex-shrink-0 px-3 pt-3 text-truncate small mb-2" style="margin-left:48px">
                    <div class="form-check">
                        <input id="facebook_checkbox" class="form-check-input" type="checkbox" t-on-change="onChangeFbCheckbox"/>
                        <label class="form-check-label" t-attf-for="facebook_checkbox">
                            <span>Facebook</span>
                        </label>
                    </div>
                </div>
            </t>
        </xpath>
    </t>
</templates>