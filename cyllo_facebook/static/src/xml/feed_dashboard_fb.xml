                        <div class="py-2  cy-social-market_box cy-border-btm">
                            <div class="d-flex gap-2 pt-3">
                                <div class="cy-social-market_profile">
                                    <img src="cyllo_facebook/static/src/img/fb.png"/>
                                </div>
                                <div>
                                    <p class="cy-social-market_subhead">Facebook</p>
                                    <span class="cy-social-market_sm-head">
                                        08-03-2024
                                    </span>
                                </div>
                                <div>
                                    <span class="badge rounded-pill">Demo</span>
                                </div>
                            </div>
                            <p class="cy-soical-market_content">
                                    Diwali Sale !...
                                </p>
                            <a href="#" class="cy-soical_marketing-link">https://www.facebook.com/post?v=FiutlsFrStcA</a>
                            <div class="row cy-soical-marketing_post m-0 py-2">
                                    <div class="col-12 p-0">
                                        <img src="/cyllo_social_media_marketing/static/src/img/demo4.jpg"
                                             alt="" class="img-fluid"/>
                                    </div>
                                </div>
                            <div class="d-flex justify-content-between align-items-center cy-soical-market_glancecontainer py-2">
                                    <div t-on-click="() => this.ComputeDemoData('fb_demo_5')">
                                        <span style="cursor: pointer;">View Insights</span>
                                    </div>
                                <div id="Details_fb_demo_5"
                                     class="d-flex align-items-center gap-2 d-none">
                                    <a class="d-flex align-items-center gap-1">
                                        <i class="ri-heart-line cy-icons cy-media_icon"/>
                                        <p class="cy-soical-market_txt">10</p>
                                    </a>
                                    <a class="d-flex align-items-center gap-1  cy-soical-market_comment">
                                        <i class="ri-chat-3-line  cy-icons cy-media_icon"/>
                                        <p class="cy-soical-market_txt">3</p>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </t>
                    <t t-foreach="state.Feeds" t-as="feed" t-key="feed.id"
                       t-if="feed.fb_media_number!=false">
                        <t t-set="flag_fb" t-value="true"/>
                        <div class="py-2  cy-social-market_box cy-border-btm ">
                            <div class="d-flex gap-2 pt-3">
                                <div class="cy-social-market_profile ">
                                    <img t-attf-src="{{feed.profile_image_url}}"
                                         onerror="this.src='/cyllo_facebook/static/src/img/facebook-profile.jpg'"/>
                                </div>
                                <div>
                                    <p class="cy-social-market_subhead">Facebook</p>
                                    <span class="cy-social-market_sm-head">
                                        <t t-esc="feed.posted_date"/>
                                    </span>
                                </div>
                            </div>
                            <p class="cy-soical-market_content">
                                <t t-esc="feed.description"/>
                            </p>
                            <a t-attf-href="{{feed.author_link_url}}"
                               class="cy-soical_marketing-link"><t t-esc="feed.author_link_url"/></a>
                            <div class="row cy-soical-marketing_post m-0 py-2">
                                <div class="col-12 p-0">
                                    <img t-attf-src="{{feed.posted_image_url}}"
                                         alt="" class="img-fluid"/>
                                </div>
                            </div>
                            <div class="d-flex justify-content-between align-items-center cy-soical-market_glancecontainer py-2">
                                <div t-on-click="() => this.ComputeDataFb(feed)">
                                    <span style="cursor: pointer;">View Insights</span>
                                </div>
                            </div>
                        </div>
                    </t>
                    <div class="cy-social-marketing-nostream"
                         t-if="flag_fb == false and !state.demo">
                        <img src="images/undraw_no_data_re_kwbl 1 (1).svg"
                             alt=""/>
                        <p class="cy-nostream_add-msg">No Post added yet!</p>
                        <span class="cy-nostream_add-subtext">
                            <a t-on-click="() => this.CreatePost()"
                               class="cy-social-marketing__link">
                                Add a post
                            </a>
                            to keep an eye on your own posts and
                            monitor all social activities
                        </span>
                    </div>
                </div>
            </div>
        </xpath>
        <xpath expr="//div[hasclass('cy-dashboard-container')]"
               position="inside">
            <div class="cy-onboard_modal-container cy-social_comment_modal"
                 t-ref="social_comment_modal_fb">
                <div class="modal-dialog cy-onboarding_modalbox">
                    <div class="modal-content cy-modal_content">
                        <div class="modal-header  cy-social_commentHead d-flex  pt-4">
                            <div t-if="feed"
                                 class="d-flex align-items-center gap-2 cy-soical-marketing_insights">
                            <span style="font-weight: bold;font-size: 20px;">Insights : </span>
                                <a class="d-flex align-items-center gap-1">
                                <i class="ri-heart-line cy-icons cy-media_icon"/>
                                    Like
                                    <p class="cy-soical-market_txt"><t t-esc="feed.likes_count"/></p>
                            </a>
                                <a class="d-flex align-items-center gap-1  cy-soical-market_comment">
                                <i class="ri-chat-3-line  cy-icons cy-media_icon"/>
                                    comment
                                    <p class="cy-soical-market_txt"><t t-esc="feed.comments_count"/></p>
                                </a>
                        </div>
                            <span class="cy-icons cy-social_cmnt-closebtn"
                                  t-on-click="() => this.CloseCommentFb()"><i class="ri-close-line"/></span>
                        </div>
                        <div class="modal-body pt-0 cy-modal_main-body">
                            <form>
                                <div class="form-group py-3 ">
                                    <textarea
                                            class="form-control cy-button-stroke"
                                            id="exampleFormControlTextarea1"
                                            rows="5"
                                            placeholder="Write a comment...."
                                            t-ref="new_message_fb"/>
                                </div>
                            </form>
                            <div class="d-flex justify-content-end">
                                <button class="btn cy-button-primary-stroke text-end"
                                        t-on-click="() => this.PostCommentFb(feed)">POST</button>
                            </div>
                            <h5 class="cy-social_maketing-title">Comments</h5>
                            <t t-foreach="state.comments" t-as="comment"
                               t-key="comment.id" t-if="state.comments">
                                <div class="cy-social_market-commentReply">
                                    <div class="cy-social_marketComment-box">
                                        <div class="d-flex justify-content-between">
                                            <div class="d-flex align-items-center gap-2">
                                                <span>
                                                    <a t-on-click="() => this.DirectPartner(comment.partner_id)"
                                                       class="cy-main-sectionhead"><t t-esc="comment.username"/></a>
                                                </span>
                                                <span class="cy-soical-comment_txt"><t t-esc="comment.timestamp"/></span>
                                            </div>
                                            <div class="d-flex align-items-center gap-2 ">
                                                <div class="badge rounded-pill"
                                                     t-on-click="convertToLeadFb"
                                                     t-att-id="comment.id">
                                                    <i class="fa fa-user"
                                                       style="color:blue;"/>
                                                                </div>
                                                <span class="cy-soical-market-count_txt"><t t-esc="comment.like_count"/></span>
                                                <span class="cy-soical-market-count_txt"><i class="ri-heart-line"/></span>
                                            </div>
                                        </div>
                                        <p class="cy-soical-market-cmnttile"><t t-esc="comment.text"/></p>
                                        <div>
                                            <span>
                                                <i class="ri-chat-3-line cy-cmt_rply-icon"/>
                                            </span>
                                            <span class="cy-cmt_rply"
                                                  t-on-click="() => this.ReplyCommentFb(comment)">
                                                Reply
                                            </span>
                                            <div class="reply_div d-none">
                                                <input class="form-control cy-button-stroke mt-2"
                                                       type="text"
                                                       placeholder="Write a reply..."
                                                       name=""
                                                       t-attf-id="reply_{{comment.id}}"/>
                                                <span class="send_button cy-soical-market-count_txt">
                                                    <i class="ri-send-plane-fill"
                                                       t-on-click="() => this.ReplyToCommentFb(comment,feed)"/>
                                                </span>
                                            </div>
                                            <t t-if="state.type=='facebook' and comment.replies">
                                                    <a class="o_fb_comment_replies btn btn-sm btn-link"
                                                       href="#"
                                                       t-att-id="comment.id"
                                                       style="margin-left:10px;"
                                                       t-on-click="onClickViewReplies">
                                                        View Replies (<t
                                                            t-esc="comment.replies.length"/>)
                                                    </a>
                                                <div id="view_replies"
                                                     t-att-id="comment.id"
                                                     class="d-none">
                                                    <t t-if="comment.replies">
                                                        <t t-foreach="comment.replies"
                                                           t-as="replies"
                                                           t-key="replies.id">
                                                            <a t-on-click="() => this.DirectPartner(replies.partner_id)"
                                                               class="cy-main-sectionhead"><span t-esc="replies.from.name"
                                                                  style="margin-left: 20%;"/>
                                                            </a>
                                                            :
                                                            <span t-esc="replies.message"/>
                                                            <br/>
                                                        </t>
                                                    </t>
                                                </div>
                                                </t>
                                        </div>
                                    </div>
                                </div>
                            </t>
                        </div>
                        <div class="cy-modal_footer cy-social_cmnt-footer">
                            <div class="d-flex justify-content-end">
                                <button class="btn cy-button-primary-stroke"
                                        t-on-click="() => this.CloseCommentFb()">OK</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </xpath>
    </t>
</templates>