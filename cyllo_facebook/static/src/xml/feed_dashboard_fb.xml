        <xpath expr="//div[hasclass('cy-dashboard-container')]"
               position="inside">
            <div class="cy-onboard_modal-container cy-social_comment_modal"
                 t-ref="social_comment_modal_fb">
                <div class="modal-dialog cy-onboarding_modalbox">
                    <div class="modal-content cy-modal_content">
                        <div class="modal-header cy-social_commentHead d-flex">
                            <div t-if="feed"
                                 class="d-flex align-items-center gap-2 cy-soical-marketing_insights">
                                <span>Comments</span>
                            </div>
                            <button type="button" class="btn-close" aria-label="Close"
                                    t-on-click="() => this.CloseCommentFb()" tabindex="-1"/>
                        </div>
                        <div class="modal-body pt-0 cy-modal_main-body">
                            <t t-foreach="state.comments" t-as="comment"
                               t-key="comment.id" t-if="state.comments">
                                <div class="cy-social_market-commentReply">
                                    <div class="cy-social_marketComment-box">
                                        <div class="cy-comment-bubble">
                                            <div class="d-flex justify-content-between">
                                                <div class="d-flex align-items-center gap-2">
                                                    <span>
                                                        <a t-on-click="() => this.DirectPartner(comment.partner_id)"
                                                           class="cy-main-sectionhead">
                                                            <t t-esc="comment.username"/>
                                                        </a>
                                                    </span>
                                                    <div class="badge rounded-pill cursor-pointer"
                                                         t-on-click="() => this.convertToLeadFb(feed.description)"
                                                         t-att-id="comment.id" data-tooltip="Create Lead" aria-label="Create Lead">
                                                        <i class="fa fa-user cy-cmt_rply"/>
                                                    </div>
                                                    <div class="d-flex align-items-center gap-1">
                                                        <span class="cy-soical-market-count_txt cy-cmt_rply"><i class="ri-heart-line"/></span>
                                                        <span class="cy-soical-market-count_txt cy-cmt_rply"><t t-esc="comment.like_count"/></span>
                                                    </div>
                                                    <span class="cy-soical-comment_txt"><t t-esc="comment.created_time"/></span>
                                                </div>
                                            </div>
                                            <p class="cy-soical-market-cmnttile"><t t-esc="comment.text"/></p>
                                        </div>
                                        <div class="d-flex justify-content-start align-items-center mt-1">
                                            <a t-on-click="(ev) => this.ReplyCommentFb(ev)"
                                               class="cursor-pointer d-flex align-items-center gap-1">
                                                <span>
                                                    <i class="ri-chat-3-line cy-cmt_rply-icon"/>
                                                </span>
                                                <span class="cy-cmt_rply">
                                                    Reply
                                                </span>
                                            </a>
                                            <t t-if="state.type=='facebook' and comment.replies?.length != 0">
                                                <a class="o_fb_comment_replies btn btn-sm btn-link"
                                                   href="#"
                                                   t-att-id="comment.id"
                                                   style="margin-left:10px;"
                                                   t-on-click="onClickViewRepliesFb">
                                                    View Replies (<t
                                                        t-esc="comment.replies?.length"/>)
                                                </a>
                                            </t>
                                        </div>
                                        <div class="reply_div d-none">
                                            <input class="form-control cy-button-stroke mt-1"
                                                   type="text"
                                                   placeholder="Write a reply..."
                                                   name="" autocomplete="off"
                                                   t-attf-id="reply_{{comment.id}}"/>
                                            <span class="send_button" t-on-click="() => this.ReplyToCommentFb(comment,feed)">
                                                <i class="ri-send-plane-2-line"/>
                                            </span>
                                        </div>
                                        <div id="view_replies"
                                             t-att-id="comment.id"
                                             class="view_replies d-none">
                                            <t t-if="comment.replies">
                                                <t t-foreach="comment.replies"
                                                   t-as="replies"
                                                   t-key="replies.id">
                                                    <div class="d-flex align-items-center">
                                                        <div class="cy-reply-line"/>
                                                        <div class="cy-comment-bubble mb-2">
                                                            <a t-on-click="() => this.DirectPartner(replies.partner_id)"
                                                               class="cy-main-sectionhead">
                                                                <span t-esc="replies.from?.name"/>
                                                            </a>
                                                            <p t-esc="replies.message"/>
                                                        </div>
                                                    </div>
                                                </t>
                                                <t t-if="comment.replies_paging?.next">
                                                    <a style="padding: 0 6rem;"
                                                       class="text-muted"
                                                       t-if="!state.loadingFbComments"
                                                       t-on-click="() => this.loadMoreFbReplies(comment)">
                                                        Load more replies <i class="ri-arrow-down-line"/>
                                                    </a>
                                                    <a style="padding: 0 6rem;"
                                                       class="text-muted"
                                                       t-if="state.loadingFbComments">
                                                        Loading...
                                                    </a>
                                                </t>
                                            </t>
                                        </div>
                                    </div>
                                </div>
                            </t>
                            <div class="text-center mt-2" t-if="state.nextFbCommentsPage">
                                <a t-if="!state.loadingFbComments"
                                   class="text-muted"
                                   t-on-click="() => this.loadMoreFbComments(feed)">
                                    Load more comments <i class="ri-arrow-down-line"/>
                                </a>
                                <a class="text-muted" t-if="state.loadingFbComments">Loading...</a>
                            </div>

                        </div>
                        <div class="cy-modal_footer cy-social_cmnt-footer">
                            <form>
                                <div class="form-group d-flex overflow-hidden">
                                    <textarea
                                        class="form-control"
                                        id="exampleFormControlTextarea1"
                                        rows="1" role="textbox"
                                        placeholder="Write a comment...."
                                        t-ref="new_message_fb"/>
                                    <div class="d-flex justify-content-end align-items-end">
                                        <button class="btn text-end" style="font-size: 20px"
                                                t-on-click="() => this.PostCommentFb(feed)"><i class="ri-send-plane-2-line"/></button>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </xpath>
    </t>
</templates>