                    </t>
                    <t t-if="state.FbFeeds" t-foreach="state.FbFeeds" t-as="feed" t-key="feed.id">
                        <t t-set="flag_fb" t-value="true"/>
                        <div class="py-2  cy-social-market_box cy-border-btm ">
                            <div class="d-flex justify-content-between gap-2 pt-3">
                                <div class="d-flex gap-2">
                                    <div class="cy-social-market_profile ">
                                        <img t-att-src="feed.profile_image_url"
                                             onerror="this.src='/cyllo_facebook/static/src/img/facebook-profile.jpg'"/>
                                    </div>
                                        <div>
                                        <p class="cy-social-market_subhead"><t t-esc="feed.author_name"/></p>
                                            <span class="cy-social-market_sm-head">
                                            <t t-esc="feed.posted_date"/>
                                        </span>
                                    </div>
                                </div>
                                <div>
                                   <a t-attf-href="{{feed.author_link_url}}" data-tooltip="External Link"
                                      aria-label="External Link" class="ri-external-link-line" style="font-size: 18px"/>
                                </div>
                            </div>
                            <p class="cy-soical-market_content">
                                <t t-esc="feed.description"/>
                            </p>
                            <div t-if="feed.posted_image_url" class="row cy-soical-marketing_post m-0 py-2">
                                <div class="col-12 p-0">
                                    <img t-attf-src="{{feed.posted_image_url}}"
                                         alt="" class="img-fluid"/>
                                </div>
                            </div>
                            <div class="d-flex justify-content-between align-items-center cy-soical-market_glancecontainer py-2">
                                <div class="d-flex align-items-center" style="font-size: 20px; gap: 16px;">
                                    <span data-tooltip="Likes" aria-label="Likes">
                                        <i class="ri-heart-line cy-icons cy-media_icon me-1"/>
                                        <t t-esc="feed.likes_count"/>
                                    </span>
                                    <span t-on-click="() => this.ComputeDataFb(feed)"
                                          role="button" tabindex="0" data-tooltip="Comments" aria-label="Comments">
                                        <i class="ri-chat-3-line  cy-icons cy-media_icon me-1"/>
                                        <t t-esc="feed.comments_count"/>
                                    </span>
                                </div>
                            </div>
                        </div>
                    </t>
                    <button t-if="state.nextFbPage and !state.loadingFb" t-on-click="loadMore" class="btn btn-primary"
                            style="margin: 16px 40%; width: 20%;">
                        Load More <i class="ri-arrow-down-line ms-2"/>
                    </button>
                    <button t-if="state.loadingFb" t-on-click="loadMore" class="btn btn-primary"
                            style="margin: 16px 40%; width: 20%;">
                        Loading...
                    </button>
                    <div class="cy-social-marketing-nostream"
                         t-if="flag_fb == false and !state.demo">
                        <img src="images/undraw_no_data_re_kwbl 1 (1).svg"
                             alt=""/>
                        <p class="cy-nostream_add-msg">No Post added yet!</p>
                        <span class="cy-nostream_add-subtext">
                            <a t-on-click="() => this.CreatePost()"
                               class="cy-social-marketing__link">
                                Add a post
                            </a>
                            to keep an eye on your own posts and
                            monitor all social activities
                        </span>
                    </div>
