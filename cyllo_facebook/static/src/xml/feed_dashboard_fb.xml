                                </div>
                            </div>
                            <div class="d-flex justify-content-between align-items-center cy-soical-market_glancecontainer py-2">
                                <div t-on-click="() => this.ComputeDemoData('fb_demo_4')">
                                    <span style="cursor: pointer;">View Insights</span>
                                </div>
                                <div id="Details_fb_demo_4"
