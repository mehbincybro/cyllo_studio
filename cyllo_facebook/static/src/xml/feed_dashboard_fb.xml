<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <t t-inherit="cyllo_social_media_marketing.SocialMediaFeed"
       t-inherit-mode="extension" owl="1">
        <xpath expr="//div[hasclass('cy-social_glance-container')]"
               position="inside">
            <div class="col py-3 cy-social-market_box cy-social_market-glancebox cy-social-market_glance_box">
                <div class="w-100 d-flex justify-content-between align-items-center flex-wrap">
                    <div class="d-flex align-items-center gap-2 cy-social-market_tophead">
                        <img src="cyllo_facebook/static/src/img/fb.png" alt=""
                             style="width: 20px;"/>
                        Facebook
                    </div>
                    <div class="d-flex align-items-center gap-2 cy-soical-market_glancecontainer">
                        <div class="d-flex align-items-center gap-1 pt-2 ">
                            <i class="ri-focus-2-line cy-icons "/>
                            <p class="cy-soical-market_txt ">
                                <t t-esc="state.FbFeeds.length"/>
                            </p>
                        </div>
                        <div class="d-flex align-items-center gap-1 pt-2">
                            <i class="ri-heart-line cy-icons"/>
                            <p class="cy-soical-market_txt">
                                <t t-esc="state.FbTotalLikes"/>
                            </p>
                        </div>
                        <div class="d-flex align-items-center gap-1 pt-2">
                            <i class="ri-chat-3-line cy-icons"/>
                            <p class="cy-soical-market_txt">
                                <t t-esc="state.FbTotalComments"/>
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </xpath>
