<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_social_media_post_form" model="ir.ui.view">
        <field name="name">view.social.media.post.form</field>
        <field name="model">social.media.post</field>
        <field name="priority" eval="10"/>
        <field name="inherit_id" ref="cyllo_social_media_marketing.view_social_media_post_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='posted_date']" position="after">
                <field name="post_on_facebook" widget="boolean_toggle" invisible="mode not in ('url', 'attachment', 'content_only')"/>
                <field name="fb_account_ids" widget="many2many_tags" domain="[('state', '=', 'connected')]" invisible="not post_on_facebook" required="post_on_facebook"/>
            </xpath>
            <xpath expr="//field[@name='ir_attachment_ids']" position="after">
                <field name="facebook_attachment_id" invisible="1"/>
            </xpath>
        </field>
    </record>
</odoo>