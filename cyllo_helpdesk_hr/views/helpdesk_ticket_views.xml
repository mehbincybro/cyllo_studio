<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="helpdesk_ticket_view_form_inherit_hr" model="ir.ui.view">
        <field name="name">helpdesk.ticket.view.form.inherit.hr</field>
        <field name="model">helpdesk.ticket</field>
        <field name="inherit_id" ref="cyllo_help_desk.helpdesk_ticket_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='canned_response_ids']" position="after">
                <field name="skill_ids" widget="many2many_tags"/>
            </xpath>
        </field>
    </record>
</odoo>
