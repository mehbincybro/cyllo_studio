<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!-- Adding the Budget Management block in settings-->
    <record id="view_res_config_settings_form" model="ir.ui.view">
        <field name="name">view.res.config.settings.form</field>
        <field name="model">res.config.settings</field>
        <field name="priority" eval="91"/>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@id= 'print_vendor_checks_setting_container']" position="after">
                <block title="Budget Management" id="budget_management">
                    <setting id="budget_management" help="A budget system is like a roadmap for your money. You track income and expenses to see where it flows, then plan how to spend it wisely and reach your financial goals.">
                        <field name="module_cyllo_budget_management"/>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>
</odoo>