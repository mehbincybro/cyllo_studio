<?xml version="1.0" encoding='utf-8'?>
<odoo>
    <!-- Report action of pdf print form view-->
    <record id="report_field_service_request_pdf" model="ir.actions.report">
        <field name="name">Field Service Request Report</field>
        <field name="model">field.service.report</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">cyllo_field_service.report_field_service_request</field>
        <field name="print_report_name">'Service_Request_%s' % (object.name or
            'Request')
        </field>
        <field name="report_file">report_field_service_request</field>
        <field name="binding_type" ref="model_field_service_report"/>
        <field name="binding_type">report</field>
    </record>
    <record id="report_field_service_form_print_pdf" model="ir.actions.report">
        <field name="name">Field Service Form Print</field>
        <field name="model">field.service.request</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">cyllo_field_service.report_field_service_request_form</field>
        <field name="print_report_name">'Service_Request_%s' % (object.name or
            'Request')
        </field>
        <field name="report_file">
            report.cyllo_field_service.report_field_service_request_form
        </field>
        <field name="binding_model_id" ref="model_field_service_request"/>
        <field name="binding_type">report</field>
    </record>
</odoo>
