<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- security group-->
    <record id="ir_module_category_field_service" model="ir.module.category">
        <field name="name">Field Service</field>
        <field name="sequence">0</field>
        <field name="visible" eval="0"/>
    </record>
    <record id="group_cyllo_field_service_user" model="res.groups">
        <field name="name">User</field>
        <field name="category_id" ref="ir_module_category_field_service"/>
    </record>
    <record id="group_cyllo_field_service_manager" model="res.groups">
        <field name="name">Administrator</field>
        <field name="category_id" ref="ir_module_category_field_service"/>
        <field name="users" eval="[Command.link(ref('base.user_admin'))]"/>
        <field name="implied_ids"
               eval="[Command.link(ref('group_cyllo_field_service_user'))]"/>
    </record>
    <!-- Multi-company record filtration and security group-->
    <record id="rule_field_service_request_company" model="ir.rule">
        <field name="name">Field Service Multi-Company</field>
        <field name="model_id" ref="model_field_service_request"/>
        <field name="domain_force">
            ['|',('company_id','=',False),('company_id', 'in', company_ids)]
        </field>
    </record>
    <record id="rule_field_service_template_company" model="ir.rule">
        <field name="name">Field Service Multi-Company</field>
        <field name="model_id" ref="model_field_service_template"/>
        <field name="domain_force">
            ['|',('company_id','=',False),('company_id', 'in', company_ids)]
        </field>
    </record>
    <record id="rule_field_service_skill_category_company" model="ir.rule">
        <field name="name">Field Service Multi-Company</field>
        <field name="model_id" ref="model_field_service_skill_category"/>
        <field name="domain_force">
            ['|',('company_id','=',False),('company_id', 'in', company_ids)]
        </field>
    </record>
</odoo>
