<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!-- Template for portal document -->
    <template id="portal_my_home_field_service" name="Show Field Service"
              customize_show="True" inherit_id="portal.portal_my_home"
              priority="32">
        <xpath expr="//div[hasclass('o_portal_docs')]" position="before">
            <t t-set="portal_client_category_enable" t-value="True"/>
        </xpath>
        <div id="portal_client_category" position="inside">
            <t t-call="portal.portal_docs_entry"
               groups="cyllo_field_service.group_cyllo_field_service_user, base.group_portal">
                <t t-set="icon" t-value="'/sale/static/src/img/bag.svg'"/>
                <t t-set="title">Field Service Request</t>
                <t t-set="url" t-value="'/my/field_service_request'"/>
                <t t-set="text">Follow or view your field service requests</t>
                <t t-set="placeholder_count" t-value="'fs_req_count'"/>
            </t>
        </div>
    </template>
</odoo>
