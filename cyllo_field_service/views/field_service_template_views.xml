<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Action, views and menu items for the fs service template model -->
    <record id="view_field_service_template_form" model="ir.ui.view">
        <field name="name">view.field.service.template.form</field>
        <field name="model">field.service.template</field>
        <field name="arch" type="xml">
            <form string="Service Template">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="company_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page name="checklist" string="Service Checklist">
                            <field name="service_checklist_ids" nolabel="1">
                                <tree editable="bottom">
                                    <field name="product_id"/>
                                    <field name="required"/>
                                    <field name="currency_id"
                                           column_invisible="1"/>
                                    <field name="service_cost"/>
                                    <field name="time_required"
                                           widget="float_time"/>
                                </tree>
                            </field>
                            <group name="note_group" col="6"
                                   class="mt-2 mt-md-0">
                                <group colspan="4">
                                    <field colspan="2" name="description"
                                           placeholder="Description..."/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="message_ids" widget="mail_thread"/>
                    <field name="activity_ids" widget="mail_activity"/>
                </div>
            </form>
        </field>
    </record>
    <record id="view_field_service_template_tree" model="ir.ui.view">
        <field name="name">view.field.service.template.tree</field>
        <field name="model">field.service.template</field>
        <field name="arch" type="xml">
            <tree string="Service Template">
                <field name="name"/>
                <field name="description"/>
                <field name="company_id"/>
            </tree>
        </field>
    </record>
    <record id="view_field_service_template_search" model="ir.ui.view">
        <field name="name">view.field.service.template.search</field>
        <field name="model">field.service.template</field>
        <field name="arch" type="xml">
            <search string="Service Template">
                <field name="name"/>
                <field name="description"/>
            </search>
        </field>
    </record>
    <record id="view_field_service_template_kanban" model="ir.ui.view">
        <field name="name">view.field.service.template.kanban</field>
        <field name="model">field.service.template</field>
        <field name="arch" type="xml">
            <kanban>
                <field name="name"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_card oe_kanban_global_click">
                            <div class="oe_kanban_content">
                                <div class="o_kanban_record_top">
                                    <div class="o_kanban_record_headings">
                                        <strong class="o_kanban_record_title">
                                            <field name="name"/>
                                        </strong>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>
    <record id="action_view_service_template" model="ir.actions.act_window">
        <field name="name">Service Template</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">field.service.template</field>
        <field name="view_mode">tree,kanban,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create New Field Service Template
            </p>
            <p>
                You can create/view Service Template from here.
            </p>
        </field>
    </record>
</odoo>
