<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Field Service Menu-->
    <menuitem id="menu_cyllo_field_service_root" name="Field Service"
              web_icon="cyllo_field_service,static/description/cyllo_field-services.svg"
              groups="cyllo_field_service.group_cyllo_field_service_user"/>

    <!-- Master Data Menu -->
    <menuitem id="menu_master_data_categ" name="Master Data"
              parent="cyllo_field_service.menu_cyllo_field_service_root"
              sequence="2"/>
    <!-- Menu to display partners-->
    <menuitem id="menu_customers" name="Customers"
              action="action_view_customers"
              parent="cyllo_field_service.menu_master_data_categ" sequence="1"/>
    <!-- Menu to display Employees-->
    <menuitem id="menu_employees" name="Employees"
              action="hr.open_view_employee_list_my"
              parent="cyllo_field_service.menu_master_data_categ" sequence="2"/>

    <!-- Operations Menu -->
    <menuitem id="menu_operations_categ" name="Operations"
              parent="cyllo_field_service.menu_cyllo_field_service_root"
              sequence="1"/>
    <!-- Menu to display My Requests-->
    <menuitem id="menu_my_requests" name="My Requests"
              parent="cyllo_field_service.menu_operations_categ"
              action="action_view_my_requests"/>
    <!-- Menu to display All Requests-->
    <menuitem id="menu_all_requests" name="All Requests"
              parent="cyllo_field_service.menu_operations_categ"
              action="action_view_all_requests"
              groups="group_cyllo_field_service_manager"/>

    <!-- Configuration Menu-->
    <menuitem id="menu_configuration_categ" name="Configuration"
              parent="cyllo_field_service.menu_cyllo_field_service_root"
              sequence="4"/>
    <!-- Menu to display Settings-->
    <menuitem id="menu_settings" name="Settings"
              parent="cyllo_field_service.menu_configuration_categ"
              sequence="0" action="action_view_settings"
              groups="cyllo_field_service.group_cyllo_field_service_manager"/>
    <!-- Menu to display Category-->
    <menuitem id="menu_category" name="Category"
              parent="cyllo_field_service.menu_configuration_categ"
              action="action_view_category"/>
    <!-- Menu to display Skills-->
    <menuitem id="menu_skills" name="Skills"
              parent="cyllo_field_service.menu_configuration_categ"
              action="action_view_skills"/>


    <!-- Reporting Menu -->
    <menuitem id="menu_reporting_categ" name="Reporting"
              parent="cyllo_field_service.menu_cyllo_field_service_root"
              sequence="3"/>
    <!-- Menu to display Reports-->
    <menuitem id="menu_reports" name="Reports"
              parent="cyllo_field_service.menu_reporting_categ"
              action="action_view_reports"/>
</odoo>
