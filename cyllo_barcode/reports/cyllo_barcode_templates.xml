<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Report Template For Employee Complaint-->
    <template id="barcode_data_report">
        <t t-call="web.html_container">
            <t t-call="web.html_container">
                <t  t-if="mode != 'inventory_commands'">
                    <div class="oe_structure"/>
                    <t t-set="nRows" t-value="7"/>
                    <t t-set="nCols" t-value="4"/>
                    <t t-set="docs" t-value="items"/>
                    <t t-foreach="[docs[x:x + nRows * nCols] for x in range(0, len(docs), nRows * nCols)]" t-as="page_docs">
                        <div class="o_label_sheet" style="padding: 10mm 3mm;">
                            <table class="my-0 table table-sm table-borderless">
                                <t t-foreach="range(nRows)" t-as="row">
                                    <tr>
                                        <t t-foreach="range(nCols)" t-as="col">
                                            <t t-set="barcode_index" t-value="(row * nCols + col)"/>
                                            <t t-if="barcode_index &lt; len(page_docs)">
                                                <t t-set="o" t-value="page_docs[barcode_index]"/>
                                                <td>
                                                    <div class="o_label_full" style="width:47mm;height:37.1mm;border: 1px solid black;">
                                                        <div class="o_label_name" style=" text-align:center;margin-top:3%;height:3em;width: 98%;">
                                                            <strong><span t-esc="o['name']">WH/Stock</span></strong>
                                                        </div>
                                                        <div style="margin-top:; text-align:center;">
                                                            <span t-if="o['barcode']" t-out="o['barcode']" style="padding:0"
                                                                t-options="{'widget': 'barcode', 'humanreadable': 1, 'symbology': 'auto', 'img_style': 'width:40mm;height:11mm'}">1234567890</span>
                                                        </div>
                                                    </div>
                                                </td>
                                            </t>
                                        </t>
                                    </tr>
                                </t>
                            </table>
                        </div>
                    </t>
                </t>
                <div t-if="mode == 'inventory_commands'">
                   <table class="table table-borderless" style="width:100%;">
                        <tbody>
                            <tr style="height:120px;">
                                <td style="text-align:center;">
                                    <t t-set="main" t-value="'action_main_menu'"/>
                                    <span t-esc="main" style="padding:0"
                                          t-options="{'widget': 'barcode', 'symbology': 'auto', 'img_style': 'width:80mm;height:20mm'}"/><br/>
                                    <strong>MAIN MENU</strong>
                                </td>
                                <td style="text-align:center;">
                                    <t t-set="main" t-value="'action_discard'"/>
                                    <span t-esc="main" style="padding:0"
                                          t-options="{'widget': 'barcode', 'symbology': 'auto', 'img_style': 'width:80mm;height:20mm'}"/><br/>
                                    <strong>DISCARD</strong>
                                </td>
                            </tr>
                            <tr style="height:120px;">
                                <td style="text-align:center;">
                                    <t t-set="main" t-value="'action_validate'"/>
                                    <span t-esc="main" style="padding:0"
                                          t-options="{'widget': 'barcode', 'symbology': 'auto', 'img_style': 'width:80mm;height:20mm'}"/><br/>
                                    <strong>VALIDATE</strong>
                                </td>
                                <td style="text-align:center;">
                                    <t t-set="main" t-value="'action_cancel'"/>
                                    <span t-esc="main" style="padding:0"
                                          t-options="{'widget': 'barcode', 'symbology': 'auto', 'img_style': 'width:80mm;height:20mm'}"/><br/>
                                    <strong>CANCEL</strong>
                                </td>
                            </tr>
                            <tr style="height:120px;">
                                <td style="text-align:center;">
                                    <t t-set="main" t-value="'action_picking'"/>
                                    <span t-esc="main" style="padding:0"
                                          t-options="{'widget': 'barcode', 'symbology': 'auto', 'img_style': 'width:80mm;height:20mm'}"/><br/>
                                    <strong>PRINT PICKING OPERATIONS</strong>
                                </td>
                                <td style="text-align:center;">
                                    <t t-set="main" t-value="'action_slip'"/>
                                    <span t-esc="main" style="padding:0"
                                          t-options="{'widget': 'barcode', 'symbology': 'auto', 'img_style': 'width:80mm;height:20mm'}"/><br/>
                                    <strong>PRINT DELIVERY SLIP</strong>
                                </td>
                            </tr>
                            <tr style="height:120px;">
                                <td style="text-align:center;">
                                    <t t-set="main" t-value="'action_put_in_pack'"/>
                                    <span t-esc="main" style="padding:0"
                                          t-options="{'widget': 'barcode', 'symbology': 'auto', 'img_style': 'width:80mm;height:20mm'}"/><br/>
                                    <strong>PUT IN PACK</strong>
                                </td>
                                <td style="text-align:center;">
                                    <t t-set="main" t-value="'action_scrap'"/>
                                    <span t-esc="main" style="padding:0"
                                          t-options="{'widget': 'barcode', 'symbology': 'auto', 'img_style': 'width:80mm;height:20mm'}"/><br/>
                                    <strong>SCRAP</strong>
                                </td>
                            </tr>
                            <tr style="height:120px;">
                                <td style="text-align:center;">
                                    <t t-set="main" t-value="'print_batch'"/>
                                    <span t-esc="main" style="padding:0"
                                          t-options="{'widget': 'barcode', 'symbology': 'auto', 'img_style': 'width:80mm;height:20mm'}"/><br/>
                                    <strong>Batch Transfer</strong>
                                </td>
                                <td style="text-align:center;">
                                    <t t-set="main" t-value="'action_previous_page'"/>
                                    <span t-esc="main" style="padding:0"
                                          t-options="{'widget': 'barcode', 'symbology': 'auto', 'img_style': 'width:80mm;height:20mm'}"/><br/>
                                    <strong>PREVIOUS PAGE</strong>
                                </td>
                            </tr>
                            <tr style="height:120px;">
                                <td style="text-align:center;">
                                    <t t-set="main" t-value="'action_next_page'"/>
                                    <span t-esc="main" style="padding:0"
                                          t-options="{'widget': 'barcode', 'symbology': 'auto', 'img_style': 'width:80mm;height:20mm'}"/><br/>
                                    <strong>NEXT PAGE</strong>
                                </td>
                                <td style="text-align:center;">
                                    <t t-set="main" t-value="'action_first_page'"/>
                                    <span t-esc="main" style="padding:0"
                                          t-options="{'widget': 'barcode', 'symbology': 'auto', 'img_style': 'width:80mm;height:20mm'}"/><br/>
                                    <strong>FIRST PAGE</strong>
                                </td>
                            </tr>
                            <tr style="height:120px;">
                                <td style="text-align:center;">
                                    <t t-set="main" t-value="'action_last_page'"/>
                                    <span t-esc="main" style="padding:0"
                                          t-options="{'widget': 'barcode', 'symbology': 'auto', 'img_style': 'width:80mm;height:20mm'}"/><br/>
                                    <strong>LAST PAGE</strong>
                                </td>
                                <td style="text-align:center;">
                                    <t t-set="main" t-value="'action_return'"/>
                                    <span t-esc="main" style="padding:0"
                                          t-options="{'widget': 'barcode', 'symbology': 'auto', 'img_style': 'width:80mm;height:20mm'}"/><br/>
                                    <strong>RETURN</strong>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </t>
        </t>
    </template>
</odoo>