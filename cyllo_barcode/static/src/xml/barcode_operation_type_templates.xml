<?xml version="1.0" encoding="UTF-8" ?>
<templates id="template" xml:space="preserve">
    <!--    templates for the BarcodeOperationType views-->
    <t t-name="cyllo_barcode.BarcodeStockPicking" owl="1">
        <div class="o_cyllo_barcode_operation" t-ref="BarcodeOperationType">
            <div class="d-flex w-100 p-0 m-0 border-bottom">
                <nav class="navbar navbar-light w-100 justify-content-between">
                    <div class="d-flex align-items-center">
                        <span class="navbar-brand text-light" t-esc="name"/>
                    </div>
                    <form class="form-inline">
                        <button class="btn go-back-big-screen btn-secondary my-2 my-sm-0"
                                type="button"
                                t-on-click="() => this.actionService.doAction('cyllo_barcode.cyllo_barcode_action')"><i class="ri-logout-box-r-line fs-3"/></button>
                    </form>
                </nav>
            </div>
            <div class="container cyllo-barcode-adjustment-container">
                <div class="card-columns row" style="padding-bottom: 10px;">
                  <div class="col-sm-3" style="margin: 10px 0;"
                       t-foreach="this.state.stockPicking" t-as="picking"
                       t-key="picking.id">
                    <div class="card"
                         t-on-click="() => this._onClickOpenTransfer(picking.id,picking.name)">
                      <div class="card-body">
                          <div class="badge-stock-picking">Ready</div>
                          <div class="row">
                            <h4 class="card-title d-flex col-sm-9"
                                t-esc="picking.name"/>
                              <i class="btn fa fa-desktop col-sm-3 d-flex justify-content-end"
                                 t-on-click="(ev) => this.OpenStockPicking(ev, picking.id, picking.name)"/>
                              <p class="text-muted col-sm-6 text-truncate"
                                 t-esc="picking.partner_id[1]"/>
                              <t t-set="date"
                                 t-value="picking.scheduled_date.split(' ')"/>
                              <p class="text-muted col-sm-6 d-flex justify-content-end"
                                 t-esc="date[0]"/>
                          </div>
                      </div>
                    </div>
                  </div>
                </div>
            </div>
        </div>
    </t>
</templates>
