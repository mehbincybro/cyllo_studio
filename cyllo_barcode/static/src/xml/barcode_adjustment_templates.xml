<?xml version="1.0" encoding="UTF-8" ?>
<templates id="template" xml:space="preserve">
    <!--    templates for the BarcodeAdjustment views-->
    <t t-name="cyllo_barcode.BarcodeAdjustment" owl="1">
        <div class="container-fluid o_cyllo_barcode_adjustment p-0"
             t-ref="BarcodeAdjustmentRoot">
            <div class="d-flex w-100 p-0 m-0 bg-white border-bottom">
                <nav class="navbar navbar-light bg-light w-100 justify-content-between barcode-cy-primary">
                    <a class="navbar-brand text-light">Inventory Adjustment</a>
                    <form class="form-inline">
                        <button class="btn btn-outline-light my-2 my-sm-0"
                                type="button" style="margin-right: 10px"
                                t-on-click="_onClickScanProduct"><i class="fa fa-barcode" /></button>
                        <button class="btn btn-outline-light my-2 my-sm-0"
                                type="button"
                                t-on-click="() => this.actionService.doAction('cyllo_barcode.cyllo_barcode_action')"><i class="fa fa-sign-out"/></button>
                    </form>
                </nav>
            </div>
            <div class="justify-content-center d-flex border-bottom">
                <a class="navbar-brand text-dark adjustment_location_header">Scan Product/Location <i
                        class="fa fa-barcode"/> </a>
            </div>
            <div class="container cyllo-barcode-adjustment-container">
                <div class="card-columns row" style="padding-bottom: 10px;">
                    <t t-foreach="this.state.adjust_stock" t-as="stock"
                       t-key="stock['id']">
                        <CylloBarcodeAdjustmentLines stock="stock"/>
                    </t>
                </div>
            </div>
            <div class="position-fixed bottom-0 w-100 d-flex">
                <div class="col-md-6 bg-light btn-adjustment-clear justify-content-center align-items-center text-dark d-flex border-top"
                     t-on-click="() => this._onClickCancelSelected(this.state.selected_stock)"
                     style="height:35px;">
                    Clear
                </div>
                <div class="col-md-6 btn-adjustment justify-content-center barcode-cy-primary align-items-center text-light d-flex"
                     t-on-click="_onClickApplySelected" style="height:35px;">
                    Apply <t t-esc="'('+this.state.selected_stock.length+')'"/>
                </div>
            </div>
        </div>
    </t>
    <!--    templates for the BarcodeAdjustmentLines views-->
    <t t-name="cyllo_barcode.BarcodeAdjustmentLines" owl="1">
        <div class="card mb-3 barcode-cy-primary col-md-4 cyllo-barcode-cards"
             t-ref="root-AdjustmentLines">
            <div class="row no-gutters selecting-card" t-on-click="_onSelectCards">
                <div t-if="state.stock.image"
                     class="col-md-4 cy-barcode-adjustment-image"
                     t-attf-style="background-image :url('data:image/png;base64,{{state.stock.image}}');">
                    <button class="btn btn-dark border-0 rounded-circle m-1 p-1 position-absolute edit_adjust_line"
                            data-tooltip="Open Edit Window"
                            aria-label="Open Edit Window"
                            t-on-click="(ev) => this._onClickOpenEdit(ev)">
                        <i class="fa fa-pencil fa-fw"/>
                    </button>
                    <button class="btn btn-dark border-0 rounded-circle m-1 p-1 position-absolute cancel_adjust_line"
                            data-tooltip="Cancel Operations"
                            aria-label="Cancel Operations"
                            t-on-click="(ev) => this._onclickCancel(ev)">
                        <i class="fa fa-trash fa-fw"/>
                    </button>
                </div>
                <div t-else="" class="col-md-4 cy-barcode-adjustment-image"
                     style="background-image :url('/cyllo_barcode/static/src/img/stock_static.jpg'); background-position: 50% 50%; background-size: 170%; cy-barcode-adjustment-image">
                    <button class="btn btn-dark border-0 rounded-circle m-1 p-1 position-absolute edit_adjust_line"
                            data-tooltip="Open Edit Window"
                            aria-label="Open Edit Window"
                            t-on-click="() => this.root.el.querySelector('#AdjustmentLinesModal').style.display = 'block'">
                        <i class="fa fa-pencil fa-fw"/>
                    </button>
                    <button class="btn btn-dark border-0 rounded-circle m-1 p-1 position-absolute cancel_adjust_line"
                            data-tooltip="Cancel Operations"
                            aria-label="Cancel Operations"
                            t-on-click="_onclickCancel">
                        <i class="fa fa-trash fa-fw"/>
                    </button>
                </div>
                <div class="col-md-8">
                    <div class="card-body barcode-cy-primary">
                        <h5 class="card-title text-light d-flex justify-content-center"
                            t-esc="state.stock.product_name"/>
                        <p class="card-text text-light"><div class="barcode-location-text "><i class="fa fa-map-marker" /> <span
                                t-esc="state.stock.location"/></div> </p>
                        <p t-if="state.stock.product_code"
                           class="card-text text-light"><i class="fa fa-tag" />
                            <span t-esc="state.stock.product_code"/> </p>
                        <p class="card-text text-light"><i class="fa fa-cubes" />
                            <button class="fa btn text-light fa-minus"
                                    t-on-click="(ev) => this._onClickExternalOperation('minus',ev)"/>
                            <span t-esc="state.stock.inv_quantity"/>
                            /
                            <span class="btn" style="color: #fff; font-weight: bold"
                                  t-esc="state.stock.quantity"/>
                            <button class="fa btn text-light fa-plus"
                                    t-on-click="(ev) => this._onClickExternalOperation('add',ev)"/> </p>
                    </div>
                </div>
            </div>
            <div id="AdjustmentLinesModal"
                 class="barcode-modal cyllo-Barcode-modal">
                <!-- Modal content -->
                <div class="barcode-modal-content">
                    <i class="fa fa-times barcode-close"
                       t-on-click="_onClickDiscardChanges"/>
                    <div class="barcode-adjustment-line-content d-grid justify-content-center">
                        <h4 class="card-text text-dark"><i class="fa fa-tags" />
                            <span class="btn" t-esc="state.stock.product_name"
                                  t-on-click="() => this._onClickOpenWizard('product.product', state.stock.product)"/> </h4>
                        <div class="d-flex" style="margin: 6px 0;"><i class="fa fa-cubes text-dark" style="font-size: 23px;padding-top: 3px;"/>
                            <input type="number" min="0"
                                   class="form-control input_for_quantity"
                                   t-att-value="state.stock.inv_quantity"
                                   style="margin-left:3px;"/>
                            <div style="border-top-right-radius: 7px;border-bottom-right-radius: 7px;width: 42px;"
                                 class="text-light align-items-center d-flex justify-content-center barcode-cy-primary"
                                 t-esc="state.stock.quantity"/>
                        </div>
                        <div id="barcode-numpad-container">
                            <ul id="barcode-numpad-keyboard">
                                <li class="letter"
                                    t-on-click="() => this._onclickNumber('1')">1</li>
                                <li class="letter"
                                    t-on-click="() => this._onclickNumber('2')">2</li>
                                <li class="letter"
                                    t-on-click="() => this._onclickNumber('3')">3</li>
                                <li class="letter barcode-numpad-clearl"
                                    t-on-click="() => this._onclickNumber('4')">4</li>
                                <li class="letter"
                                    t-on-click="() => this._onclickNumber('5')">5</li>
                                <li class="letter"
                                    t-on-click="() => this._onclickNumber('6')">6</li>
                                <li class="letter barcode-numpad-clearl"
                                    t-on-click="() => this._onclickNumber('7')">7</li>
                                <li class="letter"
                                    t-on-click="() => this._onclickNumber('8')">8</li>
                                <li class="letter"
                                    t-on-click="() => this._onclickNumber('9')">9</li>
                                <li class="letter"
                                    t-on-click="() => this._onClickDialOperation('minus')">-1</li>
                                <li class="letter  barcode-numpad-clearl"
                                    t-on-click="_onClickDialDecimal">.</li>
                                <li class="letter"
                                    t-on-click="() => this._onclickNumber('0')">0</li>
                                <li class="letter"
                                    t-on-click="() => this._onClickDialRemove"><i class="fa fa-long-arrow-left" /></li>
                                <li class="letter"
                                    t-on-click="() => this._onClickDialOperation('add')">+1</li>
                            </ul>
                        </div>
                        <h4 class="card-text text-dark"><i class="fa fa-map-marker" />
                            <span t-esc="state.stock.location" class="btn"
                                  t-on-click="() => this._onClickOpenWizard('stock.location', state.stock.location_id)"/> </h4>
                   </div>
                    <div class="row barcode-modal-buttons">
                        <div class="col-md-6 btn-adjustment-clear justify-content-center align-items-center text-dark d-flex border"
                             t-on-click="_onClickDiscardChanges">
                            Discard
                        </div>
                        <div class="col-md-6 btn-adjustment justify-content-center barcode-cy-primary align-items-center text-light d-flex"
                             t-on-click="() => this._onClickApplyChanges(this.root.el.querySelector('.input_for_quantity').value)">
                            Apply
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </t>
</templates>
