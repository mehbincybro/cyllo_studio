<?xml version="1.0" encoding="UTF-8" ?>
<templates id="template" xml:space="preserve">
    <!--    templates for the BarcodeBatchTransfer views-->
    <t t-name="cyllo_barcode.BarcodeBatchTransfer" owl="1">
        <div class="o_cyllo_barcode_batch ">
            <div class="d-flex w-100 p-0 m-0 bg-white border-bottom">
                <nav class="navbar navbar-light bg-light w-100 justify-content-between barcode-cy-primary">
                    <span class="navbar-brand text-light">Batch Transfer</span>
                    <form class="form-inline">
                        <button class="btn btn-outline-light my-2 my-sm-0"
                                type="button"
                                t-on-click="() => this.actionService.doAction('cyllo_barcode.cyllo_barcode_action')"><i class="fa fa-sign-out"/></button>
                    </form>
                </nav>
            </div>
            <div class="container"
                 style="max-height: 90.5vh; overflow-y: auto;">
                <div class="card-columns row" style="padding-bottom: 10px;">
                <div class="col-sm-4" style="margin: 10px 0;"
                     t-foreach="this.state.batches" t-as="batch"
                     t-key="batch.id">
                    <div class="card"
                         t-on-click="() => this._onClickOpenTransfer(batch.id, batch.name)">
                      <div class="card-body">
                          <div class="badge-stock-picking">Ready</div>
                          <div class="row">
                            <h4 class="card-title d-flex col-sm-9"
                                t-esc="batch.name"/>
                              <i class="btn fa fa-desktop col-sm-3 d-flex justify-content-end"
                                 t-on-click="(ev) => this.OpenBatchTransfer(ev, batch.id, batch.name)"/>
                              <p class="text-muted col-sm-8"
                                 t-esc="batch.picking_type_id[1]"/>
                              <t t-set="date"
                                 t-value="batch.scheduled_date.split(' ')"/>
                              <p class="text-muted col-sm-4 d-flex justify-content-end"
                                 t-esc="date[0]"/>
                          </div>
                      </div>
                    </div>
                  </div>
                  </div>
            </div>
        </div>
    </t>
    <!--    templates for the BarcodeBatchTransferLines views-->
    <t t-name="cyllo_barcode.BarcodeBatchTransferLines" owl="1">
        <div class="o_cyllo_barcode_batch_line"
             t-ref="BarcodeTransferLine-Root">
            <div class="d-flex w-100 p-0 m-0 bg-white border-bottom">
                <nav class="navbar navbar-light bg-light w-100 justify-content-between barcode-cy-primary">
                    <div class="d-flex align-items-center">
                        <i class="fa fa-arrow-left text-light p-2 cursor-pointer"
                           t-on-click="_onClickExit"/>
                        <span class="navbar-brand text-light"
                              t-esc="state.data.name"/>
                    </div>
                    <form class="form-inline">
                        <button class="btn btn-outline-light my-2 my-sm-0"
                                type="button" style="margin-right: 10px"
                                t-on-click="() => this.actionService.doAction('cyllo_barcode.cyllo_barcode_action')"><i class="fa fa-sign-out"/></button>
                    </form>
                </nav>
            </div>
            <t t-if="state.data.state != 'done'">
                <div class="justify-content-center d-flex border-bottom"
                     t-if="group_stock_multi_locations  &amp;&amp; this.state.data.picking_type === 'incoming'">
                    <a class="navbar-brand text-dark adjustment_location_header">Scan Destination Location <i
                            class="fa fa-barcode"/>
                        / Scan Product
                        <i class="fa fa-barcode"/>  </a>
                </div>
                    <div class="justify-content-center d-flex border-bottom"
                         t-if="group_stock_multi_locations &amp;&amp; this.state.data.picking_type === 'outgoing'">
                    <a class="navbar-brand text-dark adjustment_location_header">Scan Source Location <i
                            class="fa fa-barcode"/>
                        / Scan Product
                        <i class="fa fa-barcode"/>  </a>
                </div>
                    <div class="justify-content-center d-flex border-bottom"
                         t-if="!group_stock_multi_locations">
                    <a class="navbar-brand text-dark adjustment_location_header">Scan Product <i
                            class="fa fa-barcode"/> </a>
                </div>
                    <div class="container cyllo-barcode-adjustment-container">
                    <div class="card-columns row" style="padding-bottom: 10px;">
                          <div class="col-sm-4" style="margin: 10px 0;"
                               t-foreach="this.state.move_line" t-as="move_line"
                               t-key="move_line.id">
                            <CylloBarcodeMoveLines line="move_line" picking_type="this.state.data.picking_type"/>
                          </div>
                    </div>
                </div>
            </t>
            <t t-else="">
                <div class="row cyllo-barcode_section">
                <div class="cyllo-barcode--container cyllo_barcode-verify-container">
                    <div class="cy-barcode-img_container">
                        <img src="/cyllo_barcode/static/src/img/box.svg"  alt="verified product" class="cy-validate-img"/>
                    </div>

                    <h2 class="cyllo-barcode-verifyheader">This Batch Transfer is Validated !</h2>
                </div>
                </div>
            </t>
        </div>

        <div class="position-fixed bottom-0 w-100 row"
             t-if="state.data.state != 'done'">
            <div class="col-md-6 col-sm-6 btn-adjustment justify-content-center align-items-center d-flex border-top bg-light"
                 t-on-click="_onClickActionPackage"
                 t-if="this.group_stock_tracking_lot" style="height:43px;">
                Put In Pack
            </div>
            <div t-attf-class="btn-adjustment justify-content-center barcode-cy-primary align-items-center text-light d-flex {{this.group_stock_tracking_lot ? 'col-md-6 col-sm-6 ' : ''}}"
                 t-on-click="_onClickActionValidate" style="height:43px;">
                    Validate
            </div>
        </div>
    </t>
    <!--    templates for the CylloBarcodeMoveLines views-->
    <t t-name="cyllo_barcode.CylloBarcodeMoveLines" owl="1">
        <div class="card" t-ref="MoveLine-root">
            <div class="card-body">
                <p t-if="this.props.picking_type === 'incoming'"> <i
                        class="fa fa-sign-out"/>
                    <span t-esc="state.line.location_dest_id[1]"/> </p>
                <p t-if="this.props.picking_type === 'outgoing'"> <i
                        class="fa fa-sign-out"/>
                    <span t-esc="state.line.location_id[1]"/> </p>
                <h4 class="card-title d-flex "> <i class="fa fa-tags"/>
                    <span t-esc="state.line.product_id[1]"/></h4>
                <p><i class="fa fa-cube"/>
                    <t t-esc="state.line.qty_done"/>
                    /
                    <t t-esc="state.line.quantity_product_uom"/> </p>
                <p><i class="fa fa-truck"/>
                    <t t-esc="state.line.picking_id[1]"/></p>
                <div class="row" style="min-height: 33px;padding: 0 10px;">
                    <div class="col-md-6 col-sm-6 border justify-content-center align-items-center d-flex btn"
                         t-if="state.line.qty_done == 0"
                         t-on-click="() => this._onClickApplyChanges(state.line.quantity_product_uom)">
                        + <t t-esc="state.line.quantity_product_uom"/>
                    </div>
                    <div t-attf-class="btn-adjustment justify-content-center barcode-cy-primary btn align-items-center text-light d-flex {{state.line.qty_done == 0 ? 'col-md-6 col-sm-6 ' : ''}}"
                         t-on-click="() => this.root.el.querySelector('#BatchLineModal').style.display = 'block'">
                        <i class="fa fa-pencil"/>
                    </div>
                </div>
            </div>
            <div id="BatchLineModal" class="barcode-modal cyllo-Barcode-modal">
                <!-- Modal content -->
                <div class="barcode-modal-content">
                    <i class="fa fa-times barcode-close"
                       t-on-click="_onClickDiscardChanges"/>
                    <div class="barcode-adjustment-line-content d-grid justify-content-center">
                        <h4 class="card-text text-dark">
                            <i class="fa fa-tags"/>
                            <span class="btn" t-esc="state.line.product_id[1]"
                                  t-on-click="() => this._onClickOpenWizard('product.product', state.line.product_id[0])"/>
                        </h4>
                        <div t-if="state.line.tracking != 'none'" class="d-flex"
                             style="margin: 6px 0;">
                            <i class="fa fa-list-ol text-dark"
                               style="font-size: 23px;padding-top: 3px;"/>
                            <input type="text"
                                   class="form-control input_for_batch_serial_number"
                                   style="margin-left:3px;"
                                   placeholder="Add Lot/Serial Number..."/>
                        </div>
                        <h4 class="card-text text-dark barcode-location-text">
                            <i class="fa fa-map-marker"/>
                            <span t-esc="state.line.location_id[1]" class="btn"
                                  t-on-click="() => this._onClickOpenWizard('stock.location', state.line.location_id[0])"/>
                            <i class="fa fa-long-arrow-right"/>
                            <span t-esc="state.line.location_dest_id[1]"
                                  class="btn"
                                  t-on-click="() => this._onClickOpenWizard('stock.location', state.line.location_id[0])"/>
                        </h4>

                        <div class="d-flex" style="margin: 6px 0;">
                            <i class="fa fa-cubes text-dark"
                               style="font-size: 23px;padding-top: 3px;"/>
                            <input type="number" min="0"
                                   class="form-control input_for_quantity"
                                   t-att-value="state.line.quantity"
                                   style="margin-left:3px;"/>
                        </div>
                        <div id="barcode-numpad-container">
                            <ul id="barcode-numpad-keyboard">
                                <li class="letter"
                                    t-on-click="() => this._onclickNumber('1')">
                                    1
                                </li>
                                <li class="letter"
                                    t-on-click="() => this._onclickNumber('2')">
                                    2
                                </li>
                                <li class="letter"
                                    t-on-click="() => this._onclickNumber('3')">
                                    3
                                </li>
                                <li class="letter barcode-numpad-clearl"
                                    t-on-click="() => this._onclickNumber('4')">
                                    4
                                </li>
                                <li class="letter"
                                    t-on-click="() => this._onclickNumber('5')">
                                    5
                                </li>
                                <li class="letter"
                                    t-on-click="() => this._onclickNumber('6')">
                                    6
                                </li>
                                <li class="letter barcode-numpad-clearl"
                                    t-on-click="() => this._onclickNumber('7')">
                                    7
                                </li>
                                <li class="letter"
                                    t-on-click="() => this._onclickNumber('8')">
                                    8
                                </li>
                                <li class="letter"
                                    t-on-click="() => this._onclickNumber('9')">
                                    9
                                </li>
                                <li class="letter"
                                    t-on-click="() => this._onClickDialOperation('minus')">
                                    -1
                                </li>
                                <li class="letter  barcode-numpad-clearl"
                                    t-on-click="_onClickDialDecimal">.
                                </li>
                                <li class="letter"
                                    t-on-click="() => this._onclickNumber('0')">
                                    0
                                </li>
                                <li class="letter"
                                    t-on-click="_onClickDialRemove">
                                    <i class="fa fa-long-arrow-left"/>
                                </li>
                                <li class="letter"
                                    t-on-click="() => this._onClickDialOperation('add')">
                                    +1
                                </li>
                            </ul>
                        </div>
                    </div>
                    <div class="row barcode-modal-buttons">
                        <div class="col-md-6 btn-adjustment justify-content-center align-items-center text-dark d-flex border"
                             t-on-click="_onClickDiscardChanges">
                            Discard
                        </div>
                        <div class="col-md-6 btn-adjustment justify-content-center barcode-cy-primary align-items-center text-light d-flex"
                             t-on-click="() => this._onClickApplyChanges(this.root.el.querySelector('.input_for_quantity').value)">
                            Apply
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </t>
</templates>
