<?xml version="1.0" encoding="UTF-8" ?>
<templates>
    <t t-name="choosePicking">
        <Dialog size="'sm'" title="'Choose or Scan Picking'">
            <div class="col-12 d-flex" t-ref="root">
                <div class="col-4" style="font-weight: 500;">
                    Picking
                </div>
                <div class="col-8">
                    <Many2XAutocomplete t-props="pickingProps"/>
                </div>
            </div>
            <t t-set-slot="footer">
                <div>
                    <button class="btn btn-primary" type="button" t-on-click="applyPicking">Apply</button>
                </div>
            </t>
        </Dialog>
    </t>
</templates>