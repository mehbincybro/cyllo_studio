<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!--    adding the buttons in 'res.config.settings' for downloading corresponding pdf-->
    <record id="view_res_config_settings_form" model="ir.ui.view">
        <field name="name">view.res.config.settings.form</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="stock.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@name='barcode_setting_container']"
                   position="after">
                <block title="Barcode">
                    <setting id="cyllo_barcode_print"
                             help="Process operations faster with barcodes">
                        <div class="o_cyllo_barcode_print">
                            <button class="btn-link" type="object"
                                    string="Print Product Barcodes"
                                    name="action_print_barcode"
                                    icon="oi-arrow-right"
                                    context="{'model':'product.product'}"/>
                        </div>
                        <div class="o_cyllo_barcode_print">
                            <button class="btn-link" type="object"
                                    string="Print Location Barcodes"
                                    name="action_print_barcode"
                                    icon="oi-arrow-right"
                                    context="{'model':'stock.location'}"/>
                        </div>
                        <div class="o_cyllo_barcode_print">
                            <button class="btn-link" type="object"
                                    string="Print Inventory Commands Barcodes"
                                    name="action_print_barcode"
                                    icon="oi-arrow-right"
                                    context="{'model':'inventory_commands'}"/>
                        </div>
                         <div class="o_cyllo_barcode_print">
                            <button class="btn-link" type="object"
                                    string="Print Operation Types Barcodes"
                                    name="action_print_barcode"
                                    icon="oi-arrow-right"
                                    context="{'model':'stock.picking.type'}"/>
                        </div>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>
</odoo>