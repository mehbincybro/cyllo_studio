<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!--    Adding action for the menu item-->
    <record id="cyllo_barcode_action" model="ir.actions.client">
        <field name="name">Barcode</field>
        <field name="tag">cyllo_barcode_tags</field>
        <field name="target">main</field>
    </record>
    <!--    adding menu item for the barcode-->
    <menuitem id="menu_barcode"
              web_icon="cyllo_barcode,static/description/cyllo_barcode.svg"
              name="Barcode"/>
    <menuitem id="menu_barcode_dashboard" parent="menu_barcode" action="cyllo_barcode_action"
              name="Dashboard"/>
</odoo>
