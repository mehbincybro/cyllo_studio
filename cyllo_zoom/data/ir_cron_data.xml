<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data noupdate="1">

        <!-- Cron job to auto-refresh the global Zoom access token -->
        <record id="ir_cron_check_and_refresh_zoom_tokens" model="ir.cron">
            <field name="name">Check and Refresh Zoom Tokens</field>
            <field name="model_id" ref="base.model_res_config_settings"/>
            <field name="state">code</field>
            <field name="code">model._cron_check_and_refresh_zoom_tokens()</field>
            <field name="interval_number">5</field>
            <field name="interval_type">minutes</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
        </record>

    </data>
</odoo>