<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_calendar_event_form" model="ir.ui.view">
        <field name="name">
            calendar.event.view.form.inherit.zoom.meet.integration
        </field>
        <field name="model">calendar.event</field>
        <field name="inherit_id" ref="calendar.view_calendar_event_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='videocall_location']"
                   position="replace">
                <field name="videocall_location" invisible="is_zoom_meet"/>

                <group string="Zoom Meeting" class="mt-2 mb-2"
                       invisible="not is_zoom_meet">
                    <field name="zoom_meet_url"
                           placeholder="https://us05web.zoom.us..."
                           widget="CopyClipboardChar"
                           class="mb-2"/>
                    <field name="zoom_meet_code"
                           widget="CopyClipboardChar"
                           class="mb-2"/>

                    <div class="mb-2">
                        <button name="action_zoom_meet_url"
                                string="Join Meeting"
                                type="object"
                                class="btn-primary"/>
                    </div>

                    <field name="zoom_event" invisible="1"/>
                </group>
            </xpath>

            <xpath expr="//field[@name='start']" position="after">
                <field name="is_zoom_meet" widget="boolean_toggle"/>
            </xpath>
        </field>
    </record>
</odoo>


