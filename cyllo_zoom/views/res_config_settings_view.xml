<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_zoom" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.cyllo.zoom
        </field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id"
               ref="base_setup.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <!--            <xpath expr="//app[@name='general_settings']" position="inside">-->
            <xpath expr="//block[@name='integration']" position="after">
                <div class="app_settings_block">
                    <h2>Zoom Integration</h2>
                    <div class="row mt16 o_settings_container">

                        <!-- LEFT: Credentials -->
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <span class="o_form_label">Zoom OAuth
                                    Credentials
                                </span>
                                <div class="text-muted">
                                    Configure your Zoom app credentials.
                                    <a href="https://developers.zoom.us/docs/integrations/oauth/"
                                       class="o_doc_link"
                                       target="_blank">
                                        Zoom OAuth Documentation
                                    </a>
                                </div>
                                <div class="content-group">
                                    <div class="row mt8">
                                        <label for="zoom_client"
                                               class="col-lg-4 o_light_label">
                                            Client ID
                                        </label>
                                        <field name="zoom_client"
                                               id="zoom_client"
                                               placeholder="e.g. qwertyuiihgcx"
                                               class="col-lg-8"/>
                                    </div>
                                    <div class="row mt8">
                                        <label for="zoom_client_secret"
                                               class="col-lg-4 o_light_label">
                                            Client Secret
                                        </label>
                                        <field name="zoom_client_secret"
                                               id="zoom_client_secret"
                                               password="True"
                                               class="col-lg-8"/>
                                    </div>
                                    <div class="row mt8">
                                        <label for="zoom_redirect_uri"
                                               class="col-lg-4 o_light_label">
                                            Redirect URI
                                        </label>
                                        <field name="zoom_redirect_uri"
                                               id="zoom_redirect_uri"
                                               placeholder="http://localhost:8017/zoom/callback"
                                               class="col-lg-8"/>
                                    </div>
                                    <div class="row mt8">
                                        <label for="zoom_refresh_token"
                                               class="col-lg-4 o_light_label">
                                            Refresh Token
                                        </label>
                                        <field name="zoom_refresh_token"
                                               id="zoom_refresh_token"
                                               password="True"
                                               placeholder="Populated automatically after connecting"
                                               class="col-lg-8"/>
                                    </div>
                                    <div class="row mt8">
                                        <label for="zoom_recordings"
                                               class="col-lg-4 o_light_label">
                                            Recording Location
                                        </label>
                                        <field name="zoom_recordings"
                                               id="zoom_recordings"
                                               placeholder="/home/user/Documents/Zoom"
                                               class="col-lg-8"/>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- RIGHT: Status & Token Info -->
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <span class="o_form_label">Connection Status
                                </span>
                                <div class="text-muted">
                                    Current Zoom connection state and token
                                    information.
                                </div>
                                <div class="content-group">
                                    <div class="row mt8">
                                        <label for="zoom_status"
                                               class="col-lg-4 o_light_label">
                                            Status
                                        </label>
                                        <field name="zoom_status"
                                               id="zoom_status"
                                               readonly="1"
                                               class="col-lg-8"/>
                                    </div>
                                    <div class="row mt8">
                                        <label for="zoom_token"
                                               class="col-lg-4 o_light_label">
                                            Access Token
                                        </label>
                                        <field name="zoom_token"
                                               id="zoom_token"
                                               password="True"
                                               readonly="1"
                                               placeholder="Auto-populated after connecting"
                                               class="col-lg-8"/>
                                    </div>
                                    <div class="row mt8">
                                        <label for="zoom_token_expiry"
                                               class="col-lg-4 o_light_label">
                                            Token Expiry
                                        </label>
                                        <field name="zoom_token_expiry"
                                               id="zoom_token_expiry"
                                               readonly="1"
                                               class="col-lg-8"/>
                                    </div>
                                    <div class="row mt16">
                                        <div class="col-lg-12">
                                            <button name="action_connect_zoom"
                                                    type="object"
                                                    string="Connect Zoom"
                                                    class="btn btn-primary me-2"/>
                                            <button name="action_zoom_meet_refresh_token"
                                                    type="object"
                                                    string="Refresh Token"
                                                    class="btn btn-secondary"
                                                    icon="fa-refresh"/>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
