<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="helpdesk_ticket_view_form_inherit_repair" model="ir.ui.view">
        <field name="name">helpdesk.ticket.view.form.inherit.repair</field>
        <field name="model">helpdesk.ticket</field>
        <field name="inherit_id" ref="cyllo_help_desk.helpdesk_ticket_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header/field[@name='stage_id']" position="before">
                <button name="action_create_repair" type="object" string="Create Repair Order" invisible="not customer_id or not use_repairs"/>
            </xpath>
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_repairs" type="object" class="oe_stat_button" icon="fa-wrench" invisible="not use_repairs or repair_count == 0">
                    <field name="repair_count" widget="statinfo" string="Repairs"/>
                </button>
            </xpath>
        </field>
    </record>
</odoo>
