<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_cyllo_loan_close_wizard_form" model="ir.ui.view">
        <field name="name">cyllo.loan.close.wizard.form</field>
        <field name="model">cyllo.loan.close.wizard</field>
        <field name="arch" type="xml">
            <form string="Close Loan">
                <group string="Loan Summary">
                    <field name="loan_id" readonly="True"/>
                    <field name="amount_remaining" widget="monetary" readonly="True"
                        string="Outstanding Balance"/>
                    <field name="currency_id" invisible="True"/>
                </group>
                <group string="Closure Details">
                    <field name="close_date"/>
                    <field name="close_type"/>
                    <field name="waive_remaining"
                        invisible="close_type == 'full_settlement'"/>
                    <field name="journal_id"
                        invisible="close_type == 'full_settlement' or waive_remaining"/>
                </group>
                <group>
                    <field name="notes" placeholder="Reason for closure..."/>
                </group>
                <footer>
                    <button name="action_close_loan" type="object"
                        string="Close Loan" class="oe_highlight btn-danger"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
