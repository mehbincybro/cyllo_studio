<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_cyllo_loan_disburse_wizard_form" model="ir.ui.view">
        <field name="name">cyllo.loan.disburse.wizard.form</field>
        <field name="model">cyllo.loan.disburse.wizard</field>
        <field name="arch" type="xml">
            <form string="Disburse Loan">
                <group string="Loan Summary">
                    <field name="loan_id" readonly="True"/>
                    <field name="partner_id" readonly="True"/>
                    <field name="principal_amount" widget="monetary" readonly="True"/>
                    <field name="currency_id" invisible="True"/>
                </group>
                <group string="Disbursement Details">
                    <field name="disbursement_date"/>
                    <field name="journal_id"/>
                    <field name="generate_schedule"/>
                </group>
                <group>
                    <field name="notes" placeholder="Optional remarks for the chatter..."/>
                </group>
                <footer>
                    <button name="action_disburse" type="object"
                        string="Disburse" class="oe_highlight"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
