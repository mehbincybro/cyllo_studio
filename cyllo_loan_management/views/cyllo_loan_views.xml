<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================
         Loan — Tree View
    ============================================================ -->
    <record id="view_cyllo_loan_tree" model="ir.ui.view">
        <field name="name">cyllo.loan.tree</field>
        <field name="model">cyllo.loan</field>
        <field name="arch" type="xml">
            <tree string="Loans"
                  decoration-success="state == 'closed'"
                  decoration-warning="state in ('disbursed', 'running') and overdue_installment_count > 0"
                  decoration-danger="state == 'cancelled'"
                  decoration-muted="state == 'draft'">
                <field name="name"/>
                <field name="loan_direction" widget="badge"
                    decoration-info="loan_direction == 'giving'"
                    decoration-warning="loan_direction == 'taking'"/>
                <field name="loan_type_id"/>
                <field name="partner_id"/>
                <field name="date_start"/>
                <field name="date_end"/>
                <field name="principal_amount" sum="Total Principal" widget="monetary"/>
                <field name="interest_rate" string="Rate (%)"/>
                <field name="amount_remaining" sum="Total Remaining" widget="monetary"/>
                <field name="overdue_installment_count" string="Overdue"/>
                <field name="currency_id" optional="hide" column_invisible="1"/>
                <field name="state" widget="badge"
                    decoration-success="state == 'closed'"
                    decoration-primary="state == 'running'"
                    decoration-warning="state == 'approved'"
                    decoration-info="state == 'disbursed'"
                    decoration-danger="state == 'cancelled'"/>
                <field name="user_id" optional="hide" widget="many2one_avatar_user"/>
                <field name="company_id" optional="hide" groups="base.group_multi_company"/>
            </tree>
        </field>
    </record>

    <!-- ============================================================
         Loan — Form View
    ============================================================ -->
    <record id="view_cyllo_loan_form" model="ir.ui.view">
        <field name="name">cyllo.loan.form</field>
        <field name="model">cyllo.loan</field>
        <field name="arch" type="xml">
            <form string="Loan">
                <header>
                    <button name="action_approve" string="Approve"
                        type="object" class="oe_highlight"
                        invisible="state != 'draft'"
                        groups="cyllo_loan_management.group_cyllo_loan_manager"/>
                    <button name="action_disburse" string="Disburse"
                        type="object" class="oe_highlight"
                        invisible="state != 'approved'"
                        groups="cyllo_loan_management.group_cyllo_loan_manager"/>
                    <button name="action_generate_schedule" string="Generate Schedule"
                        type="object"
                        invisible="state not in ('draft', 'approved')"
                        confirm="This will delete and regenerate the repayment schedule. Continue?"/>
                    <button name="action_close" string="Close Loan"
                        type="object"
                        invisible="state != 'running'"
                        groups="cyllo_loan_management.group_cyllo_loan_manager"/>
                    <button name="action_cancel" string="Cancel"
                        type="object"
                        invisible="state in ('closed', 'cancelled')"
                        groups="cyllo_loan_management.group_cyllo_loan_manager"
                        confirm="Are you sure you want to cancel this loan?"/>
                    <button name="action_reset_to_draft" string="Reset to Draft"
                        type="object"
                        invisible="state != 'cancelled'"
                        groups="cyllo_loan_management.group_cyllo_loan_manager"/>
                    <field name="state" widget="statusbar"
                        statusbar_visible="draft,approved,running,closed"/>
                </header>
                <sheet>
                    <!-- Smart buttons -->
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" type="object"
                            name="action_view_invoices" icon="fa-file-text-o"
                            invisible="invoice_count == 0">
                            <field name="invoice_count" widget="statinfo" string="Invoices"/>
                        </button>
                        <button class="oe_stat_button" type="object"
                            name="action_view_moves" icon="fa-book"
                            invisible="move_count == 0">
                            <field name="move_count" widget="statinfo" string="Journal Entries"/>
                        </button>
                    </div>

                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" readonly="True"/>
                        </h1>
                        <field name="loan_direction" widget="radio" class="o_row"
                            invisible="state not in ('draft',)"/>
                        <span invisible="state == 'draft'">
                            <field name="loan_direction" readonly="True" widget="badge"
                                decoration-info="loan_direction == 'giving'"
                                decoration-warning="loan_direction == 'taking'"/>
                        </span>
                    </div>

                    <!-- Summary bar for running loans -->
                    <div class="alert alert-warning" role="alert"
                        invisible="overdue_installment_count == 0">
                        <i class="fa fa-exclamation-triangle"/> 
                        <strong><field name="overdue_installment_count"/> overdue installment(s)</strong> — 
                        Outstanding: <field name="amount_remaining" widget="monetary" nolabel="1"/> 
                        <field name="currency_id" invisible="1"/>
                    </div>

                    <group>
                        <group string="Loan Details">
                            <field name="loan_type_id"/>
                            <label for="partner_id" string_expr="partner_type_label"/>
                            <field name="partner_id" nolabel="1"/>
                            <field name="partner_type_label" invisible="1"/>
                            <field name="user_id" widget="many2one_avatar_user"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="currency_id" groups="base.group_multi_currency"/>
                        </group>
                        <group string="Loan Terms">
                            <field name="principal_amount" widget="monetary"/>
                            <field name="interest_type"/>
                            <field name="interest_rate" string="Annual Rate (%)"/>
                            <field name="repayment_frequency"/>
                            <field name="duration" string="Duration (Months)"/>
                            <field name="date_start"/>
                            <field name="date_end"/>
                        </group>
                    </group>

                    <group string="Accounting Configuration">
                        <group>
                            <field name="journal_id"/>
                            <field name="loan_account_id"/>
                        </group>
                        <group>
                            <field name="interest_account_id"/>
                            <field name="disburse_move_id" readonly="True"
                                invisible="not disburse_move_id"/>
                        </group>
                    </group>

                    <!-- Repayment Summary for running loans -->
                    <group string="Repayment Summary" invisible="state not in ('running', 'disbursed', 'closed')">
                        <group>
                            <field name="total_interest" widget="monetary"/>
                            <field name="total_repayment" widget="monetary" string="Total (P+I)"/>
                        </group>
                        <group>
                            <field name="amount_paid" widget="monetary"/>
                            <field name="amount_remaining" widget="monetary"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Repayment Schedule" name="repayment_schedule">
                            <field name="repayment_ids">
                                <tree string="Repayment Schedule"
                                      decoration-danger="state == 'overdue'"
                                      decoration-success="state == 'paid'"
                                      decoration-muted="state == 'draft'">
                                    <field name="sequence" string="#"/>
                                    <field name="due_date"/>
                                    <field name="principal_amount" widget="monetary" sum="Total"/>
                                    <field name="interest_amount" widget="monetary" sum="Total"/>
                                    <field name="penalty_amount" widget="monetary" sum="Total"
                                        optional="hide"/>
                                    <field name="total_amount" widget="monetary" sum="Total"/>
                                    <field name="amount_paid" widget="monetary" sum="Total"/>
                                    <field name="amount_remaining" widget="monetary" sum="Total"/>
                                    <field name="days_overdue" string="Days Overdue" optional="hide"/>
                                    <field name="invoice_id" optional="hide"/>
                                    <field name="move_id" optional="hide"/>
                                    <field name="payment_date" optional="hide"/>
                                    <field name="state" widget="badge"
                                        decoration-success="state == 'paid'"
                                        decoration-warning="state == 'posted'"
                                        decoration-danger="state == 'overdue'"/>
                                    <button name="action_post" type="object" string="Post"
                                        icon="fa-check" invisible="state != 'draft'"/>
                                    <button name="action_register_payment" type="object"
                                        string="Pay" icon="fa-money"
                                        invisible="state not in ('posted', 'overdue')"/>
                                    <field name="currency_id" column_invisible="1"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Invoices / Bills" name="invoices">
                            <field name="invoice_ids">
                                <tree string="Linked Invoices">
                                    <field name="name" string="Reference"/>
                                    <field name="move_type" widget="badge"/>
                                    <field name="invoice_date"/>
                                    <field name="invoice_date_due" string="Due Date"/>
                                    <field name="amount_total" widget="monetary" sum="Total"/>
                                    <field name="amount_residual" widget="monetary" string="Remaining" sum="Total"/>
                                    <field name="currency_id" column_invisible="1"/>
                                    <field name="payment_state" widget="badge"
                                        decoration-success="payment_state == 'paid'"
                                        decoration-warning="payment_state == 'partial'"
                                        decoration-danger="payment_state == 'not_paid'"/>
                                    <field name="state" widget="badge"
                                        decoration-success="state == 'posted'"
                                        decoration-muted="state == 'draft'"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Notes" name="notes">
                            <field name="notes" placeholder="Internal notes..."/>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- ============================================================
         Loan — Kanban View
    ============================================================ -->
    <record id="view_cyllo_loan_kanban" model="ir.ui.view">
        <field name="name">cyllo.loan.kanban</field>
        <field name="model">cyllo.loan</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" quick_create="false"
                class="o_kanban_small_column">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="state"/>
                <field name="loan_direction"/>
                <field name="principal_amount"/>
                <field name="amount_remaining"/>
                <field name="currency_id"/>
                <field name="overdue_installment_count"/>
                <field name="date_end"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_card oe_kanban_global_click">
                            <div class="oe_kanban_content">
                                <div class="o_kanban_record_top">
                                    <div class="o_kanban_record_headings">
                                        <strong class="o_kanban_record_title">
                                            <field name="name"/>
                                        </strong>
                                        <span class="o_kanban_record_subtitle">
                                            <field name="partner_id"/>
                                        </span>
                                    </div>
                                    <span t-if="record.loan_direction.raw_value == 'giving'"
                                        class="badge bg-info">Giving</span>
                                    <span t-else=""
                                        class="badge bg-warning">Taking</span>
                                </div>
                                <div class="o_kanban_record_body">
                                    <div>
                                        <span class="fw-bold">Principal: </span>
                                        <field name="principal_amount" widget="monetary"/>
                                    </div>
                                    <div t-if="record.amount_remaining.raw_value > 0">
                                        <span class="fw-bold">Remaining: </span>
                                        <field name="amount_remaining" widget="monetary"/>
                                    </div>
                                    <div t-if="record.overdue_installment_count.raw_value > 0"
                                        class="text-danger">
                                        <i class="fa fa-exclamation-triangle"/>
                                        <field name="overdue_installment_count"/> overdue
                                    </div>
                                </div>
                            </div>
                            <div class="oe_kanban_footer">
                                <div class="o_kanban_record_bottom">
                                    <div class="oe_kanban_bottom_left">
                                        <field name="activity_ids" widget="kanban_activity"/>
                                    </div>
                                    <div class="oe_kanban_bottom_right text-muted small">
                                        Due: <field name="date_end"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ============================================================
         Loan — Search View
    ============================================================ -->
    <record id="view_cyllo_loan_search" model="ir.ui.view">
        <field name="name">cyllo.loan.search</field>
        <field name="model">cyllo.loan</field>
        <field name="arch" type="xml">
            <search string="Search Loans">
                <field name="name" string="Reference"/>
                <field name="partner_id"/>
                <field name="loan_type_id"/>
                <field name="user_id"/>
                <separator/>
                <filter string="My Loans" name="my_loans"
                    domain="[('user_id', '=', uid)]"/>
                <filter string="Loan Giving" name="giving"
                    domain="[('loan_direction', '=', 'giving')]"/>
                <filter string="Loan Taking" name="taking"
                    domain="[('loan_direction', '=', 'taking')]"/>
                <separator/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Approved" name="approved" domain="[('state', '=', 'approved')]"/>
                <filter string="Running" name="running" domain="[('state', '=', 'running')]"/>
                <filter string="Has Overdue" name="overdue"
                    domain="[('overdue_installment_count', '>', 0)]"/>
                <filter string="Closed" name="closed" domain="[('state', '=', 'closed')]"/>
                <separator/>
                <filter string="Due This Month" name="due_this_month"
                    domain="[('date_end', '&gt;=', (context_today()).strftime('%Y-%m-01')),
                              ('date_end', '&lt;=', (context_today() + relativedelta(day=31)).strftime('%Y-%m-%d'))]"/>
                <group expand="0" string="Group By">
                    <filter string="Loan Direction" name="group_direction"
                        context="{'group_by': 'loan_direction'}"/>
                    <filter string="Loan Type" name="group_type"
                        context="{'group_by': 'loan_type_id'}"/>
                    <filter string="Partner" name="group_partner"
                        context="{'group_by': 'partner_id'}"/>
                    <filter string="Status" name="group_state"
                        context="{'group_by': 'state'}"/>
                    <filter string="Start Month" name="group_start"
                        context="{'group_by': 'date_start:month'}"/>
                    <filter string="Responsible" name="group_user"
                        context="{'group_by': 'user_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ============================================================
         Window Actions
    ============================================================ -->
    <record id="action_cyllo_loan_all" model="ir.actions.act_window">
        <field name="name">All Loans</field>
        <field name="res_model">cyllo.loan</field>
        <field name="view_mode">tree,kanban,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create your first loan!</p>
        </field>
    </record>

    <record id="action_cyllo_loan_giving" model="ir.actions.act_window">
        <field name="name">Loans Given</field>
        <field name="res_model">cyllo.loan</field>
        <field name="view_mode">tree,kanban,form</field>
        <field name="domain">[('loan_direction', '=', 'giving')]</field>
        <field name="context">{'default_loan_direction': 'giving', 'search_default_giving': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No loans given yet.</p>
            <p>Record loans you have provided to partners or employees.</p>
        </field>
    </record>

    <record id="action_cyllo_loan_taking" model="ir.actions.act_window">
        <field name="name">Loans Taken</field>
        <field name="res_model">cyllo.loan</field>
        <field name="view_mode">tree,kanban,form</field>
        <field name="domain">[('loan_direction', '=', 'taking')]</field>
        <field name="context">{'default_loan_direction': 'taking', 'search_default_taking': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No loans taken yet.</p>
            <p>Record loans borrowed from banks or other lenders.</p>
        </field>
    </record>

    <record id="action_cyllo_loan_overdue" model="ir.actions.act_window">
        <field name="name">Overdue Loans</field>
        <field name="res_model">cyllo.loan</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('overdue_installment_count', '>', 0), ('state', '=', 'running')]</field>
        <field name="context">{'search_default_overdue': 1}</field>
    </record>

</odoo>
