<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================
         Loan Type — tree View
    ============================================================ -->
    <record id="view_cyllo_loan_type_tree" model="ir.ui.view">
        <field name="name">cyllo.loan.type.tree</field>
        <field name="model">cyllo.loan.type</field>
        <field name="arch" type="xml">
            <tree string="Loan Types">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="loan_direction"/>
                <field name="interest_type"/>
                <field name="default_interest_rate" string="Rate (%)"/>
                <field name="default_duration" string="Duration (M)"/>
                <field name="repayment_frequency"/>
                <field name="loan_count" string="Loans"/>
                <field name="active" optional="hide"/>
            </tree>
        </field>
    </record>

    <!-- ============================================================
         Loan Type — Form View
    ============================================================ -->
    <record id="view_cyllo_loan_type_form" model="ir.ui.view">
        <field name="name">cyllo.loan.type.form</field>
        <field name="model">cyllo.loan.type</field>
        <field name="arch" type="xml">
            <form string="Loan Type">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" type="object"
                            name="action_view_loans" icon="fa-money"
                            invisible="loan_count == 0">
                            <field name="loan_count" widget="statinfo" string="Loans"/>
                        </button>
                    </div>
                    <widget name="web_ribbon" title="Archived" bg_color="bg-danger"
                        invisible="active"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="e.g. Personal Loan"/>
                        </h1>
                    </div>
                    <group>
                        <group string="General">
                            <field name="code"/>
                            <field name="loan_direction"/>
                            <field name="repayment_frequency"/>
                            <field name="sequence"/>
                            <field name="active"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group string="Default Terms">
                            <field name="interest_type"/>
                            <field name="default_interest_rate"/>
                            <field name="default_duration"/>
                        </group>
                    </group>
                    <group string="Default Accounting">
                        <group>
                            <field name="journal_id"/>
                            <field name="loan_account_id"/>
                        </group>
                        <group>
                            <field name="interest_income_account_id"/>
                            <field name="interest_expense_account_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Terms &amp; Conditions" name="terms">
                            <field name="notes" placeholder="Loan terms and conditions..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Window Action -->
    <record id="action_cyllo_loan_type" model="ir.actions.act_window">
        <field name="name">Loan Types</field>
        <field name="res_model">cyllo.loan.type</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first loan type!
            </p>
            <p>Define loan categories like Personal, Business, Vehicle, Mortgage, etc.</p>
        </field>
    </record>

</odoo>
