<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Module Category -->
        <record id="module_category_loan_loan" model="ir.module.category">
            <field name="name">Cyllo Loan Management</field>
            <field name="sequence">200</field>
        </record>

        <!-- User Group -->
        <record id="group_loan_loan_user" model="res.groups">
            <field name="name">User</field>
            <field name="category_id" ref="module_category_loan_loan"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!-- Manager Group -->
        <record id="group_loan_loan_manager" model="res.groups">
            <field name="name">Manager</field>
            <field name="category_id" ref="module_category_loan_loan"/>
            <field name="implied_ids" eval="[(4, ref('group_loan_loan_user'))]"/>
            <field name="users"
               eval="[Command.link(ref('base.user_root')), Command.link(ref('base.user_admin'))]"/>
        </record>

        <!-- Multi-company record rule for loan.loan -->
        <record id="rule_loan_loan_company" model="ir.rule">
            <field name="name">Cyllo Loan: Company Rule</field>
            <field name="model_id" ref="model_loan_loan"/>
            <field name="domain_force">
                ['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]
            </field>
        </record>

        <!-- Multi-company record rule for loan.type -->
        <record id="rule_loan_type_company" model="ir.rule">
            <field name="name">Cyllo Loan Type: Company Rule</field>
            <field name="model_id" ref="model_loan_type"/>
            <field name="domain_force">
                ['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]
            </field>
        </record>

    </data>
</odoo>
