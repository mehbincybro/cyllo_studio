<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="cyllo_loan_type_personal" model="cyllo.loan.type">
            <field name="name">Personal Loan</field>
            <field name="code">PERSONAL</field>
            <field name="loan_direction">both</field>
            <field name="interest_type">reducing</field>
            <field name="default_interest_rate">12.0</field>
            <field name="default_duration">24</field>
            <field name="repayment_frequency">monthly</field>
            <field name="sequence">10</field>
        </record>

        <record id="cyllo_loan_type_business" model="cyllo.loan.type">
            <field name="name">Business Loan</field>
            <field name="code">BUSINESS</field>
            <field name="loan_direction">both</field>
            <field name="interest_type">reducing</field>
            <field name="default_interest_rate">10.0</field>
            <field name="default_duration">60</field>
            <field name="repayment_frequency">monthly</field>
            <field name="sequence">20</field>
        </record>

        <record id="cyllo_loan_type_vehicle" model="cyllo.loan.type">
            <field name="name">Vehicle Loan</field>
            <field name="code">VEHICLE</field>
            <field name="loan_direction">taking</field>
            <field name="interest_type">flat</field>
            <field name="default_interest_rate">8.5</field>
            <field name="default_duration">48</field>
            <field name="repayment_frequency">monthly</field>
            <field name="sequence">30</field>
        </record>

        <record id="cyllo_loan_type_mortgage" model="cyllo.loan.type">
            <field name="name">Mortgage / Property Loan</field>
            <field name="code">MORTGAGE</field>
            <field name="loan_direction">taking</field>
            <field name="interest_type">reducing</field>
            <field name="default_interest_rate">7.0</field>
            <field name="default_duration">240</field>
            <field name="repayment_frequency">monthly</field>
            <field name="sequence">40</field>
        </record>

        <record id="cyllo_loan_type_employee" model="cyllo.loan.type">
            <field name="name">Employee Loan</field>
            <field name="code">EMPLOYEE</field>
            <field name="loan_direction">giving</field>
            <field name="interest_type">flat</field>
            <field name="default_interest_rate">0.0</field>
            <field name="default_duration">12</field>
            <field name="repayment_frequency">monthly</field>
            <field name="sequence">50</field>
        </record>

        <record id="cyllo_loan_type_overdraft" model="cyllo.loan.type">
            <field name="name">Overdraft / Short-Term</field>
            <field name="code">OVERDRAFT</field>
            <field name="loan_direction">both</field>
            <field name="interest_type">flat</field>
            <field name="default_interest_rate">18.0</field>
            <field name="default_duration">3</field>
            <field name="repayment_frequency">bullet</field>
            <field name="sequence">60</field>
        </record>

    </data>
</odoo>
