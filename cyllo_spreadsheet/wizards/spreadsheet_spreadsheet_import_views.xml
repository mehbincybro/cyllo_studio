<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <!--Form view for spreadsheet import -->
    <record id="view_spreadsheet_spreadsheet_import_form" model="ir.ui.view">
        <field name="name">view.spreadsheet.spreadsheet.import.form</field>
        <field name="model">spreadsheet.spreadsheet.import</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="mode_id" widget="selection_badge"/>
                        <field name="mode" invisible="1"/>
                        <field name="import_data" invisible="1"/>
                        <field name="spreadsheet_id"
                               domain="['|', ('owner_id', '=', uid), ('contributor_ids', '=', uid)]"
                                invisible="mode not in ['add', 'add_sheet']"
                                required="mode in ['add', 'add_sheet']"
                                options="{'no_create': True}"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_insert_spreadsheet" string="OK"
                            class="btn-primary"
                            type="object"/>
                    <button string="Cancel" class="btn-default"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
    <!-- Window action for spreadsheet import -->
    <record id="action_view_spreadsheet_spreadsheet_import"
            model="ir.actions.act_window">
        <field name="name">Add Item to Spreadsheet</field>
        <field name="res_model">spreadsheet.spreadsheet.import</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
