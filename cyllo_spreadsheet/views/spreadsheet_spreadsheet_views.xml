<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <!-- Search view for spreadsheet -->
    <record id="view_spreadsheet_spreadsheet_search" model="ir.ui.view">
        <field name="name">view.spreadsheet.spreadsheet.search</field>
        <field name="model">spreadsheet.spreadsheet</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="owner_id"/>
            </search>
        </field>
    </record>
    <!-- Tree view for spreadsheet -->
    <record id="view_spreadsheet_spreadsheet_tree" model="ir.ui.view">
        <field name="name">view.spreadsheet.spreadsheet.tree</field>
        <field name="model">spreadsheet.spreadsheet</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <button name="action_open_spreadsheet" type="object"
                        string="Edit" icon="fa-pencil"/>
            </tree>
        </field>
    </record>
    <!-- Form view for spreadsheet -->
    <record id="view_spreadsheet_spreadsheet_form" model="ir.ui.view">
        <field name="name">view.spreadsheet.spreadsheet.form</field>
        <field name="model">spreadsheet.spreadsheet</field>
        <field name="arch" type="xml">
            <form>
                <header/>
                <sheet>
                    <div name="button_box" id="button_box"
                         class="oe_button_box">
                        <button name="action_open_spreadsheet" type="object"
                                string="Edit" icon="fa-pencil"/>
                    </div>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="e.g. Master Chief"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="owner_id"/>
                            <field name="contributor_ids" widget="many2many_tags"/>
                            <field name="reader_ids" widget="many2many_tags"/>
                        </group>
                        <group>

                            <field name="filename" invisible="1"/>
                            <field name="spreadsheet_data"
                                   filename="excel_file_name"/>
                             <field name="data" filename="filename"/>
                            <field name="excel_file_name" invisible="1"/>
                                                    </group>

                            <group>
                               <field name="company_id"/>
                               <field name="create_date"/>
                            </group>


                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>

            </form>
        </field>
    </record>
     <!-- This XML code defines an Odoo search view for searching and filtering spreadsheet. -->
    <record id="view_spreadsheet_spreadsheet_search" model="ir.ui.view">
        <field name="name">view.spreadsheet.spreadsheet.search</field>
        <field name="model">spreadsheet.spreadsheet</field>
        <field name="arch" type="xml">
            <search string="Spreadsheet Search">
                <field name="name" string="Name"/>
                <field name="owner_id" string="Owner"/>
                <field name="company_id" string="Company"/>
                <filter string="My requests" name="user"
                        domain="[('owner_id.id', '=', uid )]"/>
                <group expand="0" string="Group By">
                    <filter name="group_contributors" string="Contributors"
                            context="{'group_by':'contributor_ids'}"/>
                    <filter name="group_readers" string="Readers"
                            context="{'group_by':'reader_ids'}"/>
                    <filter name="group_owners" string="Owners"
                            context="{'group_by':'owner_id'}"/>
                    <filter name="group_date" string="Date"
                            context="{'group_by':'create_date'}"/>
                </group>
            </search>
        </field>
    </record>
    <!-- Window action for spreadsheet menu -->
    <record id="action_view_spreadsheet_spreadsheet" model="ir.actions.act_window">
        <field name="name">Spreadsheets</field>
        <field name="res_model">spreadsheet.spreadsheet</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{ "search_default_user":uid, }</field>
    </record>
    <!-- Client action for spreadsheet dashboard -->
    <record id="spreadsheet_dashboard_action" model="ir.actions.client">
        <field name="name">Spreadsheet</field>
        <field name="tag">spreadsheet_view</field>
        <field name="target">current</field>
    </record>
    <!-- Menu for spreadsheet -->
    <menuitem id="menu_spreadsheet"
              name="Spreadsheet" action="spreadsheet_dashboard_action"
              groups="cyllo_spreadsheet.group_cyllo_spreadsheet_group_user" sequence="16"/>
</odoo>
