<?xml version="1.0" encoding="UTF-8" ?>
<templates>
    <t t-name="cyllo_spreadsheet.ControlPanel">
        <input type="file" t-ref="fileInput" class="fileInput d-none"
               accept=".xlsx,.xls"
               t-on-change="spreadsheet.handleOnChangeUpload"/>
        <div class="d-flex w-100 align-items-center doc_btn_container justify-content-between">
            <div>
                <ul class="navbar-nav flex-row flex-wrap gap-3">
                    <li class="nav-item" t-on-click="spreadsheet.handleUpload">
                        <div class="cy-navitem-list cursor-pointer nav-item-btn-upload-cy"
                             data-hotkey="a">
                            <i class="ri-upload-line on_upload_doc"/>
                            <span>Upload</span>
                        </div>
                    </li>
                    <li class="nav-item" t-on-click="spreadsheet.createNew">
                        <div class="cy-navitem-list cursor-pointer"
                             data-hotkey="a">
                            <i class="ri-file-add-line"/>
                            <span>New</span>
                        </div>
                    </li>
                </ul>
            </div>
        </div>
    </t>
</templates>