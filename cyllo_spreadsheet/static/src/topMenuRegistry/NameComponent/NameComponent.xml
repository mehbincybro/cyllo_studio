<?xml version="1.0" encoding="UTF-8" ?>
<templates>
    <t t-name="NameComponent">
        <div t-ref="root" class="spreadsheet-name-span">
            <div t-if="state.showInput" class="input-group">
                <input t-model="state.name" type="text" class="form-control p-0" placeholder="Name"/>
            </div>
            <div t-on-click.stop="handleOnClickSpan" t-else="" class="cursor-pointer">
                <div class="spreadsheet_name" t-out="state.name"/>
            </div>
        </div>
    </t>
</templates>