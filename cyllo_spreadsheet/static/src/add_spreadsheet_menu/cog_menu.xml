<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="cyllo_spreadsheet.SpreadsheetCogMenu" owl="1">
        <!--Added spreadsheet menu item inside the cog menu -->
        <Dropdown togglerClass="'opacity-trigger-hover'">
            <t t-set-slot="toggler">
                <i class="fa fa-fw fa-table me-1"/>Spreadsheet
            </t>
            <AddMenuSpreadsheet/>
            <AddListSpreadsheet t-if="env.config.viewType === 'list'"/>
        </Dropdown>
    </t>
    <t t-name="cyllo_spreadsheet.AddMenuSpreadsheet" owl="1">
        <!--Added link menu item inside cog menu-->
        <DropdownItem class="'o_insert_action_spreadsheet_menu'"
                      onSelected.bind="linkToSpreadsheet"
                      parentClosingMode="'none'">
            <i class="fa fa-fw fa-link me-1"/>Link menu in spreadsheet
        </DropdownItem>
    </t>
    <t t-name="cyllo_spreadsheet.AddListSpreadsheet" owl="1">
        <!--Added insert list menu item inside cog menu-->
        <DropdownItem class="'o_insert_action_spreadsheet_menu'"
                      onSelected.bind="linkToSpreadsheet"
                      parentClosingMode="'none'">
             <i class="fa fa-fw fa-align-justify me-1"/>Insert list in
            spreadsheet
        </DropdownItem>
    </t>
</templates>
