<?xml version="1.0" encoding="UTF-8" ?>
<templates>
    <t t-name="SheetListRenderer" t-inherit="web.ListRenderer" t-inherit-mode="primary">
        <xpath expr="//th[hasclass('o_list_record_selector')]" position="after">
            <th/>
        </xpath>
    </t>
    <t t-name="SheetListRenderer.RecordRaw" t-inherit="web.ListRenderer.RecordRow" t-inherit-mode="primary">
        <xpath expr="//td[hasclass('o_list_record_selector')]" position="after">
            <td >
                <img src="cyllo_documents/static/images/xls.png" alt="Image Description" style="width: 20px; height: 20px;" />
            </td>
        </xpath>
    </t>
</templates>