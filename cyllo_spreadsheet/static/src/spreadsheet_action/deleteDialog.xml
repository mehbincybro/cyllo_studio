<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <t t-name="cyllo_spreadsheet.DeleteDialog">
        <Dialog size="'md'" title="props.title">
            <p class="mx-3 mb-3"><t t-esc="props.body"/></p>
            <t t-set-slot="footer">
                <t t-set-slot="footer">
                    <button class="btn btn-primary" t-on-click="_onConfirm">Confirm</button>
                    <button class="btn btn-secondary" t-on-click="_onClose">
                    Discard
                    </button>
                </t>
            </t>
        </Dialog>
    </t>
</templates>
