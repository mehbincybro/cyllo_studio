<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <t t-name="SpreadSheetView" owl="1">
    <div class="cy-sheet__recents" t-ref="spreadsheet_root">
        <div class="cy-sheet__header">
            <h1 class="cy-sheet__h1">Recents</h1>
            <div class="cy-sheet__actions">
                <button class="cy-edit__btn btn btn-secondary select_document"
                        type="button" t-on-click="selectSheet">
                    <i class="ri-checkbox-line"/>
                   Select
                </button>
                <button t-if="state.selectedSheets.length" class="btn btn-secondary cy-edit__btn "
                        type="button" t-on-click="onDeleteSheet">
                    <i class="ri-delete-bin-6-line"/>
                   Delete
                </button>
                <button t-if="state.selectedSheets.length" class="btn btn-secondary cy-edit__btn "
                        type="button" t-on-click="onDuplicateSheet">
                    <i class="ri-file-copy-line"/>
                   Duplicate
                </button>
                <button t-if="state.selectedSheets.length" class="btn btn-secondary cy-edit__btn "
                        type="button" t-on-click="onShareMultipleSheet">
                    <i class="ri-share-line"/>
                   Share
                </button>
                <button class="btn btn-secondary cy-edit__btn btn_cancel" type="button"
                        style="display:none;"
                    t-on-click="onCancelSelect"><i class="ri-close-circle-line"/>
                   Cancel
                </button>
                <div class="cy-sheet__search">
                    <input type="search" class="cy-sheet__search-input"
                        placeholder="Search for a sheet"
                    t-on-input="(event) => this.onSearchSheet(event.target.value)"/>
                    <i class="ri-search-line cy-sheet__search-icon"/>
                </div>
                <input type="file" id="fileInput" class="fileInput cy-btn cy-btn--primary"
                    style="display: none;"
                    t-on-change="uploadFile" accept=".xlsx"/>
                <button class="cy-btn cy-btn--primary upload_sheet" onclick="$('#fileInput').click()" data-hotkey="a">
                    <i class="ri-upload-2-line"/>Upload
                </button>
                <button class="cy-btn cy-btn--primary upload_sheet" t-on-click="createNewSheet">
                    New
                </button>
                <button t-if="state.viewType == 'list'" class="btn btn-secondary cy-sheet__table-btn show cy-view-btn" type="button"
                    t-on-click="() => this.onToggleView('grid')">
                    <i class="ri-layout-grid-fill"/>
                </button>
                <button t-if="state.viewType == 'grid'" class="btn btn-secondary cy-sheet__table-btn show cy-view-btn" type="button"
                    t-on-click="() => this.onToggleView('list')">
                    <i class="ri-list-check"/>
                </button>
            </div>
        </div>
        <t t-if="state.sheets.length">
            <div class="cy-sheet__table-container" t-if="state.viewType=='list'">
                <table class="cy-sheet__table" >
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Owner</th>
                            <th>Last Edited By</th>
                            <th colspan="2">Create Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="state.sheets" t-as="sheet" t-key="sheet.id">
                            <tr class="cursor-pointer" t-on-click="(event) => this.onClickSheet(event,sheet)">
                                <td>
                                    <div class="cy-sheet__name">
                                        <span class="cy-sheet__icon"/>
                                        <t t-esc="sheet.name"/>
                                    </div>
                                </td>
                                <td><t t-esc="sheet.owner_id[1]"/></td>
                                <td><t t-esc="sheet.write_uid[1]"/></td>
                                <td><t t-esc="sheet.create_date"/></td>
                                <td>
                                    <div class="dropdown cy-sheet-dropdown-btn">
                                        <Dropdown>
                                            <t t-set-slot="toggler">
                                                <i class="ri-more-2-fill"/>
                                            </t>
                                            <DropdownItem onSelected.bind="() => this.shareSheet(sheet)">
                                                Share</DropdownItem>
                                            <DropdownItem onSelected.bind="() => this.onDeleteSheet(sheet)">
                                                Delete</DropdownItem>
                                            <DropdownItem onSelected.bind="() => this.onDuplicateSheet(sheet)">
                                                Duplicate</DropdownItem>
                                        </Dropdown>
                                    </div>
                                </td>
                            </tr>
                        </t>
                    </tbody>
                </table>
            </div>
            <div t-else="" class="col-md-12 col-lg-12 cy-sheet__container">
                <div class="grid-container">
                    <t t-foreach="state.sheets" t-as="sheet" t-key="sheet.id">
                        <div class="cy-grid-item cursor-pointer" t-on-click="(event) => this.onClickSheet(event,sheet)">
                            <div class="cyllo-sheet--file">
                                <img t-if="sheet.image_1920" class="card-img-top"
                                 t-attf-src="/web/image/spreadsheet.spreadsheet/{{sheet.id}}/image_1920" alt="Card image cap" />
                                <span t-else="" class="cy-sheet__icon cy-sheet__grid-icon"/>
                            </div>
                            <div class="cyllo-sheet--detail">
                                <div>
                                    <div class="d-flex align-items-center gap-2">
                                        <div>
                                            <img src="cyllo_spreadsheet/static/src/img/sheet-icon_.svg"
                                                 alt="img" style="width:20px;"/>
                                        </div>
                                        <div class="cy-sheet-name-div" t-att-title="sheet.name">
                                            <span class="cyllo-sheet_name"><t t-esc="sheet.name"/></span>
                                            </div>
                                    </div>
                                        <span class="cyllo-sheet_owner mt-1"><t t-esc="sheet.owner_id[1]"/></span>
                                </div>
                                <div class="dropdown cy-sheet-grid-dropdown-btn cy-sheet-dropdown-btn">
                                    <Dropdown>
                                        <t t-set-slot="toggler">
                                            <i class="ri-more-2-fill"/>
                                        </t>
                                        <DropdownItem onSelected.bind="() => this.shareSheet(sheet)">
                                            Share</DropdownItem>
                                        <DropdownItem onSelected.bind="() => this.onDeleteSheet(sheet)">
                                            Delete</DropdownItem>
                                        <DropdownItem onSelected.bind="() => this.onDuplicateSheet(sheet)">
                                            Duplicate</DropdownItem>
                                    </Dropdown>
                                </div>
                            </div>
                            <span class="cyllo-sheet__date"><t t-esc="sheet.create_date"/></span>
                        </div>
                    </t>
                </div>
                </div>
            </t>
            <t t-else="">
                <div class="d-flex align-items-center justify-content-center flex-column cy-no-sheet-main">
                    <div>
                        <i class="ri-close-circle-line cy-no-sheet-icon"/>
                    </div>
                    <h1 class="cy-no-sheet_head">No Sheets Uploaded</h1>
                    <p class="cy-empty_text">Upload your sheets</p>
                </div>
            </t>
        </div>
    </t>
</templates>

