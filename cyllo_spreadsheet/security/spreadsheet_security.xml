<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="ir_module_category_cyllo_spreadsheet_access"
            model="ir.module.category">
        <field name="name">Cyllo Spreadsheet Access</field>
        <field name="description">Category for Cyllo Spreadsheet module</field>
        <field name="sequence">35</field>
    </record>

    <record id="group_cyllo_spreadsheet_write_user" model="res.groups">
        <field name="name">Spreadsheet Write/Read User</field>
        <field name="category_id"
               ref="cyllo_spreadsheet.ir_module_category_cyllo_spreadsheet_access"/>
        <field name="implied_ids"
               eval="[Command.link(ref('base.group_user'))]"/>
    </record>

    <record id="group_cyllo_spreadsheet_admin" model="res.groups">
        <field name="name">Admin</field>
        <field name="category_id"
               ref="cyllo_spreadsheet.ir_module_category_cyllo_spreadsheet_access"/>
        <field name="implied_ids"
               eval="[Command.link(ref('group_cyllo_spreadsheet_write_user'))]"/>
        <field name="users"
               eval="[Command.link(ref('base.user_root')), Command.link(ref('base.user_admin'))]"/>
    </record>

        <!--Record Rule  for Admin on Spreadsheet View-->
    <record id="rule_spreadsheet_admin" model="ir.rule">
        <field name="name">View All Spreadsheet</field>
        <field name="model_id" ref="model_spreadsheet_sheet"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups"
               eval="[Command.link(ref('cyllo_spreadsheet.group_cyllo_spreadsheet_admin'))]"/>
    </record>
    <!--Record Rule  for User on Spreadsheet View-->
    <record id="rule_spreadsheet_user" model="ir.rule">
        <field name="name">Spreadsheet User</field>
        <field name="model_id" ref="model_spreadsheet_sheet"/>
        <field name="domain_force">['|', ('user_read_ids', 'in', user.id),
            ('user_write_ids', 'in', user.id)]
        </field>
        <field name="groups"
               eval="[Command.link(ref('cyllo_spreadsheet.group_cyllo_spreadsheet_write_user'))]"/>
    </record>
    <!-- Record Rule: Multi-Company Restriction for Spreadsheet -->
    <record id="rule_spreadsheet_multi_company" model="ir.rule">
        <field name="name">Spreadsheet Multi-Company</field>
        <field name="model_id" ref="model_spreadsheet_sheet"/>
        <field name="domain_force">[('company_id', 'in', company_ids +
            [False])]
        </field>
    </record>

</odoo>