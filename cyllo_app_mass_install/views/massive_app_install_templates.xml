<?xml version="1.0" encoding="UTF-8" ?>
<odoo noupdate="1">
    <!-- Client action for showing massive_app_install component-->
    <record id="action_first_time" model="ir.actions.client">
        <field name="name">Initial Setup</field>
        <field name="tag">massive_app_install</field>
        <field name="target">current</field>
    </record>
<!--    Menu item with action as the action_first_time-->
    <menuitem id="menu_action_first_time"
              name="Action First Time"
              sequence="-1000000"
              action="action_first_time"/>
</odoo>
