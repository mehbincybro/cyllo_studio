<?xml version="1.0" encoding="UTF-8"?>
<templates>
    <!-- Template for individual apps -->
    <t t-name="cyllo_app_mass_install.apps" owl="1">
        <div class="cy-app-install-demo-apps__label "
             t-att-app-id="this.props.app_data.id"
             t-on-click="() => this.select_app(this.props.app_data)"
             t-att-class="{ 'cy_app_install_selected': this.props.selected_apps and Object.values(this.props.selected_apps).includes(this.props.app_data.id)}">
            <div>
                <img class="cy-app-install-demo-apps__icon-container"
                     t-att-src="this.props.app_data.icon"/>
            </div>
            <t t-esc="this.props.app_data.shortdesc"/>
        </div>
    </t>
</templates>
