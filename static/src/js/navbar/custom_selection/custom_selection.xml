<?xml version="1.0" encoding="UTF-8"?>
<templates>
    <t t-name="cyllo_studio.CustomSelection">
        <div>
            <div class="cy-input cursor-pointer" t-on-click="()=> this.setShowDropdown()">
                <label t-if="!state.selectedOption" style=" display: block; margin: 1px ">Select an
                    option
                </label>
                <div t-elif="state.selectedOption"
                    class="d-flex justify-content-between align-items-center">
                    <div>
                        <span t-esc="state.selectedOption.label" />
                    </div>
                    <div>
                        <div
                            t-attf-style="background-color: #{state.selectedOption.color}; width:20px; height:20px;" />
                    </div>
                </div>
            </div>


            <div t-if="state.showDropdown" class="custom_selection_dropdown">
                <t t-foreach="options" t-as="option" t-key="option_index">
                    <div t-on-click="() => this.handleOptionClick(option)"
                        class="p-1 cursor-pointer cy-custom-selection-drop">
                        <div class="d-flex justify-content-between align-items-center p-2">
                            <div>
                                <span t-esc="option.label" />
                            </div>
                            <div>
                                <div
                                    t-attf-style="background-color: #{option.color}; width:20px; height:20px;" />
                            </div>
                        </div>

                    </div>
                </t>
            </div>

        </div>
    </t>
</templates>