<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="cyllo_studio.SelectCreateDialog" t-inherit="web.SelectCreateDialog" t-inherit-mode="primary">
        <xpath expr="//Dialog" position="attributes">
            <attribute name="size">'xl'</attribute>
        </xpath>
        <xpath expr="//button[hasclass('o_form_button_cancel')]" position="before">
            <button t-if="state.hasFolded" class="btn btn-primary me-2" t-on-click="handleUnfold">Unfold All</button>
        </xpath>
    </t>
</templates>