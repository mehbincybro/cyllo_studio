<?xml version="1.0" encoding="UTF-8"?>
<templates>
    <t t-name="cyllo_studio.PivotOverall">
        <div class="cy-pivot-panel">

            <!-- Toggles section -->
            <div class="cy-pivot-section">
                <div class="cy-pivot-toggle-row">
                    <span class="cy-pivot-toggle-label">Disable Link To Record</span>
                    <label class="cy-pivot-switch">
                        <input type="checkbox" t-model="props.mode.disableLinking"
                            t-on-click="(ev)=> this.props.handleView('disable_linking',!props.mode.disableLinking)" />
                        <span class="cy-pivot-slider" />
                    </label>
                </div>
                <div class="cy-pivot-toggle-row">
                    <span class="cy-pivot-toggle-label">Sticky Pivot</span>
                    <label class="cy-pivot-switch">
                        <input type="checkbox" t-model="props.mode.sticky"
                            t-on-click="(ev)=> this.props.handleView('sticky',!props.mode.sticky)" />
                        <span class="cy-pivot-slider" />
                    </label>
                </div>
                <div class="cy-pivot-toggle-row">
                    <span class="cy-pivot-toggle-label">Display Quantity</span>
                    <label class="cy-pivot-switch">
                        <input type="checkbox" t-model="props.mode.displayQuantity"
                            t-on-click="({target})=>this.updatePivot('display_quantity', target.checked)" />
                        <span class="cy-pivot-slider" />
                    </label>
                </div>
            </div>

            <!-- Column Grouping -->
            <div class="cy-pivot-section">
                <div class="cy-pivot-section-header">
                    <span class="cy-pivot-section-title">Column Grouping</span>
                    <button t-if="state.addNew" class="cy-pivot-add-btn"
                        t-on-click="()=>this.handleInputGrouping('colGroupBys')"
                        title="Add Column Grouping">
                        <i class="fa fa-plus" />
                    </button>
                </div>
                <div class="cy-pivot-items" id="columnGrouping">
                    <t t-foreach="state.colGroupBys" t-as="colGroupBys" t-key="colGroupBys_index">
                        <div class="cy-pivot-item">
                            <span t-if="colGroupBys" class="cy-pivot-item-label">
                                <t t-set="value"
                                    t-value="colGroupBys.includes(':') ? colGroupBys.split(':')[0] : colGroupBys" />
                                <t t-set="interval"
                                    t-value="colGroupBys.includes(':') ? colGroupBys.split(':')[1] : false" />
                                <t t-esc="props.activeFields[value].string" />
                                <t t-if="interval"> · <t t-esc="interval" /></t>
                            </span>
                            <Dropdown t-else="" togglerClass="'cy-pivot-select-btn'"
                                showCaret="false"
                                menuClass="'cy-pivot-dropdown-menu'">
                                <t t-set-slot="toggler">
                                    <span>Select an option</span>
                                    <i class="fa fa-chevron-down ms-1" />
                                </t>
                                <t t-foreach="Object.keys(fields)" t-as="field" t-key="field">
                                    <AccordionItem
                                        t-if="['date', 'datetime'].includes(fields[field]?.type)"
                                        description="fields[field].string">
                                        <div
                                            t-on-click="()=>this.updatePivot(fields[field].name, 'col', 'year')">
                                            <a class="dropdown-item" href="#">Year</a>
                                        </div>
                                        <div
                                            t-on-click="()=>this.updatePivot(fields[field].name, 'col', 'quarter')">
                                            <a class="dropdown-item" href="#">Quarter</a>
                                        </div>
                                        <div
                                            t-on-click="()=>this.updatePivot(fields[field].name, 'col', 'month')">
                                            <a class="dropdown-item" href="#">Month</a>
                                        </div>
                                        <div
                                            t-on-click="()=>this.updatePivot(fields[field].name, 'col', 'week')">
                                            <a class="dropdown-item" href="#">Week</a>
                                        </div>
                                        <div
                                            t-on-click="()=>this.updatePivot(fields[field].name, 'col', 'day')">
                                            <a class="dropdown-item" href="#">Day</a>
                                        </div>
                                    </AccordionItem>
                                    <DropdownItem t-else=""
                                        onSelected="()=>this.updatePivot(fields[field].name, 'col')">
                                        <span t-esc="fields[field].string" />
                                    </DropdownItem>
                                </t>
                            </Dropdown>
                            <button class="cy-pivot-delete-btn"
                                t-on-click="() => this.handleRemoveGroup('colPath', colGroupBys_index, 'colGroupBys')">
                                <i class="ri-close-line" />
                            </button>
                        </div>
                    </t>
                </div>
            </div>

            <!-- Row Grouping -->
            <div class="cy-pivot-section">
                <div class="cy-pivot-section-header">
                    <span class="cy-pivot-section-title">Row Grouping</span>
                    <button t-if="state.addNew" class="cy-pivot-add-btn"
                        t-on-click="()=>this.handleInputGrouping('rowGroupBys')"
                        title="Add Row Grouping">
                        <i class="fa fa-plus" />
                    </button>
                </div>
                <div class="cy-pivot-items" id="rowGrouping">
                    <t t-if="state.rowGroupBys">
                        <t t-foreach="state.rowGroupBys" t-as="rowGroupBys"
                            t-key="rowGroupBys_index">
                            <div class="cy-pivot-item">
                                <span t-if="rowGroupBys" class="cy-pivot-item-label">
                                    <t t-set="value"
                                        t-value="rowGroupBys.includes(':') ? rowGroupBys.split(':')[0] : rowGroupBys" />
                                    <t t-set="interval"
                                        t-value="rowGroupBys.includes(':') ? rowGroupBys.split(':')[1] : false" />
                                    <t t-esc="props.activeFields[value].string" />
                                    <t t-if="interval"> · <t t-esc="interval" /></t>
                                </span>
                                <Dropdown t-else="" togglerClass="'cy-pivot-select-btn'"
                                    showCaret="false"
                                    menuClass="'cy-pivot-dropdown-menu'">
                                    <t t-set-slot="toggler">
                                        <span>Select an option</span>
                                        <i class="fa fa-chevron-down ms-1" />
                                    </t>
                                    <t t-foreach="Object.keys(fields)" t-as="field" t-key="field">
                                        <AccordionItem
                                            t-if="['date', 'datetime'].includes(fields[field].type)"
                                            description="fields[field].string">
                                            <div
                                                t-on-click="()=>this.updatePivot(fields[field].name, 'row', 'year')">
                                                <a class="dropdown-item" href="#">Year</a>
                                            </div>
                                            <div
                                                t-on-click="()=>this.updatePivot(fields[field].name, 'row', 'quarter')">
                                                <a class="dropdown-item" href="#">Quarter</a>
                                            </div>
                                            <div
                                                t-on-click="()=>this.updatePivot(fields[field].name, 'row', 'month')">
                                                <a class="dropdown-item" href="#">Month</a>
                                            </div>
                                            <div
                                                t-on-click="()=>this.updatePivot(fields[field].name, 'row', 'week')">
                                                <a class="dropdown-item" href="#">Week</a>
                                            </div>
                                            <div
                                                t-on-click="()=>this.updatePivot(fields[field].name, 'row', 'day')">
                                                <a class="dropdown-item" href="#">Day</a>
                                            </div>
                                        </AccordionItem>
                                        <DropdownItem t-else=""
                                            onSelected="()=>this.updatePivot(fields[field].name, 'row')">
                                            <span t-esc="fields[field].string" />
                                        </DropdownItem>
                                    </t>
                                </Dropdown>
                                <button class="cy-pivot-delete-btn"
                                    t-on-click="() => this.handleRemoveGroup('rowPath', rowGroupBys_index, 'rowGroupBys')">
                                    <i class="ri-delete-bin-fill" />
                                </button>
                            </div>
                        </t>
                    </t>
                </div>
            </div>

            <!-- Measure -->
            <div class="cy-pivot-section">
                <div class="cy-pivot-section-header">
                    <span class="cy-pivot-section-title">Measure</span>
                    <button t-if="state.addNew" class="cy-pivot-add-btn"
                        t-on-click="()=>this.handleInputGrouping('activeMeasures')"
                        title="Add Measure">
                        <i class="fa fa-plus" />
                    </button>
                </div>
                <div class="cy-pivot-items" id="measure">
                    <t t-if="state.loadedActiveMeasures">
                        <t t-foreach="state.loadedActiveMeasures?.filter(m => m !== '__count')"
                            t-as="loadedActiveMeasure" t-key="loadedActiveMeasure_index">
                            <div class="cy-pivot-item">
                                <span class="cy-pivot-item-label"
                                    t-esc="props.activeFields[loadedActiveMeasure].string" />
                            </div>
                        </t>
                    </t>
                    <t t-if="state?.activeMeasures">
                        <t t-foreach="state.activeMeasures.filter(m => m !== '__count')"
                            t-as="activeMeasure" t-key="activeMeasure_index">
                            <div class="cy-pivot-item">
                                <span t-if="activeMeasure" class="cy-pivot-item-label"
                                    t-esc="props.activeFields[activeMeasure].string" />
                                <Dropdown t-else="" togglerClass="'cy-pivot-select-btn'"
                                    showCaret="false"
                                    menuClass="'cy-pivot-dropdown-menu'">
                                    <t t-set-slot="toggler">
                                        <span>Select an option</span>
                                        <i class="fa fa-chevron-down ms-1" />
                                    </t>
                                    <t
                                        t-foreach="Object.keys(props.mode?.measures).filter(field => field !== '__count' and !state.activeMeasures.includes(field))"
                                        t-as="field" t-key="field">
                                        <DropdownItem
                                            onSelected="()=>this.updatePivot(field, 'measure')"
                                            class="'w-100'">
                                            <span t-esc="props.mode.measures[field].string" />
                                        </DropdownItem>
                                    </t>
                                </Dropdown>
                                <button class="cy-pivot-delete-btn"
                                    t-on-click="(ev) => this.handleRemoveGroup('measurePath', activeMeasure_index, 'activeMeasures')">
                                    <i class="ri-delete-bin-fill" />
                                </button>
                            </div>
                        </t>
                    </t>
                </div>
            </div>

        </div>
    </t>
</templates>