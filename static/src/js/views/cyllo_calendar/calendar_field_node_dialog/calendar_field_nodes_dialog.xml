<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <t t-name="cyllo_studio.CalendarViewDialog">
        <CalendarDialogBox title="'Calendar'" header="true" footer="false">
            <div class="cy-studio-calendar_field_node_dialog">
                <div class="d-flex mx-3 justify-content-between">
                    <p class="cy-studio-modal_subtitle">
					  Update the Calendar Value
                    </p>
                    <div class="form-check form-switch mt-2">
                        <input class="form-check-input" t-model="state.showInvisible" type="checkbox" role="switch" id="flexSwitchCheckDefault"/>
                        <label class="form-check-label" for="flexSwitchCheckDefault">Show invisible field nodes</label>
                    </div>
                </div>
                <!-- @todo: class fc-event and data-event-id is needed for some widget  -->
                <span class="d-none fc-event" t-att-data-event-id="props.record.id || 'undefined'"/>
                <div class="d-flex">
                    <Record resModel="props.model.resModel" resId="props.record.id" fields="props.model.fields" activeFields="activeFields" mode="'readonly'" values="props.record.rawRecord" t-slot-scope="slot">
                        <div class="cy-field__box" t-att-class="!state.editable || 'border-0'">
                            <div class="d-flex align-items-center gap-2">
                                <i class="ri-code-box-fill cy-content-header-icon"/>
                                <h3 class="cy-content_header">Editor</h3>
                            </div>
                            <div class="my-3 cy-addable__list cy-scrollable-calendar overflow-auto" style="max-height: 60vh !important">
                                <div t-ref="fieldNodeRef">
                                    <t t-if="props.model.popoverFieldNodes" t-foreach="Object.keys(props.model.popoverFieldNodes)" t-as="fieldId" t-key="fieldId">
                                        <t t-set="fieldInfo" t-value="props.model.popoverFieldNodes[fieldId]"/>
                                        <div t-if="!isInvisible(fieldInfo, slot.record) or state.showInvisible" class="cy-drag-input_container mb-2" t-att-class="isInvisible(fieldInfo, slot.record) and state.showInvisible ? ' cy-studio-striped' : ''" t-att-cy-xpath="fieldInfo.MainPath">
                                            <button class="btn btn-secondary handle-drag cy-drag_edit-btn" type="button">
                                                <i class="ri-drag-move-line handle-drag"/>
                                            </button>
                                            <div class="w-100 cy-draginput--box p-1">
                                                <span class="cy-content-text">
                                                    <t t-esc="fieldInfo.string"/>
                                                </span>
                                            </div>
                                            <button class="cy-drag_edit-btn cy-drag_save" t-on-click="()=> this.handleEdit(fieldInfo)">
                                                <i class="ri-edit-2-fill"/>
                                            </button>
                                            <button class="cy-drag_edit-btn cy-drag_delete" t-on-click="()=>this.onDelete(fieldInfo.MainPath,fieldInfo.name)">
                                                <i class="ri-delete-bin-6-fill"/>
                                            </button>
                                        </div>
                                    </t>
                                </div>
                            </div>
                            <div class="d-flex align-items-center gap-2">
                                <button class="cy-btn-primary" t-on-click="addField">
                                    <i class="ri-add-line me-1"/>
Add Field

                                </button>
                            </div>
                        </div>
                        <div t-if="state.editable" class="cy-field__box border-start border-end-0">
                            <div class="d-flex align-items-center gap-2">
                                <i class="ri-gallery-fill cy-content-header-icon"/>
                                <h3 class="cy-content_header">Properties</h3>
                            </div>
                            <div class="my-3 overflow-auto" t-att-style="state.iconToggle ? 'min-height: 35vh; max-height: 40vh !important' : 'max-height: 40vh !important'">
                                <div class="mb-2" t-if="state.item.new">
                                    <label for="" class="cy-navbar_label">Field</label>
                                    <div class="cy-studio-custom-dropdown-dialog-calendar">
                                        <CylloStudioDropdown defaultValue="state.item.name ? state.item.name : ''" options="fields" onChange="(field)=> this.onSelectField(props.model.fields[field])" searchable="true" />
                                    </div>
                                </div>
                                <div class="w-100 d-flex">
                                    <div style="width:25%;" class="mb-2">
                                        <div class="align-items-center gap-2">
                                            <label for="" class="cy-navbar_label">Icon</label>
                                            <div class="form-control text-center d-flex cursor-pointer w-25 " style="align-items: center;height: 33px; width:100% !important;">
                                                <i class="flex-grow-1 fa " t-att-class="(state.item.options.icon ? state.item.options.icon : 'p-3') + ' fa'" t-on-click="()=>state.iconToggle = !state.iconToggle"/>
                                                <i t-if="state.item.options.icon" class="align-self-center text-danger ri-close-circle-fill ri-lg" t-on-click="()=>state.item.options.icon=''"/>
                                            </div>
                                        </div>
                                        <div class="modal-content cy-sheet_icon-selectBox position-absolute overflow-auto z-index-1 w-75" style="min-height:20vh !important; height:25vh !important; overflow: scroll !important;" t-att-class="state.iconToggle ? '':'d-none'">
                                            <div class="justify-content-between p-3 border-bottom cy-sheet_selection-box-head d-flex align-items-center">
                                                <h5 class=" cy-sheet_selection-heading-txt">Select Icon</h5>
                                                <span class="cy-icons cy-social_cmnt-closebtn cursor-pointer opacity-75-hover" t-on-click="()=>state.iconToggle = false">
                                                    <i class="ri-close-line"/>
                                                </span>
                                            </div>
                                            <div class="modal-body pt-0">
                                                <ul class="d-flex align-items-start gap-3 flex-wrap cy-selection_icon-list py-2 list-unstyled">
                                                    <li t-foreach="IconClass" t-as="icon" t-key="icon_index">
                                                        <div class="cy-icon_x`box-item cursor-pointer opacity-75-hover p-1" t-att-class="state.item.options.icon == icon ? 'bg-secondary rounded':''" t-on-click="()=> this.onSelectIcon(icon)">
                                                            <i class="cy-icons fa fa-fw" t-att-class="state.item.options.icon == icon ? 'text-primary '+icon: icon" style="color:#495057 !important"/>
                                                        </div>
                                                    </li>
                                                </ul>
                                            </div>
                                        </div>
                                    </div>
                                    <div style="width:75%;margin-left:4%;" class="mb-2">
                                        <label for="" class="cy-navbar_label">Label</label>
                                        <input class="form-control" name="label" autocomplete="off" t-model="state.item.string" t-att-placeholder="state.item.name ? props.model.fields[state.item.name].string : 'Enter a label'"/>
                                    </div>
                                </div>
                                <div class="mb-2 CalenderWidget">
                                    <label for="" class="cy-navbar_label">Widget</label>
                                    <div class="cy-studio-custom-dropdown-dialog-calendar">
                                        <CylloStudioDropdown options="Widget()" onChange="(value) => this.AddWidgetSelected(value)" defaultValue="selectedWidget" searchable="true" />
                                    </div>
                                </div>
                                <div t-if="['many2one', 'one2many', 'many2many'].includes(state.item.type)
                                          and state.avatarFields
                                          and Object.keys(state.avatarFields).length > 0" class="mb-2">
                                    <!--								<div t-if="['many2one', 'one2many', 'many2many'].includes(state.item.type)"-->
                                    <!-- class="mb-2">-->
                                    <label for="" class="cy-navbar_label">Avatar Field</label>
                                    <div class="form-control">
                                        <Dropdown togglerClass="'btn w-100 fw-normal text-start'" showCaret="true">
                                            <t t-set-slot="toggler">
                                                <span>
                                                    <t t-if="state.item.attrs.avatar_field" t-esc="state.avatarFields[state.item.attrs.avatar_field]"/>
                                                    <t t-else="">
													Select a Field
                                                    </t>
                                                </span>
                                            </t>
                                            <t t-foreach="Object.keys(state.avatarFields)" t-as="field" t-key="field">
                                                <DropdownItem onSelected="()=> this.state.item.attrs.avatar_field = field">
                                                    <span t-esc="state.avatarFields[field]"/>
                                                </DropdownItem>
                                            </t>
                                        </Dropdown>
                                    </div>
                                </div>
                                <!-- @todo:- check the functionality of commented attributes -->
                                <!--                         <div t-if="state.item.type === 'many2many'" class="mb-2">-->
                                <!--                            <label for="" class="cy-navbar_label">Write Model</label>-->
                                <!--                            <input class="form-control" t-model="state.item.attrs.write_model"/>-->
                                <!--                        </div>-->
                                <!--                        <t t-if="state.item.attrs.write_model">-->
                                <!--                            <div class="mb-2">-->
                                <!--                                <label for="" class="cy-navbar_label">Write Field</label>-->
                                <!--                                <input class="form-control" t-model="state.item.attrs.write_field"/>-->
                                <!--                            </div>-->
                                <!--                             <div class="mb-2">-->
                                <!--                                <label for="" class="cy-navbar_label">Filter Field</label>-->
                                <!--                                <input class="form-control" t-model="state.item.attrs.filter_field"/>-->
                                <!--                            </div>-->
                                <!--                        </t>-->
                                <div class="d-flex gap-2">
                                    <div class="ms-2 me-4 mb-2" t-if="!state.dateField">
                                        <input class="customCheckbox ViewCheck" type="checkbox" name="filter" id="filter" t-model="state.item.attrs.filters"/>
                                        <label class="cy-navbar_label customCheckbox-label" for="filter">Is Filter</label>
                                    </div>
                                    <div class="d-flex mb-2">
                                        <input class="customCheckbox ViewCheck" type="checkbox" name="calendar_invisible" id="calendar_invisible" t-on-click="onDomainRadioClick" t-att-checked="!['False','false', '0', null].includes(state.item.invisible)"/>
                                        <label class="cy-navbar_label customCheckbox-label" for="calendar_invisible">Invisible</label>
                                        <button class="cy-basedOn ms-2" data-attribute="invisible" t-on-click="onDomainClick" style="margin-left: 10px !important;margin-top: 0 !important;">
                                            <span>Based on</span>
                                            <span class="cy-setting-icon">
                                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                                                    <path fill="none" d="M0 0h24v24H0z"/>
                                                    <path d="M2.13127 13.6308C1.9492 12.5349 1.95521 11.434 2.13216 10.3695C3.23337 10.3963 4.22374 9.86798 4.60865 8.93871C4.99357 8.00944 4.66685 6.93557 3.86926 6.17581C4.49685 5.29798 5.27105 4.51528 6.17471 3.86911C6.9345 4.66716 8.0087 4.99416 8.93822 4.60914C9.86774 4.22412 10.3961 3.23332 10.369 2.13176C11.4649 1.94969 12.5658 1.9557 13.6303 2.13265C13.6036 3.23385 14.1319 4.22422 15.0612 4.60914C15.9904 4.99406 17.0643 4.66733 17.8241 3.86975C18.7019 4.49734 19.4846 5.27153 20.1308 6.1752C19.3327 6.93499 19.0057 8.00919 19.3907 8.93871C19.7757 9.86823 20.7665 10.3966 21.8681 10.3695C22.0502 11.4654 22.0442 12.5663 21.8672 13.6308C20.766 13.6041 19.7756 14.1324 19.3907 15.0616C19.0058 15.9909 19.3325 17.0648 20.1301 17.8245C19.5025 18.7024 18.7283 19.4851 17.8247 20.1312C17.0649 19.3332 15.9907 19.0062 15.0612 19.3912C14.1316 19.7762 13.6033 20.767 13.6303 21.8686C12.5344 22.0507 11.4335 22.0447 10.3691 21.8677C10.3958 20.7665 9.86749 19.7761 8.93822 19.3912C8.00895 19.0063 6.93508 19.333 6.17532 20.1306C5.29749 19.503 4.51479 18.7288 3.86862 17.8252C4.66667 17.0654 4.99367 15.9912 4.60865 15.0616C4.22363 14.1321 3.23284 13.6038 2.13127 13.6308ZM11.9997 15.0002C13.6565 15.0002 14.9997 13.657 14.9997 12.0002C14.9997 10.3433 13.6565 9.00018 11.9997 9.00018C10.3428 9.00018 8.99969 10.3433 8.99969 12.0002C8.99969 13.657 10.3428 15.0002 11.9997 15.0002Z"></path>
                                                </svg>
                                            </span>
                                        </button>
                                    </div>
                                </div>
                                <div class="d-flex btn_div w-100 my-3 gap-2">
                                    <button class="w-100 btn btn-secondary" t-on-click="onDiscard">Discard</button>
                                    <button class="btn btn-primary w-100" t-on-click="onSave">Save</button>
                                </div>
                            </div>
                        </div>
                        <div t-else="" class="cy-field__box o_cw_popover border-0">
                            <div class="d-flex align-items-center gap-2 mb-3">
                                <i class="ri-gallery-fill cy-content-header-icon"/>
                                <h3 class="cy-content_header">Preview</h3>
                            </div>
                            <ul class="list-group list-group-flush">
                                <li t-if="date" class="list-group-item">
                                    <i class="fa fa-fw fa-calendar text-400"/>
                                    <span class="fw-bold ms-2" t-esc="date"/>
                                    <small t-if="dateDuration != 'All day'">
                                        <b t-esc="dateDuration"/>
                                    </small>
                                </li>
                                <li t-if="time" class="list-group-item">
                                    <i class="fa fa-fw fa-clock-o text-400"/>
                                    <span class="fw-bold ms-2" t-esc="time"/>
                                    <small t-if="timeDuration">
                                        <b t-esc="`(${timeDuration})`"/>
                                    </small>
                                </li>
                            </ul>
                            <ul class="list-group list-group-flush o_cw_popover_fields_secondary" style="max-height: 60vh !important">
                                <div class="pe-none" t-foreach="Object.keys(props.model.popoverFieldNodes)" t-as="fieldId" t-key="fieldId">
                                    <t t-set="fieldInfo" t-value="props.model.popoverFieldNodes[fieldId]"/>
                                    <li t-if="!isInvisible(fieldInfo, slot.record) or state.showInvisible" class="list-group-item flex-shrink-0 d-flex flex-wrap align-items-start my-1" t-att-class="fieldInfo.attrs.class + (isInvisible(fieldInfo, slot.record) and state.showInvisible ? ' cy-studio-striped' : '')">
                                        <span class="fw-bold me-2" t-if="!fieldInfo.options.noLabel">
                                            <t t-if="fieldInfo.options.icon">
                                                <i t-attf-class="fa-fw {{fieldInfo.options.icon}} text-400"/>
                                            </t>
                                            <t t-else="">
                                                <t t-esc="fieldInfo.string"/>
                                            </t>
                                        </span>
                                        <div class="flex-grow-1">
                                            <Field name="fieldInfo.name" record="slot.record" fieldInfo="fieldInfo" type="fieldInfo.widget"/>
                                        </div>
                                    </li>
                                </div>
                            </ul>
                        </div>
                    </Record>
                </div>
            </div>
        </CalendarDialogBox>
    </t>
</templates>