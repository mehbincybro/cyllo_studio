<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
	<t t-name="cyllo_studio.CylloActivityPopover">
		<!-- inline = render in the Studio aside bar; otherwise the legacy modal. -->
		<t t-if="props.inline">
			<div class="cy-activity-aside">
				<div class="cy-tab-header">
					<div class="cy-tab-pill">
						<button class="cy-nav__link active">Activity</button>
					</div>
				</div>
				<t t-call="cyllo_studio.CylloActivityEditorBody"/>
			</div>
		</t>
		<t t-else="">
			<Dialog title="'Edit Activity Record'" footer="false">
				<t t-call="cyllo_studio.CylloActivityEditorBody"/>
			</Dialog>
		</t>
	</t>

	<t t-name="cyllo_studio.CylloActivityEditorBody">
		<div class="d-flex studio_activity" t-att-class="props.inline ? 'flex-column' : ''">

			<!-- ── Interactive Preview (always rendered — onMounted queries .cy-activity) ── -->
			<div class="cy-field__box o_cw_popover border-0">
				<div class="cy-activity-section">
					<div class="cy-activity-section-header">
						<i class="ri-gallery-fill cy-activity-header-icon"/>
						<span class="cy-activity-header-title">Interactive Preview</span>
					</div>
				</div>
				<div class="cy-activity-section cy-addable__list o_activity_view">
					<t t-set="recordValue" t-value="props.records.length - 1"/>
					<ul class="o_activity_record list-group list-group-flush o_cw_popover_fields_secondary cy-activity"
                        t-att-style="props.inline ? 'max-height: 60vh !important; width: 100%' : 'max-height: 60vh !important; width: 425px'">
						<CylloActivityRecord archInfo="props.archInfo" record="props.records[recordValue]"
                                             openRecord="props.openRecord"/>
					</ul>
				</div>
			</div>


			<!-- ── Field Customizer ── -->
			<div class="cy-field__box">

				<!-- Section header -->
				<div class="cy-activity-section">
					<div class="cy-activity-section-header">
						<i class="ri-code-box-fill cy-activity-header-icon"/>
						<span class="cy-activity-header-title">Field Customizer</span>
					</div>
				</div>

				<t t-if="state.editable">

					<!-- Widget warning -->
					<div t-if="state.widget" class="cy-activity-section cy-activity-warning-section">
						<div class="cy-activity-warning-row">
							<svg fill="#c6b8b8" width="16px" height="16px"
                                 xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
								<path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 15c-.55 0-1-.45-1-1v-4c0-.55.45-1 1-1s1 .45 1 1v4c0 .55-.45 1-1 1zm1-8h-2V7h2v2z"/>
							</svg>
							<span>The attribute won't work because it has a widget.</span>
						</div>
					</div>

					<!-- Display dropdown + Bold/Muted toggles -->
					<div class="cy-activity-section cy-activity-dropdown activity-edit-custom-dropdown"
                         t-att-style="state.widget ? 'pointer-events: none; opacity: 0.7;' : ''">
						<label class="cy-navbar_label">Display</label>
						<div class="cy-studio-custom-dropdown">
							<CylloStudioDropdown
                                    options="fieldsDisplay"
                                    defaultValue="displayValue"
                                    onChange="(value) => this.updatedFieldDisplay(value)"
                                    placeholder="'Select an attribute...'"
                                    searchable="true"
                                    width="''"
                                    maxHeight="'70px'"
							/>
						</div>
						<div class="cy-toggle-row">
							<span class="cy-toggle-label">Bold</span>
							<label class="cy-switch">
								<input type="checkbox" t-att-checked="state.attribute.bold"
                                       t-on-change="(ev)=>this.handleFieldBold(ev)"/>
								<span class="cy-slider"/>
							</label>
						</div>
						<div class="cy-toggle-row">
							<span class="cy-toggle-label">Muted</span>
							<label class="cy-switch">
								<input type="checkbox" t-att-checked="state.attribute.muted"
                                       t-on-change="(ev)=>this.handleFieldMuted(ev)"/>
								<span class="cy-slider"/>
							</label>
						</div>
					</div>

					<!-- Discard / Save / Delete -->
					<div class="cy-activity-section">
						<div class="cy-activity-action-btns">
							<button class="cy-activity-btn cy-activity-btn-discard"
                                    data-tooltip="Discard" t-on-click="onDiscard">
								<i class="ri-arrow-go-back-line"/>
								<span>Discard</span>
							</button>
							<button class="cy-activity-btn cy-activity-btn-save"
                                    data-tooltip="Save" t-on-click="onSave">
								<i class="ri-save-fill"/>
								<span>Save</span>
							</button>
							<button class="cy-activity-btn cy-activity-btn-delete"
                                    data-tooltip="Delete" t-on-click="onDelete">
								<i class="ri-delete-bin-5-fill"/>
								<span>Delete</span>
							</button>
						</div>
					</div>

				</t>
				<t t-elif="!this.state.editable">

					<!-- Field selector + Add Field -->
					<div class="cy-activity-section">
						<label class="cy-navbar_label">Field</label>
						<div class="cy-studio-custom-dropdown cy-activity-dropdown activity-add-custom-dropdown"
                             t-att-class="props.inline ? '' : 'col-10'">
							<CylloStudioDropdown
                                    options="allFields"
                                    defaultValue=""
                                    onChange="(value) => this.updatedField(value)"
                                    placeholder="'Select a field...'"
                                    searchable="true"
                                    width="''"
                                    maxHeight="'50px'"
							/>
						</div>
						<button class="cy-activity-add-btn w-100"
                                t-on-click="()=> this.addActivityField()">
							<i class="ri-add-line"/>
							Add Field
						</button>
					</div>

				</t>
			</div>

			<!-- Divider (dialog / side-by-side mode only) -->
			<div t-if="!props.inline" class="vr"/>

			
		</div>
	</t>
</templates>