<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
	<t t-name="cyllo_studio.CylloActivityRecord" t-inherit="mail.ActivityRecord">
		<xpath expr="//td" position="replace">
			<div style="padding: 0;">
				<td class="o_activity_record p-2 cursor-pointer position-relative cy-overlay"  style="background:#ffffff">
					<t t-call="{{ recordTemplate }}" t-call-context="this.getRenderingContext()"/>
				</td>
			</div>
		</xpath>
	</t>
</templates>