<?xml version="1.0" encoding="UTF-8" ?>
<templates>
    <t t-name="cyllo_studio.GraphOverall">
        <br/>
        <div class="cy-graph-container">
            <div class="cy-graph-selected d-flex align-items-center justify-content-center gap-1">
                <span t-if="this.state.activeGraphs.length > 3" t-on-click="() => this.prevPage()"
                      class="arrow-icon p-2"
                      style="color: #ffffff; cursor: pointer;">
                    <i class="ri-arrow-left-s-line" style="font-size: 16px;"/>
                </span>
                <t t-foreach="this.visibleGraphTypes" t-as="type" t-key="type">
                    <span class="cy-studio-graph-icon p-2 cy-status_bar_hover"
                          t-on-click="(event) => this.onClickGraphIcon(event, type)">
                        <i t-att-class="graphIcons[type]" t-att-style="state.displayedGraphType == type ? 'font-size: 16px;
                            color: #a4ad02;' : 'font-size: 16px; color: var(--custom-dropdown-color);'"/>
                        <div class="default_type_icon"
                             t-att-class="state.currentType == type ? 'fa fa-circle' : ''"></div>
                    </span>
                </t>
                <span t-if="this.state.activeGraphs.length > 3" t-on-click="() => this.nextPage()"
                      class="arrow-icon p-2"
                      style="color: #ffffff; cursor: pointer;">
                    <i class="ri-arrow-right-s-line" style="font-size: 16px;"/>
                </span>
            </div>
        </div>
        <div class="m-3 graph_properties cy-studio-custom-dropdown">
            <div class="dropdown-checkbox-container">
                <label class="cy-navbar_label customCheckbox-label">Default Type:</label>
                <!-- Dropdown Toggle -->
                <div t-on-click="() => this.state.options = !this.state.options"
                     class="d-flex align-items-center justify-content-between"
                     style="background: var(--custom-dropdown-bg);
                            border: 1px solid var(--custom-dropdown-border);
                            border-radius: 3px;
                            padding: 8px 0 8px 12px;
                            height: 35px;
                            cursor: pointer;">
                    <div style="display: flex; align-items: center; gap: 8px;">
                        <i t-att-class="graphIcons[state.currentType]"
                           class="mt-0"
                           style="font-size: 16px; color: var(--custom-dropdown-color);"/>
                        <span t-esc="capitalizeFirstLetter(state.currentType)"
                              style="color: var(--custom-dropdown-color);"/>
                    </div>
                    <i t-attf-class="ri-arrow-down-s-line #{state.isRotated ? 'rotated' : ''}"
                       style="color: var(--custom-dropdown-color); font-size: 18px; transition: transform 0.3s ease;"
                       t-on-click="toggleRotation"/>
                </div>
                <!-- Dropdown Menu -->
                <div t-if="state.options">
                    <div class="cy-graph-default-type o-autocomplete--dropdown-menu">
                        <div style="overflow-y: auto; max-height: 250px;">
                            <ul class="scroll-container" style="list-style: none; padding: 0; margin: 0;">
                                <t t-foreach="state.graphTypes" t-as="item" t-key="item">
                                    <li t-att-class="{
                                            'cy-dropdown-item': true,
                                            'pinned': state.currentType === item
                                        }"
                                        style="display: flex; justify-content: space-between; align-items: center; padding: 8px 10px; margin-bottom: 4px;">
                                        <div style="display: flex; align-items: center; gap: 8px;">
                                            <input type="checkbox"
                                                   t-att-checked="this.state.activeGraphs.includes(item) ? 'checked' : ''"
                                                   t-on-click="() => this.updateGraphElement({ type: 'modes', position: 'attributes', name: 'modes', item_type: item })"
                                                   t-att-id="'GT-' + item"
                                                   class="custom-round-checkbox"/>
                                            <label t-att-for="'GT-' + item"
                                                   style="cursor: pointer; color: var(--custom-dropdown-color); display: flex; align-items: center; gap: 6px;">
                                                <i t-att-class="graphIcons[item]" style="font-size: 16px;"></i>
                                                <span t-esc="capitalizeFirstLetter(item)"/>
                                            </label>
                                        </div>
                                        <t t-if="state.activeGraphs.includes(item)">
                                            <i t-attf-class="ri-pushpin-#{state.currentType === item ? 'fill' : 'line'} cy-pushpin-fill"
                                               t-on-click="() => this.updateGraphElement({ type: 'default_type', position: 'attributes', name: 'type', item_type: item })"
                                               style="font-size: 16px; cursor: pointer; margin-left: 12px;"/>
                                        </t>
                                    </li>
                                </t>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
            <div class="dropdown-checkbox-container">
                <label class="cy-navbar_label customCheckbox-label" for="sorting">Sorting:</label>
                <div class="cy-studio-custom-dropdown">
                    <CylloStudioDropdown
                            options="sortGraph"
                            onChange="(value) => this.updateGraphElement({ type: 'order', position: 'attributes', name: 'order', item_type: value })"
                            searchable="true"
                            defaultValue="state.currentOrder"
                    />
                </div>
            </div>
            <div class="checkbox-item">
                <input class="checkbox-input d-none ViewCheck" type="checkbox" t-model="state.stacked" id="stacked"
                       name="checkbox4"
                       t-on-click="() => this.updateGraphElement({ type: 'stacked', position: 'attributes', name: 'stacked', item_type: !state.stacked })"/>
                <label class="checkbox-label" for="stacked">
                    <span class="checkbox-indicator">
                        <svg width="12px" height="9px" viewbox="0 0 12 9">
                            <polyline points="1 5 4 8 11 1"></polyline>
                        </svg>
                    </span>
                    <span class="label-text">Stacked Graph</span>
                </label>
            </div>
            <div class="checkbox-item">
                <input class="checkbox-input d-none ViewCheck" type="checkbox" id="link_to_record"
                       name="checkbox4" t-model="state.link"
                       t-on-click="({target}) => this.updateGraphElement({ type: 'general', position: 'attributes', name: 'disable_linking', item_type: target.checked })"/>
                <label class="checkbox-label" for="link_to_record">
                    <span class="checkbox-indicator">
                        <svg width="12px" height="9px" viewbox="0 0 12 9">
                            <polyline points="1 5 4 8 11 1"></polyline>
                        </svg>
                    </span>
                    <span class="label-text">Disable Link To Record</span>
                </label>
            </div>
            <div class="d-flex mt-2">
                <button t-if="state.New" class="plus_input"
                        t-on-click="handleGroupBy">
                    <i class="fa fa-plus mt-0"/>
                </button>
                <label class="label-text" for="positionSelect">
                    <span>Group By:</span>
                </label>
            </div>
            <t t-foreach="state.groupBy" t-as="field"
               t-key="field_index">
                <div class="check_box_color cy-input d-flex justify-content-between">
                    <span t-if="field"
                          class="text-capitalize cy-graph-groupby-value">
                        <t t-esc="state.fields.find(f => f.name === state.groupBy[field_index].fieldName)?.string"/>
                        <t t-if="field.interval">-

                            <t t-esc="field.interval"/>
                        </t>
                    </span>
                    <i t-on-click="() => this.removeGroupBy('measure', field)"
                       class="cursor-pointer mt-0 ri-delete-bin-2-fill"/>
                </div>
            </t>
            <div t-if="!state.New" class="cy-input d-flex justify-content-between">
                <Dropdown togglerClass="'btn py-0 px-2 cy-studio-dropdown cy-select-back'" showCaret="true">
                    <t t-set-slot="toggler">
                        <span style="margin-left: -7px;">Select an option</span>
                    </t>
                    <t t-foreach="state.fields" t-as="field" t-key="field.name">
                        <t t-if="field.name">
                            <AccordionItem t-if="field.type &amp;&amp; ['date', 'datetime'].includes(field.type)"
                                           description="field?.string">
                                <div t-on-click="() => this.onGroupBySelect(field.name, 'year')">
                                    <a class="dropdown-item" href="#">Year</a>
                                </div>
                                <div t-on-click="() => this.onGroupBySelect(field.name, 'quarter')">
                                    <a class="dropdown-item" href="#">Quarter</a>
                                </div>
                                <div t-on-click="() => this.onGroupBySelect(field.name, 'month')">
                                    <a class="dropdown-item" href="#">Month</a>
                                </div>
                                <div t-on-click="() => this.onGroupBySelect(field.name, 'week')">
                                    <a class="dropdown-item" href="#">Week</a>
                                </div>
                                <div t-on-click="() => this.onGroupBySelect(field.name, 'day')">
                                    <a class="dropdown-item" href="#">Day</a>
                                </div>
                            </AccordionItem>
                            <DropdownItem onSelected="() => this.onGroupBySelect(field.name)">
                                <span t-esc="field.string || field.name"/>
                            </DropdownItem>
                        </t>
                    </t>
                </Dropdown>
                <i t-on-click="() => this.removeGroupBy('measure', field)"
                   class="mx-2 cursor-pointer ri-delete-bin-2-fill mt-0"/>
            </div>
            <div class="mb-2 checkbox-can-create graph_input_container">
                <label class="cy-navbar_label customCheckbox-label">Measure:</label>
                <div class="cy-studio-custom-dropdown">
                    <CylloStudioDropdown
                            options="measureValue"
                            onChange="(value) => this.updateGraphElement({ type: 'measure', position: 'inside', name: value, item_type: 'measure' })"
                            searchable="true"
                            defaultValue="state.measures[state.measure].string"
                    />
                </div>
            </div>
        </div>
    </t>
</templates>