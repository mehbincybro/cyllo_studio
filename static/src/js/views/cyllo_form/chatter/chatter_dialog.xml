<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <t t-name="cyllo_studio.ChatterDialog">
        <Dialog size="'md'" title="props.title" contentClass="'cy-kanban-preview-dialog'">
                <div class="title-card-kanban">
                    <p>Are you sure you want to Remove Chatter?</p>
                </div>
                    <t t-set-slot="footer">
                    <button class="btn btn-primary" t-on-click="(ev)=>this.confirm(ev)">
                        Yes, I'm sure
                    </button>
                        <button class="btn btn-secondary" t-on-click="onCancel.bind(this)">
                        Cancel
                    </button>
                </t>
        </Dialog>
    </t>
</templates>
