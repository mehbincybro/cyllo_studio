<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <t t-name="cyllo_studio.ChatterComponent">
        <div id="chatterComponent" class="position-relative" t-att-class="props.preview ? 'chatter-preview' : ''">
            <t t-if="showPlaceholder">
                <div class="cy-add-chatter-placeholder" t-on-click="onClick">
                    <div class="cy-add-chatter-inner">
                        <i class="ri-message-2-line cy-add-chatter-icon"/>
                        <span class="cy-add-chatter-label">Add Chatter Widget</span>
                    </div>
                </div>
            </t>
        </div>
    </t>
</templates>