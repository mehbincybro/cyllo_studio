            </div>
            <div>
                <div class="components-container">
                    <label>Attributes</label>
                </div>
                <div class="mb-4">
                    <div class="cy-toggle-row">
                        <span class="cy-toggle-label">Can Create</span>
                        <label class="cy-switch">
                            <input type="checkbox" t-model="props.mode.create"
                                t-on-click="(ev)=> this.props.handleView('create',!props.mode.create)"/>
                            <span class="cy-slider"/>
                        </label>
                    </div>
                    <div class="cy-toggle-row">
                        <span class="cy-toggle-label">Can Edit</span>
                        <label class="cy-switch">
                            <input type="checkbox" t-model="props.mode.edit"
                                t-on-click="(ev)=> this.props.handleView('edit',!props.mode.edit)"/>
                            <span class="cy-slider"/>
                        </label>
                    </div>
                    <div class="cy-toggle-row">
                        <span class="cy-toggle-label">Can Delete</span>
                        <label class="cy-switch">
                            <input type="checkbox" t-model="props.mode.delete"
                                t-on-click="(ev)=> this.props.handleView('delete',!props.mode.delete)"/>
                            <span class="cy-slider"/>
                        </label>
                    </div>
                    <div class="cy-toggle-row">
                        <span class="cy-toggle-label">Show Invisible Elements</span>
                        <label class="cy-switch">
                            <input type="checkbox" t-att-checked="props.showInvisible"
                                t-on-click="(ev)=>this.props.showInvisibleFields(ev)"/>
                            <span class="cy-slider"/>
                        </label>
                    </div>
                    <div class="cy-toggle-row">
                        <span class="cy-toggle-label">Statusbar Button Limit</span>
                        <label class="cy-switch">
                            <input type="checkbox" t-att-checked="state.buttonLimitEnabled"
                                t-model="state.buttonLimitEnabled"
                                t-on-click="(ev) => this.toggleButtonLimit(ev)"/>
                            <span class="cy-slider"/>
                        </label>
                    </div>
                    <div class="px-2" t-if="state.buttonLimitEnabled">
                        <label for="buttonLimitInput"
                            style="font-size: 11px;
                            color: #9aa07a;
                            margin: 0 0 6px 0;
                            text-transform: uppercase;
                            letter-spacing: 0.5px;
                            font-weight: 600;
                        ">Button
                            Limit Value
                        </label>
                        <input class="cy-input cy-input-field-align cy-studio-input-placeholder"
                            reqired="true"
                            type="number" id="buttonLimitInput" name="buttonLimitValue"
                            placeholder="Eg: 5"
                            autocomplete="off" t-model="state.buttonLimitValue"
                            t-on-change="(ev) => this.updateButtonLimitValue(ev)"
                            t-on-keyup="(ev) => this.updateButtonLimitValue(ev)" />
                    </div>

                </div>
            </div>
            <t t-if="state.deactivatedViews.length">
                <div>
                    <p
                        style="
            font-size: 11px;
            color: #9aa07a;
            margin: 0 0 6px 0;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            font-weight: 600;
        ">
                        Deactivated Studio Views
                    </p>
                    <div class="cy-studio-custom-dropdown mb-2">
                        <CylloStudioDropdown
                            t-props="{
                    options: state.deactivatedViews.map(v => ({ label: v.displayName, value: v.id })),
                    defaultValue: state.selectedDeactivatedViewId,
                    onChange: onDeactivatedViewSelect,
                    searchable: false,
                    placeholder: 'Select a view'
                }" />
                    </div>
                    <button
                        t-on-click="activateSelectedView"
                        style="
                            width: 100%;
                            background-color: #9ea700;
                            color: #fff;
                            border: 1.5px;
                            border-radius: 6px;
                            padding: 7px 0;
                            font-size: 12px;
                            font-weight: 400;
                            display: flex;
                            align-items: center;
                            justify-content: center;
                            gap: 6px;
                            cursor: pointer;
                        "
                    >
                        <i class="fa fa-check" style="font-size: 12px;" /> Activate Selected View </button>
                    <!-- Inside the deactivated views section, below the Activate button -->
                    <t t-if="state.isPreviewMode">
                        <button
                            t-on-click="cancelPreview"
                            style="
                                    width: 100%;
                                    margin-top: 6px;
                                    background-color: #7f8c8d;
                                    color: #fff;
                                    border: 1.5px solid #7f8c8d;
                                    border-radius: 6px;
                                    padding: 7px 0;
                                    font-size: 13px;
                                    font-weight: 500;
                                    display: flex;
                                    align-items: center;
                                    justify-content: center;
                                    gap: 6px;
                                    cursor: pointer;
                                "
                        >
                            <i class="fa fa-times" style="font-size: 12px;" /> Cancel Preview </button>
                    </t>
                </div>
            </t>
        </div>
    </t>
</templates>