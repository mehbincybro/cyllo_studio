<templates id="template" xml:space="preserve">
    <t t-name="cyllo_studio.StudioWrapper">
        <div t-att-class="asideProps.type  and asideProps.type != 'dialog_box' ? 'pe-3' : ''" class="d-flex p-3" style="height: 100dvh;">
            <div class="d-flex gap-2 w-100">
                <div class="cy-studio overflow-hidden">
                    <div t-if="props.info?.componentProps?.action?.tag == 'report_view'" class="cy-window-view d-flex gap-2 py-2 ps-3">
                        <t class="st-breadcrumbs" style="display: flex;">
                            <nav aria-label="st-breadcrumb">
                                <div class="st-breadcrumb">
                                    <div class="st-breadcrumb-item cy-breadcrumb-active" style="font-family:inter, sans-serif; font-size:13px;">
                                        <!-- x2many breadcrumb moved to navbar (cy-bc-trail) -->
                                        <!-- Report breadcrumb -->
                                        <t t-if="props.info?.componentProps?.action?.tag == 'report_view'">
                                            <a t-if="props.info?.componentProps?.action?.context?.parent_model" t-on-click="handleReportBack" href="#">
                                                <t t-esc="props.info?.componentProps?.action?.context?.parent_name"/>
                                                <img class="breadcrumb_image_arrow" style="height: 16px; width: 17px" src="/cyllo_base/static/src/img/cy_statusbar_arrow.svg" alt=""/>
                                            </a>
                                            <span class="breadcrumb_nav" style="color:#d3d3d3">
                                                <t t-esc="'Reports'"/>
                                            </span>
                                        </t>
                                    </div>
                                </div>
                            </nav>
                        </t>
                    </div>
                    <div class="o_action_manager d-flex position-relative">
                        <StudioMenuSideBar/>
                        <div class="d-flex flex-column" style="height: 100%; width: stretch !important">
                            <CylloNavBar t-props="props.viewProps"/>
                            <div class="d-flex justify-content-end h-100">
                                <div t-if="props.info and props.info?.componentProps?.action ||
                                props.info and props.info?.componentProps?.type == 'hierarchy' ||
                                props.info and props.info?.componentProps?.type == 'grid' ||
                                props.info?.componentProps?.type == 'form' and state.isPreviewMode" class="position-relative" style="height: 100%;">
                                    <t t-if="props.info.Component" t-component="props.info.Component" className="'o_action'" t-props="props.info.componentProps" t-key="props.info.id"/>
