                                </div>
                                <t t-elif="props.info.Component" t-component="props.info.Component" className="'o_action'" t-props="props.info.componentProps" t-key="props.info.id"/>
                                <t t-if="asideBarAvailable || state?.isAnimatingSidebar">
                                    <t t-if="!state.activity_view">
                                        <AsideBar t-props="asideProps"/>
                                    </t>
                                    <t t-if="state.activity_view and props.edit">
                                        <ActivityDialog t-props="activityProps"/>
                                    </t>
                                </t>
                            </div>
                        </div>
                    </div>
