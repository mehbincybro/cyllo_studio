                        <label for="" class="cy-navbar_label" style="font-size:.8rem">Right</label>
                        <input type="number" class="cy-input" min="0"
                            t-model="this.properties.paddingRight"
                            t-on-change="() => this.autoSave()" />
                    </div>
                    <div>
                        <label for="" class="cy-navbar_label" style="font-size:.8rem">Bottom</label>
                        <input type="number" class="cy-input" min="0"
                            t-model="this.properties.paddingBottom"
                            t-on-change="() => this.autoSave()" />
                    </div>
                </div>
            </div>
            <div class="d-flex btn_div w-100 my-3 gap-2">
                <button class="w-100 btn btn-secondary" t-on-click="() => this.closeDivSidebar()">
                    Cancel</button>
            </div>
        </div>
    </t>
</templates>