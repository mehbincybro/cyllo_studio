                                    </svg>
                                </span>
                            </span>
                        </button>
                    </div>
                </div>
                <div class="overall_container_list d-flex justify-content-between">
                    <div class="round">
                        <input type="checkbox" id="checkbox" t-on-click="handleInvisibleChange"
                            t-att-checked="['false', 'undefined', undefined].includes(state.invisible) ? null : 'checked'" />
                        <label for="checkbox">
                            <span style="margin-left: 25px;color: var(--checkbox-text-color);">
                                Invisible
                            </span>
                        </label>
                    </div>
                    <button class="cy-basedOn" data-attribute="invisible"
                        t-on-click="(ev) => this.attrDomain(ev)">
                        <span>Based on</span>
                        <span class="cy-setting-icon">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                                fill="currentColor">
                                <path fill="none" d="M0 0h24v24H0z"></path>
