            </div>
            <div t-if="sqlConstraints and sqlConstraints.length > 0" class="alert alert-info mt-2"
                style="background-color: var(--studio-bg-color); border-left: 4px solid #c0ca33;">
                <strong style="color: #c0ca33;">
                    <i class="fa fa-shield" style="color: #ffffff;"></i> Constraints </strong>
                <ul class="mt-2 mb-0" style="list-style: none; padding-left: 0;">
                    <t t-foreach="sqlConstraints" t-as="constraint" t-key="constraint.key">
                        <li
                            style="padding: 8px; margin-top: 8px; border-radius: 4px; position: relative; padding-right: 45px;"
                            class="cy-input cy-input-field-align">
                            <div style="display: block;">
                                <small
                                    style="color: #ffffff; word-wrap: break-word; overflow-wrap: break-word; display: block;">
                                    <code t-esc="constraint.definition" class="cy-navbar_label" />
                                </small>
                            </div>
                            <button class="btn btn-sm btn-link text-danger"
                                t-on-click="(ev) => this.removeConstraint(sqlConstraints.indexOf(constraint))"
                                style="padding: 4px 8px; position: absolute; top: 50%; right: 8px; transform: translateY(-50%); flex-shrink: 0; color: #c0ca33;">
                                <i class="fa fa-trash"></i>
                            </button>
                        </li>
                    </t>
                </ul>
            </div>
            <div class="d-flex btn_div w-100 my-3 gap-2">
                <button class="btn btn-primary w-100" t-on-click="createField">Save</button>
                <button t-if="props.create" class="btn btn-secondary w-100" t-on-click="cancelField">
                    Cancel</button>
                <button t-else="!props.create" class="btn btn-secondary w-100"
                    t-on-click="deleteField">Remove</button>
            </div>
        </div>
    </t>
</templates>