                            </svg>
                        </span>
                    </button>
                </div>
                <div class="overall_container_list d-flex justify-content-between">
                    <div class="round">
                        <input type="checkbox" id="checkbox-2" t-on-click="handleReadonlyChange"
                            t-att-checked="['false', 'undefined', undefined].includes(state.readonly) ? null : 'checked'" />
                        <label for="checkbox-2">
                            <span style="margin-left: 25px;color: var(--checkbox-text-color);">
                                Readonly
                            </span>
                        </label>
                    </div>
                    <button class="cy-basedOn" data-attribute="readonly"
                        t-on-click="(ev) => this.attrDomain(ev)">
                        <span>Based on</span>
                        <span class="cy-setting-icon">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                                fill="currentColor">
                                <path fill="none" d="M0 0h24v24H0z"></path>
