<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
	<t t-name="studio.CylloControlPanel">
        <div class="o_control_panel d-flex flex-column gap-3 gap-lg-1 px-3 pt-2 pb-3" t-ref="root"
             data-command-category="actions"
             t-att-style="
             !((!env.config.actionType &amp;&amp; env.config.viewType == 'list') || (env.config.actionType &amp;&amp; env.config.viewType == 'form'))
				&amp;&amp; !(env?.searchModel?.resModel == 'ir.model.access' || env?.searchModel?.resModel == 'ir.rule')
             ? 'display: none !important;' : ''">
			<t t-if="(env?.searchModel?.resModel == 'ir.model.access' || env?.searchModel?.resModel == 'ir.rule') and !props.isSearchView"
               t-slot="control-panel-cy-form-cogs"/>
            <div class="o_control_panel_main d-flex flex-wrap flex-lg-nowrap justify-content-between align-items-lg-start gap-3 flex-grow-1">
				<div class="o_control_panel_breadcrumbs d-flex align-items-center gap-1 order-0 h-lg-100">
					<!-- This div is intentionally hidden. Do not remove it, as it's used to prevent style/layout issues. -->
                    <div class="o_control_panel_main_buttons d-flex gap-1 d-empty-none d-print-none" t-ref="mainButtons"
                         t-on-keydown="onMainButtonsKeydown" style="visibility: hidden;">
						<div class="btn-group d-xl-none o_control_panel_collapsed_create">
							<t t-slot="control-panel-create-button"/>
                            <button t-att-class="{invisible: display.disableDropdown}" type="button"
                                    class="btn btn-primary dropdown-toggle dropdown-toggle-split o_control_panel_collapsed_create"
                                    data-bs-toggle="dropdown" aria-expanded="false">
								<span class="visually-hidden">Toggle Dropdown</span>
							</button>
                            <ul class="dropdown-menu o_control_panel_collapsed_create">
								<t t-slot="layout-buttons"/>
                                <t t-slot="control-panel-always-buttons"/>
							</ul>
						</div>
                        <div class="d-none d-xl-inline-flex gap-1">
							<t t-slot="control-panel-create-button"/>
                            <t t-slot="layout-buttons"/>
                            <t t-slot="control-panel-always-buttons"/>
						</div>
					</div>
                    <t t-if="(env?.searchModel?.resModel == 'ir.model.access' || env?.searchModel?.resModel == 'ir.rule') and !props.isSearchView">
						<t t-if="env.config.noBreadcrumbs">
							<section class="o_control_panel_breadcrumbs_actions d-contents">
								<t t-slot="control-panel-additional-actions"/>
                                <t t-slot="control-panel-status-indicator"/>
							</section>
						</t>
                        <t t-else="">
							<t t-slot="control-panel-breadcrumb">
								<t t-call="web.Breadcrumbs"/>
							</t>
						</t>
					</t>
                    <span class="d-none d-xl-block me-auto"/>
                    <span class="d-none d-xl-block me-auto"/>
                    <!-- Spacer -->
				</div>
                <div t-if="(env.config.actionType &amp;&amp; env.config.viewType == 'form' || !env.config.actionType &amp;&amp; env.config.viewType == 'list'
                		|| (env?.searchModel?.resModel == 'ir.model.access' || env?.searchModel?.resModel == 'ir.rule'))
                        and !props.isSearchView"
                     class="o_control_panel_actions d-empty-none d-flex align-items-center justify-content-start justify-content-lg-around order-2 order-lg-1 w-100 w-lg-auto">
					<t t-slot="layout-actions"/>
                    <t t-slot="control-panel-selection-actions"/>
				</div>

                <div class="o_control_panel_navigation d-flex flex-wrap flex-md-nowrap justify-content-end gap-3 gap-lg-1 gap-xl-3 order-1 order-lg-2 flex-grow-1">
					<div class="o_cp_pager text-nowrap " role="search">
                        <Pager t-if="shouldShowPager" t-props="pagerProps"/>
					</div>
				</div>
			</div>
		</div>
        <div t-if="this.env.config.viewType === 'kanban' and !this.env.searchModel.context.kanban_preview_mode and !props.isSearchView"
             class="p-3 d-flex">
			<Dropdown class="'mx-2'" togglerClass="'btn btn-secondary'" showCaret="true">
				<t t-set-slot="toggler">
					<span t-esc="state.scale"/>
				</t>
                <t t-foreach="[50, 100, 150, 200, 250, 300]" t-as="scaleValue" t-key="scaleValue_index">
					<DropdownItem
                            onSelected="()=> state.scale=scaleValue+'%'"
                            class="state.scale == scaleValue+'%' ? 'selected' : ''">
						<span t-esc="scaleValue+'%'" style="color:black !important;"/>
					</DropdownItem>
				</t>
			</Dropdown>
            <button t-if="env?.searchModel?.resModel != 'ir.actions.report'" class="btn btn-primary mx-2" t-on-click="handleKanbanPreview"><i class="ri-eye-fill me-1"/>Preview</button>
            <button t-if="env?.searchModel?.resModel === 'ir.actions.report'"
                    class="btn btn-primary mx-2 text-white"
                    t-on-click="handleCreateNewReport">
                <i class="ri-add-line me-1"/>New
            </button>
		</div>
	</t>
</templates>