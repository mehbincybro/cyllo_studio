<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="helpdesk_ticket_view_form_inherit_timesheet" model="ir.ui.view">
        <field name="name">helpdesk.ticket.view.form.inherit.timesheet</field>
        <field name="model">helpdesk.ticket</field>
        <field name="inherit_id" ref="cyllo_help_desk.helpdesk_ticket_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <field name="timesheet_bool" invisible="1"/>
                <page string="Timesheet" invisible="not timesheet_bool or not use_timesheet">
                    <field name="timesheet_ids"/>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
