<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!-- Adding the Purchase Digitization block in settings-->
    <record id="view_res_config_settings_form" model="ir.ui.view">
        <field name="name">view.res.config.settings.form</field>
        <field name="model">res.config.settings</field>
        <field name="priority" eval="91"/>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@name='matrix_setting_container']"
                   position="after">
                <block title="Digitization" name="cy_purchase_digitization">
                    <setting
                            help="This helps to retrieve data from pdf files and generate the field values of purchase rfq automatically or manually">
                        <field name="module_cyllo_purchase_digitization"/>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>

    <record id="view_purchase_res_config_settings_form_product_warranty" model="ir.ui.view">
        <field name="name">view.purchase.res.config.settings.form.product.warranty</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="purchase.res_config_settings_view_form_purchase"/>
        <field name="arch" type="xml">
            <xpath expr="//setting[@id='stock_packaging_purchase']" position="after">
                <setting id="enable_product_warranty_purchase"
                         help="Enable product warranty management in Purchase.">
                    <field name="module_cyllo_product_warranty"/>
                    <div class="content-group" invisible="not module_cyllo_product_warranty">
                        <div class="mt16">
                            <label for="is_extend_warranty_purchase" string="Extend Warranty"/>
                            <field name="is_extend_warranty_purchase" class="oe_inline"/>
                        </div>
                    </div>
                </setting>
            </xpath>
        </field>
    </record>
</odoo>
