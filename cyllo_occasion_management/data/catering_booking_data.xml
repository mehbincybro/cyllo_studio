<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Sequence for generating Catering Booking reference numbers -->
    <data noupdate="1">
        <record id="seq_catering_booking" model="ir.sequence">
            <field name="name">Catering Booking Sequence</field>
            <field name="code">catering.booking</field>
            <field name="prefix">CB/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>
    </data>
</odoo>
