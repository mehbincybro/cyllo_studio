<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <!-- Inherit product form to add catering-specific fields -->
    <record id="product_template_form_view_inherit_catering" model="ir.ui.view">
        <field name="name">product.template.form.inherit.catering</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='options']" position="inside">
                <span class="d-inline-block">
                    <field name="is_catering_product"/>
                    <label for="is_catering_product"/>
                </span>
            </xpath>
            <xpath expr="//field[@name='categ_id']" position="after">
                <field name="catering_food_category_ids"
                       widget="many2many_tags"
                       invisible="not is_catering_product"
                       required="is_catering_product"/>
            </xpath>
        </field>
    </record>
</odoo>
