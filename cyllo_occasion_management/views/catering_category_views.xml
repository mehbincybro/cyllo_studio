<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <!-- Tree view to list catering categories -->
    <record id="catering_category_view_tree" model="ir.ui.view">
        <field name="name">catering.category.view.tree</field>
        <field name="model">catering.category</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
            </tree>
        </field>
    </record>
    <!-- Form view to manage catering category and associated employees -->
    <record id="catering_category_view_form" model="ir.ui.view">
        <field name="name">catering.category.view.form</field>
        <field name="model">catering.category</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                    </group>
                    <notebook>
                        <page string="Employees">
                            <field name="employee_ids">
                                <tree>
                                    <field name="name"/>
                                    <field name="work_phone"/>
                                    <field name="work_email"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
    <!-- Action to open catering category records -->
    <record id="catering_category_action" model="ir.actions.act_window">
        <field name="name">Service Staff Categories</field>
        <field name="res_model">catering.category</field>
        <field name="view_mode">tree,form</field>
    </record>
    <!-- Menu to access catering category configuration -->
    <menuitem id="catering_category_menu"
              name="Service Staff Roles"
              parent="venue_booking_management_configuration_menu"
              action="catering_category_action"
              sequence="20"/>
</odoo>
