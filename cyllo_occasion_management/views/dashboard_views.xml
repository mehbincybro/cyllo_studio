<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <!--    The client action record to view the Dashboard-->
    <record id="dashboard_view_action" model="ir.actions.client">
        <field name="name">Dashboard</field>
        <field name="tag">dashboard_tags</field>
    </record>

    <!-- Submenu to open venue booking management dashboard -->
    <menuitem id="venue_booking_management_dashboard_menu" name="Dashboard"
              action="dashboard_view_action"
              parent="cyllo_occasion_management.occasion_management_menu_root"
              sequence="1"/>
</odoo>


