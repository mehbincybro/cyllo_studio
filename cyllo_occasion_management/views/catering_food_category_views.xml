<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <!-- Tree view to manage catering food categories with inline editing -->
    <record id="catering_food_category_view_tree" model="ir.ui.view">
        <field name="name">catering.food.category.view.tree</field>
        <field name="model">catering.food.category</field>
        <field name="arch" type="xml">
            <tree editable="bottom">
                <field name="name"/>
            </tree>
        </field>
    </record>
    <!-- Action to open catering food category records -->
    <record id="catering_food_category_action" model="ir.actions.act_window">
        <field name="name">Culinary Categories</field>
        <field name="res_model">catering.food.category</field>
        <field name="view_mode">tree</field>
    </record>
    <!-- Menu to access catering food category configuration -->
    <menuitem id="catering_food_category_menu"
              name="Culinary Categories"
              parent="venue_booking_management_configuration_menu"
              action="catering_food_category_action"
              sequence="22"/>
</odoo>
