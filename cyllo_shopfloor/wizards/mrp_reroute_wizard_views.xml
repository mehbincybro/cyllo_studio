<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_shopfloor_reroute_wizard_form" model="ir.ui.view">
        <field name="name">shopfloor.reroute.wizard.form</field>
        <field name="model">mrp.reroute.wizard</field>
        <field name="arch" type="xml">
            <form string="Reroute Work Order">
                <group>
                    <field name="workorder_id" options="{'no_create': True, 'no_open': True}"/>
                    <field name="workcenter_id" options="{'no_create': True, 'no_open': True}"/>
                </group>
                <footer>
                    <button name="action_reroute" string="Confirm" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>