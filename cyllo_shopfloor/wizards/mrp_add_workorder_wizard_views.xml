<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_mrp_add_workorder_wizard_form" model="ir.ui.view">
        <field name="name">mrp.add.workorder.wizard.form</field>
        <field name="model">mrp.add.workorder.wizard</field>
        <field name="arch" type="xml">
            <form string="Add Work Order">
                <group>
                    <group>
                        <field name="production_id" invisible="1"/>
                        <field name="company_id" invisible="1"/>
                        <field name="name" placeholder="e.g. Additional Assembly"/>
                        <field name="workcenter_id" options="{'no_create': True}"/>
                        <field name="duration_expected" widget="float_time" options="{'unit': 'minutes'}"/>
                        <field name="date_start"/>
                    </group>
                </group>
                <footer>
                    <button name="action_add_workorder" type="object" string="Add Work Order" class="btn-primary"
                            data-hotkey="q"/>
                    <button string="Cancel" class="btn-secondary" special="cancel" data-hotkey="z"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>