<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="cyllo_shopfloor.ShopfloorTemplate" owl="1">
        <div class="o_shopfloor_screen h-100 w-100 d-flex flex-column bg-100">

            <div class="d-flex justify-content-between align-items-center p-3 bg-white border-bottom shadow-sm">

                <h1 class="m-0 fs-3 text-dark">
                    <t t-if="!state.selectedWorkcenter">
                        Shopfloor Dashboard
                    </t>
                    <t t-elif="state.selectedWorkcenter and !state.selectedMO">
                        Workcenter: <t t-esc="state.selectedWorkcenter.name"/>
                    </t>
                    <t t-else="">
                        <t t-set="activeGroup" t-value="state.groupedWorkOrders.find(g => g.mo_id === state.selectedMO)"/>
                        <span class="text-muted fs-4 me-2">Work Orders for:</span> <t t-esc="activeGroup ? activeGroup.mo_name : ''"/>
                    </t>
                </h1>

                <div>
                    <button t-if="state.selectedMO" class="btn btn-outline-secondary me-2 fw-bold" t-on-click="clearMOSelection">
                        <i class="fa fa-arrow-left me-1"></i> Back to Orders
                    </button>
                    <button t-if="state.selectedWorkcenter" class="btn btn-secondary fw-bold" t-on-click="clearSelection">
                        <i class="fa fa-home me-1"></i> <t t-if="state.selectedMO">Home</t><t t-else="">Back to Workcenters</t>
                    </button>
                </div>
            </div>

            <div class="flex-grow-1 overflow-auto p-4">

                <t t-if="!state.selectedWorkcenter">
                    <div t-if="state.workcenters.length > 0" class="row g-3">
                        <t t-foreach="state.workcenters" t-as="workcenter" t-key="workcenter.id">
                            <div class="col-md-4 col-lg-3">

                                <div t-attf-class="card h-100 shadow-sm border #{workcenter.working_state == 'blocked' ? 'border-danger border-2 bg-danger bg-opacity-10' : 'border-0'}"
                                     t-on-click="() => this.selectWorkcenter(workcenter)"
                                     style="cursor: pointer;">

                                    <div class="card-body d-flex flex-column">
                                        <div class="d-flex justify-content-between align-items-start mb-auto">
                                            <h5 class="card-title text-primary fw-bold mb-0">
                                                <t t-esc="workcenter.name"/>
                                            </h5>
                                        </div>

                                        <div class="mt-4 text-end">
                                            <button t-if="workcenter.working_state == 'blocked'"
                                                    class="btn btn-sm btn-danger fw-bold"
                                                    t-on-click="(ev) => this.unblockWorkcenter(workcenter.id, ev)">
                                                <i class="fa fa-unlock me-1"></i>
                                            </button>
                                            <button t-else=""
                                                    class="btn btn-sm btn-outline-danger fw-bold"
                                                    t-on-click="(ev) => this.blockWorkcenter(workcenter.id, ev)">
                                                <i class="fa fa-lock me-1"></i>
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </div>
                </t>

                <t t-else="">
                    <div t-if="state.groupedWorkOrders.length > 0" class="w-100">

                        <t t-if="!state.selectedMO">
                            <div class="row g-3">
                                <t t-foreach="state.groupedWorkOrders" t-as="group" t-key="group.mo_id">
                                    <div class="col-md-6 col-lg-4 col-xl-3">
                                        <div class="card h-100 border shadow-sm" style="cursor: pointer;" t-on-click="() => this.selectMO(group.mo_id)">

                                            <div class="card-body p-3 bg-white">
                                                <div class="d-flex justify-content-between align-items-start mb-2">
                                                    <h6 class="fw-bold text-dark mb-0 text-truncate pe-2">
                                                        <t t-esc="group.mo_name"/>
                                                    </h6>
                                                    <span class="badge rounded-pill border px-2 py-1" style="font-size: 0.75rem;"
                                                          t-attf-class="#{['confirmed', 'progress'].includes(group.mo_state || '') ? 'border-info text-info' : 'border-success text-success'}">
                                                        <t t-esc="group.mo_state ? group.mo_state.toUpperCase() : 'DRAFT'"/>
                                                    </span>
                                                </div>

                                                <div class="d-flex justify-content-between align-items-end mt-2">
                                                    <span class="text-secondary small text-truncate pe-2"><t t-esc="group.product_name"/></span>
                                                    <span class="fw-bold text-dark small text-nowrap"><t t-esc="group.qty"/> Unit(s)</span>
                                                </div>
                                            </div>

                                            <div class="card-footer bg-light p-0 border-top">
                                                <ul class="list-group list-group-flush">
                                                    <t t-foreach="group.workOrders" t-as="wo" t-key="wo.id">
                                                        <li class="list-group-item p-2 border-0 border-bottom d-flex align-items-center bg-transparent">
                                                            <span class="badge bg-secondary bg-opacity-10 text-dark border me-2 px-2 py-1 rounded text-truncate" style="max-width: 90px; font-size: 0.7rem;">
                                                                <t t-esc="state.selectedWorkcenter.name"/>
                                                            </span>
                                                            <span class="fw-bold text-dark small text-truncate"><t t-esc="wo.name"/></span>
                                                        </li>
                                                    </t>
                                                </ul>
                                            </div>

                                        </div>
                                    </div>
                                </t>
                            </div>
                        </t>

                        <t t-else="">
                            <t t-set="activeGroup" t-value="state.groupedWorkOrders.find(g => g.mo_id === state.selectedMO)"/>

                            <div t-if="activeGroup" class="row g-3">
                                <t t-foreach="activeGroup.workOrders" t-as="wo" t-key="wo.id">
                                    <div class="col-md-6 col-lg-4 col-xl-3">

                                        <div t-attf-class="card h-100 border shadow-sm #{state.selectedWorkcenter.working_state == 'blocked' ? 'border-danger border-2' : (wo.is_user_working ? 'border-success border-2' : '')}">
                                            <div class="card-body d-flex flex-column p-3 bg-white">

                                                <div class="d-flex justify-content-between align-items-start mb-2">

                                                    <h6 class="card-title fw-bold text-dark mb-0 pe-2" style="font-size: 0.95rem; line-height: 1.4;" t-att-title="wo.name">
                                                        <t t-esc="wo.name"/>
                                                    </h6>

                                                    <div class="d-flex flex-column align-items-end" style="min-width: 85px;">
                                                        <span t-attf-class="badge w-100 py-1 mb-1 rounded-pill #{state.selectedWorkcenter.working_state == 'blocked' ? 'bg-danger' : (wo.state == 'progress' ? 'bg-info text-dark' : (wo.state == 'done' ? 'bg-success' : 'bg-secondary'))}">
                                                            <t t-if="state.selectedWorkcenter.working_state == 'blocked'">BLOCKED</t>
                                                            <t t-else=""><t t-esc="wo.state ? wo.state.toUpperCase() : 'PENDING'"/></t>
                                                        </span>

                                                        <span class="badge bg-light text-dark border font-monospace w-100 py-1 shadow-sm" style="font-size: 0.85rem;">
                                                            <t t-esc="this.formatDuration(wo.display_duration)"/>
                                                        </span>
                                                    </div>
                                                </div>

                                                <div class="flex-grow-1"></div>

                                                <div class="btn-group w-100 shadow-sm mt-3" role="group">

                                                    <t t-if="state.selectedWorkcenter.working_state == 'blocked'">
                                                        <button class="btn btn-outline-danger fw-bold disabled py-2" style="opacity: 0.8;">
                                                            <i class="fa fa-lock me-2"></i> Workcenter Blocked
                                                        </button>
                                                    </t>

                                                    <t t-else="">
                                                        <t t-if="wo.state != 'done'">
                                                            <button t-if="!wo.is_user_working"
                                                                    class="btn btn-sm btn-success fw-bold py-2"
                                                                    t-on-click="() => this.startWorkOrder(wo.id)">
                                                                <i class="fa fa-play me-1"></i>
                                                                <t t-if="wo.display_duration > 0">Resume</t>
                                                                <t t-else="">Start</t>
                                                            </button>

                                                            <t t-if="wo.is_user_working">
                                                                <button class="btn btn-sm btn-warning fw-bold text-dark py-2"
                                                                        title="Pause"
                                                                        t-on-click="() => this.pauseWorkOrder(wo.id)">
                                                                    <i class="fa fa-pause me-1"></i> Pause
                                                                </button>
                                                                <button class="btn btn-sm btn-primary fw-bold py-2"
                                                                        title="Done"
                                                                        t-on-click="() => this.finishWorkOrder(wo.id)">
                                                                    <i class="fa fa-check me-1"></i> Done
                                                                </button>
                                                            </t>
                                                        </t>

                                                        <button t-if="wo.state == 'done'" class="btn btn-sm btn-success fw-bold disabled py-2">
                                                            <i class="fa fa-check-circle me-1"></i> Completed
                                                        </button>
                                                    </t>

                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </t>
                            </div>
                        </t>

                    </div>

                    <div t-else="" class="alert alert-warning">
                        No active work orders found for this workcenter.
                    </div>
                </t>

            </div>
        </div>
    </t>

</templates>