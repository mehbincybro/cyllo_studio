<?xml version="1.0" encoding="UTF-8" ?>
<odoo noupdate="1">
    <!-- Sequence number for employee payslip  -->
    <record id="ir_sequence_employee_payslip" model="ir.sequence">
        <field name="name">Employee Payslip</field>
        <field name="code">employee.payslip</field>
        <field name="active">TRUE</field>
        <field name="prefix">SL</field>
        <field name="padding">4</field>
        <field name="number_next">1</field>
        <field name="number_increment">1</field>
    </record>
    <!-- Sequence number for employee resignation  -->
    <record id="ir_sequence_employee_resignation" model="ir.sequence">
        <field name="name">Employee Resignation</field>
        <field name="code">employee.resignation</field>
        <field name="active">TRUE</field>
        <field name="prefix">RES</field>
        <field name="padding">4</field>
        <field name="number_next">1</field>
        <field name="number_increment">1</field>
    </record>
    <!-- Sequence number for gratuity settlement  -->
    <record id="ir_sequence_employee_gratuity" model="ir.sequence">
        <field name="name">Employee Gratuity</field>
        <field name="code">gratuity.settlement</field>
        <field name="active">TRUE</field>
        <field name="prefix">GR</field>
        <field name="padding">4</field>
        <field name="number_next">1</field>
        <field name="number_increment">1</field>
    </record>
</odoo>