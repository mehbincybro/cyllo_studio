<?xml version="1.0" encoding="UTF-8" ?>
<odoo noupdate="1">
    <!-- To check the employees notice period is over, if yes neet to hide the employee-->
    <record id="ir_cron_archive_when_notice_period_is_over" model="ir.cron">
        <field name="name">Archive When Notice Period is Over</field>
        <field name="model_id" ref="cyllo_payroll_management.model_hr_employee"/>
        <field name="type">ir.actions.server</field>
        <field name="state">code</field>
        <field name="code">model.update_employee_state()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
    </record>
</odoo>