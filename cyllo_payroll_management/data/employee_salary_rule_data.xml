    <record id="employee_salary_rule_attachment_of_salary" model="employee.salary.rule">
        <field name="name">Attachment of Salary</field>
        <field name="sequence" eval="1"/>
        <field name="code">ATTACH_SALARY</field>
        <field name="category_id" ref="cyllo_payroll_management.employee_salary_rule_category_deduction"/>
        <field name="condition_select">python</field>
        <field name="condition_python">result = inputs.ATTACH_SALARY</field>
        <field name="amount_select">code</field>
        <field name="amount_python_compute">result = -inputs.ATTACH_SALARY</field>
    </record>
    <record id="employee_salary_rule_child_support" model="employee.salary.rule">
        <field name="name">Child Support</field>
        <field name="sequence" eval="1"/>
        <field name="code">CHILD_SUPPORT</field>
        <field name="category_id" ref="cyllo_payroll_management.employee_salary_rule_category_deduction"/>
        <field name="condition_select">python</field>
        <field name="condition_python">result = inputs.CHILD_SUPPORT</field>
        <field name="amount_select">code</field>
        <field name="amount_python_compute">result = -inputs.CHILD_SUPPORT</field>
    </record>
    <record id="employee_salary_rule_assignment_of_salary" model="employee.salary.rule">
