    </record>
    <record id="employee_salary_rule_gratuity_settlement" model="employee.salary.rule">
        <field name="name">Gratuity Settlement</field>
        <field name="sequence" eval="1"/>
        <field name="code">GRATUITY</field>
        <field name="category_id" ref="cyllo_payroll_management.employee_salary_rule_category_gratuity_config"/>
        <field name="condition_select">python</field>
        <field name="condition_python">result = payslip.gratuity_settlement_id</field>
        <field name="amount_select">code</field>
        <field name="amount_python_compute">result = payslip.gratuity_settlement_id.gratuity_amount</field>
    </record>
</odoo>