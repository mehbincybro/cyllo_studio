<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <!-- Data for employee salary rules-->
    <record id="employee_salary_rule_basic_salary" model="employee.salary.rule">
        <field name="name">Basic Salary</field>
        <field name="code">BASIC</field>
        <field name="category_id" ref="cyllo_payroll_management.employee_salary_rule_category_basic"/>
        <field name="condition_select">none</field>
        <field name="amount_select">code</field>
        <field name="amount_python_compute">
total_amount = payslip.total_amount
wage = contract.wage
if total_amount:
    result = total_amount
else:
    result = wage
        </field>
    </record>
    <!-- Gross salary rule -->
    <record id="employee_salary_rule_gross" model="employee.salary.rule">
        <field name="name">Gross</field>
        <field name="code">GROSS</field>
        <field name="sequence">100</field>
        <field name="category_id" ref="cyllo_payroll_management.employee_salary_rule_category_gross"/>
        <field name="condition_select">none</field>
        <field name="amount_select">code</field>
        <field name="amount_python_compute">result = categories.BASIC + categories.ALW</field>
    </record>
    <!-- Net salary rule -->
    <record id="employee_salary_rule_net_salary" model="employee.salary.rule">
        <field name="name">Net Salary</field>
        <field name="code">NET</field>
        <field name="sequence">500</field>
        <field name="category_id" ref="cyllo_payroll_management.employee_salary_rule_category_net"/>
        <field name="condition_select">none</field>
        <field name="amount_select">code</field>
        <field name="amount_python_compute">result = categories.BASIC + categories.ALW + categories.DED + categories.GRA</field>
    </record>
    <!-- House Rent Allowance salary rule -->
    <record id="employee_salary_rule_house_rent_allowance" model="employee.salary.rule">
        <field name="name">House Rent Allowance</field>
        <field name="code">HRA</field>
        <field name="category_id" ref="cyllo_payroll_management.employee_salary_rule_category_allowance"/>
        <field name="condition_select">none</field>
        <field name="amount_select">code</field>
        <field name="amount_python_compute">result = contract.house_rent</field>
    </record>
