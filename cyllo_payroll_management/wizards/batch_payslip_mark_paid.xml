<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_batch_payslip_mark_paid_form" model="ir.ui.view">
        <field name="name">view.batch.payslip.mark.paid.form</field>
        <field name="model">batch.payslip.mark.paid</field>
        <field name="arch" type="xml">
            <form>
                <body>
                    <div>
                        <span>Are you sure you want to mark all the payslips paid? <br/></span>
                    </div>
                </body>
                <footer>
                    <button string="Confirm"
                            name="action_paid"
                            type="object"
                            class="btn-primary"/>
                    <button string="Cancel"
                            class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
    <record id="action_view_employee_payslip_batch_mark_paid" model="ir.actions.act_window">
        <field name="name">Generate Payslips</field>
        <field name="res_model">batch.payslip.mark.paid</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="view_batch_payslip_mark_paid_form"/>
        <field name="target">new</field>
    </record>
</odoo>