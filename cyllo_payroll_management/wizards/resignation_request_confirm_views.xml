<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!-- View for employee resignation confirmation-->
    <record id="view_resignation_request_confirm_form" model="ir.ui.view">
        <field name="name">view.resignation.request.confirm.form</field>
        <field name="model">resignation.request.confirm</field>
        <field name="arch" type="xml">
            <form>
                <span>
                    Are you sure you want to confirm the resignation request <field name="reference"/>?
                </span>
                <footer>
                    <button type="object" name="action_confirm_resignation" string="Confirm" class="btn-primary" data-hotkey="q"/>
                    <button type="object" special="cancel" string="Cancel" class="btn-secondary" data-hotkey="q"/>
                </footer>
            </form>
        </field>
    </record>
    <record id="action_view_resignation_request" model="ir.actions.act_window">
        <field name="name">Confirm Resignation Request</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">resignation.request.confirm</field>
        <field name="view_mode">form</field>
    </record>
</odoo>