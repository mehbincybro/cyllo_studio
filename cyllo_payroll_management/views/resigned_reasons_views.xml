<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- List View-->
    <record id="view_resigned_reasons_tree" model="ir.ui.view">
        <field name="name">view.resigned.reasons.tree</field>
        <field name="model">resigned.reasons</field>
        <field name="arch" type="xml">
            <tree name="resigned_reasons" editable="bottom">
                <field name="name" placeholder="e.g. Relocation"/>
            </tree>
        </field>
    </record>
    <!-- Action-->
    <record id="action_view_resigned_reason" model="ir.actions.act_window">
        <field name="name">Resignation Reasons</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">resigned.reasons</field>
        <field name="view_mode">tree</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Resigned Reasons
            </p>
            <p>
                Create New Resigned Reasons Here
            </p>
        </field>
    </record>
</odoo>