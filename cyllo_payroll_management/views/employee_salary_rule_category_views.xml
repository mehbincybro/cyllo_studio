<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Form View-->
    <record id="view_employee_salary_rule_category_form" model="ir.ui.view">
        <field name="name">view.employee.salary.rule.category.form</field>
        <field name="model">employee.salary.rule.category</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name" placeholder="e.g. Basic"/>
                            <field name="code"/>
                            <field name="parent_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description" name="description">
                            <field name="description"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
    <!-- List View -->
    <record id="view_employee_salary_rule_category_tree" model="ir.ui.view">
        <field name="name">view.employee.salary.rule.category.tree</field>
        <field name="model">employee.salary.rule.category</field>
        <field name="arch" type="xml">
            <tree name="type_tree">
                <field name="name"/>
                <field name="code"/>
                <field name="parent_id"/>
            </tree>
        </field>
    </record>
    <record id="view_employee_salary_rule_category_search" model="ir.ui.view">
        <field name="name">view.employee.salary.rule.category.search</field>
        <field name="model">employee.salary.rule.category</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="code"/>
                <field name="parent_id"/>
            </search>
        </field>
    </record>
    <!-- Action-->
    <record id="action_view_salary_rule_category" model="ir.actions.act_window">
        <field name="name">Employee Salary Rule Category</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">employee.salary.rule.category</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Employee Salary Rule Category
            </p>
            <p>
                Create New Employee Salary Rule Category Here
            </p>
        </field>
    </record>
</odoo>