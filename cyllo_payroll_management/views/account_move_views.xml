<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Inherited the Account Move for adding new fields -->
    <record id="view_account_move_form" model="ir.ui.view">
        <field name="name">view.account.move.inherit.payroll</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='line_ids']/tree/field[@name='company_id']" position="after">
                <field name="batch_id" column_invisible="True"/>
            </xpath>
        </field>
    </record>
</odoo>