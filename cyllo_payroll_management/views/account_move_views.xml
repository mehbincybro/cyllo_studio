<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Inherited the Account Move for adding new fields -->
    <record id="view_account_move_form" model="ir.ui.view">
        <field name="name">view.account.move.</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook/page[@name='other_info']" position="before">
                <page string="Journal Items">
                    <field name="journal_item_ids">
                        <tree editable="bottom">
                            <field name="account_id"/>
                            <field name="partner_id"/>
                            <field name="label"/>
                            <field name="debit" widget="monetary" options="{'currency_field': 'currency_id'}" sum="debit"/>
                            <field name="credit" widget="monetary" options="{'currency_field': 'currency_id'}" sum="credit"/>
                            <field name="currency_id" column_invisible="True"/>
                        </tree>
                    </field>
                </page>
            </xpath>
             <xpath expr="//field[@name='line_ids']/tree/field[@name='company_id']" position="after">
                <field name="batch_id" column_invisible="True"/>
            </xpath>
        </field>
    </record>
</odoo>