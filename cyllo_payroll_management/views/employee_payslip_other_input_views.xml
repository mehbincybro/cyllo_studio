<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!-- Payslip other input form view  -->
    <record id="view_employee_payslip_other_input_form" model="ir.ui.view">
        <field name="name">view.employee.payslip.other.input.form</field>
        <field name="model">employee.payslip.other.input</field>
        <field name="arch" type="xml">
            <form string="Payslip Other Input">
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1>
                            <field name="name" placeholder="Loan"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="structure_ids" widget="many2many_tags"/>
                        </group>
                        <group>
                            <field name="company_id" options="{'no_create': True}"/>
                        </group>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>
    <!-- Payslip other input tree view  -->
    <record id="view_employee_payslip_other_input_tree" model="ir.ui.view">
        <field name="name">view.employee.payslip.other.input.tree</field>
        <field name="model">employee.payslip.other.input</field>
        <field name="arch" type="xml">
            <tree string="Payslip Other Input" sample="1">
                <field name="name"/>
                <field name="code"/>
                <field name="structure_ids" widget="many2many_tags"/>
            </tree>
        </field>
    </record>
    <!-- Payslip other input action  -->
    <record id="action_view_other_inputs" model="ir.actions.act_window">
        <field name="name">Other Inputs</field>
        <field name="res_model">employee.payslip.other.input</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>