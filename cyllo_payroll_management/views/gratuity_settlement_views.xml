<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- List View-->
    <record id="view_gratuity_settlement_tree" model="ir.ui.view">
        <field name="name">view.gratuity.settlement.tree</field>
        <field name="model">gratuity.settlement</field>
        <field name="arch" type="xml">
            <tree>
                <field name="reference"/>
                <field name="employee_id"/>
                <field name="joining_date"/>
                <field name="contract_type"/>
                <field name="basic_salary" widget="monetary"/>
                <field name="gratuity_years"/>
                <field name="state" widget="badge"/>
            </tree>
        </field>
    </record>

    <record id="view_gratuity_settlement_form" model="ir.ui.view">
        <field name="name">view.gratuity.settlement.form</field>
        <field name="model">gratuity.settlement</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_submit" string="Submit" type="object" class="btn-primary" invisible="state != 'draft'"
                            groups="cyllo_payroll_management.group_cyllo_payroll_management_manager"/>
                    <button name="action_approve" string="Approve" type="object" class="btn-primary" invisible="state != 'submit'"
                            groups="cyllo_payroll_management.group_cyllo_payroll_management_manager"/>
                    <button name="action_cancel" string="Cancel" type="object" class="btn-primary" invisible="state in ('draft', 'approve', 'cancel')"
                            groups="cyllo_payroll_management.group_cyllo_payroll_management_manager"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <div class="d-flex">
                                <field name="reference" class="text-break"/>
                            </div>
                        </h1>
                        <h1>
                            <div class="d-flex">
                                <field name="employee_id" readonly="state in('approved')" class="text-break"/>
                            </div>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <separator string="Employee Details"/>
                            <field name="currency_id" invisible="True"/>
                            <field name="contract_type" force_save="1"/>
                            <field name="joining_date" force_save="1"/>
                            <field name="basic_salary" force_save="1" options="{'currency_field': 'currency_id'}"
                                   class="oe_inline" widget="monetary"/>
                        </group>
                        <group>
                            <separator string="Gratuity Details"/>
                            <field name="gratuity_configuration_id" force_save="1"/>
                            <field name="gratuity_duration_line_id" force_save="1"/>
                            <field name="gratuity_amount" force_save="1" widget="monetary"
                                   options="{'currency_field': 'currency_id'}" class="oe_inline"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <separator string="Employee Working Details"/>
                            <field name="total_working_years" force_save="1"/>
                            <field name="gratuity_years" force_save="1"/>
                            <field name="leave_taken" force_save="1"/>
                        </group>
                        <group>
                            <separator string="Accounting Details"/>
                            <field name="journal_id" force_save="1"/>
                            <field name="credit_account_id" force_save="1"/>
                            <field name="debit_account_id" force_save="1"/>
                        </group>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Action-->
    <record id="action_view_gratuity_settlement" model="ir.actions.act_window">
        <field name="name">Gratuity Settlement</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">gratuity.settlement</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Gratuity Settlements
            </p>
            <p>
                Create New Gratuity Settlements
            </p>
        </field>
    </record>
</odoo>