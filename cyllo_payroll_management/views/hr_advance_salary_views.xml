<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ========================= -->
    <!-- Action -->
    <!-- ========================= -->
    <record id="action_hr_advance_salary" model="ir.actions.act_window">
        <field name="name">Advance Salary Requests</field>
        <field name="res_model">hr.advance.salary</field>
        <field name="view_mode">tree,form</field>
    </record>



    <!-- ========================= -->
    <!-- Tree View -->
    <!-- ========================= -->
    <record id="view_advance_salary_request_tree" model="ir.ui.view">
        <field name="name">advance.salary.tree</field>
        <field name="model">hr.advance.salary</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="employee_id"/>
                <field name="request_date"/>
                <field name="amount"/>
<!--                <field name="approved_amount"/>-->
<!--                <field name="balance_amount"/>-->
                <field name="state"/>
            </tree>
        </field>
    </record>

    <!-- ========================= -->
    <!-- Form View -->
    <!-- ========================= -->
    <record id="view_advance_salary_request_form" model="ir.ui.view">
        <field name="name">advance.salary.form</field>
        <field name="model">hr.advance.salary</field>
        <field name="arch" type="xml">
            <form string="Advance Salary Request">

                <header>

                    <button name="action_submit"
                            string="Submit"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"/>

                    <button name="action_approve"
                            string="Approve" groups='base.group_system'
                            type="object"
                            class="btn-success"
                            invisible = "state != 'submitted'"/>

                    <button name="action_reject"
                            string="Reject"
                            type="object"
                            class="btn-danger"
                            invisible="state != 'submitted'"/>

                    <button name="action_create_bill"
                            string="Create Bill"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'approved' or bill_id != False"/>

                    <button name="action_paid"
                            string="Mark Paid"
                            type="object"
                            invisible="state != 'approved' or bill_id != False"/>

                    <button name="%(cyllo_payroll_management.action_hr_advance_salary_close_wizard)d"
                            string="Close"
                            type="action"
                            class="btn-secondary"
                            invisible="state != 'paid'"
                            context="{'default_advance_id': active_id}"/>

                    <field name="state" widget="statusbar"/>
                </header>

                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="get_bill_action"
                                string="Vendor Bill"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-pencil-square-o"
                                invisible="bill_id == False"/>
                    </div>
                    <group>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="employee_id"/>
                            <field name="bill_id" invisible="bill_id == False"/>
                            <field name="request_date"/>
                            <field name="approval_date"/>
                        </group>

                        <group>
                            <field name="amount"/>
                            <field name="deduction_type" widget="radio"/>
                            <field name="deduction_amount" invisible="deduction_type != 'fixed'"/>
                            <field name="deduction_percentage" invisible="deduction_type != 'percentage'"/>
                            <field name="monthly_deduction_amount" readonly="1" force_save="1"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Deduction Schedule">
                            <field name="line_ids" readonly="1">
                                <tree decoration-info="state == 'planned'" decoration-warning="state == 'pending'" decoration-success="state == 'paid'">
                                    <field name="date"/>
                                    <field name="amount" sum="Total"/>
                                    <field name="payslip_id"/>
                                    <field name="state" widget="badge" decoration-info="state == 'planned'" decoration-warning="state == 'pending'" decoration-success="state == 'paid'"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Reason">
                            <field name="reason"/>
                        </page>
                    </notebook>

                </sheet>

            </form>
        </field>
    </record>

</odoo>
