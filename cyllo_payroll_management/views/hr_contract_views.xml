<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Inherited the Hr contract for adding new fields -->
    <record id="view_hr_contract_form" model="ir.ui.view">
        <field name="name">view.hr.contract.</field>
        <field name="model">hr.contract</field>
        <field name="inherit_id" ref="hr_contract.hr_contract_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="/form/header" position="inside">
                <button name="action_approve_contract" string="Approve" class="oe_highlight" type="object"
                        invisible="state!='training'" groups="cyllo_payroll_management.group_cyllo_payroll_management_manager"/>
            </xpath>
            <xpath expr="//field[@name='state']" position="attributes">
                <attribute name="state"/>
            </xpath>
            <xpath expr="//field[@name='employee_id']" position="after">
                <field name="training_date_from" force_save="1" invisible="(state not in ('draft','training'))"/>
                <field name="training_date_to" force_save="1" invisible="(state not in ('draft','training'))"/>
            </xpath>
            <xpath expr="//field[@name='job_id']" position="after">
                <field name="employee_salary_structure_id" force_save="1"/>
                <field name="default_schedule_pay" force_save="1"/>
            </xpath>
            <xpath expr="//group[@name='salary']" position="before">
                <group>
                    <field name="wage_type"/>
                    <field name="is_approved" invisible="1"/>
                </group>
            </xpath>
            <xpath expr="//div[@name='wage']" position="after">
                <div class="o_row mw-50" name="wage_hour" invisible="wage_type=='monthly' or wage_type==False">
                    <field name="hourly_wage" class="oe_inline o_hr_narrow_field" nolabel="1"/>
                    <div class="mb-3" name="wage_period_hour">/ hour</div>
                </div>
            </xpath>
            <xpath expr="//div[@name='wage']" position="attributes">
                <attribute name="invisible">wage_type == 'hourly'</attribute>
            </xpath>
            <xpath expr="//field[@name='date_start']" position="attributes">
                <attribute name="invisible">state in ('draft','training')</attribute>
            </xpath>
            <xpath expr="//field[@name='date_end']" position="attributes">
                <attribute name="invisible">state in ('draft','training')</attribute>
            </xpath>
            <xpath expr="//notebook/page[@name='information']" position="inside">
                <group>
                    <group>
                        <field name="yearly_wage" widget="monetary" options="{'currency_field': 'currency_id'}" class="oe_inline"/>
                    </group>
                </group>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page string="Allowance Details">
                    <separator string="Employee Allowance Details"/>
                    <group>
                        <group>
                            <field name="house_rent" force_save="1"/>
                            <field name="travel_allowance" force_save="1"/>
                            <field name="dearness_allowance" force_save="1"/>
                        </group>
                        <group>
                            <field name="meal_allowance" force_save="1"/>
                            <field name="medical_allowance" force_save="1"/>
                            <field name="other_allowance" force_save="1"/>
                        </group>
                    </group>
                </page>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page string="Training Details">
                    <separator string="Employee Training Period Details"/>
                    <group>
                        <field name="training_date_start"/>
                        <field name="training_date_end"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>