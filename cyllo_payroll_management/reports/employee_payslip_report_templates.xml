<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Template for Payslip details report-->
    <record id="report_employee_payslip_report" model="ir.actions.report">
        <field name="name">Employee Payslip</field>
        <field name="model">employee.payslip</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">cyllo_payroll_management.report_employee_payslip</field>
        <field name="report_file">cyllo_payroll_management.report_employee_payslip</field>
        <field name="print_report_name">'Payslip - %s' % (object.employee_id.name)</field>
        <field name="binding_model_id" ref="cyllo_payroll_management.model_employee_payslip"/>
        <field name="binding_type">report</field>
    </record>
    <template id="report_employee_payslip">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2 align="center">
                            <span t-field="o.payslip_name"/>
                        </h2>
                        <br/>
                        <table class="table table-bordered">
                            <tr>
                                <th>Employee</th>
                                <th>Designation</th>
                                <th>Address</th>
                                <th>Email</th>
                            </tr>
                            <tr>
                                <td>
                                    <t t-esc="o.employee_id.name"/>
                                </td>
                                <td>
                                    <t t-esc="o.employee_id.job_id.name"/>
                                </td>
                                <td>
                                    <t t-esc="o.employee_id.address_id"
                                       t-options='{"widget": "contact", "fields": ["address", "name", "phone"], "no_marker": True, "phone_icons": True}'/>
                                </td>
                                <td>
                                    <span t-field="o.employee_id.work_email"/>
                                </td>
                            </tr>
                            <tr>
                                <th>Contract</th>
                                <th>Contract Type</th>
                                <th>Contract Start Date</th>
                                <th>Pay Period</th>
                            </tr>
                            <tr>
                                <td>
                                    <t t-esc="o.contract_id.name"/>
                                </td>
                                <td>
                                    <t t-esc="o.contract_id.contract_type_id.name"/>
                                </td>
                                <td>
                                    <t t-esc="o.contract_id.date_start"/>
                                </td>
                                <td>
                                    <span t-esc="o.start_date"/>
                                    To
                                    <span t-esc="o.to_date"/>
                                </td>
                            </tr>
                        </table>
                        <strong>Basic Salary:
                            <t t-esc="o.contract_id.wage" t-options='{"widget": "monetary", "display_currency": o.company_id.currency_id}'/>
                            <hr/>
                        </strong>
                        <table class="table">
                            <th>Name</th>
                            <th>Number of Hours</th>
                            <th>Number of Days</th>
                            <th>Amount</th>
                            <t t-foreach="o.employee_worked_days_ids"
                               t-as="work">
                                <tr align="center">
                                    <td>
                                        <t t-esc="work.type"/>
                                    </td>
                                    <td>
                                        <t t-esc="work.hour"/>
                                    </td>
                                    <td>
                                        <t t-esc="work.days"/>
                                    </td>
                                    <td>
                                        <t t-esc="round(work.amount,2)"/>
                                    </td>
                                </tr>
                            </t>
                            <t t-foreach="o.employee_payslip_line_ids"
                               t-as="line">
                                <tr align="center">
                                    <td>
                                        <t t-esc="line.name"/>
                                    </td>
                                    <td/>
                                    <td/>
                                    <td>
                                        <t t-esc="round(line.total,2)"/>
                                    </td>
                                </tr>
                            </t>
                        </table>
                        <br/>
                        <p class="text-left">
                            <strong>Authorized signature</strong>
                        </p>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>