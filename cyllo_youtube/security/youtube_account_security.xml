<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="youtube_account_rule" model="ir.rule">
        <field name="name">Youtube Account multi company rule</field>
        <field name="model_id" ref="model_youtube_account"/>
        <field name="domain_force">[('company_id', 'in', company_ids +
            [False])]
        </field>
    </record>
    <record id="youtube_channel_rule" model="ir.rule">
        <field name="name">Youtube Account multi company rule</field>
        <field name="model_id" ref="model_youtube_channel"/>
        <field name="domain_force">[('company_id', 'in', company_ids +
            [False])]
        </field>
    </record>
</odoo>