                        <div class="d-flex align-items-center gap-2 cy-social-market_tophead">
                            <img src="cyllo_youtube/static/src/img/youtube.png"
                                 alt="" style="width: 25px;"/>
                            <t t-esc="state.YtFeeds[0]?.author_name">Youtube</t>
                            <select t-on-change="onChannelChange" class="form-select form-select-sm">
                                <t t-foreach="state.channels" t-as="ch" t-key="ch.id">
                                    <option t-att-value="ch.id"
                                            t-att-selected="ch.id == state.selectedChannelId ? 'selected' : false">
                                        <t t-esc="ch.name"/>
                                        (<t t-esc="ch.account_name"/>)
                                    </option>
                                </t>
                            </select>
                        </div>
