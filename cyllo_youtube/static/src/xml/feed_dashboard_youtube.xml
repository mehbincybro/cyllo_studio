        </xpath>
        <xpath expr="//div[hasclass('cy-dashboard-container')]"
               position="inside">
            <div class="cy-onboard_modal-container cy-social_comment_modal"
                 t-ref="social_comment_modal_youtube">
                <div class="modal-dialog cy-onboarding_modalbox">
                    <div class="modal-content cy-modal_content">
                        <div class="modal-header  cy-social_commentHead d-flex  pt-4">
                            <h5 class="cy-social_maketing-title">Comments</h5>
                            <span class="cy-icons cy-social_cmnt-closebtn"
                                  t-on-click="() => this.CloseCommentYoutube()"><i class="ri-close-line"/></span>
                        </div>
                        <div class="modal-body pt-0 cy-modal_main-body">
                            <form>
                                <div class="form-group py-3 ">
                                    <textarea
                                            class="form-control cy-button-stroke"
                                            id="exampleFormControlTextarea1"
                                            rows="5"
                                            placeholder="Write a comment...."
                                            t-ref="new_message_yt"/>
                                </div>
                            </form>
                            <div class="d-flex justify-content-end">
                                <button class="btn cy-button-primary-stroke text-end"
                                        t-on-click="() => this.PostCommentYoutube(feed)">POST</button>
                            </div>
                            <t t-foreach="state.comments" t-as="comment"
                               t-key="comment.id" t-if="state.comments">
                                <div class="cy-social_market-commentReply">
                                    <div class="cy-social_marketComment-box">
                                        <div class="d-flex justify-content-between">
                                            <div class="d-flex align-items-center gap-2">
                                                <span><a href="" class="cy-main-sectionhead ">
                                                    <t t-esc="comment.username"/></a></span>
                                                <span class="cy-soical-comment_txt"><t t-esc="comment.timestamp"/></span>
                                            </div>
                                            <div class="d-flex align-items-center gap-2 ">
                                                <div class="badge rounded-pill"
                                                     t-on-click="convertToLeadYt"
                                                     t-att-id="comment.id">
                                                    <i class="fa fa-user"
                                                       style="color:blue;"/>
                                                                </div>

                                                <span class="cy-soical-market-count_txt"><t t-esc="comment.like_count"/></span>
                                                <span class="cy-soical-market-count_txt"><i
                                                        class="ri-heart-line"/></span>
                                            </div>
                                        </div>
                                        <p class="cy-soical-market-cmnttile"><t t-esc="comment.text"/></p>
                                        <div>
                                            <span>
                                                <i class="ri-chat-3-line cy-cmt_rply-icon"/>
                                            </span>
                                            <span class="cy-cmt_rply"
                                                  t-on-click="() => this.ReplyCommentYoutube(comment)">
                                                Reply</span>
                                            <div class="reply_div d-none">
                                                <input class="form-control cy-button-stroke mt-2"
                                                       type="text"
                                                       placeholder="Write a reply..."
                                                       name=""
                                                       t-attf-id="yt_{{comment.id}}"/>
                                                <span class="send_button cy-soical-market-count_txt"><i
                                                        class="ri-send-plane-fill" t-on-click="() => this.ReplyToCommentYoutube(comment,feed)"/></span>
                                            </div>
                                            <t t-if="state.type=='youtube'">
                                                    <a class="o_fb_comment_replies btn btn-sm btn-link" href="#"
                                                       style="margin-left:10px;" t-on-click="onClickViewReplies">
                                                        View Replies (<t t-esc="comment.reply_count"/>)
                                                    </a>
                                                    <div id="view_replies" t-att-id="comment.id" class="d-none">
                                                    <t t-if="comment.replies">
                                                        <t t-foreach="comment.replies" t-as="replies" t-key="replies.id">
                                                            <span t-esc="replies.snippet.textDisplay" style="margin-left: 20%;"/>
                                                            <br/>
                                                        </t>
                                                    </t>
                                                </div>
                                            </t>
                                        </div>
                                    </div>
                                </div>
                            </t>
                        </div>
                        <div class="cy-modal_footer cy-social_cmnt-footer">
                            <div class="d-flex justify-content-end">
                                <button class="btn cy-button-primary-stroke"
                                        t-on-click="() => this.CloseCommentYoutube()">OK</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </xpath>
    </t>
