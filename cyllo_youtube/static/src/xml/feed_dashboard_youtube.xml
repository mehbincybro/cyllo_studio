        </xpath>
        <xpath expr="//div[hasclass('cy-dashboard-container')]"
               position="inside">
            <div class="cy-onboard_modal-container cy-social_comment_modal"
                 t-ref="social_comment_modal_youtube">
                <div class="modal-dialog cy-onboarding_modalbox">
                    <div class="modal-content cy-modal_content">
                        <div class="modal-header cy-social_commentHead d-flex">
                            <div class="d-flex align-items-center gap-2 cy-soical-marketing_insights">
                                <span>Comments</span>
                            </div>
                            <button type="button" class="btn-close" aria-label="Close"
                                    t-on-click="() => this.CloseCommentYoutube()" tabindex="-1"/>
                        </div>

                        <div class="modal-body pt-0 cy-modal_main-body">

                            <t t-foreach="state.comments" t-as="comment"
                               t-key="comment.id" t-if="state.comments">
                                <div class="cy-social_market-commentReply">
                                    <div class="cy-social_marketComment-box">

                                        <div class="d-flex gap-2">
                                            <img class="mt-1"
                                                 t-att-src="comment.author_profile_img"
                                                 style="border-radius:50%; width:28px; height:28px"/>
                                            <div class="cy-comment-bubble">
                                            <div class="d-flex justify-content-between w-100">

                                            <div class="d-flex align-items-center gap-2 w-100">
                                                 <span style="flex-grow: 1">
                                                        <a t-on-click="() => this.DirectPartner(comment.partner_id)"
                                                           class="cy-main-sectionhead">
                                                            <t t-esc="comment.username"/>
                                                        </a>
                                                    </span>

                                                <t t-set="time"
                                                   t-value="Math.floor((Date.now() - new Date(comment.publishedAt)) / (1000 * 60 * 60 * 24)) + 'd'"/>
                                                <span class="cy-soical-comment_txt"
                                                      t-att-data-tooltip="new Date().toLocaleString()"
                                                      t-att-aria-label="new Date(comment.publishedAt).toLocaleString()">
                                                        <i class="ri-time-line me-1"/>
                                                    <t t-esc="time"/>
                                                </span>

                                                <div class="badge rounded-pill cursor-pointer"
                                                     t-on-click="() => this.convertToLeadYt()"
                                                     t-att-id="comment.id"
                                                     data-tooltip="Create Lead"
                                                     aria-label="Create Lead">
                                                        <i class="fa fa-user cy-cmt_rply"/>
                                                    </div>

                                                <!-- Likes -->
                                                <div class="d-flex align-items-center gap-1" data-tooltip="Likes"
                                                     aria-label="Likes">
                                                        <span class="cy-soical-market-count_txt cy-cmt_rply">
                                                            <i class="ri-heart-line"/>
                                                        </span>
                                                    <span class="cy-soical-market-count_txt cy-cmt_rply">
                                                            <t t-esc="comment.like_count"/>
                                                        </span>
                                                    </div>
                                            </div>
                                        </div>
                                                <p class="cy-soical-market-cmnttile"><t t-esc="comment.text"/></p>

                                        </div>
                                        </div>

                                        <div>

                                        <!-- Reply & View Replies -->
                                            <div class="d-flex justify-content-start align-items-center mt-1"
                                                 style="margin-left: 38px">
                                            <a t-on-click="(ev) => this.ReplyCommentYoutube(ev)"
                                               class="cursor-pointer d-flex align-items-center gap-1">
                                                <i class="ri-chat-3-line cy-cmt_rply-icon"/>
                                                <span class="cy-cmt_rply">Reply</span>
                                            </a>

                                                <t t-if="comment.reply_count > 0">
                                                <a class="o_fb_comment_replies btn btn-sm btn-link"
                                                   href="#"
                                                   style="margin-left:10px;"
                                                   t-on-click="onClickViewReplies">
                                                    View Replies (<t t-esc="comment.reply_count"/>)
                                                </a>
                                            </t>
                                        </div>

                                            <!-- Reply Input -->
                                            <div class="reply_div d-none"
                                                 style="margin-left: 38px">
                                            <input class="form-control cy-button-stroke mt-2"
                                                   type="text"
                                                   t-attf-id="yt_{{comment.id}}"
                                                   placeholder="Write a reply..."
                                                   autocomplete="off"/>
                                                <span class="send_button"
                                                      t-on-click="() => this.ReplyToCommentYoutube(comment, state.activeFeed)">
                                                <i class="ri-send-plane-2-line"/>
                                            </span>
                                        </div>

                                            <div id="view_replies"
                                                 t-att-id="comment.id"
                                                 style="margin-left: 38px"
                                                 class="view_replies d-none">

                                                    <t t-if="comment.replies">
                                                        <t t-foreach="comment.replies"
                                                           t-as="replies"
                                                           t-key="replies.id">

                                                            <div class="d-flex align-items-center">
                                                                <div class="cy-reply-line"/>
                                                                <div class="cy-comment-bubble mb-2">
                                                                    <a t-on-click="() => this.DirectPartner(replies.partner_id)"
                                                                       class="cy-main-sectionhead">
                                                                        <span t-esc="replies?.author"/>
                                                                    </a>
                                                                    <p t-esc="replies?.text"/>
                                                                </div>
                                                            </div>
                                                        </t>
                                                    </t>
                                                </div>
                                        </div>
                                    </div>
                                </div>
                            </t>
                            <div class="text-center my-2" t-if="state.nextPageToken">
                                <button class="btn btn-outline-primary"
                                        t-on-click="() => this.LoadMoreComments()">
                                    Load More
                                </button>
                            </div>

                        </div>
                        <div class="cy-modal_footer cy-social_cmnt-footer">
                            <form>
                                <div class="form-group d-flex overflow-hidden">
                                    <textarea class="form-control"
                                              id="exampleFormControlTextarea1"
                                              rows="1"
                                              role="textbox"
                                              placeholder="Write a comment...."
                                              t-ref="new_message_yt"/>
                                    <div class="d-flex justify-content-end align-items-end">
                                        <button class="btn text-end"
                                                style="font-size: 20px"
                                                t-on-click="(ev) => this.PostCommentYoutube(ev, state.activeFeed)">
                                            <i class="ri-send-plane-2-line"/>
                                        </button>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </xpath>
    </t>
</templates>
