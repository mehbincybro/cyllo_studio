<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
        <!-- This template represents the structure for displaying YouTube feed. -->
    <t t-inherit="cyllo_social_media_marketing.SocialMediaFeed"
       t-inherit-mode="extension" owl="1">
        <xpath expr="//div[hasclass('cy-social_glance-container')]"
               position="inside">
            <div class="col py-3 cy-social-market_box cy-social_market-glancebox cy-social-market_glance_box"
                 t-att-class="state.currentAccount == 'Youtube' ? 'active' : ''"
                 t-on-click="() => this.showYtFeed()">
                <div class="w-100 d-flex justify-content-between align-items-center flex-wrap">
                <div class="d-flex align-items-center gap-2 cy-social-market_tophead">
                    <img src="cyllo_youtube/static/src/img/youtube.png"
                         alt="" style="width: 20px;"/>
                    YouTube
                </div>
                    <div class="d-flex align-items-center gap-2 cy-soical-market_glancecontainer">
                        <div class="d-flex align-items-center gap-1">
                            <i class="ri-article-line cy-icons"/>
                            <p class="cy-soical-market_txt">
                                <t t-esc="state.YtFeeds.length"/></p>
                        </div>
                        <div class="d-flex align-items-center gap-1">
                            <i class="ri-heart-line cy-icons"/>
                            <p class="cy-soical-market_txt">
                                    <t t-esc="state.YtFeeds?.reduce((sum, post) => sum + (+post.likes_count || 0), 0);"/></p>
                        </div>
                        <div class="d-flex align-items-center gap-1">
                            <i class="ri-chat-3-line cy-icons"/>
                            <p class="cy-soical-market_txt">
                                    <t t-esc="state.YtFeeds?.reduce((sum, post) => sum + (+post.comments_count || 0), 0)"/></p>
                        </div>
                    </div>
                </div>
            </div>
        </xpath>
        <xpath expr="//div[hasclass('cy-social_maketing-topSection')]" position="inside">
            <div t-if="state.currentAccount == 'Youtube'" class="col cy-social-marketing-col position-relative">
