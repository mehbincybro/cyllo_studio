                        <div>
                    </div>
                        </t>
                    <t t-if="state.YtFeeds" t-foreach="state.YtFeeds"
                       t-as="feed" t-key="feed.id">
                            <t t-set="flag_youtube" t-value="false"/>
                        <div class="py-2  cy-social-market_box cy-border-btm ">

                                <div class="d-flex justify-content-between gap-2 pt-3">
                                    <div class="d-flex gap-2">
                                        <div class="cy-social-market_profile">
                                            <img t-attf-src="{{feed.profile_image_url}}"
                                                 onerror="this.src='/cyllo_youtube/static/src/img/youtube.png'"/>
                                        </div>
                                        <div>
                                            <p class="cy-social-market_subhead"><t t-esc="feed.author_name"/></p>
                                            <span class="cy-social-market_sm-head"><t t-esc="feed.posted_date"/></span>
                                        </div>
                                    </div>
                                    <div>
                                        <a t-attf-href="{{feed.author_link_url}}" class="ri-external-link-line"
                                           data-tooltip="External Link" aria-label="External Link"
                                           style="font-size: 18px"/>
                                    </div>
                                </div>

                            <p class="cy-soical-market_content">
                                <t t-esc="feed.description"/>
                            </p>

                            <div class="row cy-soical-marketing_post m-0 py-2">
                                <div class="col-12 p-0">
                                    <iframe class="embed-responsive-item"
                                            t-attf-src="https://www.youtube.com/embed/{{feed.post_id}}"
                                            frameborder="0"
                                            style="width: inherit; height: 350px;"
                                            allowfullscreen="true"/>
                                </div>
                            </div>
                            <div class="d-flex justify-content-between align-items-center cy-soical-market_glancecontainer py-2">
                                    <div class="d-flex align-items-center" style="font-size: 20px; gap: 16px;">
                                        <span data-tooltip="Likes" aria-label="Likes">
                                            <i class="ri-thumb-up-line cy-icons cy-media_icon me-1"/>
                                            <t t-esc="feed.likes_count"/>
                                        </span>
                                        <span data-tooltip="Dislikes" aria-label="Dislikes">
                                            <i class="ri-thumb-down-line cy-icons cy-media_icon me-1"/>
                                            <t t-esc="feed.dislikes_count"/>
                                        </span>
                                        <span t-on-click="() => this.OpenCommentYoutube(feed)"
                                              role="button" tabindex="0"
                                              data-tooltip="Comments" aria-label="Comments">
                                            <i class="ri-chat-3-line cy-icons cy-media_icon me-1"/>
                                            <t t-esc="feed.comments_count"/>
                                        </span>
                                        <span data-tooltip="Views" aria-label="Views">
                                            <i class="ri-eye-line cy-icons cy-media_icon me-1"/>
                                            <t t-esc="feed.views_count"/>
                                        </span>
                                    </div>
                            </div>
                        </div>
                        </t>
                    <div class="cy-social-marketing-nostream"
                         t-if="flag_youtube  and !state.demo">
                            <img src="images/undraw_no_data_re_kwbl 1 (1).svg"
                                 alt=""/>
                        <p class="cy-nostream_add-msg">No Post added yet!</p>
                        <span class="cy-nostream_add-subtext"><a t-on-click="() => this.CreatePost()" class="cy-social-marketing__link">Add a
                                                    post</a>
                            to keep an eye on your own posts and
                            monitor all social activities</span>

                        </div>
