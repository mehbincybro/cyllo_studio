<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- This record defines the views for youtube.channel. -->
    <record id="view_youtube_channel_form" model="ir.ui.view">
        <field name="name">view.youtube.channel.form</field>
        <field name="model">youtube.channel</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <field name="channel_image" widget='image' class="oe_avatar"
                           readonly="True"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" readonly="True"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="youtube_number" readonly="True"/>
                            <field name="youtube_etag" readonly="True"/>
                        </group>
                        <group>
                            <field name="customUrl" readonly="True"/>
                        </group>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>
    <record id="view_youtube_channel_tree" model="ir.ui.view">
        <field name="name">view.youtube.channel.tree</field>
        <field name="model">youtube.channel</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
            </tree>
        </field>
    </record>
    <record id="action_view_youtube_channels" model="ir.actions.act_window">
        <field name="name">Channel</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">youtube.channel</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No channels
            </p>
        </field>
    </record>

    <menuitem id="menu_youtube_channels" action="action_view_youtube_channels"
              name="Youtube Channels"
              parent="cyllo_social_media_marketing.menu_configuration_categ"/>
</odoo>