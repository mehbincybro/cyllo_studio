<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <!-- Adding attribute t-attf-class to the element with class "modal-content" in the "web.LegacyAdaptedActionDialog" template-->
    <t t-name="cy.Dialog" t-inherit="web.ActionDialog" t-inherit-mode="extension" owl="1">
        <xpath expr="//div[@class='modal-content']" position="attributes">
            <attribute name="t-attf-class">{{ props.contentClass }} {{ props.customClass }}</attribute>
        </xpath>
    </t>
</templates>