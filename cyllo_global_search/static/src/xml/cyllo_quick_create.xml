<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <!-- QuickCreate template -->
    <t t-name="QuickCreate" t-inherit="web.NavBar" t-inherit-mode="extension" owl="1">
        <!-- Insert QuickCreateDropdown after the div with class 'systray_div' -->
        <xpath expr="//div[hasclass('systray_div')]" position="after">
            <QuickCreateDropdown/>
        </xpath>
    </t>
</templates>