#. module: cyllo_approval
#: model:mail.template,body_html:cyllo_approval.mail_template_approval_request
msgid ""
"<p>Dear Sir\n"
"                </p>\n"
"                <p>An approval request has been assigned to you. Below are the\n"
"                    details:\n"
"                </p>\n"
"                <ul>\n"
"                    <li>\n"
"                        <strong>Request ID:</strong>\n"
"                        <t t-out=\"object.rule_id.name\"></t>\n"
"                    </li>\n"
"                    <li>\n"
"                        <strong>Requested By:</strong>\n"
"                        <t t-out=\"object.requested_by.name\"></t>\n"
"                    </li>\n"
"                    <li>\n"
"                        <strong>Date:</strong>\n"
"                        <t t-out=\"object.write_date\"></t>\n"
"                    </li>\n"
"                </ul>\n"
"                <p>\n"
"                    <a t-att-href=\"'/web#id=%s&amp;model=%s&amp;view_type=form' % (object.res_id, object.res_model)\" class=\"btn btn-primary\">\n"
"                        View Record\n"
"                    </a>\n"
"                </p>\n"
"                <p>Kindly review the request.</p>\n"
"            "
msgstr ""
"<p>عزيزي السيد\n"
"                </p>\n"
"                <p>تم تعيين طلب موافقة لك. فيما يلي\n"
"                    التفاصيل:\n"
"                </p>\n"
"                <ul>\n"
"                    <li>\n"
"                        <strong>معرف الطلب:</strong>\n"
"                        <t t-out=\"object.rule_id.name\"></t>\n"
"                    </li>\n"
"                    <li>\n"
"                        <strong>مقدم الطلب:</strong>\n"
"                        <t t-out=\"object.requested_by.name\"></t>\n"
"                    </li>\n"
"                    <li>\n"
"                        <strong>التاريخ:</strong>\n"
"                        <t t-out=\"object.write_date\"></t>\n"
"                    </li>\n"
"                </ul>\n"
"                <p>\n"
"                    <a t-att-href=\"'/web#id=%s&amp;model=%s&amp;view_type=form' % (object.res_id, object.res_model)\" class=\"btn btn-primary\">\n"
"                        عرض السجل\n"
"                    </a>\n"
"                </p>\n"
"                <p>يرجى مراجعة الطلب.</p>\n"
"            "

#. module: cyllo_approval
#: model:mail.template,body_html:cyllo_approval.mail_template_request_approved
msgid ""
"<p>Dear<t t-out=\"object.requested_by.name\"></t>,\n"
"                </p>\n"
"                <p>Your approval request has been approved.</p>\n"
"                <ul>\n"
"                    <li>\n"
"                        <strong>Request ID:</strong>\n"
"                        <t t-out=\"object.rule_id.name\"></t>\n"
"                    </li>\n"
"                    <li>\n"
"                        <strong>Approved By:</strong>\n"
"                        <t t-out=\"object.approver_id.name\"></t>\n"
"                    </li>\n"
"                    <li>\n"
"                        <strong>Approved Date:</strong>\n"
"                        <t t-out=\"object.write_date\"></t>\n"
"                    </li>\n"
"<!--                    <t t-if=\"object.comment\">-->\n"
"<!--                        <li>-->\n"
"<!--                            <strong>Comment:</strong>-->\n"
"<!--                            <t t-out=\"object.comment\"/>-->\n"
"<!--                        </li>-->\n"
"<!--                    </t>-->\n"
"                </ul>\n"
"                <p>\n"
"                    <a t-att-href=\"'/web#id=%s&amp;model=%s&amp;view_type=form' % (object.res_id, object.res_model)\" class=\"btn btn-primary\">\n"
"                        View Record\n"
"                    </a>\n"
"                </p>\n"
"                <p>Thank you.</p>\n"
"            "
msgstr ""
"<p>عزيزي<t t-out=\"object.requested_by.name\"></t>،\n"
"                </p>\n"
"                <p>تمت الموافقة على طلب الموافقة الخاص بك.</p>\n"
"                <ul>\n"
"                    <li>\n"
"                        <strong>معرف الطلب:</strong>\n"
"                        <t t-out=\"object.rule_id.name\"></t>\n"
"                    </li>\n"
"                    <li>\n"
"                        <strong>تمت الموافقة من قبل:</strong>\n"
"                        <t t-out=\"object.approver_id.name\"></t>\n"
"                    </li>\n"
"                    <li>\n"
"                        <strong>تاريخ الموافقة:</strong>\n"
"                        <t t-out=\"object.write_date\"></t>\n"
"                    </li>\n"
"<!--                    <t t-if=\"object.comment\">-->\n"
"<!--                        <li>-->\n"
"<!--                            <strong>تعليق:</strong>-->\n"
"<!--                            <t t-out=\"object.comment\"/>-->\n"
"<!--                        </li>-->\n"
"<!--                    </t>-->\n"
"                </ul>\n"
"                <p>\n"
"                    <a t-att-href=\"'/web#id=%s&amp;model=%s&amp;view_type=form' % (object.res_id, object.res_model)\" class=\"btn btn-primary\">\n"
"                        عرض السجل\n"
"                    </a>\n"
"                </p>\n"
"                <p>شكراً لك.</p>\n"
"            "

#. module: cyllo_approval
#: model:mail.template,body_html:cyllo_approval.mail_template_request_rejected
msgid ""
"<p>Dear<t t-out=\"object.requested_by.name\"></t>,\n"
"                </p>\n"
"                <p>Your approval request has been rejected.</p>\n"
"                <ul>\n"
"                    <li>\n"
"                        <strong>Request ID:</strong>\n"
"                        <t t-out=\"object.rule_id.name\"></t>\n"
"                    </li>\n"
"                    <li>\n"
"                        <strong>Rejected By:</strong>\n"
"                        <t t-out=\"object.approver_id.name\"></t>\n"
"                    </li>\n"
"                </ul>\n"
"                <p>\n"
"                    <a t-att-href=\"'/web#id=%s&amp;model=%s&amp;view_type=form' % (object.res_id, object.res_model)\" class=\"btn btn-primary\">\n"
"                        View Record\n"
"                    </a>\n"
"                </p>\n"
"                <p>Thank you.</p>\n"
"            "
msgstr ""
"<p>عزيزي<t t-out=\"object.requested_by.name\"></t>،\n"
"                </p>\n"
"                <p>تم رفض طلب الموافقة الخاص بك.</p>\n"
"                <ul>\n"
"                    <li>\n"
"                        <strong>معرف الطلب:</strong>\n"
"                        <t t-out=\"object.rule_id.name\"></t>\n"
"                    </li>\n"
"                    <li>\n"
"                        <strong>تم الرفض من قبل:</strong>\n"
"                        <t t-out=\"object.approver_id.name\"></t>\n"
"                    </li>\n"
"                </ul>\n"
"                <p>\n"
"                    <a t-att-href=\"'/web#id=%s&amp;model=%s&amp;view_type=form' % (object.res_id, object.res_model)\" class=\"btn btn-primary\">\n"
"                        عرض السجل\n"
"                    </a>\n"
"                </p>\n"
"                <p>شكراً لك.</p>\n"
"            "

