"                        <strong>الرفض من:</strong>\n"
"                        <t t-out=\"object.rejected_by_id.name\"></t>\n"
"                    </li>\n"
"                </ul>\n"
"                <p>\n"
"                    <a t-att-href=\"'/web#id=%s&amp;model=%s&amp;view_type=form' % (object.res_id, object.model_name)\" class=\"btn btn-primary\">\n"
"                        عرض السجل\n"
