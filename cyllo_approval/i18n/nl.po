#. module: cyllo_approval
#: model:mail.template,body_html:cyllo_approval.mail_template_approval_request
msgid ""
"<p>Dear Sir\n"
"                </p>\n"
"                <p>An approval request has been assigned to you. Below are the\n"
"                    details:\n"
"                </p>\n"
"                <ul>\n"
"                    <li>\n"
"                        <strong>Request ID:</strong>\n"
"                        <t t-out=\"object.name\"></t>\n"
"                    </li>\n"
"                    <li>\n"
"                        <strong>Requested By:</strong>\n"
"                        <t t-out=\"object.requested_by_id.name\"></t>\n"
"                    </li>\n"
"                    <li>\n"
"                        <strong>Date:</strong>\n"
"                        <t t-out=\"object.requested_date\"></t>\n"
"                    </li>\n"
"                </ul>\n"
"                <p>\n"
"                    <a t-att-href=\"'/web#id=%s&amp;model=%s&amp;view_type=form' % (object.res_id, object.model_name)\" class=\"btn btn-primary\">\n"
"                        View Record\n"
"                    </a>\n"
"                </p>\n"
"                <p>Kindly review the request.</p>\n"
"            "
msgstr ""
"<p>Geachte heer\n"
"                </p>\n"
"                <p>Er is een goedkeuringsverzoek aan u toegewezen. Hieronder staan de\n"
"                    details:\n"
"                </p>\n"
"                <ul>\n"
"                    <li>\n"
"                        <strong>Verzoek ID:</strong>\n"
"                        <t t-out=\"object.name\"></t>\n"
"                    </li>\n"
"                    <li>\n"
"                        <strong>Aangevraagd door:</strong>\n"
"                        <t t-out=\"object.requested_by_id.name\"></t>\n"
"                    </li>\n"
"                    <li>\n"
"                        <strong>Datum:</strong>\n"
"                        <t t-out=\"object.requested_date\"></t>\n"
"                    </li>\n"
"                </ul>\n"
"                <p>\n"
"                    <a t-att-href=\"'/web#id=%s&amp;model=%s&amp;view_type=form' % (object.res_id, object.model_name)\" class=\"btn btn-primary\">\n"
"                        Record bekijken\n"
"                    </a>\n"
"                </p>\n"
"                <p>Gelieve het verzoek te beoordelen.</p>\n"
"            "

#. module: cyllo_approval
#: model:mail.template,body_html:cyllo_approval.mail_template_request_approved
msgid ""
"<p>Dear<t t-out=\"object.requested_by_id.name\"></t>,\n"
"                </p>\n"
"                <p>Your approval request has been approved.</p>\n"
"                <ul>\n"
"                    <li>\n"
"                        <strong>Request ID:</strong>\n"
"                        <t t-out=\"object.name\"></t>\n"
"                    </li>\n"
"                    <li>\n"
"                        <strong>Approved By:</strong>\n"
"                        <t t-out=\"object.approved_by_id.name\"></t>\n"
"                    </li>\n"
"                    <li>\n"
"                        <strong>Approved Date:</strong>\n"
"                        <t t-out=\"object.approved_date\"></t>\n"
"                    </li>\n"
"                    <t t-if=\"object.comment\">\n"
"                        <li>\n"
"                            <strong>Comment:</strong>\n"
"                            <t t-out=\"object.comment\"></t>\n"
"                        </li>\n"
"                    </t>\n"
"                </ul>\n"
"                <p>\n"
"                    <a t-att-href=\"'/web#id=%s&amp;model=%s&amp;view_type=form' % (object.res_id, object.model_name)\" class=\"btn btn-primary\">\n"
"                        View Record\n"
"                    </a>\n"
"                </p>\n"
"                <p>Thank you.</p>\n"
"            "
msgstr ""
"<p>Geachte <t t-out=\"object.requested_by_id.name\"></t>,\n"
"                </p>\n"
"                <p>Uw goedkeuringsverzoek is goedgekeurd.</p>\n"
"                <ul>\n"
"                    <li>\n"
"                        <strong>Verzoek ID:</strong>\n"
"                        <t t-out=\"object.name\"></t>\n"
"                    </li>\n"
"                    <li>\n"
"                        <strong>Goedgekeurd door:</strong>\n"
"                        <t t-out=\"object.approved_by_id.name\"></t>\n"
"                    </li>\n"
"                    <li>\n"
"                        <strong>Goedgekeurd op:</strong>\n"
"                        <t t-out=\"object.approved_date\"></t>\n"
"                    </li>\n"
"                    <t t-if=\"object.comment\">\n"
"                        <li>\n"
"                            <strong>Commentaar:</strong>\n"
"                            <t t-out=\"object.comment\"></t>\n"
"                        </li>\n"
"                    </t>\n"
"                </ul>\n"
"                <p>\n"
"                    <a t-att-href=\"'/web#id=%s&amp;model=%s&amp;view_type=form' % (object.res_id, object.model_name)\" class=\"btn btn-primary\">\n"
"                        Record bekijken\n"
"                    </a>\n"
"                </p>\n"
"                <p>Dank u.</p>\n"
"            "

