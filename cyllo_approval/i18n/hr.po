#. module: cyllo_approval
#: model:mail.template,body_html:cyllo_approval.mail_template_approval_request
msgid ""
"<p>Dear Sir\n"
"                </p>\n"
"                <p>An approval request has been assigned to you. Below are the\n"
"                    details:\n"
"                </p>\n"
"                <ul>\n"
"                    <li>\n"
"                        <strong>Request ID:</strong>\n"
"                        <t t-out=\"object.name\"></t>\n"
"                    </li>\n"
"                    <li>\n"
"                        <strong>Requested By:</strong>\n"
"                        <t t-out=\"object.requested_by_id.name\"></t>\n"
"                    </li>\n"
"                    <li>\n"
"                        <strong>Date:</strong>\n"
"                        <t t-out=\"object.requested_date\"></t>\n"
"                    </li>\n"
"                </ul>\n"
"                <p>\n"
"                    <a t-att-href=\"'/web#id=%s&amp;model=%s&amp;view_type=form' % (object.res_id, object.model_name)\" class=\"btn btn-primary\">\n"
"                        View Record\n"
"                    </a>\n"
"                </p>\n"
"                <p>Kindly review the request.</p>\n"
"            "
msgstr ""
"<p>Poštovani gospodine\n"
"                </p>\n"
"                <p>Dodijeljen vam je zahtjev za odobrenje. U nastavku su\n"
"                    detalji:\n"
"                </p>\n"
"                <ul>\n"
"                    <li>\n"
"                        <strong>ID zahtjeva:</strong>\n"
"                        <t t-out=\"object.name\"></t>\n"
"                    </li>\n"
"                    <li>\n"
"                        <strong>Zahtijevao:</strong>\n"
"                        <t t-out=\"object.requested_by_id.name\"></t>\n"
"                    </li>\n"
"                    <li>\n"
"                        <strong>Datum:</strong>\n"
"                        <t t-out=\"object.requested_date\"></t>\n"
"                    </li>\n"
"                </ul>\n"
"                <p>\n"
"                    <a t-att-href=\"'/web#id=%s&amp;model=%s&amp;view_type=form' % (object.res_id, object.model_name)\" class=\"btn btn-primary\">\n"
"                        Pregledaj zapis\n"
"                    </a>\n"
"                </p>\n"
"                <p>Molimo pregledajte zahtjev.</p>\n"
"            "

#. module: cyllo_approval
#: model:mail.template,body_html:cyllo_approval.mail_template_request_approved
msgid ""
"<p>Dear<t t-out=\"object.requested_by_id.name\"></t>,\n"
"                </p>\n"
"                <p>Your approval request has been approved.</p>\n"
"                <ul>\n"
"                    <li>\n"
"                        <strong>Request ID:</strong>\n"
"                        <t t-out=\"object.name\"></t>\n"
"                    </li>\n"
"                    <li>\n"
"                        <strong>Approved By:</strong>\n"
"                        <t t-out=\"object.approved_by_id.name\"></t>\n"
"                    </li>\n"
"                    <li>\n"
"                        <strong>Approved Date:</strong>\n"
"                        <t t-out=\"object.approved_date\"></t>\n"
"                    </li>\n"
"                    <t t-if=\"object.comment\">\n"
"                        <li>\n"
"                            <strong>Comment:</strong>\n"
"                            <t t-out=\"object.comment\"></t>\n"
"                        </li>\n"
"                    </t>\n"
"                </ul>\n"
"                <p>\n"
"                    <a t-att-href=\"'/web#id=%s&amp;model=%s&amp;view_type=form' % (object.res_id, object.model_name)\" class=\"btn btn-primary\">\n"
"                        View Record\n"
"                    </a>\n"
"                </p>\n"
"                <p>Thank you.</p>\n"
"            "
msgstr ""
"<p>Poštovani<t t-out=\"object.requested_by_id.name\"></t>,\n"
"                </p>\n"
"                <p>Vaš zahtjev za odobrenje je odobren.</p>\n"
"                <ul>\n"
"                    <li>\n"
"                        <strong>ID zahtjeva:</strong>\n"
"                        <t t-out=\"object.name\"></t>\n"
"                    </li>\n"
"                    <li>\n"
"                        <strong>Odobrio:</strong>\n"
"                        <t t-out=\"object.approved_by_id.name\"></t>\n"
"                    </li>\n"
"                    <li>\n"
"                        <strong>Datum odobrenja:</strong>\n"
"                        <t t-out=\"object.approved_date\"></t>\n"
"                    </li>\n"
"                    <t t-if=\"object.comment\">\n"
"                        <li>\n"
"                            <strong>Komentar:</strong>\n"
"                            <t t-out=\"object.comment\"></t>\n"
"                        </li>\n"
"                    </t>\n"
"                </ul>\n"
"                <p>\n"
"                    <a t-att-href=\"'/web#id=%s&amp;model=%s&amp;view_type=form' % (object.res_id, object.model_name)\" class=\"btn btn-primary\">\n"
"                        Pregledaj zapis\n"
"                    </a>\n"
"                </p>\n"
"                <p>Hvala.</p>\n"
"            "

#. module: cyllo_approval
#: model:mail.template,body_html:cyllo_approval.mail_template_request_rejected
msgid ""
"<p>Dear<t t-out=\"object.requested_by_id.name\"></t>,\n"
"                </p>\n"
"                <p>Your approval request has been rejected.</p>\n"
"                <ul>\n"
"                    <li>\n"
"                        <strong>Request ID:</strong>\n"
"                        <t t-out=\"object.name\"></t>\n"
"                    </li>\n"
"                    <li>\n"
"                        <strong>Rejected By:</strong>\n"
"                        <t t-out=\"object.rejected_by_id.name\"></t>\n"
"                    </li>\n"
"                </ul>\n"
"                <p>\n"
"                    <a t-att-href=\"'/web#id=%s&amp;model=%s&amp;view_type=form' % (object.res_id, object.model_name)\" class=\"btn btn-primary\">\n"
"                        View Record\n"
"                    </a>\n"
"                </p>\n"
"                <p>Thank you.</p>\n"
"            "
msgstr ""
"<p>Poštovani<t t-out=\"object.requested_by_id.name\"></t>,\n"
"                </p>\n"
"                <p>Vaš zahtjev za odobrenje je odbijen.</p>\n"
"                <ul>\n"
"                    <li>\n"
"                        <strong>ID zahtjeva:</strong>\n"
"                        <t t-out=\"object.name\"></t>\n"
"                    </li>\n"
"                    <li>\n"
"                        <strong>Odbio:</strong>\n"
"                        <t t-out=\"object.rejected_by_id.name\"></t>\n"
"                    </li>\n"
"                </ul>\n"
"                <p>\n"
"                    <a t-att-href=\"'/web#id=%s&amp;model=%s&amp;view_type=form' % (object.res_id, object.model_name)\" class=\"btn btn-primary\">\n"
"                        Pregledaj zapis\n"
"                    </a>\n"
"                </p>\n"
"                <p>Hvala.</p>\n"
"            "

