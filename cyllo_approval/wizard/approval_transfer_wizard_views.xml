<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_approval_transfer_wizard_form" model="ir.ui.view">
        <field name="name">approval.transfer.wizard.form</field>
        <field name="model">approval.transfer.wizard</field>
        <field name="arch" type="xml">
            <form string="Approval Transfer" create="false" edit="false">
                 <group>
                    <field name="request_id" readonly="1"/>
                    <field name="current_user_id" readonly="1"/>
                    <field name="user_id" options="{'no_create': True}"/>
                </group>
                <footer>
                    <button string="Transfer" type="object" name="action_transfer_approval" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>


</odoo>
