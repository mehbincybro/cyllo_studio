<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_approval_request_wizard_form" model="ir.ui.view">
        <field name="name">approval.request.wizard.form</field>
        <field name="model">approval.request.wizard</field>
        <field name="arch" type="xml">
            <form string="Approval Required" create="false" edit="false">
                    <p>
                        This action requires an approval.
<!--                        <b><field name="rule_id" options="{'no_open': True}"/></b>.-->
                        Do you want to create an approval request?
                    </p>
                <footer>
                    <button string="Request Approval" type="object" name="action_request_approval" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>


</odoo>
