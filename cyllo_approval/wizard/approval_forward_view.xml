<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_approval_forward_form" model="ir.ui.view">
        <field name="name">view.approval.forward.form</field>
        <field name="model">approval.forward</field>
        <field name="arch" type="xml">
            <form string="Forward Approval">
                <group>
                    <field name="approval_request_id" readonly="1"/>
                    <field name="from_user_ids" widget="many2many_tags"
                           readonly="1"/>
                    <field name="approver_ids" invisible="1"/>
                    <field name="to_user_ids" widget="many2many_tags"
                           domain="[('id', 'in', approver_ids)]"/>
                </group>
                <footer>
                    <button string="Confirm" type="object"
                            name="action_confirm_forward" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
