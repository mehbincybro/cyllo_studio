<odoo>
    <template id="portal_my_home_request" name="Show Requests" inherit_id="portal.portal_my_home">
        <xpath expr="//div[hasclass('o_portal_docs')]" position="before">
            <t t-set="portal_client_category_enable" t-value="True"/>
            <t t-set="portal_vendor_category_enable" t-value="True"/>
        </xpath>
        <div id="portal_client_category" position="inside">
            <t t-call="portal.portal_docs_entry">
                <t t-set="icon" t-value="'/account/static/src/img/Bill.svg'"/>
                <t t-set="title">Approval Requests</t>
                <t t-set="url" t-value="'/my/approval_requests?user_id=%s' % request.uid"/>
                <t t-set="text">Follow, download or pay your invoices</t>
                <t t-set="placeholder_count" t-value="'invoice_count'"/>
            </t>
        </div>
    </template>
    <template id="portal_my_approval_requests" name="Approval Requests Page">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True"/>
            <t t-call="portal.portal_searchbar">
                <t t-set="title">Approval Request</t>
            </t>
            <t t-call="portal.portal_table">
                <thead>
                    <tr class="active">
                        <th class="text-left">Request Name</th>
                        <th class="text-center">Requested By</th>
                        <th class="text-center">Model Name</th>
                        <th class="text-end">State</th>
                    </tr>
                </thead>
                <t t-foreach="approval_requests" t-as="record">
                    <tr>
                        <td class='text-left'>
                            <span t-field="record.name"/>
                        </td>
                        <td class='text-center'>
                            <span t-field="record.requested_by_id"/>
                        </td>
                        <td class='text-center'>
                            <span t-field="record.model_name"/>
                        </td>
                        <td class='text-end'>
                            <span t-field="record.state"/>
                        </td>
                        <td class='text-center'>
                            <form method="post" action="/my/approval_request/action">
                                <input type="hidden" name="request_id" t-att-value="record.id"/>
                                <t t-if="record.state != 'approved'">
                                    <button type="submit" name="action" value="accept" class="btn btn-success">Accept
                                    </button>
                                </t>
                                <button type="submit" name="action" value="reject" class="btn btn-danger">Reject
                                </button>
                            </form>
                        </td>
                    </tr>
                </t>
            </t>
        </t>
    </template>
</odoo>