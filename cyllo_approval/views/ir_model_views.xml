<?xml version="1.0"?>
<odoo>

    <record id="ir_model_form" model="ir.ui.view">
        <field name="name">ir.model.form.inherited</field>
        <field name="model">ir.model</field>
        <field name="inherit_id" ref="base.view_model_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='modules']" position="after">
                <field name="approval_need"/>
            </xpath>
        </field>
    </record>
</odoo>
