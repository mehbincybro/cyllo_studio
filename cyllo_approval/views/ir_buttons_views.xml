<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="ir_buttons_view_list" model="ir.ui.view">
        <field name="name">ir.buttons.view.list</field>
        <field name="model">ir.buttons</field>
        <field name="arch" type="xml">
            <tree create="false">
                <header>
                    <button name="action_sync_buttons" string="Sync Buttons"
                            type="object" class="oe_highlight"/>
                </header>
                <field name="name"/>
                <field name="string"/>
                <field name="model_id" context="{'model': True}"/>
            </tree>
        </field>
    </record>

    <record id="action_ir_buttons" model="ir.actions.act_window">
        <field name="name">Buttons</field>
        <field name="res_model">ir.buttons</field>
        <field name="view_mode">tree</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face"></p>
        </field>
    </record>

    <menuitem id="menu_ir_buttons" name="Buttons" parent="base.next_id_2"
              action="action_ir_buttons" sequence="10"/>
</odoo>
