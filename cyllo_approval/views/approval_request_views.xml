<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_approval_request_tree" model="ir.ui.view">
        <field name="name">approval.request.tree</field>
        <field name="model">approval.request</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="rule_id"/>
                <field name="res_model"/>
                <field name="res_id"/>
                <field name="requested_by"/>
                <field name="company_id" groups="base.group_multi_company" optional="show"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <record id="view_approval_request_form" model="ir.ui.view">
        <field name="name">approval.request.form</field>
        <field name="model">approval.request</field>
        <field name="arch" type="xml">
            <form string="Approval Request">
                <header>
                    <field name="can_approve" invisible="1"/>
                    <button name="action_approve" type="object" string="Approve" class="btn-primary"
                            invisible="not can_approve or state != 'pending'"/>
                    <button name="action_reject" type="object" string="Reject" class="btn-secondary"
                            invisible="not can_approve or state != 'pending'"/>
                    <button name="action_transfer" type="object" string="Transfer" class="btn-info"
                            invisible="not can_approve or state != 'pending'"/>
                    <button name="action_open_related_record"
                            string="View Document"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-external-link"/>
                    <field name="state" widget="statusbar" statusbar_visible="pending,approved,rejected"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="rule_id" readonly="1" options="{'no_open': True}"/>
                            <field name="rule_type" readonly="1"/>
                            <field name="res_model" readonly="1"/>
                            <field name="res_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="requested_by" readonly="1"/>
                            <field name="approver_id" readonly="1"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <group string="Response Details">
                        <field name="note" placeholder="Reason for rejection or transfer..."/>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="activity_ids" widget="mail_activity"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_approval_request_search" model="ir.ui.view">
        <field name="name">approval.request.search</field>
        <field name="model">approval.request</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="rule_id"/>
                <field name="requested_by"/>
                <filter string="Pending" name="pending" domain="[('state', '=', 'pending')]"/>
                <filter string="Approved" name="approved" domain="[('state', '=', 'approved')]"/>
                <filter string="Rejected" name="rejected" domain="[('state', '=', 'rejected')]"/>
                <group expand="0" string="Group By">
                    <filter string="Rule" name="group_rule" context="{'group_by': 'rule_id'}"/>
                    <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_approval_request" model="ir.actions.act_window">
        <field name="name">Approval Requests</field>
        <field name="res_model">approval.request</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'create': False}</field>
    </record>

    <menuitem id="menu_approval_requests" name="Requests"
              parent="menu_approval_root" action="action_approval_request" sequence="20"/>
</odoo>
