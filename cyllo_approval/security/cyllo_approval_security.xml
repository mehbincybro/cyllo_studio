<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_cyllo_approval" model="ir.module.category">
        <field name="name">Cyllo Approval</field>
        <field name="description">Helps you manage approval requests.</field>
        <field name="sequence">10</field>
    </record>

    <record id="group_approval_user" model="res.groups">
        <field name="name">User</field>
        <field name="category_id" ref="module_category_cyllo_approval"/>
        <field name="implied_ids" eval="[Command.link(ref('base.group_user'))]"/>
    </record>

    <record id="group_approval_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="category_id" ref="module_category_cyllo_approval"/>
        <field name="implied_ids" eval="[Command.link(ref('group_approval_user'))]"/>
        <field name="users" eval="[Command.link(ref('base.user_root')), Command.link(ref('base.user_admin'))]"/>
    </record>

    <!-- Record Rules -->
    <record id="rule_approval_request_user" model="ir.rule">
        <field name="name">Approval Request: User Visibility</field>
        <field name="model_id" ref="model_approval_request"/>
        <field name="domain_force">['|', '|', ('requested_by', '=', user.id), ('approver_id', '=', user.id), ('rule_id.group_id', 'in', user.groups_id.ids)]</field>
        <field name="groups" eval="[Command.link(ref('group_approval_user'))]"/>
    </record>

    <record id="rule_approval_request_manager" model="ir.rule">
        <field name="name">Approval Request: Manager Visibility</field>
        <field name="model_id" ref="model_approval_request"/>
        <field name="domain_force">[]</field>
        <field name="groups" eval="[Command.link(ref('group_approval_manager'))]"/>
    </record>

    <record id="rule_approval_request_company" model="ir.rule">
        <field name="name">Approval Request: Multi-Company</field>
        <field name="model_id" ref="model_approval_request"/>
        <field name="domain_force">['|', ('company_id', '=', False),
            ('company_id', 'in', company_ids)]
        </field>
    </record>

</odoo>
