<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--    Report Action of Budget Pdf-->
    <record id="report_budget_pdf" model="ir.actions.report">
        <field name="name">Budget Pdf</field>
        <field name="model">budget.budget</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">cyllo_budget_management.report_budget_document</field>
        <field name="report_file">cyllo_budget_management.report_budget_document</field>
        <field name="print_report_name">'Budget Report - %s' % (object.name)
        </field>
        <field name="binding_model_id"
               ref="cyllo_budget_management.model_budget_budget"/>
        <field name="binding_view_types">form</field>
        <field name="binding_type">report</field>
    </record>
    <!--    Report Action of Debt Pdf-->

    <record id="report_pdf_debt_management" model="ir.actions.report">
        <field name="name">Debt Pdf</field>
        <field name="model">debt.management</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">cyllo_budget_management.report_debt_document</field>
        <field name="report_file">cyllo_budget_management.report_debt_document</field>
        <field name="print_report_name">'Debt Report - %s' %
            (object.display_name)
        </field>
        <field name="binding_model_id"
               ref="cyllo_budget_management.model_debt_management"/>
        <field name="binding_view_types">form</field>
        <field name="binding_type">report</field>
    </record>
</odoo>