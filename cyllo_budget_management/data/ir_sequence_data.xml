<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!--Defines a sequence for Debt Management.
        Code: debt.management
        Prefix: DTR, Padding: 5 digits-->
    <record id="ir_sequence_debt_management" model="ir.sequence">
        <field name="name">Debt Management</field>
        <field name="code">debt.management</field>
        <field name="prefix">DBM</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>

</odoo>
