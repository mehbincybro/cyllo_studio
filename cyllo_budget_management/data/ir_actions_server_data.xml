<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
<!--    Server Action For Xlsx Report-->
    <record id="model_budget_xlsx" model="ir.actions.server">
        <field name="name">Budget XLSX</field>
        <field name="model_id" ref="cyllo_budget_management.model_budget_budget"/>
        <field name="binding_model_id" ref="model_budget_budget"/>
        <field name="binding_view_types">form</field>
        <field name="binding_type">report</field>
        <field name="state">code</field>
        <field name="code">action = model.action_generate_xlsx()</field>
    </record>

    <record id="model_debt_xlsx" model="ir.actions.server">
        <field name="name">Debt XLSX</field>
        <field name="model_id" ref="cyllo_budget_management.model_debt_management"/>
        <field name="binding_model_id" ref="model_debt_management"/>
        <field name="binding_view_types">form</field>
        <field name="binding_type">report</field>
        <field name="state">code</field>
        <field name="code">action = model.action_generate_xlsx()</field>

    </record>
</odoo>