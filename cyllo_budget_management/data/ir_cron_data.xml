<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--Scheduled Action for Payback in debt management-->
    <record id="ir_cron_payback_mail" model="ir.cron">
        <field name="name">Payback Mail</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="model_id" ref="cyllo_budget_management.model_debt_management"/>
        <field name="code">model.payback_mail()</field>
        <field name="state">code</field>
    </record>

    <!--Scheduled Action for Budget Delay in Budget Management-->
    <record id="ir_cron_budget_delay_mail" model="ir.cron">
        <field name="name">Budget Delay Mail</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="model_id" ref="cyllo_budget_management.model_budget_budget"/>
        <field name="code">model.budget_delay_mail()</field>
        <field name="state">code</field>
    </record>
</odoo>
