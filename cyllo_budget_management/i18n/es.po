#. module: cyllo_budget_management
#: model:mail.template,body_html:cyllo_budget_management.mail_template_payback_alert
msgid ""
"<div style=\"background-color: #f9f9f9; padding: 20px;\">\n"
"                <p style=\"font-size: 16px; color: #333;\">\n"
"                    Hi There,\n"
"                    <br>\n"
"                    Payback date of the debt\n"
"                    <t t-out=\"object.display_name\"></t>\n"
"                    is tomorrow.\n"
"                    <table class=\"table\" style=\" border-collapse: collapse;width: 100%;\">\n"
"                        <thead class=\"table-light\" style=\"background-color: #f2f2f2;  padding: 8px;text-align: left;border-bottom: 1px solid #ddd;\">\n"
"                            <th>\n"
"                                Debt Type\n"
"                            </th>\n"
"                            <th>\n"
"                                Partner\n"
"                            </th>\n"
"                            <th>\n"
"                                Amount\n"
"                            </th>\n"
"                            <th>\n"
"                                Payback Date\n"
"                            </th>\n"
"                            <th>\n"
"                                State\n"
"                            </th>\n"
"                        </thead>\n"
"                        <tr>\n"
"                            <td style=\"text-align: center;padding: 8px;text-align: left;border-bottom: 1px solid #ddd;\">\n"
"                                <t t-esc=\"object.debt_type\"></t>\n"
"                            </td>\n"
"                            <td style=\"text-align: center;padding: 8px;text-align: left;border-bottom: 1px solid #ddd;\">\n"
"                                <t t-esc=\"object.person_id.name\"></t>\n"
"                            </td>\n"
"                            <td style=\"text-align: center;padding: 8px;text-align: left;border-bottom: 1px solid #ddd;\">\n"
"                                <t t-esc=\"object.amount\"></t>\n"
"                                <t t-esc=\"object.currency_id.symbol\"></t>\n"
"                            </td>\n"
"                            <td style=\"text-align: center;padding: 8px;text-align: left;border-bottom: 1px solid #ddd;\">\n"
"                                <t t-esc=\"object.payback_date\"></t>\n"
"                            </td>\n"
"                            <td style=\"text-align: center;padding: 8px;text-align: left;border-bottom: 1px solid #ddd;\">\n"
"                                <t t-if=\"object.state == 'lend_borrow'\">\n"
"                                    Lend/Borrowed\n"
"                                </t>\n"
"                                <t t-if=\"object.state == 'partial_return'\">\n"
"                                    Partially Returned\n"
"                                </t>\n"
"                            </td>\n"
"                        </tr>\n"
"                    </table>\n"
"                    <br>\n"
"                    <br>\n"
"                    Kind regards,\n"
"                </p>\n"
"            </div>\n"
"        "
msgstr ""
"<div style = \"Color de fondo: #F9F9F9; Padding: 20px;\">\n"
"<p style = \"Font-Size: 16px; color: #333;\">\n"
"Hola,\n"
"<br>\n"
"Fecha de recuperación de la deuda\n"
"<t tout = \"object.display_name\"> </t>\n"
"es mañana.\n"
"<table class = \"table\" style = \"border-colapso: colapso; ancho: 100%;\">\n"
"<thhead class = \"table-light\" style = \"de fondo de fondo: #f2f2f2; relleno: 8px; text-align: left; border-bottom: 1px solid #ddd;\">\n"
"<th>\n"
"Tipo de deuda\n"
"</th>\n"
"<th>\n"
"Pareja\n"
"</th>\n"
"<th>\n"
"Cantidad\n"
"</th>\n"
"<th>\n"
"Fecha de recuperación\n"
"</th>\n"
"<th>\n"
"Estado\n"
"</th>\n"
"</thead>\n"
"<tr>\n"
"<td style = \"text-align: Center; relleno: 8px; text-align: izquierda; border-bottom: 1px solid #ddd;\">\n"
"<t t-esc = \"object.debt_type\"> </t>\n"
"</td>\n"
"<td style = \"text-align: Center; relleno: 8px; text-align: izquierda; border-bottom: 1px solid #ddd;\">\n"
"<t t-esc = \"objeto.person_id.name\"> </t>\n"
"</td>\n"
"<td style = \"text-align: Center; relleno: 8px; text-align: izquierda; border-bottom: 1px solid #ddd;\">\n"
"<t t-esc = \"objeto.amount\"> </t>\n"
"<t t-esc = \"objeto.currency_id.symbol\"> </t>\n"
"</td>\n"
"<td style = \"text-align: Center; relleno: 8px; text-align: izquierda; border-bottom: 1px solid #ddd;\">\n"
"<t t-esc = \"objeto.payback_date\"> </t>\n"
"</td>\n"
"<td style = \"text-align: Center; relleno: 8px; text-align: izquierda; border-bottom: 1px solid #ddd;\">\n"
"<t t-if = \"object.state == 'Lend_Borrow'\">\n"
"Prestado/prestado\n"
"</t>\n"
"<t t-if = \"object.state == 'parcial_return'\">\n"
"Devuelto parcialmente\n"
"</t>\n"
"</td>\n"
"</tr>\n"
"</able>\n"
"<br>\n"
"<br>\n"
"Atentamente,\n"
"</p>\n"
"</div>"

