#. module: cyllo_budget_management
#: model:mail.template,body_html:cyllo_budget_management.mail_template_payback_alert
msgid ""
"<div style=\"background-color: #f9f9f9; padding: 20px;\">\n"
"                <p style=\"font-size: 16px; color: #333;\">\n"
"                    Hi There,\n"
"                    <br>\n"
"                    Payback date of the debt\n"
"                    <t t-out=\"object.display_name\"></t>\n"
"                    is tomorrow.\n"
"                    <table class=\"table\" style=\" border-collapse: collapse;width: 100%;\">\n"
"                        <thead class=\"table-light\" style=\"background-color: #f2f2f2;  padding: 8px;text-align: left;border-bottom: 1px solid #ddd;\">\n"
"                            <th>\n"
"                                Debt Type\n"
"                            </th>\n"
"                            <th>\n"
"                                Partner\n"
"                            </th>\n"
"                            <th>\n"
"                                Amount\n"
"                            </th>\n"
"                            <th>\n"
"                                Payback Date\n"
"                            </th>\n"
"                            <th>\n"
"                                State\n"
"                            </th>\n"
"                        </thead>\n"
"                        <tr>\n"
"                            <td style=\"text-align: center;padding: 8px;text-align: left;border-bottom: 1px solid #ddd;\">\n"
"                                <t t-esc=\"object.debt_type\"></t>\n"
"                            </td>\n"
"                            <td style=\"text-align: center;padding: 8px;text-align: left;border-bottom: 1px solid #ddd;\">\n"
"                                <t t-esc=\"object.person_id.name\"></t>\n"
"                            </td>\n"
"                            <td style=\"text-align: center;padding: 8px;text-align: left;border-bottom: 1px solid #ddd;\">\n"
"                                <t t-esc=\"object.amount\"></t>\n"
"                                <t t-esc=\"object.currency_id.symbol\"></t>\n"
"                            </td>\n"
"                            <td style=\"text-align: center;padding: 8px;text-align: left;border-bottom: 1px solid #ddd;\">\n"
"                                <t t-esc=\"object.payback_date\"></t>\n"
"                            </td>\n"
"                            <td style=\"text-align: center;padding: 8px;text-align: left;border-bottom: 1px solid #ddd;\">\n"
"                                <t t-if=\"object.state == 'lend_borrow'\">\n"
"                                    Lend/Borrowed\n"
"                                </t>\n"
"                                <t t-if=\"object.state == 'partial_return'\">\n"
"                                    Partially Returned\n"
"                                </t>\n"
"                            </td>\n"
"                        </tr>\n"
"                    </table>\n"
"                    <br>\n"
"                    <br>\n"
"                    Kind regards,\n"
"                </p>\n"
"            </div>\n"
"        "
msgstr ""
"<div style = \"pozadinska boja: #f9f9f9; padding: 20px;\">\n"
"<p style = \"font-size: 16px; boja: #333;\">\n"
"Bok tamo,\n"
"<br>\n"
"Datum povrata duga\n"
"<t t-out = \"objekt.display_name\"> </t>\n"
"je sutra.\n"
"<tablica class = \"tablica\" stil = \"granični kolnik: kolaps; širina: 100%;\">\n"
"<thead class = \"tablica svjetla\" stil = \"pozadinska boja: #f2f2f2; padding: 8px; text-ellign: lijevo; granica dna: 1px solid #ddd;\">\n"
"<h>\n"
"Tip duga\n"
"</h>\n"
"<h>\n"
"Partner\n"
"</h>\n"
"<h>\n"
"Iznositi\n"
"</h>\n"
"<h>\n"
"Datum povrata\n"
"</h>\n"
"<h>\n"
"Stanje\n"
"</h>\n"
"</head>\n"
"<tr>\n"
"<td style = \"Text-align: Centar; padding: 8px; Text-align: lijevo; granica dna: 1px solid #ddd;\">\n"
"<t t-esc = \"Object.debt_type\"> </t>\n"
"</td>\n"
"<td style = \"Text-align: Centar; padding: 8px; Text-align: lijevo; granica dna: 1px solid #ddd;\">\n"
"<t t-esc = \"Object.person_id.name\"> </t>\n"
"</td>\n"
"<td style = \"Text-align: Centar; padding: 8px; Text-align: lijevo; granica dna: 1px solid #ddd;\">\n"
"<t t-esc = \"objekt.amount\"> </t>\n"
"<t t-esc = \"Object.Currency_ID.Symbol\"> </t>\n"
"</td>\n"
"<td style = \"Text-align: Centar; padding: 8px; Text-align: lijevo; granica dna: 1px solid #ddd;\">\n"
"<t t-esc = \"Object.payback_date\"> </t>\n"
"</td>\n"
"<td style = \"Text-align: Centar; padding: 8px; Text-align: lijevo; granica dna: 1px solid #ddd;\">\n"
"<t t-if = \"Object.State == 'LEND_BORM'\">\n"
"Posuditi/posuditi\n"
"</t>\n"
"<t t-if = \"Object.State == 'Partial_return'\">\n"
"Djelomično vraćen\n"
"</t>\n"
"</td>\n"
"</tr>\n"
"</BALPER>\n"
"<br>\n"
"<br>\n"
"Ljubazan pozdrav,\n"
"</p>\n"
"</IV>\n"

