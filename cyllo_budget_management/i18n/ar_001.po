#. module: cyllo_budget_management
#: model:mail.template,body_html:cyllo_budget_management.mail_template_budget_delay_mail
msgid ""
"<div style=\"background-color: #f9f9f9; padding: 20px;\">\n"
"                <p style=\"font-size: 16px; color: #333;\">\n"
"                    Hi  <t t-out=\"object.responsible_id.name\"></t>,\n"
"                    <br>\n"
"                    Your budget\n"
"                    <b>\n"
"                        <t t-out=\"object.name\"></t>\n"
"                    </b>\n"
"                    achievement is currently low. Let's work on increasing it before the due date of\n"
"                    <b>\n"
"                        <t t-out=\"object.due_date\"></t>\n"
"                    </b>\n"
"                    .\n"
"                    Attached the pdf report along with this mail.\n"
"                </p>\n"
"            </div>\n"
"        "
msgstr ""
"<div style = \"background-color: #f9f9f9 ؛ padding: 20px ؛\">\n"
"<p style = \"font-size: 16px ؛ color: #333 ؛\">\n"
"مرحبًا <t tout = \"object.sponsible_id.name\"> </t> ،\n"
"<br>\n"
"ميزانيتك\n"
"<b>\n"
"<t tout = \"object.name\"> </t>\n"
"</b>\n"
