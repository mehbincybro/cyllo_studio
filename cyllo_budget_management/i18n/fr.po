#. module: cyllo_budget_management
#: model:mail.template,body_html:cyllo_budget_management.mail_template_payback_alert
msgid ""
"<div style=\"background-color: #f9f9f9; padding: 20px;\">\n"
"                <p style=\"font-size: 16px; color: #333;\">\n"
"                    Hi There,\n"
"                    <br>\n"
"                    Payback date of the debt\n"
"                    <t t-out=\"object.display_name\"></t>\n"
"                    is tomorrow.\n"
"                    <table class=\"table\" style=\" border-collapse: collapse;width: 100%;\">\n"
"                        <thead class=\"table-light\" style=\"background-color: #f2f2f2;  padding: 8px;text-align: left;border-bottom: 1px solid #ddd;\">\n"
"                            <th>\n"
"                                Debt Type\n"
"                            </th>\n"
"                            <th>\n"
"                                Partner\n"
"                            </th>\n"
"                            <th>\n"
"                                Amount\n"
"                            </th>\n"
"                            <th>\n"
"                                Payback Date\n"
"                            </th>\n"
"                            <th>\n"
"                                State\n"
"                            </th>\n"
"                        </thead>\n"
"                        <tr>\n"
"                            <td style=\"text-align: center;padding: 8px;text-align: left;border-bottom: 1px solid #ddd;\">\n"
"                                <t t-esc=\"object.debt_type\"></t>\n"
"                            </td>\n"
"                            <td style=\"text-align: center;padding: 8px;text-align: left;border-bottom: 1px solid #ddd;\">\n"
"                                <t t-esc=\"object.person_id.name\"></t>\n"
"                            </td>\n"
"                            <td style=\"text-align: center;padding: 8px;text-align: left;border-bottom: 1px solid #ddd;\">\n"
"                                <t t-esc=\"object.amount\"></t>\n"
"                                <t t-esc=\"object.currency_id.symbol\"></t>\n"
"                            </td>\n"
"                            <td style=\"text-align: center;padding: 8px;text-align: left;border-bottom: 1px solid #ddd;\">\n"
"                                <t t-esc=\"object.payback_date\"></t>\n"
"                            </td>\n"
"                            <td style=\"text-align: center;padding: 8px;text-align: left;border-bottom: 1px solid #ddd;\">\n"
"                                <t t-if=\"object.state == 'lend_borrow'\">\n"
"                                    Lend/Borrowed\n"
"                                </t>\n"
"                                <t t-if=\"object.state == 'partial_return'\">\n"
"                                    Partially Returned\n"
"                                </t>\n"
"                            </td>\n"
"                        </tr>\n"
"                    </table>\n"
"                    <br>\n"
"                    <br>\n"
"                    Kind regards,\n"
"                </p>\n"
"            </div>\n"
"        "
msgstr ""
"<div style = \"Background-Color: # f9f9f9; padding: 20px;\">\n"
"<p style = \"Font-Size: 16px; couleur: # 333;\">\n"
"Salut,\n"
"<br>\n"
"Date de récupération de la dette\n"
"<t t-out = \"object.display_name\"> </t>\n"
"est demain.\n"
"<table class = \"table\" style = \"border-collapse: effondrement; largeur: 100%;\">\n"
"<thead class = \"table-light\" style = \"background-color: # f2f2f2; padding: 8px; text-align: Left; border-bottom: 1px solide #ddd;\">\n"
"<h>\n"
"Type de dette\n"
"</th>\n"
"<h>\n"
"Partenaire\n"
"</th>\n"
"<h>\n"
"Montant\n"
"</th>\n"
"<h>\n"
"Date de récupération\n"
"</th>\n"
"<h>\n"
"État\n"
"</th>\n"
"</thEad>\n"
"<tr>\n"
"<TD Style = \"Text-Align: Centre; Padding: 8px; Text-Align: Left; Border-Bottom: 1px solide #ddd;\">\n"
"<t t-esc = \"object.debt_type\"> </t>\n"
"</td>\n"
"<TD Style = \"Text-Align: Centre; Padding: 8px; Text-Align: Left; Border-Bottom: 1px solide #ddd;\">\n"
"<t t-esc = \"object.person_id.name\"> </t>\n"
"</td>\n"
"<TD Style = \"Text-Align: Centre; Padding: 8px; Text-Align: Left; Border-Bottom: 1px solide #ddd;\">\n"
"<t t-esc = \"object.amount\"> </t>\n"
"<t t-esc = \"object.currency_id.symbol\"> </ t>\n"
"</td>\n"
"<TD Style = \"Text-Align: Centre; Padding: 8px; Text-Align: Left; Border-Bottom: 1px solide #ddd;\">\n"
"<t t-esc = \"object.payback_date\"> </t>\n"
"</td>\n"
"<TD Style = \"Text-Align: Centre; Padding: 8px; Text-Align: Left; Border-Bottom: 1px solide #ddd;\">\n"
"<t t-if = \"object.state == 'LAND_BROROR'\">\n"
"Prêter / emprunter\n"
"</t>\n"
"<t t-if = \"object.state == 'partial_return'\">\n"
"Partiellement retourné\n"
"</t>\n"
"</td>\n"
"</tr>\n"
"</ table>\n"
"<br>\n"
"<br>\n"
"Cordialement,\n"
"</p>\n"
"</div>"

