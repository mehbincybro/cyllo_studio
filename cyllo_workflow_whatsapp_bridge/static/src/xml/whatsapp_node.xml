<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <t t-name="cyllo_workflow_whatsapp_bridge.WhatsAppNodeDialog" owl="1">
        <Dialog contentClass="'cy-work-config-modal'">
            <t t-set-slot="header">
                <h4 class="mb-0">WhatsApp</h4>
            </t>
            <div class="modal-body py-3">
                <div class="mb-3">
                    <label class="form-label">Label</label>
                    <input class="form-control" t-att-value="state.label" t-on-input="onChangeLabel"/>
                </div>
                <div class="mb-3">
                    <label class="form-label">Mode</label>
                    <select class="form-select" t-on-change="onChangeMode">
                        <option value="template" t-att-selected="state.whatsapp_isTemplate">Template</option>
                        <option value="custom" t-att-selected="!state.whatsapp_isTemplate">Custom Message</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label">Record</label>
                    <select class="form-select" t-on-change="onChangeRecord">
                        <option value="">Select a record</option>
                        <t t-foreach="recordOptions" t-as="record" t-key="record.id">
                            <option t-att-value="record.id" t-att-selected="selectedRecordValue === record.id">
                                <t t-out="record.variable_name"/>
                            </option>
                        </t>
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label">Recipient</label>
                    <Many2XAutocomplete
                        resModel="'res.partner'"
                        getDomain.bind="getPartnerDomain"
                        fieldString="'Partner'"
                        activeActions="{}"
                        update.bind="onSelectPartner"
                        value="selectedPartnerName"
                    />
                </div>
                <div class="mb-3" t-if="state.whatsapp_isTemplate">
                    <label class="form-label">WhatsApp Template</label>
                    <Many2XAutocomplete
                        resModel="'whatsapp.template'"
                        getDomain.bind="getTemplateDomain"
                        fieldString="'WhatsApp Template'"
                        activeActions="{}"
                        update.bind="onSelectTemplate"
                        value="selectedTemplateName"
                    />
                </div>
                <div class="mb-3" t-if="!state.whatsapp_isTemplate">
                    <label class="form-label">Message</label>
                    <textarea class="form-control" rows="4" t-on-input="onChangeMessage"><t t-out="state.whatsapp_message"/></textarea>
                </div>
            </div>
            <t t-set-slot="footer">
                <button class="btn btn-primary" t-on-click="onConfirm">Confirm</button>
                <button class="btn btn-secondary" t-on-click="props.close">Cancel</button>
            </t>
        </Dialog>
    </t>

    <t t-name="cyllo_workflow_whatsapp_bridge.SidebarButton"
       t-inherit="client_action.automation_view"
       t-inherit-mode="extension"
       owl="1">
        <xpath expr="//div[@data-node='Mail']" position="after">
            <div class="collapse_btn"
                 t-on-dragstart="(ev) => this.dragStart(ev,'WhatsApp')"
                 draggable="true"
                 data-node="WhatsApp">
                <img draggable="false"
                     src="cyllo_whatsapp/static/description/whatsapp_icon.svg"
                     alt=""/>
                <p>WhatsApp</p>
            </div>
        </xpath>
    </t>
</templates>
