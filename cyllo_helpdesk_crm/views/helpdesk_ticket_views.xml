<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="helpdesk_ticket_view_form_inherit_crm" model="ir.ui.view">
        <field name="name">helpdesk.ticket.view.form.inherit.crm</field>
        <field name="model">helpdesk.ticket</field>
        <field name="inherit_id" ref="cyllo_help_desk.helpdesk_ticket_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header/field[@name='stage_id']" position="before">
                <field name="use_crm" invisible="1"/>
                <button name="action_create_crm_lead" type="object" string="Create CRM Lead" invisible="not customer_id or not use_crm"/>
            </xpath>
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_crm_leads" type="object" class="oe_stat_button" icon="fa-bullseye" invisible="not use_crm or crm_lead_count == 0">
                    <field name="crm_lead_count" widget="statinfo" string="CRM Leads"/>
                </button>
            </xpath>
        </field>
    </record>
</odoo>
