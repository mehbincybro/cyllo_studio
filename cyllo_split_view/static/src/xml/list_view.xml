<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-inherit="web.ListView" t-inherit-mode="extension" owl="1">
        <xpath expr="//t[@t-component='props.Renderer']" position="after">
                <t t-if="is_split_view &amp;&amp; state.currentSelectedId">
                    <div class="col-6" t-ref="split-form-parent"
                         style="height: -webkit-fill-available;">
                       <div data-role="splitter" class="h-100"
                            t-attf-style="border-left: solid #D9D9D9; border-left-width: 1.5px;">
                           <i class="fa fa-times-circle"
                              t-on-click="closeSplit"
                              style="font-size: 25px; cursor: pointer;"
                              onmouseover="this.style.color='red';"
                              onmouseout="this.style.color='';"/>
                           <View t-props="SpiltFormView"
                                 t-key="state.currentSelectedId"/>
                       </div>
                    </div>
                </t>
        </xpath>
    </t>
    <t t-inherit="web.ListRenderer" t-inherit-mode="extension" owl="1">
        <xpath t-if="env.config.viewType =='list'"
               expr="//div[hasclass('o_list_renderer')]" position="attributes">
            <attribute name="t-attf-class"
                       add="{{ spil.split_view_enable  ? 'col-6' : 'col-12 ' }}"
                       separator=" "/>
            <attribute name="t-attf-style"
                       add="{{ spil.split_view_enable ? 'width: 50%' : '' }}"
                       separator=" "/>
        </xpath>
    </t>
</templates>
