<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-inherit="web.FormView" t-inherit-mode="extension">
        <xpath expr="//Layout/t[@t-set-slot='control-panel-create-button']"
               position="after">
            <xpath expr="//Layout/t[@t-set-slot='layout-actions']"
                   position="replace">
                <t t-set-slot="layout-actions">
                    <t t-if="buttonBoxTemplate">
                        <t t-call="{{ buttonBoxTemplate }}"
                           t-call-context="{ __comp__: Object.assign(Object.create(this), { this, props: { ...this.props, record: this.model.root, splitView:this.splitView }})}"/>
                    </t>
                </t>
            </xpath>
        </xpath>
    </t>
</templates>
