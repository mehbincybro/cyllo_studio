<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--   FORM VIEW   -->
    <record id="view_frontdesk_enquiry_form" model="ir.ui.view">
        <field name="name">frontdesk.enquiry.form</field>
        <field name="model">frontdesk.enquiry</field>
        <field name="arch" type="xml">
            <form string="Enquiry">
                <header>
                    <button name="action_in_progress" string="Start" type="object"
                            class="btn-primary"
                            invisible="state != 'new'"/>
                    <button name="action_convert_to_visitor" string="Convert to Visitor" type="object"
                            class="btn-primary"
                            invisible="state not in ('new','in_progress')"
                            confirm="This will create a Visitor record and mark the enquiry as Converted. Continue?"/>
                    <button name="action_view_visitor" string="View Visitor" type="object"
                            class="btn-secondary"
                            invisible="not visitor_id"/>
                    <button name="action_close" string="Close" type="object"
                            invisible="state in ('converted','closed','lost')"/>
                    <button name="action_mark_lost" string="Mark as Lost" type="object"
                            invisible="state in ('converted','lost','closed')"/>
                    <button name="action_reset_new" string="Reset to New" type="object"
                            invisible="state in ('converted','new')"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="new,in_progress,converted,closed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                        <h2>
                            <field name="subject" placeholder="Subject of enquiry..."/>
                        </h2>
                    </div>
                    <group>
                        <group string="Visitor Information">
                            <field name="visitor_name"/>
                            <field name="phone"/>
                            <field name="email"/>
                            <field name="company"/>
                            <field name="partner_id"/>
                        </group>
                        <group string="Enquiry Details">
                            <field name="station_id"/>
                            <field name="handled_by"/>
                            <field name="enquiry_type"/>
                            <field name="priority" widget="priority"/>
                            <field name="enquiry_date"/>
                            <field name="follow_up_date"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description">
                            <field name="description" placeholder="Describe the enquiry in detail..."/>
                        </page>
                        <page string="Follow-Up">
                            <group>
                                <field name="follow_up_date"/>
                                <field name="follow_up_notes" placeholder="Notes for follow-up action..."/>
                            </group>
                        </page>
                        <page string="Conversion" invisible="not visitor_id">
                            <group>
                                <field name="visitor_id"/>
                                <field name="is_converted"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!--  TREE VIEW  -->
    <record id="view_frontdesk_enquiry_list" model="ir.ui.view">
        <field name="name">frontdesk.enquiry.list</field>
        <field name="model">frontdesk.enquiry</field>
        <field name="arch" type="xml">
            <tree string="Enquiries" decoration-success="state == 'converted'"
                  decoration-muted="state in ('closed','lost')"
                  decoration-warning="state == 'in_progress'">
                <field name="name"/>
                <field name="enquiry_date"/>
                <field name="visitor_name"/>
                <field name="phone"/>
                <field name="company"/>
                <field name="station_id"/>
                <field name="enquiry_type"/>
                <field name="handled_by"/>
                <field name="priority" widget="priority"/>
                <field name="follow_up_date" optional="show"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'converted'"
                       decoration-warning="state == 'in_progress'"
                       decoration-danger="state == 'lost'"
                       decoration-muted="state == 'closed'"
                       decoration-info="state == 'new'"/>
            </tree>
        </field>
    </record>

    <!--  KANBAN VIEW  -->
    <record id="view_frontdesk_enquiry_kanban" model="ir.ui.view">
        <field name="name">frontdesk.enquiry.kanban</field>
        <field name="model">frontdesk.enquiry</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column">
                <field name="name"/>
                <field name="visitor_name"/>
                <field name="phone"/>
                <field name="company"/>
                <field name="station_id"/>
                <field name="enquiry_type"/>
                <field name="priority"/>
                <field name="state"/>
                <field name="follow_up_date"/>
                <field name="handled_by"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                            <div class="oe_kanban_details">
                                <strong class="o_kanban_record_title">
                                    <field name="visitor_name"/>
                                </strong>
                                <div class="o_kanban_record_subtitle text-muted">
                                    <field name="name"/>
                                </div>
                                <div>
                                    <span class="badge rounded-pill text-bg-secondary">
                                        <field name="enquiry_type"/>
                                    </span>
                                </div>
                                <ul class="mt-1 mb-0">
                                    <li t-if="record.company.value">
                                        <i class="fa fa-building-o"/> <field name="company"/>
                                    </li>
                                    <li t-if="record.phone.value">
                                        <i class="fa fa-phone"/> <field name="phone"/>
                                    </li>
                                    <li t-if="record.station_id.value">
                                        <i class="fa fa-map-marker"/> <field name="station_id"/>
                                    </li>
                                    <li t-if="record.follow_up_date.value">
                                        <i class="fa fa-calendar"/> Follow-up: <field name="follow_up_date"/>
                                    </li>
                                </ul>
                                <div class="oe_kanban_bottom_right mt-2">
                                    <field name="priority" widget="priority"/>
                                    <field name="handled_by" widget="many2one_avatar_employee"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!--  SEARCH VIEW  -->
    <record id="view_frontdesk_enquiry_search" model="ir.ui.view">
        <field name="name">frontdesk.enquiry.search</field>
        <field name="model">frontdesk.enquiry</field>
        <field name="arch" type="xml">
            <search string="Search Enquiries">
                <field name="visitor_name" string="Visitor Name"/>
                <field name="phone"/>
                <field name="company"/>
                <field name="subject"/>
                <field name="station_id"/>
                <field name="handled_by"/>
                <filter name="filter_new" string="New" domain="[('state','=','new')]"/>
                <filter name="filter_in_progress" string="In Progress" domain="[('state','=','in_progress')]"/>
                <filter name="filter_converted" string="Converted" domain="[('state','=','converted')]"/>
                <filter name="filter_closed" string="Closed" domain="[('state','=','closed')]"/>
                <filter name="filter_lost" string="Lost" domain="[('state','=','lost')]"/>
                <separator/>
                <filter name="filter_today" string="Today"
                        domain="[('enquiry_date','&gt;=', datetime.datetime.combine(context_today(), datetime.time(0,0,0)).strftime('%Y-%m-%d %H:%M:%S')),
                                 ('enquiry_date','&lt;=', datetime.datetime.combine(context_today(), datetime.time(23,59,59)).strftime('%Y-%m-%d %H:%M:%S'))]"/>
                <filter name="filter_follow_up_due" string="Follow-Up Due"
                        domain="[('follow_up_date','&lt;=', context_today().strftime('%Y-%m-%d')), ('state','not in',('converted','closed','lost'))]"/>
                <filter name="filter_high_priority" string="High Priority"
                        domain="[('priority','in',('1','2'))]"/>
                <group expand="0" string="Group By">
                    <filter name="group_state" string="Status" context="{'group_by': 'state'}"/>
                    <filter name="group_type" string="Enquiry Type" context="{'group_by': 'enquiry_type'}"/>
                    <filter name="group_station" string="Station" context="{'group_by': 'station_id'}"/>
                    <filter name="group_handled_by" string="Handled By" context="{'group_by': 'handled_by'}"/>
                    <filter name="group_date" string="Date" context="{'group_by': 'enquiry_date:day'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ================================================================
         ACTION
    ================================================================ -->
    <record id="action_frontdesk_enquiry" model="ir.actions.act_window">
        <field name="name">Enquiries</field>
        <field name="res_model">frontdesk.enquiry</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="search_view_id" ref="view_frontdesk_enquiry_search"/>
        <field name="context">{'search_default_filter_new': 1, 'search_default_filter_in_progress': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No enquiries yet!
            </p>
            <p>
                Record walk-in or call-in enquiries here.
                Once qualified, convert them into a visitor or appointment.
            </p>
        </field>
    </record>

</odoo>
