<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Module Category -->
        <record id="module_category_cyllo_front_desk" model="ir.module.category">
            <field name="name">Front Desk</field>
            <field name="description">Helps manage front desk stations and visitor check-ins.</field>
            <field name="sequence">30</field>
        </record>

        <!-- Groups -->
        <record id="group_frontdesk_user" model="res.groups">
            <field name="name">User</field>
            <field name="category_id" ref="module_category_cyllo_front_desk"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_frontdesk_admin" model="res.groups">
            <field name="name">Administrator</field>
            <field name="category_id" ref="module_category_cyllo_front_desk"/>
            <field name="implied_ids" eval="[(4, ref('group_frontdesk_user'))]"/>
            <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        </record>

        <record id="group_frontdesk_security" model="res.groups">
            <field name="name">Security Team</field>
            <field name="category_id" ref="module_category_cyllo_front_desk"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!-- Record Rules -->
        <record id="frontdesk_rule" model="ir.rule">
            <field name="name">Frontdesk Station Multi-Company</field>
            <field name="model_id" ref="model_frontdesk_frontdesk"/>
            <field name="global" eval="True"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        </record>

        <record id="visitor_rule" model="ir.rule">
            <field name="name">Visitor Multi-Company</field>
            <field name="model_id" ref="model_frontdesk_visitor"/>
            <field name="global" eval="True"/>
            <field name="domain_force">['|', ('station_id.company_id', '=', False), ('station_id.company_id', 'in', company_ids)]</field>
        </record>
    </data>
</odoo>
