<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Sequence for Emergency Log -->
        <record id="seq_frontdesk_emergency_log" model="ir.sequence">
            <field name="name">Frontdesk Emergency Alert Log</field>
            <field name="code">frontdesk.emergency.log</field>
            <field name="prefix">EMG/%(year)s/</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

        <!-- Sequence for Enquiry Reference -->
        <record id="seq_frontdesk_enquiry" model="ir.sequence">
            <field name="name">Frontdesk Enquiry</field>
            <field name="code">frontdesk.enquiry</field>
            <field name="prefix">ENQ/%(year)s/</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_frontdesk_visitor" model="ir.sequence">
            <field name="name">Frontdesk Visitor</field>
            <field name="code">frontdesk.visitor</field>
            <field name="prefix">VIS/%(year)s/</field>
            <field name="padding">4</field>
        </record>
    </data>
</odoo>
