<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="frontdesk_visitor_enquiry_wizard_view_form" model="ir.ui.view">
        <field name="name">frontdesk.visitor.enquiry.wizard.view.form</field>
        <field name="model">frontdesk.visitor.enquiry.wizard</field>
        <field name="arch" type="xml">
            <form string="Create Enquiry">
                <group>
                    <group string="Visitor Information">
                        <field name="visitor_id"/>
                        <field name="visitor_name"/>
                        <field name="phone"/>
                        <field name="email"/>
                        <field name="company"/>
                    </group>
                    <group string="Enquiry Details">
                        <field name="station_id" options="{'no_create': True}"/>
                        <field name="handled_by" options="{'no_create': True}"/>
                        <field name="enquiry_type"/>
                        <field name="priority" widget="priority"/>
                        <field name="subject"/>
                        <field name="follow_up_date"/>
                    </group>
                </group>
                <notebook>
                    <page string="Description">
                        <field name="description" placeholder="Describe the enquiry in detail..."/>
                    </page>
                    <page string="Follow-Up">
                        <field name="follow_up_notes" placeholder="Notes for follow-up action..."/>
                    </page>
                </notebook>
                <footer>
                    <button name="action_create_enquiry" string="Create" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
