#. module: cyllo_accounting_follow_up
#: model:mail.template,body_html:cyllo_accounting_follow_up.mail_template_payment_reminder
msgid ""
"<div style=\"margin: 20px; font-family: Arial, sans-serif; line-height: 1.6;\">\n"
"                <p style=\"margin-bottom: 15px;\">\n"
"                    Dear\n"
"                    <t t-out=\"object.name or 'Valued Client'\"></t>,\n"
"                </p>\n"
"                <p style=\"margin-bottom: 15px;\">\n"
"                    We would like to bring to your attention that the following\n"
"                    amount remains unpaid. Kindly take the necessary measures to\n"
"                    settle this payment at your earliest convenience. If the\n"
"                    payment has already been made, please disregard this\n"
"                    message.\n"
"                </p>\n"
"                <p style=\"margin-bottom: 15px;\">\n"
"                    Should you have any questions or require further\n"
"                    clarification, do not hesitate to reach out to our\n"
"                    accounting department.\n"
"                </p>\n"
"                <p style=\"margin-bottom: 25px;\">Best Regards,</p>\n"
"                <p style=\"margin-bottom: 15px;\">Here are your invoice details:\n"
"                </p>\n"
"                <table style=\"width: 100%; border-collapse: collapse; text-align: left;\">\n"
"                    <thead>\n"
"                        <tr style=\"background-color: #f5f5f5;\">\n"
"                            <th style=\"border: 1px solid #ddd; padding: 8px; text-align: center;\">\n"
"                                Invoice Date\n"
"                            </th>\n"
"                            <th style=\"border: 1px solid #ddd; padding: 8px; text-align: center;\">\n"
"                                Number\n"
"                            </th>\n"
"                            <th style=\"border: 1px solid #ddd; padding: 8px; text-align: center;\">\n"
"                                Due Date\n"
"                            </th>\n"
"                            <th style=\"border: 1px solid #ddd; padding: 8px; text-align: center;\">\n"
"                                Amount\n"
"                            </th>\n"
"                        </tr>\n"
"                    </thead>\n"
"                    <tbody>\n"
"                        <t t-foreach=\"ctx.get('move_id')\" t-as=\"move\">\n"
"                            <tr>\n"
"                                <td style=\"border: 1px solid #ddd; padding: 8px; text-align: center;\">\n"
"                                    <t t-out=\"move.invoice_date or ''\"></t>\n"
"                                </td>\n"
"                                <td style=\"border: 1px solid #ddd; padding: 8px; text-align: center;\">\n"
"                                    <t t-out=\"move.name or ''\"></t>\n"
"                                </td>\n"
"                                <td style=\"border: 1px solid #ddd; padding: 8px; text-align: center;\">\n"
"                                    <t t-out=\"move.invoice_date_due or ''\"></t>\n"
"                                </td>\n"
"                                <td style=\"border: 1px solid #ddd; padding: 8px; text-align: center;\">\n"
"                                    <t t-out=\"move.amount_residual_signed or ''\"></t>\n"
"                                </td>\n"
"                            </tr>\n"
"                        </t>\n"
"                    </tbody>\n"
"                </table>\n"
"            </div>\n"
"        "
msgstr ""
"<div style=\"margin: 20px; font-family: Arial, sans-serif; line-height: 1.6;\">\n"
"                <p style=\"margin-bottom: 15px;\">\n"
"                    عزيزي\n"
"                    <t t-out=\"object.name or 'العميل الكريم'\"></t>،\n"
"                </p>\n"
"                <p style=\"margin-bottom: 15px;\">\n"
"                    نود لفت انتباهكم إلى أن المبلغ التالي لا يزال غير مسدد.\n"
"                    يرجى اتخاذ الإجراءات اللازمة لتسوية هذا المبلغ في أقرب\n"
"                    وقت ممكن. في حال تم السداد بالفعل، يرجى تجاهل هذه\n"
"                    الرسالة.\n"
"                </p>\n"
"                <p style=\"margin-bottom: 15px;\">\n"
"                    في حال كان لديكم أي استفسارات أو كنتم بحاجة إلى مزيد من\n"
"                    التوضيح، لا تترددوا في التواصل مع قسم المحاسبة لدينا.\n"
"                </p>\n"
"                <p style=\"margin-bottom: 25px;\">مع خالص التحية،</p>\n"
"                <p style=\"margin-bottom: 15px;\">فيما يلي تفاصيل الفاتورة الخاصة بكم:\n"
"                </p>\n"
"                <table style=\"width: 100%; border-collapse: collapse; text-align: left;\">\n"
"                    <thead>\n"
"                        <tr style=\"background-color: #f5f5f5;\">\n"
"                            <th style=\"border: 1px solid #ddd; padding: 8px; text-align: center;\">\n"
"                                تاريخ الفاتورة\n"
"                            </th>\n"
"                            <th style=\"border: 1px solid #ddd; padding: 8px; text-align: center;\">\n"
"                                الرقم\n"
"                            </th>\n"
"                            <th style=\"border: 1px solid #ddd; padding: 8px; text-align: center;\">\n"
"                                تاريخ الاستحقاق\n"
"                            </th>\n"
"                            <th style=\"border: 1px solid #ddd; padding: 8px; text-align: center;\">\n"
"                                المبلغ\n"
"                            </th>\n"
"                        </tr>\n"
"                    </thead>\n"
"                    <tbody>\n"
"                        <t t-foreach=\"ctx.get('move_id')\" t-as=\"move\">\n"
"                            <tr>\n"
"                                <td style=\"border: 1px solid #ddd; padding: 8px; text-align: center;\">\n"
"                                    <t t-out=\"move.invoice_date or ''\"></t>\n"
"                                </td>\n"
"                                <td style=\"border: 1px solid #ddd; padding: 8px; text-align: center;\">\n"
"                                    <t t-out=\"move.name or ''\"></t>\n"
"                                </td>\n"
"                                <td style=\"border: 1px solid #ddd; padding: 8px; text-align: center;\">\n"
"                                    <t t-out=\"move.invoice_date_due or ''\"></t>\n"
"                                </td>\n"
"                                <td style=\"border: 1px solid #ddd; padding: 8px; text-align: center;\">\n"
"                                    <t t-out=\"move.amount_residual_signed or ''\"></t>\n"
"                                </td>\n"
"                            </tr>\n"
"                        </t>\n"
"                    </tbody>\n"
"                </table>\n"
"            </div>\n"
"        "

