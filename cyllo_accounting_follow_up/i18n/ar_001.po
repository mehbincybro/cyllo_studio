#. module: cyllo_accounting_follow_up
#: model:mail.template,body_html:cyllo_accounting_follow_up.mail_template_payment_reminder
msgid ""
"<div style=\"margin: 0px; padding: 0px;\">\n"
"                    <p style=\"margin: 0px; padding: 0px;\">\n"
"                        Dear <t t-out=\"object.name or ''\"></t>,\n"
"                        <br>\n"
"                    </p>\n"
"                    <p>\n"
"                        Exception made if there was a mistake of ours, it seems that the following amount stays unpaid. Please, take appropriate measures in order to carry out this payment in the next 8 days.\n"
"                        Would your payment have been carried out after this mail was sent, please ignore this message. Do not hesitate to contact our accounting department.\n"
"                    </p>\n"
"                    <p>\n"
"                        Best Regards,\n"
"                    </p>\n"
"                    <br>\n"
"                    <p>Here is your invoice details</p>\n"
"                    <table style=\"margin-left: 35 px;\">\n"
"                        <thead>\n"
"                            <th style=\"border: 1px solid black;\" class=\"col\" align=\"center\">\n"
"                                <strong>Invoice Date</strong>\n"
"                            </th>\n"
"                            <th style=\"border: 1px solid black;\" class=\"col\" align=\"center\">\n"
"                                <strong>Number</strong>\n"
"                            </th>\n"
"                            <th style=\"border: 1px solid black;\" class=\"col\" align=\"center\">\n"
"                                <strong>Due Date</strong>\n"
"                            </th>\n"
"                            <th style=\"border: 1px solid black;\" class=\"col\" align=\"center\">\n"
"                                <strong>Amount</strong>\n"
"                            </th>\n"
"                        </thead>\n"
"                        <t t-foreach=\"object.move_ids\" t-as=\"move\">\n"
"                        <tbody>\n"
"                            <td style=\"border: 1px solid black;\" class=\"col\" align=\"center\"><t t-out=\"move.invoice_date or ''\"></t></td>\n"
"                            <td style=\"border: 1px solid black;\" class=\"col\" align=\"center\"><t t-out=\"move.name or ''\"></t></td>\n"
"                            <td style=\"border: 1px solid black;\" class=\"col\" align=\"center\"><t t-out=\"move.invoice_date_due or ''\"></t></td>\n"
"                            <td style=\"border: 1px solid black;\" class=\"col\" align=\"center\"><t t-out=\"move.amount_residual_signed or ''\"></t></td>\n"
"                        </tbody>\n"
"                        </t>\n"
"                    </table>\n"
"                </div>\n"
"            "
msgstr ""
"<div style=\"margin: 0px; padding: 0px;\">\n"
"                    <p style=\"margin: 0px; padding: 0px;\">\n"
"                        عزيزي <t t-out=\"object.name or ''\"></t>,\n"
"                        <br>\n"
"                    </p>\n"
"                    <p>\n"
"                        استثناء إذا كان هناك خطأ منا، يبدو أن المبلغ التالي يبقى غير مدفوع. يرجى.\n"
"                        استثناء إذا كان هناك خطأ منا، يبدو أن المبلغ التالي يبقى غير مدفوع. يرجى اتخاذ الإجراءات المناسبة لتنفيذ هذه الدفعة خلال الأيام الثمانية القادمة.\n"
"هل كان سيتم تنفيذ دفعتك بعد إرسال هذا البريد، يرجى تجاهل هذه الرسالة. لا تتردد في الاتصال بقسم المحاسبة لدينا"
"                    </p>\n"
"                    <p>\n"
"                        أطيب التحيات,\n"
"                    </p>\n"
"                    <br>\n"
"                    <p>هنا تفاصيل الفاتورة الخاصة بك</p>\n"
"                    <table style=\"margin-left: 35 px;\">\n"
"                        <thead>\n"
"                            <th style=\"border: 1px solid black;\" class=\"col\" align=\"center\">\n"
"                                <strong>تاريخ الفاتورة</strong>\n"
"                            </th>\n"
"                            <th style=\"border: 1px solid black;\" class=\"col\" align=\"center\">\n"
"                                <strong>رقم</strong>\n"
"                            </th>\n"
"                            <th style=\"border: 1px solid black;\" class=\"col\" align=\"center\">\n"
"                                <strong>تاريخ الاستحقاق</strong>\n"
"                            </th>\n"
"                            <th style=\"border: 1px solid black;\" class=\"col\" align=\"center\">\n"
"                                <strong>كمية</strong>\n"
"                            </th>\n"
"                        </thead>\n"
"                        <t t-foreach=\"object.move_ids\" t-as=\"move\">\n"
"                        <tbody>\n"
"                            <td style=\"border: 1px solid black;\" class=\"col\" align=\"center\"><t t-out=\"move.invoice_date or ''\"></t></td>\n"
"                            <td style=\"border: 1px solid black;\" class=\"col\" align=\"center\"><t t-out=\"move.name or ''\"></t></td>\n"
"                            <td style=\"border: 1px solid black;\" class=\"col\" align=\"center\"><t t-out=\"move.invoice_date_due or ''\"></t></td>\n"
"                            <td style=\"border: 1px solid black;\" class=\"col\" align=\"center\"><t t-out=\"move.amount_residual_signed or ''\"></t></td>\n"
"                        </tbody>\n"
"                        </t>\n"
"                    </table>\n"
"                </div>\n"
"            "

