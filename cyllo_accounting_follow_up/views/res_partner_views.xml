<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_res_partner_form_inherit_followup" model="ir.ui.view">
        <field name="name">view.res.partner.form.inherit.followup</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='internal_notes']" position="after">
                <page string="Follow Ups">
                    <div class="o_account_reports_followup-no-action"
                         id='no-action' role="alert">
                        <field name="move_ids" context="{
                            'tree_view_ref': 'cyllo_accounting_follow_up.view_out_invoice_tree_inherit_followup',
                            }"/>
                        <field name="check_followups" invisible="True"/>
                    </div>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
