<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_out_invoice_tree_inherit_followup" model="ir.ui.view">
        <field name="name">view.account.move.tree.inherit.followup</field>
        <field name="model">account.move</field>
        <field name="mode">primary</field>
        <field name="inherit_id" ref="account.view_out_invoice_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='invoice_date_due']" position="after">
                <field name="next_follow_up_id" widget="many2one_button"/>
                <field name="last_follow_up_id" widget="many2one_button"
                       options="{'clickable': false}"/>
            </xpath>
        </field>
    </record>
</odoo>