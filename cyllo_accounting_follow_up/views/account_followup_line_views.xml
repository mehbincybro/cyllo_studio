<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_account_followup_line_tree" model="ir.ui.view">
        <field name="name">view.account.followup.line.tree</field>
        <field name="model">account.followup.line</field>
        <field name="arch" type="xml">
            <tree string="Follow-up Steps" >
                <field name="name"/>
                <field name="delay"/>
                <field name="send_email"/>
            </tree>
        </field>
    </record>
    <record id="view_account_followup_line_form" model="ir.ui.view">
        <field name="name">view.account.followup.line.form</field>
        <field name="model">account.followup.line</field>
        <field name="arch" type="xml">
            <form string="Follow-up Steps">
                <sheet>
                    <label for="name" class="oe_edit_only"/>
                    <h1><field name="name"/></h1>
                    <div class="oe_inline">
                        Remind After <field name="delay" class="oe_inline"/>Days of Due Date
                    </div>
                    <group>
                        <group>
                            <field name="send_email"/>
                            <field name="mail_template_id" invisible="send_email != True"/>
                        </group>
                        <group>
                            <field name="company_id" reaonly="1"/>
                        </group>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>
    <record id="action_view_follow_up_levels" model="ir.actions.act_window">
        <field name="name">Follow Ups</field>
        <field name="res_model">account.followup.line</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                No Follow Ups Found
            </p>
        </field>
    </record>
    <menuitem id="menu_follow_up_levels" name="Follow-Up Levels"
              action="action_view_follow_up_levels" parent="account.account_management_menu"/>
</odoo>
