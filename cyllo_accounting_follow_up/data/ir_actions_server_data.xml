<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--Server Action for sending follow-up mails -->
    <record id="model_res_partner_action_send_followups" model="ir.actions.server">
            <field name="name">Send Follow Up Mail</field>
            <field name="groups_id" eval="[Command.link(ref('account.group_account_invoice'))]"/>
            <field name="model_id" ref="base.model_res_partner"/>
            <field name="binding_model_id" ref="base.model_res_partner" />
            <field name="state">code</field>
            <field name="code">
                if records:
                    action = records.action_send_followups()
            </field>
        </record>
</odoo>
