<templates>
    <t t-name="Many2OneButtonTemplate" owl="1">
        <div class="col-12 col-sm-4 mb-3 mb-sm-0 o_kanban_primary_left" t-att-class="{no_click: !canClick}">
            <t t-if="this.props.record.data[this.props.name]">
                <button class="btn btn-primary followup-button"
                        t-on-click.stop="onClickFollowupAction">
                    <span class="followup-text">
                        <t t-esc="this.props.record.data[this.props.name][1]"/>
                    </span>
                </button>
            </t>
        </div>
    </t>
</templates>
