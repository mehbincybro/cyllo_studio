<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="churn_prediction_dashboard_action" model="ir.actions.client">
        <field name="name">Churn Prediction Dashboard</field>
        <field name="tag">churn_prediction</field>
        <field name="target">current</field>
    </record>
    <record id="sales_prediction_dashboard_action" model="ir.actions.client">
        <field name="name">Sales Prediction Dashboard</field>
        <field name="tag">sales_prediction</field>
        <field name="target">current</field>
    </record>
    <record id="demand_prediction_dashboard_action" model="ir.actions.client">
        <field name="name">Demand Prediction Dashboard</field>
        <field name="tag">demand_prediction</field>
        <field name="target">current</field>
    </record>
    <menuitem id="menu_predictive_analytics_categ" parent="cyllo_analytics.menu_cyllo_analytics_root" name="Predictive Analytics"
              groups="cyllo_analytics.group_cyllo_analytics_admin"/>
    <menuitem id="menu_sales_forecasting" name="Sales Forecasting"
              action="sales_prediction_dashboard_action" parent="menu_predictive_analytics_categ" sequence="50"/>
    <menuitem id="menu_churn_prediction" name="Churn Prediction"
              action="churn_prediction_dashboard_action" parent="menu_predictive_analytics_categ" sequence="100"/>
    <menuitem id="menu_demand_forecasting" name="Demand Forecasting"
              action="demand_prediction_dashboard_action" parent="menu_predictive_analytics_categ" sequence="150"/>
</odoo>