<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <t t-name="ChurnPredictionDashboard" owl="1">
        <div class="cy-main">
            <div class="row d-flex align-items-center py-2 cy-border-btm cy-sticky--header">
                <div class="col cy-main-sectionhead d-flex align-items-center">
                    <span class="nav-link cy-template-title">Churn Prediction Dashboard</span>
                </div>
                <div class="col d-flex align-items-center justify-content-end gap-2 px-2"> </div>
            </div>
            <div t-ref="root" class="row p-3 pt-0 pb-3">
                <div>
                    <div class="col">
                        <div class="churn_prediction_selected_filter">
                            <div class="d-flex justify-content-between align-items-center py-4">
                                <div>
                                    <h5 class="cy-churn-main_head">
                                        Based on Last
                                        <t t-esc="state.numberOfPeriods" />
                                        <span t-if="state.period == 'Quarter'"> Quarters</span>
                                        <span t-elif="state.period == 'Year'"> Years</span>
                                        <span t-elif="state.period == 'Month'"> Months</span>
                                        <span t-else=""> Half Years</span>
                                    </h5>
                                    <!--                                     <div class="info-container"> -->
                                    <div class="info-content gap-1 px-2">
                                        <i class="ri-information-line cy-icons" />
                                        <p class="info-message d-flex cy-template-title mb-0">
                                            <span class="info-hover-msg info-message mb-0 px-1"> Prediction based on the data from </span>
                                            <t t-esc="state.churnData.start_date" />
                                            to
                                            <t t-esc="state.churnData.end_date" />
                                        </p>
                                    </div>
                                    <!--                                     </div> -->
                                </div>
                                <div class="d-flex align-items-center gap-3 mx-3 justify-content-end flex-wrap">
                                    <FilterDropdown onClick.bind="onChangePeriod" name="'Filters'" display_name="'Filters'">
                                        <t t-set-slot="contents">
                                            <div class="col-12">
                                                <label for="" class="cy-marketing-auto-dialog-txt">Number of Periods</label>
                                                <div class="col-12">
                                                    <input type="number" t-ref="input" t-att-value="state.numberOfPeriods" class="cy-button-stroke w-100 p-1 cy-market-modal-selection-box" id="inputAddress" min="4" title="Enter a value greater than or equal to 4" />
                                                </div>
                                            </div>
                                            <div class="col-12 my-3">
                                                <label for="start-date" class="cy-marketing-auto-dialog-txt">Period</label>
                                                <select id="churn_period" required="" class="form-select" t-ref="period">
                                                    <option t-att-selected="state.period == 'Quarter' ? 'selected': ''" value="quarter">Quarter</option>
                                                    <option t-att-selected="state.period == 'Year' ? 'selected': ''" value="year">Year</option>
                                                    <option t-att-selected="state.period == 'Month' ? 'selected': ''" value="month">Month</option>
                                                    <option t-att-selected="state.period == 'Half Year' ? 'selected': ''" value="six_months">Half Year</option>
                                                </select>
                                            </div>
                                            <div class="col-12 my-3">
                                                <label for="" class="cy-marketing-auto-dialog-txt">Period Type</label>
                                                <div title="Select the period type for data retrieval: If 'Current Date' is selected, data will be taken up to today's date. If 'Financial Year' is selected, data will be taken based on your company's financial year. Data will be taken up to previous year's end date">
                                                    <select id="period_type" required="" class="form-select" t-ref="period_type" t-att-disabled="!state.churnData.is_financial_year">
                                                        <option t-att-selected="state.periodType == 'current_date' ? 'selected': ''" value="current_date">Current Date</option>
                                                        <option t-if="state.churnData.is_financial_year" t-att-selected="state.periodType == 'financial_year' ? 'selected': ''" value="financial_year">Financial Year</option>
                                                    </select>
                                                </div>
                                            </div>
                                        </t>
                                    </FilterDropdown>
                                    <FilterDropdown name="'Export'" footer="false" display_name="'Export'">
                                        <t t-set-slot="contents">
                                            <div class="col-12 px-2 pt-2">
                                                <button class="btn btn-primary w-100" type="button" t-on-click="exportPDF">PDF</button>
                                            </div>
                                            <div class="col-12 px-2 pt-2">
                                                <button class="btn btn-secondary w-100" type="button" t-on-click="exportXLSX">XLSX</button>
                                            </div>
                                        </t>
                                    </FilterDropdown>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div t-if="state.predictData" class="row flex-wrap cy_kpi-sale-card-container justify-content-between position-relative">
                        <div class="col-lg-8 d-flex flex-wrap mb-4 tile-div justify-content-center">
                            <div class="col-lg-6 cy-churn_tile top-churn-tile gap-2 p-2 d-flex justify-content-center flex-column position-relative">
                                <button class="cy_kpi_icon cy_churn_total_cust_info cy_churn_info">
                                    <i class="ri-question-line" />
                                </button>
                                <div class="cy_churn_info_content total_cust_explanation">
                                    <p class="mb-0">Total number of customers in the company.</p>
                                </div>
                                <div class="d-flex gap-2 align-items-center" style="padding-left: 4px;">
                                    <i class="ri-team-fill cy-churn_tile--icon" />
                                    <p class="cy-churn_tile-text"> Total Customers</p>
                                </div>
                                <h2 class="cy-churn_tile--perc">
                                    <t t-esc="state.churnData.total_cust" />
                                </h2>
                            </div>
                            <div class="col-lg-6 cy-churn_tile bot-churn-tile gap-2 d-flex justify-content-center position-relative flex-column">
                                <button class="cy_kpi_icon cy_churn_active_info cy_churn_info ">
                                    <i class="ri-question-line" />
                                </button>
                                <div class="cy_churn_info_content active_cust_explanation">
                                    <p class="mb-0">Total number of customers who have engaged with your business by making at least one sale order.</p>
                                </div>
                                <div class="d-flex gap-2 align-items-center">
                                    <i class="ri-check-fill cy-churn_tile--icon cy-churn_tile-activeChurn" />
                                    <p class="cy-churn_tile-text">Active Customers</p>
                                </div>
                                <h2 class="cy-churn_tile--perc">
                                    <t t-esc="state.churnData.active_cust" />
                                </h2>
                            </div>
                            <div class=" col-lg-6 cy-churn_tile top-churn-tile gap-2 d-flex justify-content-center flex-column position-relative">
                                <button class="cy_kpi_icon cy_churn_perc_info cy_churn_info">
                                    <i class="ri-question-line" />
                                </button>
                                <div class="cy_churn_info_content churn_perc_explanation">
                                    <p class="mb-0">Estimated percentage of total customers that is predicted to discontinue or stop using your services or products based on the data within selected period.</p>
                                </div>
                                <div class="d-flex gap-2 align-items-center">
                                    <i class="ri-arrow-right-down-line cy-churn_tile--icon cy-churn_tile-notChurn " />
                                    <p class="cy-churn_tile-text">Customers likely to be churn</p>
                                </div>
                                <h2 class="cy-churn_tile--perc">
                                    <t t-esc="state.churnData.churn_perc" />
                                    %
                                </h2>
                            </div>
                            <div class="col-lg-6 col cy-churn_tile bot-churn-tile gap-2 d-flex justify-content-center flex-column position-relative">
                                <button class="cy_kpi_icon cy_not_churn_perc_info cy_churn_info">
                                    <i class="ri-question-line" />
                                </button>
                                <div class="cy_churn_info_content not_churn_perc_explanation">
                                    <p class="mb-0">Estimated percentage of total customers that is predicted or expected to continue using your services or products without discontinuing based on the data within selected period.</p>
                                </div>
                                <div class="d-flex gap-2 align-items-center">
                                    <i class="ri-arrow-right-up-line cy-churn_tile--icon cy-churn_tile-toChurn" />
                                    <p class="cy-churn_tile-text">Customers likely to be not churn</p>
                                </div>
                                <h2 class="cy-churn_tile--perc">
                                    <t t-esc="state.churnData.not_churn_perc" />
                                    %
                                </h2>
                            </div>
                        </div>
                        <div class="col-lg-4 mb-2">
                            <div class="churn-chart cy-button-stroke cy-churn-hover mb-3">
                                <div class="cy-border-btm p-3">
                                    <h2 class="cy-churn_tile-text">Overall Churn v/s Not Churn</h2>
                                </div>
                                <div class="d-flex align-items-center justify-content-center p-3">
                                    <div class=" cy-churn_graph churn_prediction-graph_img">
                                        <GraphTile t-if="state.generate" value="state.churnChart" style="chartStyle" />
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-lg-8 d-flex flex-wrap mb-4 tile-div justify-content-center">
                            <div class="cy-churn_table--container">
                                <div class="cy-churn_tabl-header__section d-flex justify-content-between align-items-center p-3 cy-border-btm">
                                    <h2 class="cy-churn_tile-text" />
                                    <div class="d-flex align-items-center gap-2">
                                        <form class="d-flex">
                                            <div class="cy-button-stroke d-flex align-items-center px-2" style="width:400px;">
                                                <i class="ri-search-line cy-icons" />
                                                <input class="form-control cy-churn_cust-search-bar" type="text" placeholder="Search customers..." aria-label="Search" t-on-input="(event) => this.onInputCustomer(event.target.value)" />
                                            </div>
                                        </form>
                                        <div class="d-flex">
                                            <button class=" cy-churn-nav_btn" t-if="hasPrev" t-on-click="() => this.onClick(-1)">
                                                <i class="ri-arrow-left-line" />
                                            </button>
                                            <button class=" cy-churn-nav_btn" t-if="hasNext" t-on-click="() => this.onClick(1)">
                                                <i class="ri-arrow-right-line cy-icon" />
                                            </button>
                                        </div>
                                    </div>
                                </div>
                                <div class="cy-churn_table">
                                    <table class="cy-listView-table ch-churn_predict--table">
                                        <thead class="cy-listview-head cy-churn-prdt_thead">
                                            <tr>
                                                <th>Sl.No</th>
                                                <th>Customer </th>
                                                <th>Last Purchase Date</th>
                                                <th>Total Sale Orders</th>
                                                <th>Total Amount</th>
                                                <th>Churn </th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <t t-if="state.churnData.cust_wise_details">
                                                <t t-foreach="state.arr" t-as="cust" t-key="cust_index">
                                                    <tr t-on-click="() => this.onClickCustomer(cust)" t-if="cust?.custName">
                                                        <td class="d-flex justify-content-center">
                                                            <t t-esc="cust.index" />
                                                        </td>
                                                        <td>
                                                            <img class="card-img-top cy-ps_profile" t-attf-src="/web/image/res.partner/{{cust.custId}}/image_1920" alt="Card image cap" />
                                                            <t t-esc="cust.custName" />
                                                        </td>
                                                        <td>
                                                            <t t-esc="cust.last_purchase_date" />
                                                        </td>
                                                        <td class="d-flex align-items-center justify-content-between cy_sale_cell">
                                                            <div class="d-flex">
                                                                <t t-esc="cust.total_sales" />
                                                            </div>
                                                            <div class="cy_sale_redirect">
                                                                <a href="#" t-on-click="() => this.onClickFrequency(cust)">
                                                                    <i class="px-1 ri-arrow-right-circle-fill cy-icons" />
                                                                </a>
                                                            </div>
                                                        </td>
                                                        <td>
                                                            <t t-esc="cust.total_amount" />
                                                        </td>
                                                        <td class="d-flex align-items-center justify-content-between">
                                                            <div class="d-flex">
                                                                <span t-if="cust.Churn == 'No'" class="cy-churn__success" />
                                                                <span t-if="cust.Churn == 'Yes'" class="cy-churn__success cy-churn__failed" />
                                                                <t t-esc="cust.Churn" />
                                                            </div>
                                                            <div>
                                                                <a href="#" t-on-click="() => this.onClickCustomerDetails(cust)">
                                                                    <i class="px-1 ri-eye-line cy-icons" />
                                                                </a>
                                                            </div>
                                                        </td>
                                                    </tr>
                                                </t>
                                            </t>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                        <div class="col-lg-4 mb-2">
                            <div class="churn-chart cy-button-stroke cy-churn-hover mb-3">
                                <div class="cy-border-btm p-3">
                                    <h2 class="cy-churn_tile-text">
                                        <t t-esc="state.customer" />
                                    </h2>
                                </div>
                                <div class="d-flex align-items-center justify-content-center p-3">
                                    <div class=" cy-churn_graph churn_prediction-graph_img">
                                        <GraphTile t-if="state.generate" value="state.cust" style="chartStyle" />
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div t-else="" class="row cy-empty_data text-center align-items-center justify-content-center h-100">
                        <div class="d-flex align-items-center justify-content-center flex-column">
                            <div class="cy-empty_data-img">
                                <img src="/cyllo_sale_analytics/static/src/img/no_data.png" class="cy-image" />
                            </div>
                            <h1 class="cy-demand-predit_head">No Data for Prediction</h1>
                            <p class="cy-empty_text">There should be enough customers and sale orders for prediction.The dataset is too small to perform a meaningful prediction. The model may have limited accuracy due to the small dataset size. Please check with more data.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </t>
</templates>

