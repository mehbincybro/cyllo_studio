<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!--Product template view-->
    <record id="action_view_products" model="ir.actions.act_window">
        <field name="name">Products</field>
        <field name="res_model">product.template</field>
        <field name="view_mode">tree,kanban,activity,form</field>
        <field name="view_id" ref="product.product_template_kanban_view"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No Product is Found!
            </p>
            <p>Create some Products!.</p>
        </field>
    </record>
    <!--Approval and reject button in product template view-->
    <record id="view_product_template_form_inherit_approve" model="ir.ui.view">
        <field name="name">view.product.template.form.inherit.approve</field>
        <field name="model">product.template</field>
        <field name="priority">110</field>
        <field name="inherit_id"
               ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_button_approve" string="Approve"
                        type="object"
                        groups="cyllo_product.group_cyllo_product"
                        class="oe_highlight"
                        invisible="status_approval or not approval_button_visibility"/>
                <button name="action_product_reject" string="Reject"
                        type="object" class="oe_highlight"
                        groups="cyllo_product.group_cyllo_product"
                        invisible="status_approval or not approval_button_visibility"/>
                <field name="state" widget="statusbar" invisible="1"/>
                <field name="approval_button_visibility" invisible="1"/>
                <field name="type_approval" widget="statusbar" invisible="1"/>
                <field name="approver_page_visibility" invisible="1"/>
                <field name="status_approval" invisible="1"/>
            </xpath>
            <xpath expr="//header" position="after">
                <div class="alert alert-warning mb-0" role="alert"
                     invisible="state != 'to_approve'">
                    The Product
                    <b>
                        <field name="name" readonly="1"/>
                    </b>
                    is under
                    <b>
                        <field name="state" readonly="1"/>
                    </b>
                    for
                    <b>
                        <field name="type_approval" readonly="1"/>
                    </b>
                </div>
            </xpath>
            <!--Approvers page view-->
            <xpath expr="//notebook" position="inside">
                <page string="Approvers"
                      invisible="not approver_page_visibility">
                    <field name="product_approver_line_ids" readonly="1">
                        <tree create="0" delete="0">
                            <field name="product_approver_id"/>
                            <field name="reason"/>
                            <field name="status"
                                   widget="badge"
                                   decoration-warning="status == 'pending'"
                                   decoration-success="status == 'approved'"
                                   decoration-danger="status == 'rejected'"
                            />
                        </tree>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
</odoo>