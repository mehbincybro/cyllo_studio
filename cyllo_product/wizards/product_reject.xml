<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--    Rejection wizard form view-->
    <record id="view_product_reject_form" model="ir.ui.view">
        <field name="name">view.product.reject.form</field>
        <field name="model">product.reject</field>
        <field name="arch" type="xml">
            <form string="Reject">
                <group>
                    <field name="rejection_reason"
                           placeholder="Reason for rejection"/>
                </group>
                <footer>
                    <button name="action_reject_product" string="Reject Product"
                            type="object" class="btn-primary"
                            invisible="button_visible"/>
                    <button name="action_reject_product_variant"
                            string="Reject Variant" type="object"
                            class="btn-primary" invisible="not button_visible"/>
                    <button string="Cancel" class="btn-secondary"
                            special="cancel"/>
                    <field name='button_visible' string="Condition"
                           invisible="1"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>