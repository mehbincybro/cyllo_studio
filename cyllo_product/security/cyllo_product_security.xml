<?xml version="1.0" encoding="UTF-8"?>
<odoo noupdate="1">
    <!-- Create new module category and security group Approval Manager for the module -->
    <record id="ir_module_category_approval" model="ir.module.category">
        <field name="name">Approval</field>
        <field name="description">User access level for Approval model</field>
        <field name="sequence">1</field>
    </record>
    <record id="group_cyllo_product" model="res.groups">
        <field name="name">Product Manager</field>
        <field name="category_id" ref="ir_module_category_approval"/>
        <field name="users" eval="[(4, ref('base.user_admin'))]"/>
    </record>
</odoo>
