<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.cyllo.project.base</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="project.res_config_settings_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//block[@id='tasks_management']" position="inside">
                <setting id="module_cyllo_project_product_setting" help="Add products/materials to project tasks">
                    <field name="module_cyllo_project_product"/>
                </setting>
                <setting id="module_cyllo_budget_project_setting" help="Create or Add project from Budget">
                    <field name="module_cyllo_budget_project"/>
                </setting>
                <setting id="module_cyllo_project_planning_setting" help="Allocate the Employees to Task directly from Project">
                    <field name="module_cyllo_project_planning"/>
                </setting>
                <setting id="module_hr_expense_setting" help="Add expenses from project">
                    <field name="module_hr_expense"/>
                </setting>
                <setting id="module_cyllo_field_service_project_setting" help="Manage tasks in the Field Service module">
                    <field name="module_cyllo_field_service_project"/>
                </setting>
            </xpath>
        </field>
    </record>
</odoo>
