<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_res_config_settings_form_inherit_ai" model="ir.ui.view">
        <field name="name">view.res.config.settings.form.inherit.ai</field>
        <field name="model">res.config.settings</field>
         <field name="priority">110</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <!-- Add Cyllo AI configuration section to settings -->
            <xpath expr="//block[@name='integration']" position="after">
                <block title="Cyllo AI" name="cyllo_agent">
                    <setting string="Cyllo AI" help="Integrate with LLM" id="cyllo_agent_setting">
                        <field name="cyllo_agent"/>
                        <div class="content-group mt16 fixed-box" invisible="cyllo_agent == False">
                            <div class="mt4">
                                <label for="cyllo_agent_llm" class="o_light_label mr8"/>
                                <field name="cyllo_agent_llm" string="LLM Provider" required="cyllo_agent == True"/>
                            </div>

                            <!-- Model Selection for ChatGPT and Google Gemini (existing models) -->
                            <div class="mt4" invisible="cyllo_agent_llm == 'OpenRouter'">
                                <label for="agent_llm_model_id" class="o_light_label mr8"/>
                                <field name="agent_llm_model_id" string="Model Name"
                                       required="cyllo_agent == True and cyllo_agent_llm != 'OpenRouter'"/>
                            </div>

                            <!-- OpenRouter Model Selection (dynamic from API) -->
                            <div class="mt4" invisible="cyllo_agent_llm != 'OpenRouter'">
                                <label for="openrouter_model" class="o_light_label mr8"/>
                                <field name="openrouter_model" string="Model Name"
                                       required="cyllo_agent == True and cyllo_agent_llm == 'OpenRouter'"
                                       placeholder="Select a model..."
                                       options="{'no_create': True, 'no_open': True}"/>

                                <a class="ml4 oe_link"
                                   type="object"
                                   name="action_refresh_openrouter_models">
                                    <i class="fa fa-refresh"/>
                                    Refresh Models
                                </a>

                                <div class="text-muted fs-7 mt4">
                                    <a class="fs-7" href="https://openrouter.ai/models" target="_blank">
                                        <i class="fa fa-external-link"/>
                                        View all available models
                                    </a>
                                </div>
                            </div>
                            <div class="mt4">
                                <label for="cyllo_agent_api" class="o_light_label mr8"/>
                                <field name="cyllo_agent_api" password="1" string="API Key"
                                       required="cyllo_agent == True"/>
                                <a class="ml4 oe_link" type="object" name="action_test_cyllo_llm_connection"
                                   data-action="action_test_cyllo_llm_connection">
                                    <i class="oi oi-arrow-right"/>
                                    Connect API
                                </a>

                                <!-- Dynamic help text based on selected provider -->
                                <div class="text-muted fs-7" invisible="cyllo_agent_llm != 'ChatOpenAI'">
                                    Don't have an API key?
                                    <a class="fs-7" href="https://platform.openai.com/api-keys" target="_blank">
                                        Get Your OpenAI API Key
                                    </a>
                                </div>

                                <div class="text-muted fs-7" invisible="cyllo_agent_llm != 'ChatGoogleGenerativeAI'">
                                    Don't have an API key?
                                    <a class="fs-7" href="https://ai.google.dev/gemini-api/docs" target="_blank">
                                        Get Your Gemini API Key
                                    </a>
                                </div>

                                <div class="text-muted fs-7" invisible="cyllo_agent_llm != 'OpenRouter'">
                                    Don't have an API key?
                                    <a class="fs-7" href="https://openrouter.ai/keys" target="_blank">
                                        Get Your OpenRouter API Key
                                    </a>
                                </div>
                            </div>
                        </div>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>
</odoo>
