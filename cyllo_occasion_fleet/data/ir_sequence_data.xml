<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Sequence for generating Transport Booking reference numbers -->
    <data noupdate="1">
        <record id="seq_transport_booking" model="ir.sequence">
            <field name="name">Transport Booking</field>
            <field name="code">transport.booking</field>
            <field name="prefix">TB/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>
    </data>
</odoo>
