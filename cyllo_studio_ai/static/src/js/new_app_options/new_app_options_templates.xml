<?xml version="1.0" encoding="UTF-8"?>
<templates>
    <t t-name="cyllo_studio_ai.cyllo_studio_ai_page_content" owl="1">
        <Dialog title="props.title" size="'md'" footer="false" header="false">
            <div class="cyst1 new-app-component modal-dialog-centered " role="document">
                <div class="modal-content" style="padding:0px;">
                    <div class="cy-app-install-demo-card__header" style="margin-left: -16px; border-bottom: 1px solid #ddd; margin-right: -16px; padding-bottom:12px;">
                        <p class="cy-app-install-demo-card__page" style="font-size: 20px;font-weight: bold;">
                            Choose an Option
                        </p>
                        <button class="close" aria-label="Close"
                                t-on-click="onClose" style="font-size:27px;">×
                        </button>
                    </div>
                    <div class="cy-options-section" style="text-align:center; padding:40px;">
                        <button class="cy-create-new-app-button"
                                style="width: 280px; margin-bottom: 20px; border-radius: 4px; background-color: #fffde5; font-size: 16px; color: #9ea700; padding: 12px; border: 1px solid #9ea700"
                                t-on-click="CreateApp">
                            Create New App
                        </button><br/>
                        <button class="cy-create-new-app-ai-button"
                                style="width: 280px; border-radius: 4px; background-color: #9ea700; font-size: 16px; color: #fff; padding: 12px; border: 1px solid #9ea700"
                                t-on-click="CreateAppWithAI">
                            Create New App with AI Prompt
                        </button>
                    </div>
                </div>
            </div>
        </Dialog>
    </t>
</templates>
