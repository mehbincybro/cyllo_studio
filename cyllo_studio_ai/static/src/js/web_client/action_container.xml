<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
	<t t-name="cyllo_studio_ai.ActionContainer">
        <StudioWrapper t-if="info.componentProps?.action?.tag != 'PromptDialog'" t-props="wrapperProps"/>
        <div t-else="" class="o_action_manager d-flex user-select-none">
            <div t-if="info.componentProps?.action" class="position-relative">
                    <t t-if="info.Component" t-component="info.Component" className="'o_action'"
                       t-props="info.componentProps"
                       t-key="info.id"/>
                <span>qwertyuiuytrewertyuioiuytrewertyuioiuytrertyuio</span>
                <div t-if="info.componentProps?.action.tag != 'PromptDialog'"
                     class="cy-studio-overlay opacity-0 opacity-75-hover" style="z-index: 111;">
                        <div class="text-center">
                            <i class="ri-lock-2-fill text-danger" style="font-size: 10rem;"/>
                            <h2 class="fw-bolder text-danger"><t t-esc="info.componentProps.action?.display_name"/>
                                Editing Restricted !</h2>
                        </div>
                    </div>
                </div>
            <t t-elif="info.Component" t-component="info.Component" className="'o_action'" t-props="info.componentProps"
               t-key="info.id"/>
            </div>
	</t>
</templates>