<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--    Tree view for plan allocation type-->
    <record id="view_allocation_type_tree" model="ir.ui.view">
        <field name="name">view.allocation.type.tree</field>
        <field name="model">allocation.type</field>
        <field name="arch" type="xml">
            <tree string="Allocation Type" multi_edit="1">
                <field name="name"/>
                <field name="color" widget="colorpicker"/>
            </tree>
        </field>
    </record>
    <!--    Form view for plan allocation type-->
    <record id="view_allocation_type_form" model="ir.ui.view">
        <field name="name">view.allocation.type.form</field>
        <field name="model">allocation.type</field>
        <field name="arch" type="xml">
            <form string="Allocation Type">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <group>
                                <field name="name" placeholder="e.g. Problem Solver"/>
                            </group>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="color" widget="colorpicker"/>
                            <field name="user_id"/>
                            <field name="company_id"/>
                            <field name="description"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <!--    Action view for plan allocation type-->
    <record id="action_view_allocation_type" model="ir.actions.act_window">
        <field name="name">Allocation Type</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">allocation.type</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your Allocation Type
            </p>
            <p>
                Use these created Allocation Type while raising Service requests.
            </p>
        </field>
    </record>
    <!--    Menu for plan allocation type-->
    <menuitem id="menu_allocation_type" name="Allocation Type"
              parent="cyllo_planning.menu_cyllo_planning_root"
              action="action_view_allocation_type"
              sequence="2"/>
</odoo>