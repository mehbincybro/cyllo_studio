<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="mail_template_request_submitted" model="mail.template">
        <field name="name">REQUEST SUBMITTED</field>
        <field name="model_id" ref="cyllo_hr_service_management.model_hr_service"/>
        <field name="email_from">"{{object.company_id.email}}"</field>
        <field name="email_to">{{object.employee_id.work_email}}</field>
        <field name="subject">" Request for service {{object.name}}"</field>
        <field name="lang">{{object.employee_id.lang}}</field>
        <field name="auto_delete" eval="True"/>
        <field name="body_html" type="html">
            <div style="background-color: #f9f9f9; padding: 20px;">
                <p style="font-size: 16px; color: #333;">
                    Hi there,
                    <br/>
                    <br/>
                    Your request is submitted.
                    <br/>
                    <br/>
                    Kind regards,
                </p>
            </div>
        </field>
    </record>
