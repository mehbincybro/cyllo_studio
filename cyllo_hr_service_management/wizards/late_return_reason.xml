<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_late_return_reason_form" model="ir.ui.view">
        <field name="name">view.late.return.reason.form</field>
        <field name="model">late.return.reason</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="service_request_id" readonly="True"/>
                            <field name="reason" required="True"/>
                        </group>
                    </group>
                    <footer>
                        <button name="action_return" type="object" string="RETURN" class="btn-primary"/>
                    </footer>
                </sheet>
            </form>
        </field>
    </record>
</odoo>