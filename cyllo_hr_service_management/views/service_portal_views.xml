<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Template for portal document -->
    <template id="portal_my_home_service_requests" name="Service Requests"
              customize_show="True"
              inherit_id="portal.portal_my_home" priority="35">
        <xpath expr="//div[hasclass('o_portal_docs')]" position="before">
            <t t-set="portal_client_category_enable" t-value="True"/>
        </xpath>
        <div id="portal_client_category" position="inside">
            <t t-call="portal.portal_docs_entry"
               t-if="request.env.user.employee_ids">
                <t t-set="icon" t-value="'/sale/static/src/img/bag.svg'"/>
                <t t-set="title">Service Management</t>
                <t t-set="url" t-value="'/service_management'"/>
                <t t-set="text">Manage your service requests</t>
                <t t-set="placeholder_count" t-value="'service_count'"/>
            </t>
        </div>
    </template>
</odoo>