<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_service_category_tree" model="ir.ui.view">
        <field name="name">view.hr.service.category.tree</field>
        <field name="model">hr.service.category</field>
        <field name="arch" type="xml">
            <tree string="Service Categories" multi_edit="1">
                <field name="name"/>
                <field name="parent_id"/>
            </tree>
        </field>
    </record>
    <record id="view_hr_service_category_form" model="ir.ui.view">
        <field name="name">view.hr.service.category.form</field>
        <field name="model">hr.service.category</field>
        <field name="arch" type="xml">
            <form string="Service Categories">
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1>
                            <field name="name"
                                   placeholder="e.g. Technical Issues"/>
                        </h1>
                    </div>
                    <group>
                        <group colspan="8" col="4">
                            <field name="parent_id"/>
                            <field name="require_maintenance_order"/>
                        </group>
                    </group>
                    <notebook>
                        <page name="description" string="Description">
                            <group>
                                <field name="description"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"
                           groups="base.group_user"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>
    <record id="action_view_service_categories" model="ir.actions.act_window">
        <field name="name">Service Categories</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">hr.service.category</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your Service category
            </p>
            <p>
                Use these created Service categories while raising Service
                requests.
            </p>
        </field>
    </record>
    <menuitem id="menu_service_categories" name="Service Categories"
              parent="cyllo_hr_service_management.menu_service_management_categ"
              action="action_view_service_categories" sequence="2"/>
</odoo>