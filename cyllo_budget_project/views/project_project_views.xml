<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!--    Defines the Inherited View of Project-->
    <record id="view_project_project_form" model="ir.ui.view">
        <field name="name">view.project.project.form</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.edit_project"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='action_view_tasks']" position="before">
                <field name="budget_id" invisible="1"/>
                <div class="oe_button_box" name="button_box">
                    <button name="action_view_budget"
                            class="oe_stat_button"
                            icon="fa-tasks"
                            type="object" invisible="not budget_id">
                        <div class="o_stat_info">
                            <span class="o_stat_text">Budget</span>
                        </div>
                    </button>
                </div>
            </xpath>
        </field>
    </record>
</odoo>