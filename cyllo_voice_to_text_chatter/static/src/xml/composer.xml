<?xml version="1.0" encoding="UTF-8"?>
<template xml:space="preserve">
    <t t-name="Composer" t-inherit="mail.Composer" t-inherit-mode="extension"
       owl="1">
    <xpath expr="//*[@t-ref='emoji-button']" position="after">
        <VoiceToText t-if="state.is_voice_chat and thread.type == 'chatter'"
             composer="props.composer"
             attachmentUploader="attachmentUploader"
             onchangeRecording.bind="() => this.state.recording = !this.state.recording"/>
    </xpath>
    <xpath expr="//textarea" position="after">
            <div style="display: flex;justify-content: end;padding-right: 20px;margin-bottom: 10px;">
                <button class="btn btn-primary summarise-button d-none"
                        t-on-click="summariseText">
                    Summarize
                </button>
            </div>
    </xpath>
    </t>
</template>
