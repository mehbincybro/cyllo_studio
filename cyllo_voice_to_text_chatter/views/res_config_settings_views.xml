<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--     Setup Voice chatter and API key view on settings     -->
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">
            res.config.settings.view.form.inherit.cyllo.voice.to.text.chatter
        </field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@name='integration']" position="inside">
                 <div class="col-lg-6 col-12 o_setting_box">
                    <div class="o_setting_left_pane">
                        <field name="is_voice_chat" string="Voice in chatter"/>
                    </div>
                    <div class="o_setting_right_pane">
                        <label for="is_voice_chat"/>
                            <div invisible="(is_voice_chat == False)">
                                <div class="text-muted"> Open AI API key:</div>
                                <field name="open_ai_api_key" required="is_voice_chat == True"
                                       string=" Open Ai Api key"
                                        password="True"/>
                            </div>
                    </div>
                 </div>
            </xpath>
        </field>
    </record>
</odoo>
