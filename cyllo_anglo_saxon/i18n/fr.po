#. module: cyllo_anglo_saxon
#: model_terms:ir.ui.view,arch_db:cyllo_anglo_saxon.view_res_config_settings_form_inherit_anglo_saxon
msgid ""
"Activate automatic journal                                         entries "
"for stock operations."
msgstr "Activer les écritures de journal automatiques pour les opérations de stock."

#. module: cyllo_anglo_saxon
#: model:ir.model.fields.selection,name:cyllo_anglo_saxon.selection__product_category__property_valuation__real_time
msgid "Automated"
msgstr "Automatisé"

#. module: cyllo_anglo_saxon
#: model_terms:ir.ui.view,arch_db:cyllo_anglo_saxon.view_res_config_settings_form_inherit_anglo_saxon
msgid "Automatic Accounting"
msgstr "Comptabilité automatique"

#. module: cyllo_anglo_saxon
#: model:ir.model,name:cyllo_anglo_saxon.model_res_config_settings
msgid "Config Settings"
msgstr "Paramètres de configuration"

#. module: cyllo_anglo_saxon
#: model:ir.model.fields,help:cyllo_anglo_saxon.field_product_category__property_stock_account_input_categ_id
msgid ""
"Counterpart journal items for all incoming stock moves will be posted in this account, unless there is a specific valuation account\n"
"                set on the source location. This is the default value for all products in this category. It can also directly be set on each product."
msgstr "Les écritures de contrepartie pour tous les mouvements de stock entrants seront comptabilisées dans ce compte, à moins qu'un compte de valorisation spécifique ne soit défini sur l'emplacement d'origine. C'est la valeur par défaut pour tous les produits de cette catégorie. Elle peut également être définie directement sur chaque produit."

#. module: cyllo_anglo_saxon
#: model:ir.model.fields,field_description:cyllo_anglo_saxon.field_res_config_settings__property_account_expense_categ_id
msgid "Expense Account"
msgstr "Compte de dépenses"

#. module: cyllo_anglo_saxon
#: model:ir.model,name:cyllo_anglo_saxon.model_report_cyllo_accounting_general_ledger
msgid "General Ledger Report"
msgstr "Rapport du grand livre"

#. module: cyllo_anglo_saxon
#: model:ir.model.fields,field_description:cyllo_anglo_saxon.field_res_config_settings__property_account_income_categ_id
msgid "Income Account"
msgstr "Compte de revenus"

#. module: cyllo_anglo_saxon
#: model:ir.model.fields,field_description:cyllo_anglo_saxon.field_product_category__property_valuation
msgid "Inventory Valuation"
msgstr "Valorisation des stocks"

#. module: cyllo_anglo_saxon
#: model:ir.model.fields.selection,name:cyllo_anglo_saxon.selection__product_category__property_valuation__manual_periodic
msgid "Manual"
msgstr "Manuel"

#. module: cyllo_anglo_saxon
#: model:ir.model.fields,help:cyllo_anglo_saxon.field_product_category__property_valuation
msgid ""
"Manual: The accounting entries to value the inventory are not posted automatically.\n"
"        Automated: An accounting entry is automatically created to value the inventory when a product enters or leaves the company.\n"
"        "
msgstr "Manuel : Les écritures comptables pour valoriser l'inventaire ne sont pas passées automatiquement.\n        Automatisé : Une écriture comptable est automatiquement créée pour valoriser l'inventaire lorsqu'un produit entre ou sort de l'entreprise.\n        "

#. module: cyllo_anglo_saxon
#: model:ir.model,name:cyllo_anglo_saxon.model_product_category
msgid "Product Category"
msgstr "Catégorie de produit"

#. module: cyllo_anglo_saxon
#: model:ir.model.fields,field_description:cyllo_anglo_saxon.field_product_category__property_stock_account_input_categ_id
#: model:ir.model.fields,field_description:cyllo_anglo_saxon.field_res_config_settings__property_stock_account_input_categ_id
msgid "Stock Input Account"
msgstr "Compte d'entrée de stock"

#. module: cyllo_anglo_saxon
#: model:ir.model.fields,field_description:cyllo_anglo_saxon.field_product_category__property_stock_journal
#: model:ir.model.fields,field_description:cyllo_anglo_saxon.field_res_config_settings__property_stock_journal
msgid "Stock Journal"
msgstr "Journal de stock"

#. module: cyllo_anglo_saxon
#: model:ir.model.fields,field_description:cyllo_anglo_saxon.field_product_category__property_stock_account_output_categ_id
#: model:ir.model.fields,field_description:cyllo_anglo_saxon.field_res_config_settings__property_stock_account_output_categ_id
msgid "Stock Output Account"
msgstr "Compte de sortie de stock"

#. module: cyllo_anglo_saxon
#: model_terms:ir.ui.view,arch_db:cyllo_anglo_saxon.view_res_config_settings_form_inherit_anglo_saxon
msgid "Stock Valuation"
msgstr "Valorisation de stock"

#. module: cyllo_anglo_saxon
#: model:ir.model.fields,field_description:cyllo_anglo_saxon.field_product_category__property_stock_valuation_account_id
#: model:ir.model.fields,field_description:cyllo_anglo_saxon.field_res_config_settings__property_stock_valuation_account_id
msgid "Stock Valuation Account"
msgstr "Compte de valorisation de stock"

#. module: cyllo_anglo_saxon
#: model_terms:ir.ui.view,arch_db:cyllo_anglo_saxon.view_res_config_settings_form_inherit_anglo_saxon
msgid ""
"The accounts configured below will be used for\n"
"                                automatic entries related to stock movements."
msgstr "Les comptes configurés ci-dessous seront utilisés pour les écritures automatiques liées aux mouvements de stock."

#. module: cyllo_anglo_saxon
#: model:ir.model.fields,help:cyllo_anglo_saxon.field_product_category__property_stock_valuation_account_id
msgid ""
"When automated inventory valuation is enabled on a product, this account "
"will hold the current value of the products."
msgstr "Lorsque la valorisation automatisée de l'inventaire est activée sur un produit, ce compte contiendra la valeur actuelle des produits."

#. module: cyllo_anglo_saxon
#: model:ir.model.fields,help:cyllo_anglo_saxon.field_product_category__property_stock_account_output_categ_id
msgid ""
"When doing automated inventory valuation, counterpart journal items for all outgoing stock moves will be posted in this account,\n"
"                unless there is a specific valuation account set on the destination location. This is the default value for all products in this category.\n"
"                It can also directly be set on each product."
msgstr "Lors de la valorisation automatisée de l'inventaire, les écritures de contrepartie pour tous les mouvements de stock sortants seront comptabilisées dans ce compte, à moins qu'un compte de valorisation spécifique ne soit défini sur l'emplacement de destination. C'est la valeur par défaut pour tous les produits de cette catégorie. Elle peut également être définie directement sur chaque produit."

#. module: cyllo_anglo_saxon
#: model:ir.model.fields,help:cyllo_anglo_saxon.field_product_category__property_stock_journal
msgid ""
"When doing automated inventory valuation, this is the Accounting Journal in "
"which entries will be automatically posted when stock moves are processed."
msgstr "Lors de la valorisation automatisée de l'inventaire, il s'agit du journal comptable dans lequel les écritures seront automatiquement passées lors du traitement des mouvements de stock."
