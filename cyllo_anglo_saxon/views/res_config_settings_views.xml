<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_res_config_settings_form_inherit_anglo_saxon"
            model="ir.ui.view">
        <field name="name">view.res.config.settings.form.inherit.anglo.saxon
        </field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="account.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@id='default_accounts']"
                   position="after">
                <block title="Stock Valuation"
                       id="default_stock_valuation_accounts">
                    <setting id="default_stock_valuation_accounts"
                             help="Activate automatic journal
                                        entries for stock operations."
                             invisible="not module_cyllo_anglo_saxon">
                        <field name="group_stock_accounting_automatic"
                               string="Automatic Accounting"/>
                        <div name="default_accounts" class="content-group"
                             invisible="not group_stock_accounting_automatic">
                            <div class="text-muted">
                                The accounts configured below will be used for
                                automatic entries related to stock movements.
                            </div>
                            <div class="row mt8">
                                <label for="property_stock_valuation_account_id"
                                       class="col-lg-5 o_light_label"/>
                                <field name="property_stock_valuation_account_id"/>
                            </div>
                            <div class="row mt8">
                                <label for="property_stock_journal"
                                       class="col-lg-5 o_light_label"/>
                                <field name="property_stock_journal"/>
                            </div>
                            <div class="row mt8">
                                <label for="property_stock_account_input_categ_id"
                                       class="col-lg-5 o_light_label"/>
                                <field name="property_stock_account_input_categ_id"/>
                            </div>
                            <div class="row mt8">
                                <label for="property_stock_account_output_categ_id"
                                       class="col-lg-5 o_light_label"/>
                                <field name="property_stock_account_output_categ_id"/>
                            </div>
                        </div>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>
</odoo>
